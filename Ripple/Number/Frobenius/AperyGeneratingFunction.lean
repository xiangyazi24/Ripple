          Number.aperyConifoldZ1Poly 1
            ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_pure_singular_on_disk h0 h hε₁ hε₂ hdet h_reg ht htdisk

/-- **`yAperyHalf` vanishes for nonneg argument.** For `t ≥ 0`, the
prefactor `Real.sqrt (-t)` equals zero (Mathlib convention: real sqrt
of nonpositive is zero), so the entire half-branch value is zero
regardless of seed. This is the analytic-continuation cutoff: only the
real-analytic regular and one branches survive on the right side of
`z₁`. -/
lemma yAperyHalf_eq_zero_of_nonneg (c₀ : ℝ) {t : ℝ} (ht : 0 ≤ t) :
    yAperyHalf c₀ t = 0 := by
  unfold yAperyHalf
  have h : Real.sqrt (-t) = 0 := Real.sqrt_eq_zero'.mpr (by linarith)
  rw [h, zero_mul]

/-- **Predicate-level disk decomposition for `t ≥ 0`.** On the right side
of `z₁` (where `√(-t) = 0`), the half-branch contribution drops
automatically — even with non-zero `a_h`. The witness function reduces
to the two real-analytic branches: regular + one. -/
lemma IsAperyConnectionCoeffsOn.decomp_right_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      (a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) +
      (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) := by
  have h_full := h.decomp_on_frobeniusDisk ht htdisk
  have h_sqrt : Real.sqrt (-t) = 0 := Real.sqrt_eq_zero'.mpr (by linarith)
  rw [h_full, h_sqrt]
  ring

/-- **Data-layer right-side decomposition on disk.** For `t ≥ 0` in the
corridor and Frobenius disk, the half-branch contribution vanishes
automatically (via `√(-t) = 0`), reducing `d.F (z₁+t)` to the two
real-analytic branches: regular + one. -/
lemma AperyConnectionData.F_right_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htnn : 0 ≤ t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      (d.extractRegular + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m) +
      (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
          t ^ m) := by
  have h_full := d.F_explicit_frobenius_decomp_on_disk hε₁ hε₂ hdet ht htdisk
  have h_sqrt : Real.sqrt (-t) = 0 := Real.sqrt_eq_zero'.mpr (by linarith)
  rw [h_full, h_sqrt]
  ring

/-- **Ext-layer right-side decomposition on disk.** Companion of
data-layer `F_right_on_disk` with `connectionCoefficients` seeds. -/
lemma AperyAnalyticExtension.F_right_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) +
      ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
        ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1
            ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) := by
  have h_full :=
    ext.F_explicit_frobenius_decomp_on_disk h0 h hε₁ hε₂ hdet ht htdisk
  have h_sqrt : Real.sqrt (-t) = 0 := Real.sqrt_eq_zero'.mpr (by linarith)
  rw [h_full, h_sqrt]
  ring

/-- **GFA-layer right-side decomposition on disk.** On the overlap of
GFA convergence small disk, corridor, and Frobenius disk, for `t ≥ 0`,
the half-branch drops and `aperyGFAReal (z₁+t)` reduces to regular +
one only. This is the right-of-conifold real-analytic form bridging
GFA → corridor → Frobenius. -/
lemma AperyAnalyticExtension.GFA_right_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (ht : t ∈ I) (htnn : 0 ≤ t)
    (hdisk_GFA : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) +
      ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
        ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1
            ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_right_on_disk h0 h hε₁ hε₂ hdet ht htnn htdisk

/-- **Half-branch isolation on disk.** Subtract the regular and one
contributions from `f(z₁+t)` to leave just the half-branch part:
`f(z₁+t) - (regular) - (one) = √(-t) · (a_h + t·T_H)`. Pure
rearrangement of `decomp_on_frobeniusDisk`; isolates the singular
branch without sign-on-`t` assumptions. -/
lemma IsAperyConnectionCoeffsOn.half_branch_isolated_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) -
        (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) =
      Real.sqrt (-t) * (a_half + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_half (m + 1) * t ^ m) := by
  have h_full := h.decomp_on_frobeniusDisk ht htdisk
  linarith [h_full]

/-- **Sqrt of negative is positive on the strict left.** For `t < 0`,
`Real.sqrt (-t) > 0`. Companion of `yAperyHalf_eq_zero_of_nonneg`:
the half-branch prefactor is *strictly positive* on the left side of
`z₁`, where the half-integer Frobenius branch carries genuine
analytic content. -/
lemma sqrt_neg_pos_of_neg {t : ℝ} (ht : t < 0) : 0 < Real.sqrt (-t) :=
  Real.sqrt_pos.mpr (by linarith)

/-- **Half-branch extraction on the strict left disk.** For `t < 0`
in the disk, divide the isolated half-branch by `√(-t)` to recover
`a_h + t·T_H` directly. This is the analytic-continuation extractor:
on the left of `z₁` the half-integer branch is non-degenerate and its
seed `a_h` is recoverable from `f` values. -/
lemma IsAperyConnectionCoeffsOn.half_branch_extractor_left_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htneg : t < 0)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) -
        (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m)) /
      Real.sqrt (-t) =
      a_half + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_half (m + 1) * t ^ m := by
  have h_iso := h.half_branch_isolated_on_frobeniusDisk ht htdisk
  have h_pos : 0 < Real.sqrt (-t) := sqrt_neg_pos_of_neg htneg
  have h_ne : Real.sqrt (-t) ≠ 0 := ne_of_gt h_pos
  rw [h_iso, mul_div_cancel_left₀ _ h_ne]

/-- **Data-layer half-branch isolation on disk.** Subtract regular and
one contributions from `d.F (z₁+t)` to leave just the half-branch
`√(-t)·(extractHalf + t·T_H)`. -/
lemma AperyConnectionData.F_half_branch_isolated_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    d.F (Number.aperyConifoldZ1Poly + t) -
        (d.extractRegular + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m) -
        (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
            t ^ m) =
      Real.sqrt (-t) * (d.extractHalf ε₁ ε₂ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (d.extractHalf ε₁ ε₂) (m + 1) *
          t ^ m) := by
  have h_full := d.F_explicit_frobenius_decomp_on_disk hε₁ hε₂ hdet ht htdisk
  linarith [h_full]

/-- **Data-layer half-branch extractor on the strict left disk.** For
`t < 0` in corridor and disk, recover `extractHalf + t·T_H` directly
by dividing the isolated half-branch by `√(-t) > 0`. -/
lemma AperyConnectionData.F_half_branch_extractor_left_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htneg : t < 0)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (d.F (Number.aperyConifoldZ1Poly + t) -
        (d.extractRegular + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m) -
        (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
            t ^ m)) /
      Real.sqrt (-t) =
      d.extractHalf ε₁ ε₂ + t * ∑' m, frobeniusCoeff
