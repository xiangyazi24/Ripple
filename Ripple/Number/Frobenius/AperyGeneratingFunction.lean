        ∑ i ∈ Finset.range (m + 1),
          |frobeniusCoeff
              (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
              Number.aperyConifoldZ1Poly (1 / 2) c₀ i| := by
  have h3eq : (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 3 =
      Number.aperyPconifold := rfl
  have h2eq : (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2 =
