    (s : ℝ) (hs_nn : 0 ≤ s)
    (hs_lt : s * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)|) < 1)
    {ε₁ ε₂ : ℝ} (hε₁ : ε₁ ∈ Set.Icc (-s) s) (hε₂ : ε₂ ∈ Set.Icc (-s) s) :
    ContinuousOn (fun ε₃ : ℝ => apery3Det ε₁ ε₂ ε₃) (Set.Icc (-s) s) := by
  have hjoint :
      ContinuousOn (fun p : ℝ × ℝ × ℝ => apery3Det p.1 p.2.1 p.2.2)
        ((Set.Icc (-s) s) ×ˢ ((Set.Icc (-s) s) ×ˢ (Set.Icc (-s) s))) :=
    apery3Det_continuousOn_general M₀ B hB_nn
      hM0_small_zero hM0_large_zero hM0_thresh_zero
      hM0_small_half hM0_large_half hM0_thresh_half
      hM0_small_one hM0_large_one hM0_thresh_one
      hB s hs_nn hs_lt
  have hinj : ContinuousOn (fun ε₃ : ℝ => (ε₁, ε₂, ε₃)) (Set.Icc (-s) s) :=
    (continuous_const.prodMk (continuous_const.prodMk continuous_id)).continuousOn
  have hmaps : Set.MapsTo (fun ε₃ : ℝ => (ε₁, ε₂, ε₃)) (Set.Icc (-s) s)
      ((Set.Icc (-s) s) ×ˢ ((Set.Icc (-s) s) ×ˢ (Set.Icc (-s) s))) := by
    intro ε₃ hε₃
    exact Set.mk_mem_prod hε₁ (Set.mk_mem_prod hε₂ hε₃)
  exact hjoint.comp hinj hmaps

/-- **`apery3Det` at unit cores reduces to the negated Vandermonde det of
`(1, √ε, ε)`.** Polynomial identity exposing the Vandermonde-like
structure of `apery3Det` as the underlying determinant of the leading-
order matrix. The hypotheses fix `aperyBranchAmplitude_zero`,
`aperyBranchHalfCore`, `aperyBranchOneCore` to all equal `1` (only
literally true at `ε = 0`, but useful as the leading-order target);
under those, `apery3Det = -(√ε₂ − √ε₁)(√ε₃ − √ε₁)(√ε₃ − √ε₂)`. -/
lemma apery3Det_unit_cores_eq_neg_vandermonde {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    (hZ1 : aperyBranchAmplitude_zero ε₁ = 1)
    (hZ2 : aperyBranchAmplitude_zero ε₂ = 1)
    (hZ3 : aperyBranchAmplitude_zero ε₃ = 1)
    (hH1 : aperyBranchHalfCore ε₁ = 1)
    (hH2 : aperyBranchHalfCore ε₂ = 1)
    (hH3 : aperyBranchHalfCore ε₃ = 1)
    (hO1 : aperyBranchOneCore ε₁ = 1)
    (hO2 : aperyBranchOneCore ε₂ = 1)
    (hO3 : aperyBranchOneCore ε₃ = 1) :
    apery3Det ε₁ ε₂ ε₃ =
      -((Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂)) := by
  rw [apery3Det_factored h₁ h₂ h₃, hZ1, hZ2, hZ3, hH1, hH2, hH3, hO1, hO2, hO3]
  ring

/-- **Vandermonde-of-sqrt non-vanishing.** For nonneg pairwise-distinct
`ε_i`, the product `(√ε₂−√ε₁)(√ε₃−√ε₁)(√ε₃−√ε₂)` is nonzero. Combined
with `apery3Det_unit_cores_eq_neg_vandermonde`, gives the leading-order
non-vanishing of the 3-probe det. -/
lemma vandermonde_sqrt_ne_zero {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    (h12 : ε₁ ≠ ε₂) (h13 : ε₁ ≠ ε₃) (h23 : ε₂ ≠ ε₃) :
    (Real.sqrt ε₂ - Real.sqrt ε₁) * (Real.sqrt ε₃ - Real.sqrt ε₁) *
        (Real.sqrt ε₃ - Real.sqrt ε₂) ≠ 0 := by
  refine mul_ne_zero (mul_ne_zero ?_ ?_) ?_
  · intro h
    have hs : Real.sqrt ε₂ = Real.sqrt ε₁ := sub_eq_zero.mp h
    exact h12.symm ((Real.sqrt_inj h₂ h₁).mp hs)
  · intro h
    have hs : Real.sqrt ε₃ = Real.sqrt ε₁ := sub_eq_zero.mp h
    exact h13.symm ((Real.sqrt_inj h₃ h₁).mp hs)
  · intro h
    have hs : Real.sqrt ε₃ = Real.sqrt ε₂ := sub_eq_zero.mp h
    exact h23.symm ((Real.sqrt_inj h₃ h₂).mp hs)

/-- **`apery3Det` non-vanishing in the unit-core ideal limit.** Combines
the unit-core Vandermonde reduction with the sqrt-Vandermonde non-
vanishing: under `0 < ε_i`, pairwise distinct probes, and unit core
hypotheses, `apery3Det ε₁ ε₂ ε₃ ≠ 0`. The ideal-limit reference for
the genuine analytic non-vanishing target. -/
lemma apery3Det_unit_cores_ne_zero {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 < ε₁) (h₂ : 0 < ε₂) (h₃ : 0 < ε₃)
    (h12 : ε₁ ≠ ε₂) (h13 : ε₁ ≠ ε₃) (h23 : ε₂ ≠ ε₃)
    (hZ1 : aperyBranchAmplitude_zero ε₁ = 1)
    (hZ2 : aperyBranchAmplitude_zero ε₂ = 1)
    (hZ3 : aperyBranchAmplitude_zero ε₃ = 1)
    (hH1 : aperyBranchHalfCore ε₁ = 1)
    (hH2 : aperyBranchHalfCore ε₂ = 1)
    (hH3 : aperyBranchHalfCore ε₃ = 1)
    (hO1 : aperyBranchOneCore ε₁ = 1)
    (hO2 : aperyBranchOneCore ε₂ = 1)
    (hO3 : aperyBranchOneCore ε₃ = 1) :
    apery3Det ε₁ ε₂ ε₃ ≠ 0 := by
  rw [apery3Det_unit_cores_eq_neg_vandermonde h₁.le h₂.le h₃.le
        hZ1 hZ2 hZ3 hH1 hH2 hH3 hO1 hO2 hO3]
  exact neg_ne_zero.mpr
    (vandermonde_sqrt_ne_zero h₁.le h₂.le h₃.le h12 h13 h23)

/-- **`apery3Det` perturbation identity.** Expresses the deviation of
`apery3Det` from its unit-core leading value `−V` (with `V` the
sqrt-Vandermonde) as an explicit sum of six terms, each a product of
three branch-core values minus `1` times a fixed `ε`-monomial. Used
to bound `|apery3Det + V|` by deviation magnitudes via triangle
inequality. Requires `ε_i ≥ 0` to simplify `√ε_i · √ε_i = ε_i`. -/
lemma apery3Det_perturbation_eq {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃) :
    apery3Det ε₁ ε₂ ε₃ +
        (Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂) =
      (aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₃ *
            aperyBranchOneCore ε₂ - 1) * ε₂ * Real.sqrt ε₃
        - (aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₂ *
              aperyBranchOneCore ε₃ - 1) * Real.sqrt ε₂ * ε₃
        - (aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₃ *
              aperyBranchOneCore ε₁ - 1) * ε₁ * Real.sqrt ε₃
        + (aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₁ *
              aperyBranchOneCore ε₃ - 1) * Real.sqrt ε₁ * ε₃
        + (aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₂ *
              aperyBranchOneCore ε₁ - 1) * ε₁ * Real.sqrt ε₂
        - (aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₁ *
              aperyBranchOneCore ε₂ - 1) * Real.sqrt ε₁ * ε₂ := by
  rw [apery3Det_factored h₁ h₂ h₃]
  have hs1 : Real.sqrt ε₁ * Real.sqrt ε₁ = ε₁ := Real.mul_self_sqrt h₁
  have hs2 : Real.sqrt ε₂ * Real.sqrt ε₂ = ε₂ := Real.mul_self_sqrt h₂
  have hs3 : Real.sqrt ε₃ * Real.sqrt ε₃ = ε₃ := Real.mul_self_sqrt h₃
  linear_combination
    (-aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₃ *
        aperyBranchOneCore ε₁ * Real.sqrt ε₃ +
      aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₂ *
        aperyBranchOneCore ε₁ * Real.sqrt ε₂ +
      (Real.sqrt ε₃ - Real.sqrt ε₂)) * hs1 +
    (aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₃ *
        aperyBranchOneCore ε₂ * Real.sqrt ε₃ -
      aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₁ *
        aperyBranchOneCore ε₂ * Real.sqrt ε₁ +
      (Real.sqrt ε₁ - Real.sqrt ε₃)) * hs2 +
    (-aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₂ *
        aperyBranchOneCore ε₃ * Real.sqrt ε₂ +
      aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₁ *
        aperyBranchOneCore ε₃ * Real.sqrt ε₁ +
      (Real.sqrt ε₂ - Real.sqrt ε₁)) * hs3

/-- **`apery3Det` perturbation triangle bound.** Applies the triangle
inequality and absolute-value distribution to
`apery3Det_perturbation_eq` to bound `|apery3Det + V|` by a sum of
six positive products `|Z·H·O − 1|·ε·√ε`. Each product factor is a
three-core deviation magnitude, ready for the next decomposition step
which expands `|Z·H·O − 1|` via `Z·H·O − 1 = (Z−1)·H·O + (H−1)·O + (O−1)`. -/
lemma apery3Det_perturbation_abs_le {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃) :
    |apery3Det ε₁ ε₂ ε₃ +
        (Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂)| ≤
      |aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₃ *
            aperyBranchOneCore ε₂ - 1| * ε₂ * Real.sqrt ε₃
        + |aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₂ *
              aperyBranchOneCore ε₃ - 1| * Real.sqrt ε₂ * ε₃
        + |aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₃ *
              aperyBranchOneCore ε₁ - 1| * ε₁ * Real.sqrt ε₃
        + |aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₁ *
              aperyBranchOneCore ε₃ - 1| * Real.sqrt ε₁ * ε₃
        + |aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₂ *
              aperyBranchOneCore ε₁ - 1| * ε₁ * Real.sqrt ε₂
        + |aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₁ *
              aperyBranchOneCore ε₂ - 1| * Real.sqrt ε₁ * ε₂ := by
  rw [apery3Det_perturbation_eq h₁ h₂ h₃]
  have hs1 : 0 ≤ Real.sqrt ε₁ := Real.sqrt_nonneg ε₁
  have hs2 : 0 ≤ Real.sqrt ε₂ := Real.sqrt_nonneg ε₂
  have hs3 : 0 ≤ Real.sqrt ε₃ := Real.sqrt_nonneg ε₃
  set A : ℝ := (aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₃ *
      aperyBranchOneCore ε₂ - 1) * ε₂ * Real.sqrt ε₃
  set B : ℝ := (aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₂ *
      aperyBranchOneCore ε₃ - 1) * Real.sqrt ε₂ * ε₃
  set C : ℝ := (aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₃ *
      aperyBranchOneCore ε₁ - 1) * ε₁ * Real.sqrt ε₃
  set D : ℝ := (aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₁ *
      aperyBranchOneCore ε₃ - 1) * Real.sqrt ε₁ * ε₃
  set E : ℝ := (aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₂ *
      aperyBranchOneCore ε₁ - 1) * ε₁ * Real.sqrt ε₂
  set F : ℝ := (aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₁ *
      aperyBranchOneCore ε₂ - 1) * Real.sqrt ε₁ * ε₂
  have habsA : |A| = |aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₃ *
      aperyBranchOneCore ε₂ - 1| * ε₂ * Real.sqrt ε₃ := by
    simp [A, abs_mul, abs_of_nonneg h₂, abs_of_nonneg hs3]
  have habsB : |B| = |aperyBranchAmplitude_zero ε₁ * aperyBranchHalfCore ε₂ *
      aperyBranchOneCore ε₃ - 1| * Real.sqrt ε₂ * ε₃ := by
    simp [B, abs_mul, abs_of_nonneg hs2, abs_of_nonneg h₃]
  have habsC : |C| = |aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₃ *
      aperyBranchOneCore ε₁ - 1| * ε₁ * Real.sqrt ε₃ := by
    simp [C, abs_mul, abs_of_nonneg h₁, abs_of_nonneg hs3]
  have habsD : |D| = |aperyBranchAmplitude_zero ε₂ * aperyBranchHalfCore ε₁ *
      aperyBranchOneCore ε₃ - 1| * Real.sqrt ε₁ * ε₃ := by
    simp [D, abs_mul, abs_of_nonneg hs1, abs_of_nonneg h₃]
  have habsE : |E| = |aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₂ *
      aperyBranchOneCore ε₁ - 1| * ε₁ * Real.sqrt ε₂ := by
    simp [E, abs_mul, abs_of_nonneg h₁, abs_of_nonneg hs2]
  have habsF : |F| = |aperyBranchAmplitude_zero ε₃ * aperyBranchHalfCore ε₁ *
      aperyBranchOneCore ε₂ - 1| * Real.sqrt ε₁ * ε₂ := by
    simp [F, abs_mul, abs_of_nonneg hs1, abs_of_nonneg h₂]
  have htri : |A - B - C + D + E - F| ≤ |A| + |B| + |C| + |D| + |E| + |F| := by
    have eq1 : A - B - C + D + E - F = (A - B - C + D + E) + (-F) := by ring
    have eq2 : A - B - C + D + E = (A - B - C + D) + E := by ring
    have eq3 : A - B - C + D = (A - B - C) + D := by ring
    have eq4 : A - B - C = (A - B) + (-C) := by ring
    have eq5 : A - B = A + (-B) := by ring
    rw [eq1]
    calc |(A - B - C + D + E) + (-F)|
        ≤ |A - B - C + D + E| + |-F| := abs_add_le _ _
      _ = |A - B - C + D + E| + |F| := by rw [abs_neg]
      _ ≤ (|A - B - C + D| + |E|) + |F| := by
          gcongr; rw [eq2]; exact abs_add_le _ _
      _ ≤ ((|A - B - C| + |D|) + |E|) + |F| := by
          gcongr; rw [eq3]; exact abs_add_le _ _
      _ ≤ (((|A - B| + |C|) + |D|) + |E|) + |F| := by
          gcongr
          rw [eq4]
          calc |(A - B) + (-C)|
              ≤ |A - B| + |-C| := abs_add_le _ _
            _ = |A - B| + |C| := by rw [abs_neg]
      _ ≤ ((((|A| + |B|) + |C|) + |D|) + |E|) + |F| := by
          gcongr
          rw [eq5]
          calc |A + (-B)|
              ≤ |A| + |-B| := abs_add_le _ _
            _ = |A| + |B| := by rw [abs_neg]
      _ = |A| + |B| + |C| + |D| + |E| + |F| := by ring
  calc |A - B - C + D + E - F|
      ≤ |A| + |B| + |C| + |D| + |E| + |F| := htri
    _ = _ := by rw [habsA, habsB, habsC, habsD, habsE, habsF]

/-- **Three-factor deviation decomposition.** Expresses `x·y·z − 1` as
the sum `(x − 1)·y·z + (y − 1)·z + (z − 1)`. Pure ring identity,
used to bound `|x·y·z − 1|` by the three single-factor deviation
magnitudes via triangle inequality. -/
lemma three_factor_sub_one_eq (x y z : ℝ) :
    x * y * z - 1 = (x - 1) * y * z + (y - 1) * z + (z - 1) := by
  ring

/-- **Three-factor absolute deviation bound.** Triangle-inequality
corollary of `three_factor_sub_one_eq`: bounds `|x·y·z − 1|` by
`|x − 1|·|y|·|z| + |y − 1|·|z| + |z − 1|`. The right-hand side splits
the joint deviation into three single-core deviation magnitudes,
each bounded by an individual `aperyBranch*_abs_sub_one_le` lemma. -/
lemma three_factor_abs_sub_one_le (x y z : ℝ) :
    |x * y * z - 1| ≤ |x - 1| * |y| * |z| + |y - 1| * |z| + |z - 1| := by
  rw [three_factor_sub_one_eq]
  calc |(x - 1) * y * z + (y - 1) * z + (z - 1)|
      ≤ |(x - 1) * y * z + (y - 1) * z| + |z - 1| := abs_add_le _ _
    _ ≤ (|(x - 1) * y * z| + |(y - 1) * z|) + |z - 1| := by
        gcongr; exact abs_add_le _ _
    _ = |x - 1| * |y| * |z| + |y - 1| * |z| + |z - 1| := by
        rw [abs_mul, abs_mul, abs_mul]

/-- **Three-factor absolute deviation bound from individual deviations.**
Combines `three_factor_abs_sub_one_le` with `|y| ≤ 1 + |y − 1|` and
`|z| ≤ 1 + |z − 1|` to give a bound purely in terms of the single-core
deviation magnitudes `δx, δy, δz`. -/
lemma three_factor_abs_sub_one_le_of_dev
    {x y z δx δy δz : ℝ}
    (hx : |x - 1| ≤ δx) (hy : |y - 1| ≤ δy) (hz : |z - 1| ≤ δz) :
    |x * y * z - 1| ≤ δx * (1 + δy) * (1 + δz) + δy * (1 + δz) + δz := by
  have hδx_nn : 0 ≤ δx := le_trans (abs_nonneg _) hx
  have hδy_nn : 0 ≤ δy := le_trans (abs_nonneg _) hy
  have hδz_nn : 0 ≤ δz := le_trans (abs_nonneg _) hz
  have h_y : |y| ≤ 1 + δy := by
    have heq : y = 1 + (y - 1) := by ring
    have step : |1 + (y - 1)| ≤ |(1 : ℝ)| + |y - 1| := abs_add_le 1 (y - 1)
    have hy_eq : |y| = |1 + (y - 1)| := by rw [← heq]
    have h1 : |(1 : ℝ)| = 1 := abs_one
    linarith [hy, h1, step, hy_eq]
  have h_z : |z| ≤ 1 + δz := by
    have heq : z = 1 + (z - 1) := by ring
    have step : |1 + (z - 1)| ≤ |(1 : ℝ)| + |z - 1| := abs_add_le 1 (z - 1)
    have hz_eq : |z| = |1 + (z - 1)| := by rw [← heq]
    have h1 : |(1 : ℝ)| = 1 := abs_one
    linarith [hz, h1, step, hz_eq]
  have h_y_nn : 0 ≤ |y| := abs_nonneg _
  have h_z_nn : 0 ≤ |z| := abs_nonneg _
  calc |x * y * z - 1|
      ≤ |x - 1| * |y| * |z| + |y - 1| * |z| + |z - 1| :=
        three_factor_abs_sub_one_le x y z
    _ ≤ δx * (1 + δy) * (1 + δz) + δy * (1 + δz) + δz := by
        gcongr

/-- **Apéry three-core deviation bound.** Specializes
`three_factor_abs_sub_one_le_of_dev` to the three Apéry branch cores
`Z = aperyBranchAmplitude_zero`, `H = aperyBranchHalfCore`,
`O = aperyBranchOneCore`, each evaluated at its own probe. Bounds the
joint deviation `|Z(a)·H(b)·O(c) − 1|` by the closed-form expression
`δa·(1+δb)·(1+δc) + δb·(1+δc) + δc` in the three single-core deviation
magnitudes. Each `δ` is supplied to the caller from the matching
`aperyBranch*_abs_sub_one_le` lemma at the appropriate probe. -/
lemma apery_three_core_abs_sub_one_le {a b c : ℝ}
    {δa δb δc : ℝ}
    (hZ : |aperyBranchAmplitude_zero a - 1| ≤ δa)
    (hH : |aperyBranchHalfCore b - 1| ≤ δb)
    (hO : |aperyBranchOneCore c - 1| ≤ δc) :
    |aperyBranchAmplitude_zero a * aperyBranchHalfCore b *
        aperyBranchOneCore c - 1|
      ≤ δa * (1 + δb) * (1 + δc) + δb * (1 + δc) + δc :=
  three_factor_abs_sub_one_le_of_dev hZ hH hO

/-- **`apery3Det` perturbation bound from individual core deviations.**
Combines `apery3Det_perturbation_abs_le` (six-term triangle bound) with
`apery_three_core_abs_sub_one_le` (three-factor decomposition) for each
of the six six terms. Produces an explicit upper bound on
`|apery3Det + V|` parametrized by nine single-core deviation magnitudes
`δZ₁,δZ₂,δZ₃,δH₁,δH₂,δH₃,δO₁,δO₂,δO₃`. Each `δ` is supplied by the
caller from the matching `aperyBranch*_abs_sub_one_le` lemma at the
relevant probe. -/
lemma apery3Det_perturbation_abs_le_of_dev
    {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    {δZ₁ δZ₂ δZ₃ δH₁ δH₂ δH₃ δO₁ δO₂ δO₃ : ℝ}
    (hZ₁ : |aperyBranchAmplitude_zero ε₁ - 1| ≤ δZ₁)
    (hZ₂ : |aperyBranchAmplitude_zero ε₂ - 1| ≤ δZ₂)
    (hZ₃ : |aperyBranchAmplitude_zero ε₃ - 1| ≤ δZ₃)
    (hH₁ : |aperyBranchHalfCore ε₁ - 1| ≤ δH₁)
    (hH₂ : |aperyBranchHalfCore ε₂ - 1| ≤ δH₂)
    (hH₃ : |aperyBranchHalfCore ε₃ - 1| ≤ δH₃)
    (hO₁ : |aperyBranchOneCore ε₁ - 1| ≤ δO₁)
    (hO₂ : |aperyBranchOneCore ε₂ - 1| ≤ δO₂)
    (hO₃ : |aperyBranchOneCore ε₃ - 1| ≤ δO₃) :
    |apery3Det ε₁ ε₂ ε₃ +
        (Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂)|
      ≤ (δZ₁ * (1 + δH₃) * (1 + δO₂) + δH₃ * (1 + δO₂) + δO₂) * ε₂ * Real.sqrt ε₃
        + (δZ₁ * (1 + δH₂) * (1 + δO₃) + δH₂ * (1 + δO₃) + δO₃) * Real.sqrt ε₂ * ε₃
        + (δZ₂ * (1 + δH₃) * (1 + δO₁) + δH₃ * (1 + δO₁) + δO₁) * ε₁ * Real.sqrt ε₃
        + (δZ₂ * (1 + δH₁) * (1 + δO₃) + δH₁ * (1 + δO₃) + δO₃) * Real.sqrt ε₁ * ε₃
        + (δZ₃ * (1 + δH₂) * (1 + δO₁) + δH₂ * (1 + δO₁) + δO₁) * ε₁ * Real.sqrt ε₂
        + (δZ₃ * (1 + δH₁) * (1 + δO₂) + δH₁ * (1 + δO₂) + δO₂) * Real.sqrt ε₁ * ε₂ := by
  have hs1 : 0 ≤ Real.sqrt ε₁ := Real.sqrt_nonneg ε₁
  have hs2 : 0 ≤ Real.sqrt ε₂ := Real.sqrt_nonneg ε₂
  have hs3 : 0 ≤ Real.sqrt ε₃ := Real.sqrt_nonneg ε₃
  have hbase := apery3Det_perturbation_abs_le h₁ h₂ h₃
  have hk1 := apery_three_core_abs_sub_one_le hZ₁ hH₃ hO₂
  have hk2 := apery_three_core_abs_sub_one_le hZ₁ hH₂ hO₃
  have hk3 := apery_three_core_abs_sub_one_le hZ₂ hH₃ hO₁
  have hk4 := apery_three_core_abs_sub_one_le hZ₂ hH₁ hO₃
  have hk5 := apery_three_core_abs_sub_one_le hZ₃ hH₂ hO₁
  have hk6 := apery_three_core_abs_sub_one_le hZ₃ hH₁ hO₂
  refine hbase.trans ?_
  gcongr
  all_goals first
    | exact hk1 | exact hk2 | exact hk3 | exact hk4 | exact hk5 | exact hk6

/-- **`apery3Det` perturbation bound under a uniform deviation
ceiling.** Specializes `apery3Det_perturbation_abs_le_of_dev` to the
case where all nine single-core deviations are bounded by a common
constant `R`. The right-hand side then collapses to a single scalar
`R·(1+R)² + R·(1+R) + R` times the sum of six `ε·√ε` cross-terms,
which is the form most convenient for connecting to the
`vandermonde_sqrt_ne_zero` lower bound on `|V|`. -/
lemma apery3Det_perturbation_abs_le_of_uniform_dev
    {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    {R : ℝ}
    (hZ₁ : |aperyBranchAmplitude_zero ε₁ - 1| ≤ R)
    (hZ₂ : |aperyBranchAmplitude_zero ε₂ - 1| ≤ R)
    (hZ₃ : |aperyBranchAmplitude_zero ε₃ - 1| ≤ R)
    (hH₁ : |aperyBranchHalfCore ε₁ - 1| ≤ R)
    (hH₂ : |aperyBranchHalfCore ε₂ - 1| ≤ R)
    (hH₃ : |aperyBranchHalfCore ε₃ - 1| ≤ R)
    (hO₁ : |aperyBranchOneCore ε₁ - 1| ≤ R)
    (hO₂ : |aperyBranchOneCore ε₂ - 1| ≤ R)
    (hO₃ : |aperyBranchOneCore ε₃ - 1| ≤ R) :
    |apery3Det ε₁ ε₂ ε₃ +
        (Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂)|
      ≤ (R * (1 + R) ^ 2 + R * (1 + R) + R) *
          (ε₂ * Real.sqrt ε₃ + Real.sqrt ε₂ * ε₃ +
            ε₁ * Real.sqrt ε₃ + Real.sqrt ε₁ * ε₃ +
            ε₁ * Real.sqrt ε₂ + Real.sqrt ε₁ * ε₂) := by
  have hbase := apery3Det_perturbation_abs_le_of_dev h₁ h₂ h₃
    hZ₁ hZ₂ hZ₃ hH₁ hH₂ hH₃ hO₁ hO₂ hO₃
  refine hbase.trans (le_of_eq ?_)
  ring

/-- **Six-cross-term sum bound under a uniform probe ceiling.** Each
of the six terms `εᵢ · √εⱼ` is bounded by `M · √M` whenever
`εᵢ ≤ M`. Summing gives the clean upper bound `6 · M · √M`. Used to
collapse the cross-term factor in
`apery3Det_perturbation_abs_le_of_uniform_dev` to a single
`6·M^{3/2}` scalar. -/
lemma apery3Det_cross_term_sum_le
    {ε₁ ε₂ ε₃ M : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    (hM₁ : ε₁ ≤ M) (hM₂ : ε₂ ≤ M) (hM₃ : ε₃ ≤ M) :
    ε₂ * Real.sqrt ε₃ + Real.sqrt ε₂ * ε₃ +
      ε₁ * Real.sqrt ε₃ + Real.sqrt ε₁ * ε₃ +
      ε₁ * Real.sqrt ε₂ + Real.sqrt ε₁ * ε₂
    ≤ 6 * M * Real.sqrt M := by
  have hM : 0 ≤ M := h₁.trans hM₁
  have hsM : 0 ≤ Real.sqrt M := Real.sqrt_nonneg _
  have hs1M : Real.sqrt ε₁ ≤ Real.sqrt M := Real.sqrt_le_sqrt hM₁
  have hs2M : Real.sqrt ε₂ ≤ Real.sqrt M := Real.sqrt_le_sqrt hM₂
  have hs3M : Real.sqrt ε₃ ≤ Real.sqrt M := Real.sqrt_le_sqrt hM₃
  calc ε₂ * Real.sqrt ε₃ + Real.sqrt ε₂ * ε₃ +
      ε₁ * Real.sqrt ε₃ + Real.sqrt ε₁ * ε₃ +
      ε₁ * Real.sqrt ε₂ + Real.sqrt ε₁ * ε₂
      ≤ M * Real.sqrt M + Real.sqrt M * M
        + M * Real.sqrt M + Real.sqrt M * M
        + M * Real.sqrt M + Real.sqrt M * M := by
          gcongr
    _ = 6 * M * Real.sqrt M := by ring

/-- **`apery3Det` perturbation single-scalar bound.** Combines
`apery3Det_perturbation_abs_le_of_uniform_dev` (deviation factor) with
`apery3Det_cross_term_sum_le` (cross-term factor). Given a uniform
deviation ceiling `R` for all nine cores and a uniform probe ceiling
`M ≥ εᵢ`, bounds `|apery3Det + V|` by the single scalar
`6 · K(R) · M · √M` where `K(R) = R·(1+R)² + R·(1+R) + R`. This is
the form ready for matching against the Vandermonde lower bound. -/
lemma apery3Det_perturbation_abs_le_scalar
    {ε₁ ε₂ ε₃ M R : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    (hM₁ : ε₁ ≤ M) (hM₂ : ε₂ ≤ M) (hM₃ : ε₃ ≤ M)
    (hZ₁ : |aperyBranchAmplitude_zero ε₁ - 1| ≤ R)
    (hZ₂ : |aperyBranchAmplitude_zero ε₂ - 1| ≤ R)
    (hZ₃ : |aperyBranchAmplitude_zero ε₃ - 1| ≤ R)
    (hH₁ : |aperyBranchHalfCore ε₁ - 1| ≤ R)
    (hH₂ : |aperyBranchHalfCore ε₂ - 1| ≤ R)
    (hH₃ : |aperyBranchHalfCore ε₃ - 1| ≤ R)
    (hO₁ : |aperyBranchOneCore ε₁ - 1| ≤ R)
    (hO₂ : |aperyBranchOneCore ε₂ - 1| ≤ R)
    (hO₃ : |aperyBranchOneCore ε₃ - 1| ≤ R) :
    |apery3Det ε₁ ε₂ ε₃ +
        (Real.sqrt ε₂ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₁) *
          (Real.sqrt ε₃ - Real.sqrt ε₂)|
      ≤ (R * (1 + R) ^ 2 + R * (1 + R) + R) * (6 * M * Real.sqrt M) := by
  have hR_nn : 0 ≤ R := (abs_nonneg _).trans hZ₁
  have hone_R_nn : 0 ≤ 1 + R := by linarith
  have hK_nn : 0 ≤ R * (1 + R) ^ 2 + R * (1 + R) + R := by positivity
  have hbase := apery3Det_perturbation_abs_le_of_uniform_dev h₁ h₂ h₃
    hZ₁ hZ₂ hZ₃ hH₁ hH₂ hH₃ hO₁ hO₂ hO₃
  have hcross := apery3Det_cross_term_sum_le h₁ h₂ h₃ hM₁ hM₂ hM₃
  exact hbase.trans (mul_le_mul_of_nonneg_left hcross hK_nn)

/-- **`apery3Det` near-unit-cores non-vanishing — abstract perturbation
form.** Replaces the strict `core = 1` hypotheses with the weaker
condition that the perturbation `apery3Det − (−V)` is bounded in
absolute value by a quantity strictly below a lower bound on `|V|`,
where `V = (√ε₂−√ε₁)(√ε₃−√ε₁)(√ε₃−√ε₂)` is the unit-core leading
term. Then `apery3Det ε₁ ε₂ ε₃ ≠ 0` follows by triangle inequality:
if `apery3Det = 0`, then `|V| = |0 − (−V)| ≤ R < M ≤ |V|`,
contradiction. The two parameters `M` (Vandermonde lower bound) and
`R` (perturbation upper bound) are abstract — downstream callers fill
them in from `vandermonde_sqrt_ne_zero` plus deviation-bound lemmas. -/
lemma apery3Det_ne_zero_of_near_unit_cores {ε₁ ε₂ ε₃ : ℝ}
    (M : ℝ) (hM_pos : 0 < M)
    (hMV : M ≤ |(Real.sqrt ε₂ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₂)|)
    (R : ℝ)
    (hR : |apery3Det ε₁ ε₂ ε₃ +
            (Real.sqrt ε₂ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₂)| ≤ R)
    (hRM : R < M) :
    apery3Det ε₁ ε₂ ε₃ ≠ 0 := by
  intro heq
  set V : ℝ := (Real.sqrt ε₂ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₂) with hV_def
  have hV_le_R : |V| ≤ R := by
    have : |apery3Det ε₁ ε₂ ε₃ + V| = |V| := by rw [heq, zero_add]
    rw [this] at hR
    exact hR
  have : M ≤ R := hMV.trans hV_le_R
  exact absurd this (not_le.mpr hRM)

/-- **`apery3Det` non-vanishing from deviation + probe + Vandermonde
bounds.** End-to-end wrapper: combines
`apery3Det_perturbation_abs_le_scalar` (perturbation upper bound) with
a Vandermonde lower bound `|V| ≥ V_lo` via
`apery3Det_ne_zero_of_near_unit_cores`. The single quantitative gate
condition
`K(R)·6·M_eps·√M_eps < V_lo`
expresses the existence of a corridor where `apery3Det ≠ 0` via
deviation control on the three cores and probe control on the three
`εᵢ`. Concrete instantiations supply the gate inequality from explicit
numerical estimates of `R, M_eps, V_lo` at the standard probe triple. -/
lemma apery3Det_ne_zero_of_dev_and_probe_bounds
    {ε₁ ε₂ ε₃ M_eps R V_lo : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃)
    (hM₁ : ε₁ ≤ M_eps) (hM₂ : ε₂ ≤ M_eps) (hM₃ : ε₃ ≤ M_eps)
    (hZ₁ : |aperyBranchAmplitude_zero ε₁ - 1| ≤ R)
    (hZ₂ : |aperyBranchAmplitude_zero ε₂ - 1| ≤ R)
    (hZ₃ : |aperyBranchAmplitude_zero ε₃ - 1| ≤ R)
    (hH₁ : |aperyBranchHalfCore ε₁ - 1| ≤ R)
    (hH₂ : |aperyBranchHalfCore ε₂ - 1| ≤ R)
    (hH₃ : |aperyBranchHalfCore ε₃ - 1| ≤ R)
    (hO₁ : |aperyBranchOneCore ε₁ - 1| ≤ R)
    (hO₂ : |aperyBranchOneCore ε₂ - 1| ≤ R)
    (hO₃ : |aperyBranchOneCore ε₃ - 1| ≤ R)
    (hVlo_pos : 0 < V_lo)
    (hVlo : V_lo ≤ |(Real.sqrt ε₂ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₁) *
              (Real.sqrt ε₃ - Real.sqrt ε₂)|)
    (hgap : (R * (1 + R) ^ 2 + R * (1 + R) + R) *
              (6 * M_eps * Real.sqrt M_eps) < V_lo) :
    apery3Det ε₁ ε₂ ε₃ ≠ 0 := by
  refine apery3Det_ne_zero_of_near_unit_cores V_lo hVlo_pos hVlo
    ((R * (1 + R) ^ 2 + R * (1 + R) + R) * (6 * M_eps * Real.sqrt M_eps))
    ?_ hgap
  exact apery3Det_perturbation_abs_le_scalar h₁ h₂ h₃ hM₁ hM₂ hM₃
    hZ₁ hZ₂ hZ₃ hH₁ hH₂ hH₃ hO₁ hO₂ hO₃

/-- **`apery3Det` collapse when the first probe is at the conifold
itself.** With ε₁ = 0, the regular branch amplitude is `1` and both
remaining `aperyConnectionDet`'s with a zero argument vanish, so the
3-probe det reduces to the 2-probe det of the other two probes. -/
@[simp] lemma apery3Det_first_zero (ε₂ ε₃ : ℝ) :
    apery3Det 0 ε₂ ε₃ = aperyConnectionDet ε₂ ε₃ := by
  unfold apery3Det
  rw [aperyConnectionDet_zero_left, aperyConnectionDet_zero_left,
    aperyBranchAmplitude_zero_at_zero]
  ring

/-- **`apery3Det` collapse when the second probe is at the conifold.**
By swap antisymmetry, the second-position zero gives a sign-flipped
2-probe det. -/
@[simp] lemma apery3Det_second_zero (ε₁ ε₃ : ℝ) :
    apery3Det ε₁ 0 ε₃ = -(aperyConnectionDet ε₁ ε₃) := by
  rw [show apery3Det ε₁ 0 ε₃ = -(apery3Det 0 ε₁ ε₃) from
    by rw [apery3Det_swap12]]
  rw [apery3Det_first_zero]

/-- **`apery3Det` collapse when the third probe is at the conifold.**
By cyclic symmetry, the third-position zero gives the 2-probe det of
the first two. -/
@[simp] lemma apery3Det_third_zero (ε₁ ε₂ : ℝ) :
    apery3Det ε₁ ε₂ 0 = aperyConnectionDet ε₁ ε₂ := by
  rw [show apery3Det ε₁ ε₂ 0 = apery3Det 0 ε₁ ε₂ from
    apery3Det_cycle 0 ε₁ ε₂]
  rw [apery3Det_first_zero]

/-- **`apery3Det` cofactor expansion along the A_½ column.** Same value
as the def (which expands along A_0); useful when working with A_½
factors in proofs. Sign pattern `(-, +, -)` for column 1. -/
lemma apery3Det_expand_half_column (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₁ ε₂ ε₃ =
      -(aperyBranchAmplitude_half ε₁ *
          (aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₃ -
            aperyBranchAmplitude_zero ε₃ * aperyBranchValue_one ε₂)) +
        aperyBranchAmplitude_half ε₂ *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₃ -
            aperyBranchAmplitude_zero ε₃ * aperyBranchValue_one ε₁) -
        aperyBranchAmplitude_half ε₃ *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₂ -
            aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₁) := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` cofactor expansion along the V_1 column.** Sign
pattern `(+, -, +)` for column 2. -/
lemma apery3Det_expand_one_column (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₁ ε₂ ε₃ =
      aperyBranchValue_one ε₁ *
          (aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₃ -
            aperyBranchAmplitude_zero ε₃ * aperyBranchAmplitude_half ε₂) -
        aperyBranchValue_one ε₂ *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₃ -
            aperyBranchAmplitude_zero ε₃ * aperyBranchAmplitude_half ε₁) +
        aperyBranchValue_one ε₃ *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₂ -
            aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₁) := by
  unfold apery3Det aperyConnectionDet; ring

/-- **3-probe canonical recovery of the regular extract.** Pure
formula in three GFA values: by Cramer applied to the 3×3 system
`GFA(z₁ - εi) = c₀·A_0(εi) + c_h·A_½(εi) + c_1·V_1(εi)`, the seed `c₀`
is recovered as the cofactor combination along the A_0 column. No
ext/data dependency — purely the GFA values + the explicit branch
amplitudes. -/
noncomputable def aperyCanonicalExtractRegular3 (ε₁ ε₂ ε₃ : ℝ) : ℝ :=
  (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) *
        aperyConnectionDet ε₂ ε₃ -
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) *
        aperyConnectionDet ε₁ ε₃ +
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₃)) *
        aperyConnectionDet ε₁ ε₂) /
    apery3Det ε₁ ε₂ ε₃

/-- **Data-layer regular extract factors through the 3-probe canonical
formula on disk.** Given three valid disk probes with `apery3Det ≠ 0`,
`d.extractRegular = aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃`. The
cofactor combination of the right-endpoint identities yields
`d.extractRegular · apery3Det = (numerator)`; divide by `apery3Det` to
get the canonical formula. -/
lemma AperyConnectionData.extractRegular_eq_canonical3_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractRegular = aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃ := by
  have hd1 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₁ hdisk₁
  have hd2 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₂ hdisk₂
  have hd3 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₃ hdisk₃
  have hkey : d.extractRegular * apery3Det ε₁ ε₂ ε₃ =
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) *
            aperyConnectionDet ε₂ ε₃ -
        aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) *
            aperyConnectionDet ε₁ ε₃ +
        aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₃)) *
            aperyConnectionDet ε₁ ε₂ := by
    rw [hd1, hd2, hd3]
    unfold apery3Det aperyConnectionDet; ring
  unfold aperyCanonicalExtractRegular3
  field_simp [h3det]
  linarith [hkey]

/-- **Ext-layer mirror: regular extract via 3-probe Cramer.** Bridges
`ext.F` evaluated at the conifold to the canonical 3-probe formula
`aperyCanonicalExtractRegular3`. Delegates through
`AperyConnectionData.of_witness`. -/
lemma AperyAnalyticExtension.extractRegular_eq_canonical3_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I) (hε₃ : (-ε₃) ∈ I)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.F Number.aperyConifoldZ1Poly = aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃ :=
  (AperyConnectionData.of_witness ext I h0 h).extractRegular_eq_canonical3_on_disk
    hε₁ hε₂ hε₃ hdet12 h3det hdisk₁ hdisk₂ hdisk₃

/-- **3-probe canonical recovery of the half extract.** Composition of
the 3-probe `c₀` recovery (`aperyCanonicalExtractRegular3`) with the
2-probe canonical `c_h` formula. With three valid disk probes, no seed
input is needed. -/
noncomputable def aperyCanonicalExtractHalf3 (ε₁ ε₂ ε₃ : ℝ) : ℝ :=
  aperyCanonicalExtractHalf (aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃) ε₁ ε₂

/-- **Data-layer half extract factors through 3-probe canonical formula
on disk.** Combines the 2-probe `extractHalf_eq_canonical_on_disk`
bridge with the 3-probe regular-extract bridge to eliminate the seed. -/
lemma AperyConnectionData.extractHalf_eq_canonical3_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractHalf ε₁ ε₂ = aperyCanonicalExtractHalf3 ε₁ ε₂ ε₃ := by
  unfold aperyCanonicalExtractHalf3
  rw [d.extractHalf_eq_canonical_on_disk hdisk₁ hdisk₂,
    d.extractRegular_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃]

/-- **3-probe canonical recovery of the one extract.** Composition of
the 3-probe `c₀` recovery (`aperyCanonicalExtractRegular3`) with the
2-probe canonical `c_1` formula. -/
noncomputable def aperyCanonicalExtractOne3 (ε₁ ε₂ ε₃ : ℝ) : ℝ :=
  aperyCanonicalExtractOne (aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃) ε₁ ε₂

/-- **Data-layer one extract factors through 3-probe canonical formula
on disk.** Mirror of `extractHalf_eq_canonical3_on_disk`. -/
lemma AperyConnectionData.extractOne_eq_canonical3_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractOne ε₁ ε₂ = aperyCanonicalExtractOne3 ε₁ ε₂ ε₃ := by
  unfold aperyCanonicalExtractOne3
  rw [d.extractOne_eq_canonical_on_disk hdisk₁ hdisk₂,
    d.extractRegular_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃]

