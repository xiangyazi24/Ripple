    have : (2 : ℝ) ≤ (m : ℝ) - 2 := by nlinarith
    have : 1 / ((m : ℝ) - 2) ≤ 1 / 2 := one_div_le_one_div_of_le (by norm_num) this
    nlinarith
  have hprev_low : L1 * u (m - 1) ≤ u m := by
    simpa [u, L1, hm1_cast] using hprev.1
  have hprev_high : u m ≤ u (m - 1) := by
    simpa [u] using hprev.2
  have hprev2_low : L2 * u (m - 2) ≤ u (m - 1) := by
    simpa [u, L2, hm2_cast] using hprev2.1
  have hprev2_high : u (m - 1) ≤ u (m - 2) := by
    simpa [u] using hprev2.2
  constructor
  · have huprev_bound : u (m - 1) ≤ u m / L1 := by
      rw [le_div_iff₀ hL1_pos]
      nlinarith [hprev_low]
    have hL12_pos : 0 < L1 * L2 := mul_pos hL1_pos hL2_pos
    have hlow12 : L1 * (L2 * u (m - 2)) ≤ u m := by
      have hmul := mul_le_mul_of_nonneg_left hprev2_low hL1_pos.le
      nlinarith [hmul, hprev_low]
    have huprev2_bound : u (m - 2) ≤ u m / (L1 * L2) := by
      rw [le_div_iff₀ hL12_pos]
      nlinarith [hlow12]
    have hB_low : B * (u m / L1) ≤ B * u (m - 1) :=
      mul_le_mul_of_nonpos_left huprev_bound hB_nonpos
    have hG_low : G * (u m / (L1 * L2)) ≤ G * u (m - 2) :=
      mul_le_mul_of_nonpos_left huprev2_bound hG_nonpos
    have hscaled : 1 - 1 / (m : ℝ) ≤ A + B / L1 + G / (L1 * L2) := by
      dsimp [A, B, G, L1, L2, z]
      exact aperyFrobenius_half_scaled_lower hm
    have hscaled_mul :
        (1 - 1 / (m : ℝ)) * u m ≤ (A + B / L1 + G / (L1 * L2)) * u m :=
      mul_le_mul_of_nonneg_right hscaled hu_nonneg
    have hscaled_mul' :
        (1 - 1 / (m : ℝ)) * u m ≤
          A * u m + B * (u m / L1) + G * (u m / (L1 * L2)) := by
      calc
        (1 - 1 / (m : ℝ)) * u m
            ≤ (A + B / L1 + G / (L1 * L2)) * u m := hscaled_mul
        _ = A * u m + B * (u m / L1) + G * (u m / (L1 * L2)) := by
          field_simp [hL1_pos.ne', hL2_pos.ne']
    change (1 - 1 / (m : ℝ)) * u m ≤ u (m + 1)
    rw [hrec]
    nlinarith [hB_low, hG_low, hscaled_mul']
  · have hB_high : B * u (m - 1) ≤ B * u m :=
      mul_le_mul_of_nonpos_left hprev_high hB_nonpos
    have hG_high : G * u (m - 2) ≤ G * u m :=
      mul_le_mul_of_nonpos_left (le_trans hprev_high hprev2_high) hG_nonpos
    have hsum_mul : (A + B + G) * u m ≤ 1 * u m :=
      mul_le_mul_of_nonneg_right hsum_le hu_nonneg
    change u (m + 1) ≤ u m
    rw [hrec]
    nlinarith

lemma aperyFrobenius_half_abs_mul_pow_eq_u {m : ℕ}
    (hu : 0 < aperyFrobenius_half_u m) :
    |aperyFrobenius_half_c m| * Number.aperyConifoldZ1Poly ^ m =
      aperyFrobenius_half_u m := by
  have hzpow_pos : 0 < Number.aperyConifoldZ1Poly ^ m :=
    pow_pos aperyConifoldZ1Poly_pos m
  have hc_neg : aperyFrobenius_half_c m < 0 := by
    unfold aperyFrobenius_half_u at hu
    nlinarith
  rw [abs_of_neg hc_neg]
  unfold aperyFrobenius_half_u
  ring

lemma aperyFrobenius_half_ratio_of_u {m : ℕ} (hm : 1 ≤ m)
    (hu : 0 < aperyFrobenius_half_u m)
    (hunext : 0 < aperyFrobenius_half_u (m + 1))
    (hle : aperyFrobenius_half_u (m + 1) ≤ aperyFrobenius_half_u m) :
    |aperyFrobenius_half_c (m + 1)| ≤
      (1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
        |aperyFrobenius_half_c m| := by
  have hz_pos : 0 < Number.aperyConifoldZ1Poly := aperyConifoldZ1Poly_pos
  have hzpow_pos : 0 < Number.aperyConifoldZ1Poly ^ (m + 1) :=
    pow_pos hz_pos (m + 1)
  have habs_next := aperyFrobenius_half_abs_mul_pow_eq_u hunext
  have habs_m := aperyFrobenius_half_abs_mul_pow_eq_u hu
  have hfactor_ge : 1 ≤ 1 + 1 / (m : ℝ) := by
    have hmR : (1 : ℝ) ≤ (m : ℝ) := by exact_mod_cast hm
    have hfrac_nonneg : 0 ≤ 1 / (m : ℝ) := one_div_nonneg.mpr (by nlinarith)
    linarith
  have hle_scaled :
      aperyFrobenius_half_u (m + 1) ≤
        (1 + 1 / (m : ℝ)) * aperyFrobenius_half_u m := by
    have hmul := mul_le_mul_of_nonneg_right hfactor_ge hu.le
    nlinarith
  have hmul :
      |aperyFrobenius_half_c (m + 1)| * Number.aperyConifoldZ1Poly ^ (m + 1) ≤
        ((1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
          |aperyFrobenius_half_c m|) *
          Number.aperyConifoldZ1Poly ^ (m + 1) := by
    calc
      |aperyFrobenius_half_c (m + 1)| * Number.aperyConifoldZ1Poly ^ (m + 1)
          = aperyFrobenius_half_u (m + 1) := habs_next
      _ ≤ (1 + 1 / (m : ℝ)) * aperyFrobenius_half_u m := hle_scaled
      _ = ((1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
          |aperyFrobenius_half_c m|) *
          Number.aperyConifoldZ1Poly ^ (m + 1) := by
            rw [← habs_m]
            rw [pow_succ]
            field_simp [hz_pos.ne']
  exact le_of_mul_le_mul_right hmul hzpow_pos

/-- **Apéry ρ=1/2 ratio bound (cancellation-essential, Apéry-specific).**

For `m ≥ M₀` (some threshold to be determined, e.g. M₀ = 4 from the
analysis comment "At m=4: total effective ratio ≈ 27 < 34 ≈ 1/z₁"),
the Frobenius coefficient ratio satisfies
```
|c_{m+1}| ≤ (1/z₁) · (1 + 1/m) · |c_m|
```

This is the cancellation-essential algebraic fact: it requires the
explicit char-poly factorization `taylorShift(P) = t·(t-z₁)²·(t+24√2)`,
the denominator factorization `aperyFrobenius_half_denom_ne_zero`, and
the 3-step reduction `aperyFrobenius_three_step_sum`. -/
theorem aperyFrobenius_half_ratio_bound :
    ∃ M₀ : ℕ, 1 ≤ M₀ ∧ ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| ≤
      (1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly (1 / 2) 1 m| := by
  refine ⟨4, by norm_num, ?_⟩
  have hcoef_pos : ∀ n : ℕ, 2 ≤ n → 0 < 1 - 1 / (n : ℝ) := by
    intro n hn
    have hnR : (2 : ℝ) ≤ (n : ℝ) := by exact_mod_cast hn
    have : 1 / (n : ℝ) ≤ 1 / 2 := one_div_le_one_div_of_le (by norm_num) hnR
    nlinarith
  have hQ : ∀ n : ℕ, 2 ≤ n →
      0 < aperyFrobenius_half_u n ∧
        ((1 - 1 / (n : ℝ)) * aperyFrobenius_half_u n ≤
            aperyFrobenius_half_u (n + 1) ∧
          aperyFrobenius_half_u (n + 1) ≤ aperyFrobenius_half_u n) := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
      intro hn
      by_cases hn2 : n = 2
      · subst n
        exact ⟨aperyFrobenius_half_u2_pos, aperyFrobenius_half_base_q2⟩
      by_cases hn3 : n = 3
      · subst n
        have hbase2 := aperyFrobenius_half_base_q2
        have hu3 : 0 < aperyFrobenius_half_u 3 := by
          have hprod : 0 < (1 - 1 / (2 : ℝ)) * aperyFrobenius_half_u 2 := by
            have hc := hcoef_pos 2 (by norm_num)
            exact mul_pos hc aperyFrobenius_half_u2_pos
          nlinarith [hbase2.1, hprod]
        exact ⟨hu3, aperyFrobenius_half_base_q3⟩
      have hn4 : 4 ≤ n := by omega
      have hprev_all := ih (n - 1) (by omega : n - 1 < n) (by omega : 2 ≤ n - 1)
      have hprev2_all := ih (n - 2) (by omega : n - 2 < n) (by omega : 2 ≤ n - 2)
      have hn1succ : n - 1 + 1 = n := by omega
      have hn2succ : n - 2 + 1 = n - 1 := by omega
      have hprev :
          (1 - 1 / ((n - 1 : ℕ) : ℝ)) * aperyFrobenius_half_u (n - 1) ≤
              aperyFrobenius_half_u n ∧
            aperyFrobenius_half_u n ≤ aperyFrobenius_half_u (n - 1) := by
        simpa [hn1succ] using hprev_all.2
      have hprev2 :
          (1 - 1 / ((n - 2 : ℕ) : ℝ)) * aperyFrobenius_half_u (n - 2) ≤
              aperyFrobenius_half_u (n - 1) ∧
            aperyFrobenius_half_u (n - 1) ≤ aperyFrobenius_half_u (n - 2) := by
        simpa [hn2succ] using hprev2_all.2
      have hu_n : 0 < aperyFrobenius_half_u n := by
        have hc := hcoef_pos (n - 1) (by omega : 2 ≤ n - 1)
        have hprod : 0 <
            (1 - 1 / ((n - 1 : ℕ) : ℝ)) * aperyFrobenius_half_u (n - 1) :=
          mul_pos hc hprev_all.1
        nlinarith [hprev.1, hprod]
      have hstep := aperyFrobenius_half_u_step hn4 hprev hprev2 hu_n.le
      exact ⟨hu_n, hstep⟩
  intro m hm
  have hqm := hQ m (by omega : 2 ≤ m)
  have hqnext := hQ (m + 1) (by omega : 2 ≤ m + 1)
  simpa [aperyFrobenius_half_c] using
    aperyFrobenius_half_ratio_of_u (m := m) (by omega : 1 ≤ m) hqm.1 hqnext.1 hqm.2.2

/-- **Frobenius coefficient growth bound (Apéry ρ=1/2).**
The coefficients grow at most polynomially times geometrically:
`|c_m| ≤ C · (m+1) · (1/z₁)^m`. This follows from the eigenvalue
decomposition of the 3-step recurrence, whose characteristic
polynomial factors as `(λ - 1/z₁)²·(λ + 1/(24√2))` (from the
Taylor shift factorization of P). The double root at `1/z₁` gives
the polynomial factor `m+1`; triangle inequality alone fails because
the effective ratio exceeds `1/z₁` — cancellation is essential.

Closed via `Ripple.Frobenius.PoincaréPerron.growth_bound_of_ratio_bound_one`
applied to `aperyFrobenius_half_ratio_bound`. -/
theorem aperyFrobenius_half_coeff_growth_bound :
    ∃ C : ℝ, 0 < C ∧ ∀ m : ℕ,
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1 / 2) 1 m| ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  obtain ⟨M₀, hM₀, hratio⟩ := aperyFrobenius_half_ratio_bound
  have hpos : 0 < (1 / Number.aperyConifoldZ1Poly) := by
    have := aperyConifoldZ1Poly_pos; positivity
  have habs : |1 / Number.aperyConifoldZ1Poly| = 1 / Number.aperyConifoldZ1Poly :=
    abs_of_pos hpos
  have hev_pos : 0 < |1 / Number.aperyConifoldZ1Poly| := by rw [habs]; exact hpos
  have hratio' : ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| ≤
      |1 / Number.aperyConifoldZ1Poly| * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly (1 / 2) 1 m| := by
    intro m hm
    rw [habs]; exact hratio m hm
  have h := Ripple.Frobenius.PoincaréPerron.growth_bound_of_ratio_bound_one
    (c := fun m => frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2) 1 m)
    (ev₁ := 1 / Number.aperyConifoldZ1Poly) hev_pos hM₀ hratio'
  obtain ⟨C, hC_pos, hC⟩ := h
  refine ⟨C, hC_pos, fun m => ?_⟩
  have hC_m := hC m
  rw [habs] at hC_m
  exact hC_m

/-- **Frobenius value summability (Apéry ρ=1/2) on the full disk.**
From the coefficient growth bound: `|c_m t^m| ≤ C·(m+1)·(|t|/z₁)^m`,
summable for `|t| < z₁`. -/
lemma aperyFrobenius_half_summable {t : ℝ}
    (ht : |t| < Number.aperyConifoldZ1Poly) :
    Summable (fun m => frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2) 1 m * t ^ m) := by
  obtain ⟨C, hC_pos, hbound⟩ := aperyFrobenius_half_coeff_growth_bound
  have hz1 := aperyConifoldZ1Poly_pos
  have hr : |t| / Number.aperyConifoldZ1Poly < 1 := div_lt_one hz1 |>.mpr ht
  have hr_nn : 0 ≤ |t| / Number.aperyConifoldZ1Poly := div_nonneg (abs_nonneg _) hz1.le
  have hr_norm : ‖|t| / Number.aperyConifoldZ1Poly‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr
  -- (m+1)·r^m = m·r^m + r^m, both summable.
  have h_pow : Summable (fun m : ℕ => (m : ℝ) * (|t| / Number.aperyConifoldZ1Poly) ^ m) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    refine h.congr (fun n => ?_); simp [pow_one]
  have h_geom : Summable (fun m : ℕ => (|t| / Number.aperyConifoldZ1Poly) ^ m) :=
    summable_geometric_of_norm_lt_one hr_norm
  have h_sum : Summable (fun m : ℕ => C * (((m : ℝ) + 1) * (|t| / Number.aperyConifoldZ1Poly) ^ m)) := by
    refine ((h_pow.add h_geom).mul_left C).congr (fun n => ?_)
    push_cast; ring
  refine Summable.of_norm_bounded h_sum (fun m => ?_)
  rw [Real.norm_eq_abs, abs_mul, abs_pow]
  calc |frobeniusCoeff _ 2 _ (1/2) 1 m| * |t| ^ m
      ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * |t| ^ m :=
        mul_le_mul_of_nonneg_right (hbound m) (pow_nonneg (abs_nonneg _) _)
    _ = C * ((m : ℝ) + 1) * (|t| / Number.aperyConifoldZ1Poly) ^ m := by
        have hz_ne : (Number.aperyConifoldZ1Poly : ℝ) ≠ 0 := aperyConifoldZ1Poly_pos.ne'
        rw [show (|t| / Number.aperyConifoldZ1Poly) ^ m =
              (1 / Number.aperyConifoldZ1Poly) ^ m * |t| ^ m from by
          rw [div_pow, div_pow, one_pow, mul_comm]
          field_simp]
        ring
    _ = C * (((m : ℝ) + 1) * (|t| / Number.aperyConifoldZ1Poly) ^ m) := by ring

/-- **`frobeniusValue` for ρ=1/2 is continuous on `[-δ, δ]` for `δ < z₁`.**
From the coefficient growth bound + Weierstrass M-test. -/
lemma aperyFrobenius_half_continuousOn_small {δ : ℝ} (hδ_nn : 0 ≤ δ)
    (hδ : δ < Number.aperyConifoldZ1Poly) :
    ContinuousOn
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1 / 2) 1 t)
      (Set.Icc (-δ) δ) := by
  obtain ⟨C, hC_pos, hbound⟩ := aperyFrobenius_half_coeff_growth_bound
  have hz1 := aperyConifoldZ1Poly_pos
  have hr : δ / Number.aperyConifoldZ1Poly < 1 := div_lt_one hz1 |>.mpr hδ
  have hr_nn : 0 ≤ δ / Number.aperyConifoldZ1Poly := div_nonneg hδ_nn hz1.le
  have hr_norm : ‖δ / Number.aperyConifoldZ1Poly‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr
  have h_pow : Summable (fun m : ℕ => (m : ℝ) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    refine h.congr (fun n => ?_); simp [pow_one]
  have h_geom : Summable (fun m : ℕ => (δ / Number.aperyConifoldZ1Poly) ^ m) :=
    summable_geometric_of_norm_lt_one hr_norm
  have h_sum : Summable (fun m : ℕ => C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m)) := by
    refine ((h_pow.add h_geom).mul_left C).congr (fun n => ?_)
    push_cast; ring
  unfold frobeniusValue
  refine continuousOn_tsum
    (fun m => (continuous_const.mul (continuous_id.pow m)).continuousOn) h_sum
    (fun m t ht => ?_)
  have ht_abs : |t| ≤ δ := by
    rw [abs_le]; exact ⟨by linarith [ht.1], ht.2⟩
  have hz_ne : (Number.aperyConifoldZ1Poly : ℝ) ≠ 0 := aperyConifoldZ1Poly_pos.ne'
  rw [Real.norm_eq_abs, abs_mul, abs_pow]
  calc |frobeniusCoeff _ 2 _ (1/2) 1 m| * |t| ^ m
      ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * |t| ^ m :=
        mul_le_mul_of_nonneg_right (hbound m) (pow_nonneg (abs_nonneg _) _)
    _ ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * δ ^ m := by
        refine mul_le_mul_of_nonneg_left ?_ (by positivity)
        exact pow_le_pow_left₀ (abs_nonneg _) ht_abs m
    _ = C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
        rw [show ((δ : ℝ) / Number.aperyConifoldZ1Poly) ^ m =
              (1 / Number.aperyConifoldZ1Poly) ^ m * δ ^ m from by
          rw [div_pow, div_pow, one_pow, mul_comm]; field_simp]
        ring

/-- **`frobeniusValue` for ρ=1/2 tends to 1 as `t → 0`.** -/
lemma aperyFrobenius_half_tendsto_at_zero :
    Filter.Tendsto
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1 / 2) 1 t)
      (nhds 0) (nhds 1) := by
  have h_eq : (1 : ℝ) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1/2) 1 0 :=
    (frobeniusValue_zero _ 2 _ (1/2) 1).symm
  conv_rhs => rw [h_eq]
  have hδ : Number.aperyConifoldZ1Poly / 2 < Number.aperyConifoldZ1Poly :=
    half_lt_self aperyConifoldZ1Poly_pos
  have h_cont := aperyFrobenius_half_continuousOn_small
    (le_of_lt (half_pos aperyConifoldZ1Poly_pos)) hδ
  have hz1_pos := aperyConifoldZ1Poly_pos
  have h_neg_δ : -(Number.aperyConifoldZ1Poly / 2) < 0 := by linarith
  have h_pos_δ : (0 : ℝ) < Number.aperyConifoldZ1Poly / 2 := half_pos hz1_pos
  exact h_cont.continuousAt (Icc_mem_nhds h_neg_δ h_pos_δ)

/-- **3-step recurrence form for ρ=1 (sub-lemma 1 of ρ=1 ratio_bound proof).**
Parallel of `aperyFrobenius_half_3step_recurrence` for the ρ=1 branch.
For `m ≥ 3`:
```
c(m+1) · denom(m+1) =
  -(c(m-2)·w_{m-2} + c(m-1)·w_{m-1} + c(m)·w_m)
```
where `denom(m+1) = (-1)²·simpleZeroIndicialPoly(Q, P, z₁, 2, 1 + (m+1))` and
each `w_i = coeff(m+2)(substLHSGen ps 3 z₁ 1 (X^i))`. -/
lemma aperyFrobenius_one_3step_recurrence
    {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly 1 1
    let w (i : ℕ) := PowerSeries.coeff (R := ℝ) (m + 1 + 1)
              (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                3 Number.aperyConifoldZ1Poly 1
                ((PowerSeries.X : PowerSeries ℝ) ^ i))
    let denom_val := ((-1 : ℝ) ^ 2) *
              simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
                Number.aperyConifoldZ1Poly 2 ((1 : ℝ) + ((m + 1 : ℕ) : ℝ))
    c (m + 1) * denom_val =
      -(c (m - 2) * w (m - 2) + c (m - 1) * w (m - 1) + c m * w m) := by
  intro c w denom_val
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  have h_rec := frobeniusCoeff_succ_linear_combination
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
    Number.aperyConifoldZ1Poly 1 1 m hP_zero
  have h_3step := aperyFrobenius_three_step_sum hm (1 : ℝ) 1
  have h_denom_ne : denom_val ≠ 0 := aperyFrobenius_one_denom_ne_zero m
  have h_eq1 :
      c (m + 1) * denom_val =
        -(∑ i ∈ Finset.range (m + 1), c i * w i) := by
    show frobeniusCoeff _ 2 _ 1 1 (m + 1) * denom_val = _
    rw [h_rec]
    have hps2 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2 =
        Number.aperyQconifold := rfl
    have hps3 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1) =
        Number.aperyPconifold := rfl
    rw [hps2, hps3]
    rw [neg_div, neg_mul, div_mul_cancel₀ _ h_denom_ne]
  rw [h_eq1]
  congr 1
  have h_3step_local :
