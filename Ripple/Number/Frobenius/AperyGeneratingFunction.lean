    aperyGFAReal (Number.aperyConifoldZ1Poly + t) -
        Real.sqrt (-t) * ((ext.connectionCoefficients ε₁ ε₂).2.1 +
          t * ∑' m, frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly (1 / 2)
              ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) -
        ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
          ∑' m, frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly 1
              ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) =
      (ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_regular_branch_isolated_on_disk h0 h hε₁ hε₂ hdet ht htdisk

/-- **Sqrt-of-neg squared identity.** For `t ≤ 0`, `(√(-t))² = -t`.
Direct consequence of `Real.sq_sqrt` applied to `-t ≥ 0`. -/
lemma sqrt_neg_sq_of_nonpos {t : ℝ} (ht : t ≤ 0) :
    (Real.sqrt (-t)) ^ 2 = -t := by
  rw [sq, Real.mul_self_sqrt (by linarith)]

/-- **Half-branch squared isolation on disk (left half).** Squaring the
half-branch isolation and using `t ≤ 0` (so `(√(-t))² = -t`) eliminates
the square root, giving a polynomial-in-`t` identity:
`(f - regular - one)² = (-t)·(a_h + t·T_H)²`. Useful for downstream
reasoning that wants to avoid `Real.sqrt`. -/
lemma IsAperyConnectionCoeffsOn.half_branch_squared_isolated_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htnp : t ≤ 0)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) -
        (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m)) ^ 2 =
      (-t) * (a_half + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_half (m + 1) * t ^ m) ^ 2 := by
  have h_iso := h.half_branch_isolated_on_frobeniusDisk ht htdisk
  rw [h_iso, mul_pow, sqrt_neg_sq_of_nonpos htnp]

/-- **Data-layer half-branch squared isolation.** -/
lemma AperyConnectionData.F_half_branch_squared_isolated_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htnp : t ≤ 0)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (d.F (Number.aperyConifoldZ1Poly + t) -
        (d.extractRegular + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m) -
        (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
            t ^ m)) ^ 2 =
      (-t) * (d.extractHalf ε₁ ε₂ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (d.extractHalf ε₁ ε₂) (m + 1) *
          t ^ m) ^ 2 := by
  have h_iso := d.F_half_branch_isolated_on_disk hε₁ hε₂ hdet ht htdisk
  rw [h_iso, mul_pow, sqrt_neg_sq_of_nonpos htnp]

/-- **Ext-layer half-branch squared isolation.** -/
lemma AperyAnalyticExtension.F_half_branch_squared_isolated_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) (htnp : t ≤ 0)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (ext.F (Number.aperyConifoldZ1Poly + t) -
        ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0
            ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) -
        ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
          ∑' m, frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly 1
              ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m)) ^ 2 =
      (-t) * ((ext.connectionCoefficients ε₁ ε₂).2.1 +
        t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2)
            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) ^ 2 := by
  have h_iso := ext.F_half_branch_isolated_on_disk h0 h hε₁ hε₂ hdet ht htdisk
  rw [h_iso, mul_pow, sqrt_neg_sq_of_nonpos htnp]

/-- **GFA-layer half-branch squared isolation.** -/
lemma AperyAnalyticExtension.GFA_half_branch_squared_isolated_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (ht : t ∈ I) (htnp : t ≤ 0)
    (hdisk_GFA : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (aperyGFAReal (Number.aperyConifoldZ1Poly + t) -
        ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0
            ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) -
        ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
          ∑' m, frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly 1
              ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m)) ^ 2 =
      (-t) * ((ext.connectionCoefficients ε₁ ε₂).2.1 +
        t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2)
            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) ^ 2 := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_half_branch_squared_isolated_on_disk h0 h hε₁ hε₂ hdet ht htnp
    htdisk

/-- **Regular-branch right-side extractor on disk.** For `t ≥ 0` in the
Frobenius disk, the half-branch automatically drops via `√(-t) = 0`, so
subtracting the one-branch contribution from `f(z₁+t)` directly recovers
the regular series `a₀ + t·T_Z`. -/
lemma IsAperyConnectionCoeffsOn.regular_branch_extractor_right_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) -
        (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) =
      a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m := by
  have h_right := h.decomp_right_on_frobeniusDisk ht htnn htdisk
  linarith [h_right]

/-- **Data-layer regular-branch right-side extractor.** -/
lemma AperyConnectionData.F_regular_branch_extractor_right_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htnn : 0 ≤ t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    d.F (Number.aperyConifoldZ1Poly + t) -
        (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
            t ^ m) =
      d.extractRegular + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m := by
  have h_right := d.F_right_on_disk hε₁ hε₂ hdet ht htnn htdisk
  linarith [h_right]

/-- **Ext-layer regular-branch right-side extractor.** -/
lemma AperyAnalyticExtension.F_regular_branch_extractor_right_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
