    (hb' : b' ≤ 1 / 64) :
    sSup (h.some.F '' Set.Icc a b) ≤
      sSup (h.some.F '' Set.Icc a b') :=
  h.sSup_some_F_image_Icc_le_of_subset
    ha hab
    ha (le_trans hab hbb') hb'
    (Icc_a_b_subset_Icc_a_b' hbb')

/-- **`sInf` of `some.F` on `Icc a b'` ≤ `sInf` on `Icc a b`
