/-- **Packaged 3-probe canonical triple.** Bundles
`(extractRegular3, extractHalf3, extractOne3)` into a single seedless
`ℝ × ℝ × ℝ` value, parameterized only by the three probes. -/
noncomputable def aperyCanonicalTriple3 (ε₁ ε₂ ε₃ : ℝ) : ℝ × ℝ × ℝ :=
  (aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃,
    aperyCanonicalExtractHalf3 ε₁ ε₂ ε₃,
    aperyCanonicalExtractOne3 ε₁ ε₂ ε₃)

/-- **Data-layer triple factors through 3-probe canonical triple on
disk.** Bundles the three individual 3-probe extract bridges into one
triple equation. -/
lemma AperyConnectionData.canonicalTriple3_eq_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    (d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂) =
      aperyCanonicalTriple3 ε₁ ε₂ ε₃ := by
  unfold aperyCanonicalTriple3
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · exact d.extractRegular_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃
  · exact d.extractHalf_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃
  · exact d.extractOne_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃

/-- **Ext-layer mirror: triple factors through 3-probe canonical triple
