/-! #### Same-`ext` family is pairwise compatible at the analytic level

Mirrors `toRegularDiskAt_compatible` / `_pairwise_compatible` /
`_F_eq_chain`. Adjacent compatibility is automatic when every disk in
the family has the form `ext.toAnalyticDiskAt …`. -/

/-- **Two `ext`-induced analytic-at disks are compatible.** Direct lift
of `toRegularDiskAt_compatible` through the analytic-At projection. -/
lemma AperyAnalyticExtension.toAnalyticDiskAt_compatible
    (ext : AperyAnalyticExtension)
    {c₁ : ℝ} (h_reg₁ : AperyConifoldRegularPoint c₁)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (ext.F (c₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {c₂ : ℝ} (h_reg₂ : AperyConifoldRegularPoint c₂)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (ext.F (c₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n)) :
    AperyAnalyticDiskAt.Compatible
      (ext.toAnalyticDiskAt c₁ h_reg₁ r₁ hr₁ coeffs₁ hs₁ hSum₁)
      (ext.toAnalyticDiskAt c₂ h_reg₂ r₂ hr₂ coeffs₂ hs₂ hSum₂) :=
  ext.toRegularDiskAt_compatible h_reg₁ hr₁ coeffs₁ hs₁ h_reg₂ hr₂ coeffs₂ hs₂

/-- **All-the-same-`ext` analytic-At family is pairwise compatible.** -/
lemma AperyAnalyticExtension.toAnalyticDiskAt_pairwise_compatible
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyAnalyticDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (i j : ℕ) :
    AperyAnalyticDiskAt.Compatible (ds i) (ds j) := by
  have hi : (ds i).toAperyRegularDisk.F = ext.F := h_ext i
  have hj : (ds j).toAperyRegularDisk.F = ext.F := h_ext j
  exact AperyRegularDisk.Compatible.of_F_eq (hi.trans hj.symm)

/-- **Chain F-equality for an all-the-same-`ext` analytic-At family.** -/
lemma AperyAnalyticExtension.toAnalyticDiskAt_F_eq_chain
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    {z : ℝ} (hz : ∀ i, i ≤ n → z ∈ (ds i).toAperyRegularDisk.diskOpen) :
    (ds 0).F z = (ds n).F z :=
  AperyAnalyticDiskAt.Compatible.F_eq_chain ds n
    (fun i _ => ext.toAnalyticDiskAt_pairwise_compatible ds h_ext i (i + 1)) hz

/-- **Endpoint values both equal `ext.F z`** (analytic-At family). -/
lemma AperyAnalyticExtension.toAnalyticDiskAt_F_eq_ext
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyAnalyticDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) (z : ℝ) :
    (ds n).F z = ext.F z := by
  rw [h_ext n]

/-! #### GFA → analytic-At chain capstone

Lifts `aperyGFA_value_via_chain_to_ext` to the `AperyAnalyticDiskAt`
layer. The GFA-side compatibility hypothesis is unchanged
(`AperyRegularDisk.Compatible aperyGFARegularDisk (ds 0).…`) — only the
chain elements are upgraded from regular-At to analytic-At. -/

/-- **GFA value via analytic-At chain to `ext`.** Mirror of
`aperyGFA_value_via_chain_to_ext` for `AperyAnalyticDiskAt` chains. -/
lemma aperyGFA_value_via_analytic_chain_to_ext
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    (hcompGFA : AperyRegularDisk.Compatible aperyGFARegularDisk
      (ds 0).toAperyRegularDisk)
    {z : ℝ} (hzGFA : |z| < 1 / 64)
    (hz : ∀ i, i ≤ n → z ∈ (ds i).toAperyRegularDisk.diskOpen) :
    aperyGFAReal z = ext.F z := by
  have hzGFAmem : z ∈ aperyGFARegularDisk.diskOpen := by
    rw [aperyGFARegularDisk_mem_diskOpen]; exact hzGFA
  have hz0 : z ∈ (ds 0).toAperyRegularDisk.diskOpen := hz 0 (Nat.zero_le _)
  have h0 : aperyGFAReal z = (ds 0).F z := by
    have := hcompGFA z hzGFAmem hz0
    simpa using this
  have hchain : (ds 0).F z = (ds n).F z :=
    ext.toAnalyticDiskAt_F_eq_chain ds n h_ext hz
  rw [h0, hchain]
  exact ext.toAnalyticDiskAt_F_eq_ext ds h_ext n z

/-! #### End-to-end analytic-At bridge

Combines the GFA-side analytic-At entry
(`aperyGFAInteriorAnalyticDiskAt`) with an ext-anchored analytic-At
chain into a single closed lemma yielding `aperyGFAReal z = ext.F z`.

Pipeline:
1. **GFA-side entry.** `aperyGFAInteriorAnalyticDiskAt` builds an
   analytic-At disk centered at `z₀ ∈ (0, 1/64)` with `F = aperyGFAReal`,
   automatically compat with `aperyGFARegularDisk` (shared `F`).
2. **Bridge to ext side.** A user-supplied `h_bridge`:
   `Compatible bridge_disk (ds 0)` connects the GFA-interior bridge to
   the first disk of the ext-anchored chain.
3. **Chain.** Standard `toAnalyticDiskAt_F_eq_chain` carries the value
   along the rest of the chain.
4. **Land.** `toAnalyticDiskAt_F_eq_ext` collapses the endpoint to
   `ext.F z`.

The bridge can be discharged by the user via, e.g., a Frobenius
expansion at `z₀` whose coefficients arise from `aperyGFAReal`; the
compatibility is then automatic via shared underlying function. -/

/-- **End-to-end analytic-At capstone with explicit GFA-side bridge.**
Takes a GFA-interior analytic-At bridge disk and an ext-anchored
analytic-At chain (already proved bridge-compat). Conclusion is the
gap-B identification `aperyGFAReal z = ext.F z` at any `z` in the
bridge disk's open domain and every chain disk. -/
lemma aperyGFA_eq_ext_via_analytic_GFA_bridge
    (ext : AperyAnalyticExtension)
    {z₀ : ℝ} (h_pos : 0 < z₀) (h_lt : z₀ < 1 / 64)
    {r₀ : ℝ} (hr₀ : 0 < r₀) (coeffs₀ : ℕ → ℝ)
    (hs₀ : ∀ t : ℝ, |t| < r₀ →
      HasSum (fun n => coeffs₀ n * t ^ n) (aperyGFAReal (z₀ + t)))
    (hSum₀ : ∀ r' : NNReal, (r' : ℝ) < r₀ →
      Summable (fun n : ℕ => |coeffs₀ n| * (r' : ℝ) ^ n))
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    (h_bridge : AperyAnalyticDiskAt.Compatible
      (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀ hr₀ coeffs₀ hs₀ hSum₀)
      (ds 0))
    {z : ℝ}
    (hz_bridge : z ∈ (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀ hr₀
      coeffs₀ hs₀ hSum₀).toAperyRegularDisk.diskOpen)
    (hz : ∀ i, i ≤ n → z ∈ (ds i).toAperyRegularDisk.diskOpen) :
    aperyGFAReal z = ext.F z := by
  have hzGFA : aperyGFAReal z = (ds 0).F z := by
    have hG := h_bridge z hz_bridge (hz 0 (Nat.zero_le _))
    simpa [aperyGFAInteriorAnalyticDiskAt_F] using hG
  have hchain : (ds 0).F z = (ds n).F z :=
    ext.toAnalyticDiskAt_F_eq_chain ds n h_ext hz
  rw [hzGFA, hchain]
  exact ext.toAnalyticDiskAt_F_eq_ext ds h_ext n z

/-! #### Auto-bridge from a probe point in `[0, 1/64)`

Hypothesis-light companion of
`aperyGFA_eq_ext_via_analytic_GFA_bridge`. Instead of requiring the
user to supply `h_bridge : Compatible bridge (ds 0)`, this version
auto-discharges it from a single probe point `z* ∈ (0, 1/64)` lying in
both the bridge and `ds 0`. The probe witnesses pointwise agreement
between `aperyGFAReal` (bridge's `F`) and `ext.F` (`ds 0`'s `F`) on a
nhd of `z*` via `agrees_on_small`, then the Identity Theorem extends
this to the entire preconnected overlap. -/

/-- **Auto-bridge compatibility from a probe in `(0, 1/64)`.** A
GFA-side analytic-At bridge disk and an `ext`-anchored analytic-At
disk are compatible whenever they share a probe point `z* ∈ (0, 1/64)`
(strict-interior so a full open nhd lies in `[0, 1/64)`). -/
lemma aperyGFAInteriorAnalyticDiskAt_compatible_with_ext_at_probe
    (ext : AperyAnalyticExtension)
    {z₀ : ℝ} (h_pos : 0 < z₀) (h_lt : z₀ < 1 / 64)
    {r₀ : ℝ} (hr₀ : 0 < r₀) (coeffs₀ : ℕ → ℝ)
    (hs₀ : ∀ t : ℝ, |t| < r₀ →
      HasSum (fun n => coeffs₀ n * t ^ n) (aperyGFAReal (z₀ + t)))
    (hSum₀ : ∀ r' : NNReal, (r' : ℝ) < r₀ →
      Summable (fun n : ℕ => |coeffs₀ n| * (r' : ℝ) ^ n))
    (E : AperyAnalyticDiskAt) (h_ext_E : E.F = ext.F)
    {z_probe : ℝ} (hp_pos : 0 < z_probe) (hp_lt : z_probe < 1 / 64)
    (hp_bridge : z_probe ∈ (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀
      hr₀ coeffs₀ hs₀ hSum₀).toAperyRegularDisk.diskOpen)
    (hp_E : z_probe ∈ E.toAperyRegularDisk.diskOpen) :
    AperyAnalyticDiskAt.Compatible
      (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀ hr₀ coeffs₀ hs₀ hSum₀)
      E := by
  set B := aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀ hr₀ coeffs₀ hs₀ hSum₀
  -- analytic-disk-level compatibility (same predicate as analytic-At-level)
  apply AperyAnalyticDisk.Compatible.of_eventuallyEq_of_preconnected_overlap
    (d₁ := B.toAperyAnalyticDisk) (d₂ := E.toAperyAnalyticDisk)
    (z₀ := z_probe)
  · exact AperyRegularDisk.diskOpen_inter_isPreconnected _ _
  · exact ⟨hp_bridge, hp_E⟩
  · -- B.F = aperyGFAReal eventually equal to E.F = ext.F on a nhd of z_probe
    have h_open : IsOpen (Set.Ioo (0 : ℝ) (1 / 64)) := isOpen_Ioo
    have h_mem : z_probe ∈ Set.Ioo (0 : ℝ) (1 / 64) := ⟨hp_pos, hp_lt⟩
    apply Filter.eventually_of_mem (h_open.mem_nhds h_mem)
    intro w hw
    have hw_Ico : w ∈ Set.Ico (0 : ℝ) (1 / 64) :=
      ⟨le_of_lt hw.1, hw.2⟩
    have h_ext_eq : ext.F w = aperyGFAReal w := ext.F_eq_GFA_on_small hw_Ico
    -- B.F w = aperyGFAReal w (definitional); E.F w = ext.F w (h_ext_E)
    have hB : B.F w = aperyGFAReal w := by
      simp [B, aperyGFAInteriorAnalyticDiskAt_F]
    have hE : E.F w = ext.F w := by rw [h_ext_E]
    rw [hB, hE, h_ext_eq]

/-- **End-to-end analytic-At capstone, hypothesis-light variant.**
Drops the explicit `h_bridge` of
`aperyGFA_eq_ext_via_analytic_GFA_bridge`: when a probe
`z_probe ∈ (0, 1/64)` lies in both the GFA bridge and `ds 0`, the
bridge compatibility is automatic. -/
lemma aperyGFA_eq_ext_via_analytic_GFA_bridge_at_probe
    (ext : AperyAnalyticExtension)
    {z₀ : ℝ} (h_pos : 0 < z₀) (h_lt : z₀ < 1 / 64)
    {r₀ : ℝ} (hr₀ : 0 < r₀) (coeffs₀ : ℕ → ℝ)
    (hs₀ : ∀ t : ℝ, |t| < r₀ →
      HasSum (fun n => coeffs₀ n * t ^ n) (aperyGFAReal (z₀ + t)))
    (hSum₀ : ∀ r' : NNReal, (r' : ℝ) < r₀ →
      Summable (fun n : ℕ => |coeffs₀ n| * (r' : ℝ) ^ n))
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    {z_probe : ℝ} (hp_pos : 0 < z_probe) (hp_lt : z_probe < 1 / 64)
    (hp_bridge : z_probe ∈ (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀
      hr₀ coeffs₀ hs₀ hSum₀).toAperyRegularDisk.diskOpen)
    (hp_E : z_probe ∈ (ds 0).toAperyRegularDisk.diskOpen)
    {z : ℝ}
    (hz_bridge : z ∈ (aperyGFAInteriorAnalyticDiskAt z₀ h_pos h_lt r₀ hr₀
      coeffs₀ hs₀ hSum₀).toAperyRegularDisk.diskOpen)
    (hz : ∀ i, i ≤ n → z ∈ (ds i).toAperyRegularDisk.diskOpen) :
    aperyGFAReal z = ext.F z := by
  have h_bridge :=
    aperyGFAInteriorAnalyticDiskAt_compatible_with_ext_at_probe ext h_pos
      h_lt hr₀ coeffs₀ hs₀ hSum₀ (ds 0) (h_ext 0) hp_pos hp_lt hp_bridge hp_E
  exact aperyGFA_eq_ext_via_analytic_GFA_bridge ext h_pos h_lt hr₀ coeffs₀
    hs₀ hSum₀ ds n h_ext h_bridge hz_bridge hz

/-! #### API ergonomics check

Sanity exercise of the analytic-At chain API: two GFA-side analytic-At
disks at *different* centers (both inside `(0, 1/64)`) are pairwise
compatible — both share `F = aperyGFAReal`, so compatibility is a
direct `of_F_eq` invocation. Tests that the simp projection lemmas
suffice for users not to have to unwrap structures manually. -/

/-- **Two GFA-interior analytic-At disks are compatible.** Both have
`F = aperyGFAReal` so compatibility reduces to `of_F_eq` after
projecting through the analytic-At ↦ analytic-disk ↦ regular-disk
ladder. -/
lemma aperyGFAInteriorAnalyticDiskAt_pairwise_compatible
    {c₁ : ℝ} (h_pos₁ : 0 < c₁) (h_lt₁ : c₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (c₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {c₂ : ℝ} (h_pos₂ : 0 < c₂) (h_lt₂ : c₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (c₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n)) :
    AperyAnalyticDiskAt.Compatible
      (aperyGFAInteriorAnalyticDiskAt c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁)
      (aperyGFAInteriorAnalyticDiskAt c₂ h_pos₂ h_lt₂ r₂ hr₂ coeffs₂ hs₂ hSum₂) :=
  AperyRegularDisk.Compatible.of_F_eq rfl

/-- **GFA-interior analytic-At chain agrees with `aperyGFAReal`.** The
endpoint value of any all-GFA-source analytic-At chain is just
`aperyGFAReal z` itself. Combines `Compatible.F_eq_chain` with the
`F = aperyGFAReal` simp projection. -/
lemma aperyGFAInteriorAnalyticDiskAt_chain_F_eq
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (hcomp : ∀ i, i < n → AperyAnalyticDiskAt.Compatible (ds i) (ds (i + 1)))
    {z : ℝ}
    (hz : ∀ i, i ≤ n → z ∈ (ds i).toAperyRegularDisk.diskOpen) :
    (ds n).F z = aperyGFAReal z := by
  have hchain : (ds 0).F z = (ds n).F z :=
    AperyAnalyticDiskAt.Compatible.F_eq_chain ds n hcomp hz
  rw [← hchain, h_F 0]

/-! ### End-to-end forward continuation of `aperyGFAReal`

Combining `chainGlue` with the GFA-anchoring of every disk gives a single
function (`chainGlue ds n`) that equals `aperyGFAReal` on the union of the
chained open disks AND is real-analytic there. This is the gap-B
forward-continuation statement at the analytic-At layer: from a list of
analytic disks, each anchored at a regular interior point of `(0, 1/64)`
and each carrying `aperyGFAReal` as its `F`, we get a real-analytic
function on the union that agrees with `aperyGFAReal` everywhere. -/

/-- **GFA-anchored chains give all-pairs Compatible automatically.** When
every disk in the chain has `F = aperyGFAReal`, pairwise compatibility is
free (use `Compatible.of_F_eq`). -/
lemma aperyGFAInteriorAnalyticDiskAt_pairwise_compatible_of_F
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal) :
    ∀ j k, j ≤ n → k ≤ n → AperyAnalyticDiskAt.Compatible (ds j) (ds k) := by
  intro j k _ _ z _ _
  change (ds j).F z = (ds k).F z
  rw [h_F j, h_F k]

/-- **Per-piece equality with `aperyGFAReal` on a GFA-anchored chain glue.** -/
lemma aperyGFAInteriorAnalyticDiskAt_chainGlue_eq
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    {k : ℕ} (hk : k ≤ n) {z : ℝ}
    (hz : z ∈ (ds k).toAperyRegularDisk.diskOpen) :
    AperyAnalyticDiskAt.chainGlue ds n z = aperyGFAReal z := by
  rw [AperyAnalyticDiskAt.chainGlue_eq_of_pairwise_compatible ds n
        (aperyGFAInteriorAnalyticDiskAt_pairwise_compatible_of_F ds n h_F) hk hz,
      h_F k]

/-- **Analyticity of the GFA-anchored chain glue on the union.** This is
the gap-B forward-continuation conclusion: a single real-analytic function
on `⋃ k ≤ n, (ds k).diskOpen` that agrees with `aperyGFAReal` everywhere. -/
lemma aperyGFAInteriorAnalyticDiskAt_chainGlue_analyticOnNhd
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal) :
    AnalyticOnNhd ℝ (AperyAnalyticDiskAt.chainGlue ds n)
      (⋃ k ∈ Finset.range (n + 1), (ds k).toAperyRegularDisk.diskOpen) :=
  AperyAnalyticDiskAt.chainGlue_analyticOnNhd_of_pairwise_compatible ds n
    (aperyGFAInteriorAnalyticDiskAt_pairwise_compatible_of_F ds n h_F)

/-! ### Local analytic extension as a structured target

Structure bundling an open domain + an analytic function that equals
`aperyGFAReal` on that domain. The natural target object produced by
`chainGlue` over a GFA-anchored chain. Hides the chain construction
behind a uniform handle. -/

/-- **Local analytic extension of `aperyGFAReal`.** A real-analytic
function `F` on an open set `domain` of `ℝ`, agreeing with
`aperyGFAReal` everywhere on `domain`. Strictly stronger than
`AperyAnalyticExtension`'s small-disk agreement: requires equality on the
full domain, but in exchange the domain can be larger than `[0, 1/64)`
and the regularity is real-analytic, not merely continuous. -/
structure AperyLocalAnalyticExtension where
  /-- Open domain of the local extension. -/
  domain : Set ℝ
  /-- The domain is open. -/
  domain_isOpen : IsOpen domain
  /-- The analytic extension. -/
  F : ℝ → ℝ
  /-- `F` is real-analytic on the domain. -/
  analyticOnNhd_domain : AnalyticOnNhd ℝ F domain
  /-- `F` agrees with `aperyGFAReal` everywhere on the domain. -/
  eq_aperyGFAReal_on_domain : Set.EqOn F aperyGFAReal domain

/-- **Chain construction of a local analytic extension.** Any
GFA-anchored chain produces a `AperyLocalAnalyticExtension` whose
`domain` is the chain union and whose `F` is `chainGlue`. -/
noncomputable def AperyLocalAnalyticExtension.ofGFAChain
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal) :
    AperyLocalAnalyticExtension where
  domain := ⋃ k ∈ Finset.range (n + 1), (ds k).toAperyRegularDisk.diskOpen
  domain_isOpen :=
    isOpen_biUnion (fun k _ => (ds k).toAperyRegularDisk.diskOpen_isOpen)
  F := AperyAnalyticDiskAt.chainGlue ds n
  analyticOnNhd_domain :=
    aperyGFAInteriorAnalyticDiskAt_chainGlue_analyticOnNhd ds n h_F
  eq_aperyGFAReal_on_domain := by
    intro z hz
    rcases Set.mem_iUnion₂.mp hz with ⟨k, hkn, hzk⟩
    have hk : k ≤ n := Nat.lt_succ_iff.mp (Finset.mem_range.mp hkn)
    exact aperyGFAInteriorAnalyticDiskAt_chainGlue_eq ds n h_F hk hzk

@[simp] lemma AperyLocalAnalyticExtension.ofGFAChain_F
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal) :
    (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).F =
      AperyAnalyticDiskAt.chainGlue ds n := rfl

@[simp] lemma AperyLocalAnalyticExtension.ofGFAChain_domain
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal) :
    (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).domain =
      ⋃ k ∈ Finset.range (n + 1), (ds k).toAperyRegularDisk.diskOpen := rfl

/-- **Pointwise restatement of `eq_aperyGFAReal_on_domain`.** -/
lemma AperyLocalAnalyticExtension.F_eq_aperyGFAReal
    (ext : AperyLocalAnalyticExtension) {z : ℝ} (hz : z ∈ ext.domain) :
    ext.F z = aperyGFAReal z := ext.eq_aperyGFAReal_on_domain hz

/-! ### Two-piece union of local analytic extensions

Two `AperyLocalAnalyticExtension` instances combine into one whose
`domain` is the union of theirs. The piecewise function is well-defined
because both pieces equal `aperyGFAReal` on the overlap. -/

open Classical in
/-- **Union of two local analytic extensions.** Domain = union of the two
domains; `F` is `ext₁.F` on `ext₁.domain` and `ext₂.F` elsewhere. -/
noncomputable def AperyLocalAnalyticExtension.union
    (ext₁ ext₂ : AperyLocalAnalyticExtension) :
    AperyLocalAnalyticExtension where
  domain := ext₁.domain ∪ ext₂.domain
  domain_isOpen := ext₁.domain_isOpen.union ext₂.domain_isOpen
  F := fun z => if z ∈ ext₁.domain then ext₁.F z else ext₂.F z
  analyticOnNhd_domain := by
    rintro z (hz₁ | hz₂)
    · have ha₁ := ext₁.analyticOnNhd_domain z hz₁
      have hev : ext₁.F =ᶠ[nhds z]
          fun w => if w ∈ ext₁.domain then ext₁.F w else ext₂.F w := by
        refine Filter.eventually_of_mem (ext₁.domain_isOpen.mem_nhds hz₁) ?_
        intro w hw
        simp [hw]
      exact ha₁.congr hev
    · have ha₂ := ext₂.analyticOnNhd_domain z hz₂
      have hev : ext₂.F =ᶠ[nhds z]
          fun w => if w ∈ ext₁.domain then ext₁.F w else ext₂.F w := by
        refine Filter.eventually_of_mem (ext₂.domain_isOpen.mem_nhds hz₂) ?_
        intro w hw
        by_cases hw₁ : w ∈ ext₁.domain
        · simp only [hw₁, if_true]
          rw [ext₁.F_eq_aperyGFAReal hw₁, (ext₂.F_eq_aperyGFAReal hw).symm]
        · simp [hw₁]
      exact ha₂.congr hev
  eq_aperyGFAReal_on_domain := by
    rintro z (hz₁ | hz₂)
    · simp only [hz₁, if_true]
      exact ext₁.F_eq_aperyGFAReal hz₁
    · by_cases hz₁ : z ∈ ext₁.domain
      · simp only [hz₁, if_true]
        exact ext₁.F_eq_aperyGFAReal hz₁
      · simp only [hz₁, if_false]
        exact ext₂.F_eq_aperyGFAReal hz₂

@[simp] lemma AperyLocalAnalyticExtension.union_domain
    (ext₁ ext₂ : AperyLocalAnalyticExtension) :
    (ext₁.union ext₂).domain = ext₁.domain ∪ ext₂.domain := rfl

/-- **Left-piece value of the union.** -/
lemma AperyLocalAnalyticExtension.union_F_of_mem_left
    (ext₁ ext₂ : AperyLocalAnalyticExtension) {z : ℝ}
    (hz : z ∈ ext₁.domain) :
    (ext₁.union ext₂).F z = ext₁.F z := by
  unfold AperyLocalAnalyticExtension.union
  simp [hz]

/-- **Right-piece value of the union (when outside the left domain).** -/
lemma AperyLocalAnalyticExtension.union_F_of_notMem_left
    (ext₁ ext₂ : AperyLocalAnalyticExtension) {z : ℝ}
    (hz : z ∉ ext₁.domain) :
    (ext₁.union ext₂).F z = ext₂.F z := by
  unfold AperyLocalAnalyticExtension.union
  simp [hz]

/-- **Inclusion of the left domain into the union domain.** -/
lemma AperyLocalAnalyticExtension.subset_union_left
    (ext₁ ext₂ : AperyLocalAnalyticExtension) :
    ext₁.domain ⊆ (ext₁.union ext₂).domain := Set.subset_union_left

/-- **Inclusion of the right domain into the union domain.** -/
lemma AperyLocalAnalyticExtension.subset_union_right
    (ext₁ ext₂ : AperyLocalAnalyticExtension) :
    ext₂.domain ⊆ (ext₁.union ext₂).domain := Set.subset_union_right

/-- **Union F agrees with right-piece F on the right domain (regardless
of left).** Even when `z ∈ ext₁.domain ∩ ext₂.domain`, the union value
matches `ext₂.F z` since both equal `aperyGFAReal z`. -/
lemma AperyLocalAnalyticExtension.union_F_eq_right_on_right
    (ext₁ ext₂ : AperyLocalAnalyticExtension) {z : ℝ}
    (hz : z ∈ ext₂.domain) :
    (ext₁.union ext₂).F z = ext₂.F z := by
  by_cases hz₁ : z ∈ ext₁.domain
  · rw [ext₁.union_F_of_mem_left ext₂ hz₁,
        ext₁.F_eq_aperyGFAReal hz₁, ← ext₂.F_eq_aperyGFAReal hz]
  · exact ext₁.union_F_of_notMem_left ext₂ hz₁

/-! ### Finite union of local analytic extensions

Recursive union over `ℕ → AperyLocalAnalyticExtension`. -/

/-- **Recursive union over the first `n+1` extensions.** -/
noncomputable def AperyLocalAnalyticExtension.unionRange
    (exts : ℕ → AperyLocalAnalyticExtension) : ℕ → AperyLocalAnalyticExtension
  | 0 => exts 0
  | n + 1 => (unionRange exts n).union (exts (n + 1))

@[simp] lemma AperyLocalAnalyticExtension.unionRange_zero
    (exts : ℕ → AperyLocalAnalyticExtension) :
    AperyLocalAnalyticExtension.unionRange exts 0 = exts 0 := rfl

@[simp] lemma AperyLocalAnalyticExtension.unionRange_succ
    (exts : ℕ → AperyLocalAnalyticExtension) (n : ℕ) :
    AperyLocalAnalyticExtension.unionRange exts (n + 1) =
      (AperyLocalAnalyticExtension.unionRange exts n).union (exts (n + 1)) := rfl

/-- **Domain of the finite union.** -/
lemma AperyLocalAnalyticExtension.unionRange_domain
    (exts : ℕ → AperyLocalAnalyticExtension) (n : ℕ) :
    (AperyLocalAnalyticExtension.unionRange exts n).domain =
      ⋃ k ∈ Finset.range (n + 1), (exts k).domain := by
  induction n with
  | zero =>
    simp [AperyLocalAnalyticExtension.unionRange]
  | succ n ih =>
    simp only [AperyLocalAnalyticExtension.unionRange_succ,
      AperyLocalAnalyticExtension.union_domain, ih]
    ext z
    simp only [Set.mem_union, Set.mem_iUnion, Finset.mem_range]
    constructor
    · rintro (⟨k, hk, hzk⟩ | hz)
      · exact ⟨k, by omega, hzk⟩
      · exact ⟨n + 1, by omega, hz⟩
    · rintro ⟨k, hk, hzk⟩
      rcases Nat.lt_succ_iff_lt_or_eq.mp hk with hk' | hk'
      · exact Or.inl ⟨k, hk', hzk⟩
      · subst hk'
        exact Or.inr hzk

/-- **Each extension's domain is included in the finite-union domain.** -/
lemma AperyLocalAnalyticExtension.subset_unionRange
    (exts : ℕ → AperyLocalAnalyticExtension) (n : ℕ)
    {k : ℕ} (hk : k ≤ n) :
    (exts k).domain ⊆
      (AperyLocalAnalyticExtension.unionRange exts n).domain := by
  rw [AperyLocalAnalyticExtension.unionRange_domain]
  intro z hz
  exact Set.mem_iUnion₂.mpr ⟨k, Finset.mem_range.mpr (Nat.lt_succ_iff.mpr hk), hz⟩

/-! ### Canonicity at the local-extension layer

Any two `AperyLocalAnalyticExtension` instances agree pointwise on the
intersection of their domains: both are forced to equal `aperyGFAReal`
there. Direct corollary of the structure's defining condition. Used to
verify that different construction routes (chain composition, finite
union, etc.) yield consistent values. -/

/-- **Two local extensions agree on their domain intersection.** Both
restrict to `aperyGFAReal` everywhere on their respective domains, so
they coincide pointwise on the overlap. -/
lemma AperyLocalAnalyticExtension.F_eq_F_on_intersection
    (ext₁ ext₂ : AperyLocalAnalyticExtension) {z : ℝ}
    (hz₁ : z ∈ ext₁.domain) (hz₂ : z ∈ ext₂.domain) :
    ext₁.F z = ext₂.F z := by
  rw [ext₁.F_eq_aperyGFAReal hz₁, ext₂.F_eq_aperyGFAReal hz₂]

/-- **Set-level agreement on the domain intersection.** -/
lemma AperyLocalAnalyticExtension.eqOn_inter
    (ext₁ ext₂ : AperyLocalAnalyticExtension) :
    Set.EqOn ext₁.F ext₂.F (ext₁.domain ∩ ext₂.domain) :=
  fun _ hz => ext₁.F_eq_F_on_intersection ext₂ hz.1 hz.2

/-- **Cross-construction commutation.** Whatever route built each local
extension (chain composition, finite union, mixed), on shared coverage
the two routes produce equal values. Identical to `F_eq_F_on_intersection`
restated for the unionRange/ofGFAChain pair. -/
lemma AperyLocalAnalyticExtension.unionRange_F_eq_ofGFAChain_F_on_overlap
    (exts : ℕ → AperyLocalAnalyticExtension)
    (n : ℕ)
    (ds : ℕ → AperyAnalyticDiskAt) (m : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    {z : ℝ}
    (hz_union : z ∈ (AperyLocalAnalyticExtension.unionRange exts n).domain)
    (hz_chain : z ∈ (AperyLocalAnalyticExtension.ofGFAChain ds m h_F).domain) :
    (AperyLocalAnalyticExtension.unionRange exts n).F z =
      (AperyLocalAnalyticExtension.ofGFAChain ds m h_F).F z :=
  (AperyLocalAnalyticExtension.unionRange exts n).F_eq_F_on_intersection
    (AperyLocalAnalyticExtension.ofGFAChain ds m h_F) hz_union hz_chain

/-- **`unionRange` collapses to `aperyGFAReal` on its own domain.**
A specialization of `F_eq_aperyGFAReal` to the recursive finite union;
useful for downstream callers who treat the union as a coverage device. -/
lemma AperyLocalAnalyticExtension.unionRange_F_eq_aperyGFAReal
    (exts : ℕ → AperyLocalAnalyticExtension) (n : ℕ)
    {z : ℝ}
    (hz : z ∈ (AperyLocalAnalyticExtension.unionRange exts n).domain) :
    (AperyLocalAnalyticExtension.unionRange exts n).F z = aperyGFAReal z :=
  (AperyLocalAnalyticExtension.unionRange exts n).F_eq_aperyGFAReal hz

/-- **Set-level: `unionRange` agrees with `aperyGFAReal` on its domain.** -/
lemma AperyLocalAnalyticExtension.unionRange_eqOn_aperyGFAReal
    (exts : ℕ → AperyLocalAnalyticExtension) (n : ℕ) :
    Set.EqOn (AperyLocalAnalyticExtension.unionRange exts n).F aperyGFAReal
      (AperyLocalAnalyticExtension.unionRange exts n).domain :=
  (AperyLocalAnalyticExtension.unionRange exts n).eq_aperyGFAReal_on_domain

/-- **Same for `ofGFAChain`.** On the chain-built local extension's domain,
`F` agrees pointwise with `aperyGFAReal`. -/
lemma AperyLocalAnalyticExtension.ofGFAChain_F_eq_aperyGFAReal
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    {z : ℝ}
    (hz : z ∈ (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).domain) :
    (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).F z = aperyGFAReal z :=
  (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).F_eq_aperyGFAReal hz

/-- **Upgrade: local extension → full `AperyAnalyticExtension`.** Whenever
the local-extension domain covers the corridor `[0, z₁)`, the local
package promotes to the full `AperyAnalyticExtension` interface
(small-disk agreement + corridor continuity) by direct projection. -/
noncomputable def AperyLocalAnalyticExtension.toAperyAnalyticExtension
    (ext : AperyLocalAnalyticExtension)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆ ext.domain) :
    AperyAnalyticExtension where
  F := ext.F
  agrees_on_small := by
    have h_small : Set.Ico (0 : ℝ) (1 / 64) ⊆ ext.domain := by
      intro z hz
      exact h_corridor
        ⟨hz.1, lt_trans hz.2 aperyConifoldZ1Poly_gt_one_div_64⟩
    exact ext.eq_aperyGFAReal_on_domain.mono h_small
  continuousOn_corridor :=
    ext.analyticOnNhd_domain.continuousOn.mono h_corridor

/-- **Existence shortcut.** A local extension covering the corridor
witnesses `HasAperyAnalyticExtension`. -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension
    (ext : AperyLocalAnalyticExtension)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆ ext.domain) :
    HasAperyAnalyticExtension :=
  ⟨ext.toAperyAnalyticExtension h_corridor⟩

/-- **Projection equality.** The upgraded `F` is literally the local
`F`. Useful for rewriting through the upgrade. -/
@[simp] lemma AperyLocalAnalyticExtension.toAperyAnalyticExtension_F
    (ext : AperyLocalAnalyticExtension)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆ ext.domain) :
    (ext.toAperyAnalyticExtension h_corridor).F = ext.F := rfl

/-- **Corridor coverage from a disk family.** If a finite GFA-anchored
disk chain covers the corridor `[0, z₁)` pointwise (each point lies in
some disk of the chain), the chain's `ofGFAChain` domain contains the
whole corridor. Pure translation of the iUnion definition. -/
lemma AperyLocalAnalyticExtension.ofGFAChain_domain_covers_corridor
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (h_cover : ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
      ∃ k ≤ n, z ∈ (ds k).toAperyRegularDisk.diskOpen) :
    Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
      (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).domain := by
  intro z hz
  obtain ⟨k, hk, hzk⟩ := h_cover z hz
  exact Set.mem_iUnion₂.mpr
    ⟨k, Finset.mem_range.mpr (Nat.lt_succ_of_le hk), hzk⟩

/-- **Disk-family shortcut to a full extension.** A finite GFA-anchored
chain that covers the corridor immediately produces a full
`AperyAnalyticExtension`. Bypasses constructing the local extension
manually. -/
noncomputable def AperyLocalAnalyticExtension.ofGFAChainCovering
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (h_cover : ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
      ∃ k ≤ n, z ∈ (ds k).toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension :=
  (AperyLocalAnalyticExtension.ofGFAChain ds n h_F).toAperyAnalyticExtension
    (AperyLocalAnalyticExtension.ofGFAChain_domain_covers_corridor
      ds n h_F h_cover)

/-- **Existence from a covering chain.** Pure existence wrapper around
`ofGFAChainCovering`. -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_covering_chain
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (h_cover : ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
      ∃ k ≤ n, z ∈ (ds k).toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofGFAChainCovering ds n h_F h_cover⟩

/-- **Two-disk corridor cover specialization.** A disjunctive cover of
the corridor by two GFA-anchored disks gives a full extension. The
sequence wrapper `if k = 0 then d₀ else d₁` slots into the general
covering shortcut. -/
noncomputable def AperyLocalAnalyticExtension.ofTwoDiskCovering
    (d₀ d₁ : AperyAnalyticDiskAt)
    (h_F₀ : d₀.F = aperyGFAReal) (h_F₁ : d₁.F = aperyGFAReal)
    (h_cover : ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
      z ∈ d₀.toAperyRegularDisk.diskOpen ∨
        z ∈ d₁.toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension := by
  classical
  refine AperyLocalAnalyticExtension.ofGFAChainCovering
    (fun k => if k = 0 then d₀ else d₁) 1 ?_ ?_
  · intro i
    by_cases hi : i = 0
    · simp [hi, h_F₀]
    · simp [hi, h_F₁]
  · intro z hz
    rcases h_cover z hz with h₀ | h₁
    · refine ⟨0, by norm_num, ?_⟩
      simpa using h₀
    · refine ⟨1, le_refl _, ?_⟩
      simpa using h₁

/-- **Existence from a two-disk cover.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_two_disk_cover
    (d₀ d₁ : AperyAnalyticDiskAt)
    (h_F₀ : d₀.F = aperyGFAReal) (h_F₁ : d₁.F = aperyGFAReal)
    (h_cover : ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
      z ∈ d₀.toAperyRegularDisk.diskOpen ∨
        z ∈ d₁.toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofTwoDiskCovering d₀ d₁ h_F₀ h_F₁ h_cover⟩

/-- **Single-disk corridor cover.** A single GFA-anchored disk whose
open ball contains the entire corridor produces a full extension. The
simplest possible specialization. -/
noncomputable def AperyLocalAnalyticExtension.ofOneDiskCovering
    (d : AperyAnalyticDiskAt)
    (h_F : d.F = aperyGFAReal)
    (h_cover :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        d.toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension :=
  AperyLocalAnalyticExtension.ofGFAChainCovering
    (fun _ => d) 0 (fun _ => h_F)
    (fun z hz => ⟨0, le_refl _, h_cover hz⟩)

/-- **Existence from a single-disk cover.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_one_disk_cover
    (d : AperyAnalyticDiskAt)
    (h_F : d.F = aperyGFAReal)
    (h_cover :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        d.toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofOneDiskCovering d h_F h_cover⟩

/-- **Threshold-split two-disk cover.** Refines `ofTwoDiskCovering` to
the common geometric form: a threshold `t ∈ [0, z₁]` splits the
corridor into a left half `[0, t)` covered by `d₀.diskOpen` and a right
half `[t, z₁)` covered by `d₁.diskOpen`. Every corridor point falls in
one half by `lt_or_ge z t`. -/
noncomputable def AperyLocalAnalyticExtension.ofTwoDiskCoveringSplit
    (d₀ d₁ : AperyAnalyticDiskAt)
    (h_F₀ : d₀.F = aperyGFAReal) (h_F₁ : d₁.F = aperyGFAReal)
    (t : ℝ)
    (h_left : Set.Ico (0 : ℝ) t ⊆ d₀.toAperyRegularDisk.diskOpen)
    (h_right :
      Set.Ico t Number.aperyConifoldZ1Poly ⊆
        d₁.toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension := by
  classical
  refine AperyLocalAnalyticExtension.ofTwoDiskCovering d₀ d₁ h_F₀ h_F₁ ?_
  intro z hz
  rcases lt_or_ge z t with hzt | hzt
  · exact Or.inl (h_left ⟨hz.1, hzt⟩)
  · exact Or.inr (h_right ⟨hzt, hz.2⟩)

/-- **Existence from a threshold-split two-disk cover.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_two_disk_cover_split
    (d₀ d₁ : AperyAnalyticDiskAt)
    (h_F₀ : d₀.F = aperyGFAReal) (h_F₁ : d₁.F = aperyGFAReal)
    (t : ℝ)
    (h_left : Set.Ico (0 : ℝ) t ⊆ d₀.toAperyRegularDisk.diskOpen)
    (h_right :
      Set.Ico t Number.aperyConifoldZ1Poly ⊆
        d₁.toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofTwoDiskCoveringSplit
    d₀ d₁ h_F₀ h_F₁ t h_left h_right⟩

/-- **`n+1`-disk threshold-split cover.** Generalizes
`ofTwoDiskCoveringSplit` to a chain of `n+1` disks: a threshold sequence
`ts 0 = 0`, `ts (n+1) = z₁` partitions the corridor into pieces
`[ts k, ts (k+1))`, each covered by `(ds k).diskOpen`. The piece for a
given `z ∈ [0, z₁)` is found by `Nat.findGreatest (fun j => ts j ≤ z) n`. -/
noncomputable def AperyLocalAnalyticExtension.ofChainCoveringSplit
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆ (ds k).toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension := by
  classical
  refine AperyLocalAnalyticExtension.ofGFAChainCovering ds n h_F ?_
  intro z hz
  set k := Nat.findGreatest (fun j => ts j ≤ z) n with hk_def
  have h0 : ts 0 ≤ z := by rw [ht_zero]; exact hz.1
  have hk_le : k ≤ n := Nat.findGreatest_le n
  have hk_prop : ts k ≤ z :=
    Nat.findGreatest_spec (P := fun j => ts j ≤ z) (Nat.zero_le n) h0
  have h_strict : z < ts (k + 1) := by
    by_contra h_neg
    push_neg at h_neg
    by_cases hk_eq_n : k = n
    · rw [hk_eq_n, ht_last] at h_neg
      exact absurd h_neg (not_le.mpr hz.2)
    · have hkn_lt : k < n := lt_of_le_of_ne hk_le hk_eq_n
      have h_kk1 : k + 1 ≤ n := hkn_lt
      have h_not : ¬ (ts (k + 1) ≤ z) :=
        Nat.findGreatest_is_greatest (P := fun j => ts j ≤ z)
          (Nat.lt_succ_self k) h_kk1
      exact h_not h_neg
  exact ⟨k, hk_le, h_pieces k hk_le ⟨hk_prop, h_strict⟩⟩

/-- **Existence from a chain threshold-split cover.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_chain_cover_split
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆ (ds k).toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofChainCoveringSplit ds n h_F ts
    ht_zero ht_last h_pieces⟩

/-- **Zero-anchor: `0` lies in the first disk.** Given a chain
threshold-split cover with `ts 0 = 0` and `0 < ts 1`, the corridor
left endpoint is automatically inside `(ds 0).diskOpen` — the first
piece is non-empty so contains its left endpoint `0`. -/
lemma AperyLocalAnalyticExtension.ofChainCoveringSplit_zero_mem
    {ds : ℕ → AperyAnalyticDiskAt} {n : ℕ}
    {ts : ℕ → ℝ}
    (ht_zero : ts 0 = 0)
    (ht_pos : 0 < ts 1)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆ (ds k).toAperyRegularDisk.diskOpen)
    (hn : 0 ≤ n) :
    (0 : ℝ) ∈ (ds 0).toAperyRegularDisk.diskOpen :=
  h_pieces 0 hn ⟨ht_zero.le, ht_zero ▸ ht_pos⟩

/-- **Right-endpoint anchor: every point just below `z₁` lies in the
last disk.** Given a chain threshold-split cover with `ts (n+1) = z₁`
and `ts n < z₁`, every point in `[ts n, z₁)` is inside `(ds n).diskOpen`
— the last piece. -/
lemma AperyLocalAnalyticExtension.ofChainCoveringSplit_last_piece
    {ds : ℕ → AperyAnalyticDiskAt} (n : ℕ)
    {ts : ℕ → ℝ}
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆ (ds k).toAperyRegularDisk.diskOpen) :
    Set.Ico (ts n) Number.aperyConifoldZ1Poly ⊆
      (ds n).toAperyRegularDisk.diskOpen := by
  rw [← ht_last]
  exact h_pieces n (le_refl n)

/-- **F-projection through `ofChainCoveringSplit`.** The extended `F` is
literally the chain-glue function. Useful for evaluating the extension
at concrete points by reducing to chain-piece values. -/
@[simp] lemma AperyLocalAnalyticExtension.ofChainCoveringSplit_F
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆ (ds k).toAperyRegularDisk.diskOpen) :
    (AperyLocalAnalyticExtension.ofChainCoveringSplit ds n h_F ts
      ht_zero ht_last h_pieces).F =
      AperyAnalyticDiskAt.chainGlue ds n := rfl

/-- **Two GFA-interior disks: threshold-split shortcut.** Builds an
`AperyAnalyticExtension` directly from two concrete GFA-interior disk
parameter packs and a threshold split. The `F = aperyGFAReal`
hypotheses are auto-discharged via `aperyGFAInteriorAnalyticDiskAt_F`
— no manual `Eq`-witness required at the call site. -/
noncomputable def AperyLocalAnalyticExtension.ofTwoGFAInteriorDiskCoveringSplit
    (c₀ : ℝ) (h_pos₀ : 0 < c₀) (h_lt₀ : c₀ < 1 / 64)
    (r₀ : ℝ) (hr₀ : 0 < r₀) (coeffs₀ : ℕ → ℝ)
    (hs₀ : ∀ t : ℝ, |t| < r₀ →
      HasSum (fun n => coeffs₀ n * t ^ n) (aperyGFAReal (c₀ + t)))
    (hSum₀ : ∀ r' : NNReal, (r' : ℝ) < r₀ →
      Summable (fun n : ℕ => |coeffs₀ n| * (r' : ℝ) ^ n))
    (c₁ : ℝ) (h_pos₁ : 0 < c₁) (h_lt₁ : c₁ < 1 / 64)
    (r₁ : ℝ) (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (c₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    (t : ℝ)
    (h_left : Set.Ico (0 : ℝ) t ⊆
      (aperyGFAInteriorAnalyticDiskAt c₀ h_pos₀ h_lt₀ r₀ hr₀ coeffs₀ hs₀
        hSum₀).toAperyRegularDisk.diskOpen)
    (h_right : Set.Ico t Number.aperyConifoldZ1Poly ⊆
      (aperyGFAInteriorAnalyticDiskAt c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁
        hSum₁).toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension :=
  AperyLocalAnalyticExtension.ofTwoDiskCoveringSplit
    (aperyGFAInteriorAnalyticDiskAt c₀ h_pos₀ h_lt₀ r₀ hr₀ coeffs₀ hs₀ hSum₀)
    (aperyGFAInteriorAnalyticDiskAt c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁)
    (aperyGFAInteriorAnalyticDiskAt_F c₀ h_pos₀ h_lt₀ r₀ hr₀ coeffs₀ hs₀ hSum₀)
    (aperyGFAInteriorAnalyticDiskAt_F c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁)
    t h_left h_right

/-- **Bundled GFA-interior disk parameters.** Packages the parameter
data for a single GFA-interior analytic disk into one structure,
allowing indexed families `ℕ → AperyGFAInteriorDiskParams`. -/
structure AperyGFAInteriorDiskParams where
  center : ℝ
  center_pos : 0 < center
  center_lt : center < 1 / 64
  radius : ℝ
  radius_pos : 0 < radius
  coeffs : ℕ → ℝ
  hasSum_local : ∀ t : ℝ, |t| < radius →
    HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))
  summable_local : ∀ r' : NNReal, (r' : ℝ) < radius →
    Summable (fun n : ℕ => |coeffs n| * (r' : ℝ) ^ n)

/-- **Bundled-to-disk projection.** -/
noncomputable def AperyGFAInteriorDiskParams.toAnalyticDiskAt
    (p : AperyGFAInteriorDiskParams) : AperyAnalyticDiskAt :=
  aperyGFAInteriorAnalyticDiskAt p.center p.center_pos p.center_lt
    p.radius p.radius_pos p.coeffs p.hasSum_local p.summable_local

/-- **F-projection: bundled disk has `F = aperyGFAReal`.** -/
@[simp] lemma AperyGFAInteriorDiskParams.toAnalyticDiskAt_F
    (p : AperyGFAInteriorDiskParams) :
    p.toAnalyticDiskAt.F = aperyGFAReal := rfl

/-- **Center projection.** -/
@[simp] lemma AperyGFAInteriorDiskParams.toAnalyticDiskAt_center
    (p : AperyGFAInteriorDiskParams) :
    p.toAnalyticDiskAt.toAperyRegularDisk.center = p.center := rfl

/-- **Radius projection.** -/
@[simp] lemma AperyGFAInteriorDiskParams.toAnalyticDiskAt_radius
    (p : AperyGFAInteriorDiskParams) :
    p.toAnalyticDiskAt.toAperyRegularDisk.radius = p.radius := rfl

/-- **Coeffs projection.** -/
@[simp] lemma AperyGFAInteriorDiskParams.toAnalyticDiskAt_coeffs
    (p : AperyGFAInteriorDiskParams) :
    p.toAnalyticDiskAt.toAperyRegularDisk.coeffs = p.coeffs := rfl

/-- **Membership criterion: `z ∈ p.diskOpen ↔ |z - p.center| < p.radius`.** -/
lemma AperyGFAInteriorDiskParams.mem_toAnalyticDiskAt_diskOpen
    (p : AperyGFAInteriorDiskParams) (z : ℝ) :
    z ∈ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen ↔
      |z - p.center| < p.radius := Iff.rfl

/-- **`Set.Ico a b ⊆ p.diskOpen` from `|· - center| < radius` on `[a, b)`.**
Bridges the threshold-split coverage requirement to a pointwise `|z - c| < r`
inequality. -/
lemma AperyGFAInteriorDiskParams.Ico_subset_diskOpen
    (p : AperyGFAInteriorDiskParams) {a b : ℝ}
    (h : ∀ z ∈ Set.Ico a b, |z - p.center| < p.radius) :
    Set.Ico a b ⊆ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen :=
  fun z hz => (p.mem_toAnalyticDiskAt_diskOpen z).mpr (h z hz)

/-- **Endpoint criterion for `Set.Ico a b ⊆ p.diskOpen`.**
`p.center - p.radius < a` (left endpoint inside the open ball) plus
`b ≤ p.center + p.radius` (right limit at most upper end of the ball)
suffices. Reduces a coverage obligation to two linear inequalities. -/
lemma AperyGFAInteriorDiskParams.Ico_subset_diskOpen_of_endpoints
    (p : AperyGFAInteriorDiskParams) {a b : ℝ}
    (h_left : p.center - p.radius < a)
    (h_right : b ≤ p.center + p.radius) :
    Set.Ico a b ⊆ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen := by
  intro z hz
  rw [p.mem_toAnalyticDiskAt_diskOpen, abs_lt]
  refine ⟨?_, ?_⟩
  · linarith [hz.1]
  · linarith [hz.2]

/-- **Two bundled-params disks are mutually compatible.** Both carry
`aperyGFAReal` as their underlying function, so on any shared point
their values coincide — a one-step rewrite. -/
lemma AperyGFAInteriorDiskParams.compatible
    (p₁ p₂ : AperyGFAInteriorDiskParams) :
    AperyAnalyticDiskAt.Compatible p₁.toAnalyticDiskAt p₂.toAnalyticDiskAt :=
  AperyRegularDisk.Compatible.of_F_eq rfl

/-- **Pairwise compatibility for an indexed family.** Direct corollary
of `compatible` lifted to families. -/
lemma AperyGFAInteriorDiskParams.pairwise_compatible
    (params : ℕ → AperyGFAInteriorDiskParams) :
    ∀ i j, AperyAnalyticDiskAt.Compatible
      (params i).toAnalyticDiskAt (params j).toAnalyticDiskAt :=
  fun i j => (params i).compatible (params j)

/-- **Single bundled-params disk as a local analytic extension.**
Reuses `ofGFAChain` with the constant family `fun _ => p.toAnalyticDiskAt`
at length `0`, so the resulting local ext has domain equal to a single
disk's open ball. -/
noncomputable def AperyGFAInteriorDiskParams.toLocal
    (p : AperyGFAInteriorDiskParams) : AperyLocalAnalyticExtension :=
  AperyLocalAnalyticExtension.ofGFAChain
    (fun _ => p.toAnalyticDiskAt) 0
    (fun _ => p.toAnalyticDiskAt_F)

/-- **Domain of `toLocal` is the single disk's open ball.**
After `Finset.range 1` simplifies to `{0}`, the union collapses. -/
lemma AperyGFAInteriorDiskParams.toLocal_domain
    (p : AperyGFAInteriorDiskParams) :
    p.toLocal.domain =
      ⋃ k ∈ Finset.range 1, p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen := rfl

/-- **Containment: any point in the diskOpen sits in `toLocal.domain`.** -/
lemma AperyGFAInteriorDiskParams.mem_toLocal_domain
    (p : AperyGFAInteriorDiskParams) {z : ℝ}
    (hz : z ∈ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    z ∈ p.toLocal.domain :=
  Set.mem_iUnion₂.mpr ⟨0, by simp, hz⟩

/-- **`toLocal.F` agrees with `aperyGFAReal` on the disk's open ball.** -/
lemma AperyGFAInteriorDiskParams.toLocal_F_eq_aperyGFAReal_on_diskOpen
    (p : AperyGFAInteriorDiskParams) {z : ℝ}
    (hz : z ∈ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    p.toLocal.F z = aperyGFAReal z :=
  p.toLocal.F_eq_aperyGFAReal (p.mem_toLocal_domain hz)

/-- **Cross-route equivalence at a single disk.** A single bundled-params
disk's `toLocal.F` agrees with any other GFA-anchored local ext on
their shared coverage. Pure corollary of `F_eq_F_on_intersection`. -/
lemma AperyGFAInteriorDiskParams.toLocal_F_eq_other_on_overlap
    (p : AperyGFAInteriorDiskParams)
    (other : AperyLocalAnalyticExtension) {z : ℝ}
    (hz_disk : z ∈ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen)
    (hz_other : z ∈ other.domain) :
    p.toLocal.F z = other.F z :=
  p.toLocal.F_eq_F_on_intersection other (p.mem_toLocal_domain hz_disk) hz_other

/-- **`unionRange` from a family of bundled-params disks.** Builds a
local analytic extension whose domain is the union of the individual
disks' open balls. -/
noncomputable def AperyLocalAnalyticExtension.unionRangeFromParams
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ) :
    AperyLocalAnalyticExtension :=
  AperyLocalAnalyticExtension.unionRange (fun k => (params k).toLocal) n

/-- **Domain of `unionRangeFromParams` is the union of disk-open balls.** -/
lemma AperyLocalAnalyticExtension.unionRangeFromParams_domain
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ) :
    (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain =
      ⋃ k ∈ Finset.range (n + 1),
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen := by
  unfold AperyLocalAnalyticExtension.unionRangeFromParams
  rw [AperyLocalAnalyticExtension.unionRange_domain]
  ext z
  simp only [Set.mem_iUnion, Finset.mem_range]
  refine ⟨?_, ?_⟩
  · rintro ⟨k, hk, hzk⟩
    refine ⟨k, hk, ?_⟩
    have : z ∈ (params k).toLocal.domain := hzk
    rw [(params k).toLocal_domain] at this
    simpa using this
  · rintro ⟨k, hk, hzk⟩
    exact ⟨k, hk, (params k).mem_toLocal_domain hzk⟩

/-- **A disk-membership point lies in `unionRangeFromParams.domain`.** -/
lemma AperyLocalAnalyticExtension.mem_unionRangeFromParams_domain
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    {k : ℕ} (hk : k ≤ n) {z : ℝ}
    (hz : z ∈ (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    z ∈ (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain := by
  rw [AperyLocalAnalyticExtension.unionRangeFromParams_domain]
  exact Set.mem_iUnion₂.mpr ⟨k, Finset.mem_range.mpr (Nat.lt_succ_of_le hk), hz⟩

/-- **`unionRangeFromParams.F` agrees with `aperyGFAReal` on its domain.** -/
lemma AperyLocalAnalyticExtension.unionRangeFromParams_F_eq_aperyGFAReal
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ) {z : ℝ}
    (hz : z ∈ (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain) :
    (AperyLocalAnalyticExtension.unionRangeFromParams params n).F z =
      aperyGFAReal z :=
  (AperyLocalAnalyticExtension.unionRangeFromParams params n).F_eq_aperyGFAReal hz

/-- **Upgrade: `unionRangeFromParams` to a full `AperyAnalyticExtension`.**
Whenever the union of disk-open balls covers the corridor, the
param-bundle local extension promotes to a full
`AperyAnalyticExtension` directly. -/
noncomputable def AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain) :
    AperyAnalyticExtension :=
  (AperyLocalAnalyticExtension.unionRangeFromParams params n).toAperyAnalyticExtension
    h_corridor

/-- **Existence wrapper for the union-from-params upgrade.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_unionRangeFromParams
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
    params n h_corridor⟩

/-- **Corridor coverage in disk-open form.** Recasts the
`unionRangeFromParams` corridor coverage as a pointwise existence
statement at the params layer: every corridor point lies in some
disk's open ball. -/
lemma AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_iff
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ) :
    Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain ↔
      ∀ z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly,
        ∃ k ∈ Finset.range (n + 1),
          z ∈ (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen := by
  rw [AperyLocalAnalyticExtension.unionRangeFromParams_domain]
  refine ⟨fun h z hz => ?_, fun h z hz => ?_⟩
  · obtain ⟨S, ⟨k, hk_eq⟩, hzS⟩ := h hz
    subst hk_eq
    rw [Set.mem_iUnion] at hzS
    obtain ⟨hkrange, hzk⟩ := hzS
    exact ⟨k, hkrange, hzk⟩
  · obtain ⟨k, hk, hzk⟩ := h z hz
    exact Set.mem_iUnion₂.mpr ⟨k, hk, hzk⟩

/-- **Symmetric endpoint criterion using disk-radius distance.**
If both endpoints satisfy `|· - center| < radius` strictly (more precisely,
`a > center - radius` and `b ≤ center + radius`), the closed-open
interval is contained. Phrased on the *closed* version of `[a, b]`'s
left endpoint and the *open* right endpoint via `≤` on the right. -/
lemma AperyGFAInteriorDiskParams.Ico_subset_diskOpen_of_dist
    (p : AperyGFAInteriorDiskParams) {a b : ℝ}
    (h_a : |a - p.center| < p.radius)
    (h_b : b ≤ p.center + p.radius) :
    Set.Ico a b ⊆ p.toAnalyticDiskAt.toAperyRegularDisk.diskOpen := by
  rw [abs_lt] at h_a
  refine p.Ico_subset_diskOpen_of_endpoints ?_ h_b
  linarith [h_a.1]

/-- **Chain wrapper for a family of bundled GFA-interior disks.**
Takes an indexed family of disk parameter packs plus a threshold
sequence and per-piece coverage. The `F = aperyGFAReal` witness for
each disk is auto-discharged from the bundled structure. -/
noncomputable def AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension :=
  AperyLocalAnalyticExtension.ofChainCoveringSplit
    (fun k => (params k).toAnalyticDiskAt) n
    (fun _ => AperyGFAInteriorDiskParams.toAnalyticDiskAt_F _)
    ts ht_zero ht_last h_pieces

/-- **Existence from a bundled-disk chain cover.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_chain_gfa_interior_disks_split
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
    params n ts ht_zero ht_last h_pieces⟩

/-- **Chain F at a covered point equals `aperyGFAReal`.** When `z` lies
in some `(params k).diskOpen` for `k ≤ n`, the chain-built extension's
`F` at `z` equals `aperyGFAReal z`. Direct chainGlue evaluation. -/
lemma AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_disk
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen)
    {z : ℝ} {k : ℕ} (hk : k ≤ n)
    (hz : z ∈ (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
      params n ts ht_zero ht_last h_pieces).F z = aperyGFAReal z :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_eq
    (fun k => (params k).toAnalyticDiskAt) n
    (fun _ => AperyGFAInteriorDiskParams.toAnalyticDiskAt_F _) hk hz

/-- **Cross-route equivalence on disk coverage.** On any point covered
by some chain piece, the chain-route extension and the union-route
extension produce the same value (both equal `aperyGFAReal`). -/
lemma AperyLocalAnalyticExtension.chain_F_eq_unionFromParams_F_on_disk
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain)
    {z : ℝ} {k : ℕ} (hk : k ≤ n)
    (hz : z ∈ (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
        params n ts ht_zero ht_last h_pieces).F z =
      (AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
        params n h_corridor).F z := by
  rw [AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_disk
        params n ts ht_zero ht_last h_pieces hk hz]
  unfold AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
  rw [AperyLocalAnalyticExtension.toAperyAnalyticExtension_F]
  exact ((AperyLocalAnalyticExtension.unionRangeFromParams_F_eq_aperyGFAReal
    params n
    (AperyLocalAnalyticExtension.mem_unionRangeFromParams_domain
      params n hk hz))).symm

/-- **Cross-route corridor agreement.** Whenever the union-of-disks
covers the corridor, the chain-route extension and the union-route
extension agree on every corridor point. Both sides equal
`aperyGFAReal` at that point — the chain side via per-disk evaluation,
the union side via the underlying local extension. -/
lemma AperyLocalAnalyticExtension.chain_F_eq_unionFromParams_F_on_corridor
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain) :
    Set.EqOn
      (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
        params n ts ht_zero ht_last h_pieces).F
      (AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
        params n h_corridor).F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z hz
  have hcov :=
    (AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_iff
      params n).mp h_corridor z hz
  obtain ⟨k, hkrange, hzk⟩ := hcov
  have hk_le : k ≤ n := Nat.lt_succ_iff.mp (Finset.mem_range.mp hkrange)
  exact AperyLocalAnalyticExtension.chain_F_eq_unionFromParams_F_on_disk
    params n ts ht_zero ht_last h_pieces h_corridor hk_le hzk

/-- **Chain coverage entails union coverage.** A threshold-and-piece
chain covering of the corridor automatically furnishes the
`unionRangeFromParams` corridor inclusion: every corridor point lies
in some piece, hence in some disk. The k-extraction reuses the
`Nat.findGreatest` strategy from `ofChainCoveringSplit`. -/
lemma AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_of_chain
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
      (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain := by
  classical
  rw [AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_iff]
  intro z hz
  set k := Nat.findGreatest (fun j => ts j ≤ z) n with hk_def
  have h0 : ts 0 ≤ z := by rw [ht_zero]; exact hz.1
  have hk_le : k ≤ n := Nat.findGreatest_le n
  have hk_prop : ts k ≤ z :=
    Nat.findGreatest_spec (P := fun j => ts j ≤ z) (Nat.zero_le n) h0
  have h_strict : z < ts (k + 1) := by
    by_contra h_neg
    push_neg at h_neg
    by_cases hk_eq_n : k = n
    · rw [hk_eq_n, ht_last] at h_neg
      exact absurd h_neg (not_le.mpr hz.2)
    · have hkn_lt : k < n := lt_of_le_of_ne hk_le hk_eq_n
      have h_kk1 : k + 1 ≤ n := hkn_lt
      have h_not : ¬ (ts (k + 1) ≤ z) :=
        Nat.findGreatest_is_greatest (P := fun j => ts j ≤ z)
          (Nat.lt_succ_self k) h_kk1
      exact h_not h_neg
  refine ⟨k, Finset.mem_range.mpr (Nat.lt_succ_of_le hk_le), ?_⟩
  exact h_pieces k hk_le ⟨hk_prop, h_strict⟩

/-- **Self-contained chain → analytic extension wrapper.** Given just
the chain-of-pieces data, produce the `AperyAnalyticExtension`
directly: chain coverage automatically supplies the union coverage. -/
noncomputable def AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    AperyAnalyticExtension :=
  AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
    params n
    (AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_of_chain
      params n ts ht_zero ht_last h_pieces)

/-- **Existence wrapper for `fromChainGFAInteriorDisks`.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_fromChainGFAInteriorDisks
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
    params n ts ht_zero ht_last h_pieces⟩

/-- **F-projection through `fromChainGFAInteriorDisks`.** The wrapper's
`F` is definitionally the union-route's `F`, which is the underlying
local extension's `F`. -/
@[simp] lemma AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_F
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F =
      (AperyLocalAnalyticExtension.unionRangeFromParams params n).F := rfl

/-- **Closure: chain coverage forces F to equal `aperyGFAReal` on the
corridor.** Combines the F-projection with the union-route
`F = aperyGFAReal` lemma to give the headline statement: under a
threshold-and-piece chain covering of `[0, aperyConifoldZ1Poly)`, the
constructed extension's value is `aperyGFAReal` everywhere on that
interval. -/
lemma AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_F_eq_aperyGFAReal_on_corridor
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.EqOn
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z hz
  have h_corridor :=
    AperyLocalAnalyticExtension.unionRangeFromParams_domain_supset_corridor_of_chain
      params n ts ht_zero ht_last h_pieces
  exact AperyLocalAnalyticExtension.unionRangeFromParams_F_eq_aperyGFAReal
    params n (h_corridor hz)

/-- **Continuity projection through `fromChainGFAInteriorDisks`.** The
wrapper's `F` is continuous on the corridor, courtesy of the
underlying `AperyAnalyticExtension.continuousOn_corridor` field. -/
lemma AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_continuousOn_corridor
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    ContinuousOn
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :=
  (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
    params n ts ht_zero ht_last h_pieces).continuousOn_corridor

/-- **Small-interval agreement projection through
`fromChainGFAInteriorDisks`.** The wrapper's `F` agrees with
`aperyGFAReal` on `[0, 1/64)` — `agrees_on_small` field repackaged. -/
lemma AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_agrees_on_small
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.EqOn
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      aperyGFAReal
      (Set.Ico (0 : ℝ) (1 / 64)) :=
  (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
    params n ts ht_zero ht_last h_pieces).agrees_on_small

/-- **The chain-route extension equals `aperyGFAReal` on the
corridor.** A direct closure for `ofChainGFAInteriorDisksCoveringSplit`
mirroring the `fromChainGFAInteriorDisks` version: on every corridor
point, the chain extension's `F` value is `aperyGFAReal z`. Reduces to
the disk-covered evaluation by extracting a covering piece via
`Nat.findGreatest`. -/
lemma AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_corridor
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.EqOn
      (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
        params n ts ht_zero ht_last h_pieces).F
      aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  classical
  intro z hz
  set k := Nat.findGreatest (fun j => ts j ≤ z) n with hk_def
  have h0 : ts 0 ≤ z := by rw [ht_zero]; exact hz.1
  have hk_le : k ≤ n := Nat.findGreatest_le n
  have hk_prop : ts k ≤ z :=
    Nat.findGreatest_spec (P := fun j => ts j ≤ z) (Nat.zero_le n) h0
  have h_strict : z < ts (k + 1) := by
    by_contra h_neg
    push_neg at h_neg
    by_cases hk_eq_n : k = n
    · rw [hk_eq_n, ht_last] at h_neg
      exact absurd h_neg (not_le.mpr hz.2)
    · have hkn_lt : k < n := lt_of_le_of_ne hk_le hk_eq_n
      have h_kk1 : k + 1 ≤ n := hkn_lt
      have h_not : ¬ (ts (k + 1) ≤ z) :=
        Nat.findGreatest_is_greatest (P := fun j => ts j ≤ z)
          (Nat.lt_succ_self k) h_kk1
      exact h_not h_neg
  have hzk : z ∈ (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen :=
    h_pieces k hk_le ⟨hk_prop, h_strict⟩
  exact AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_disk
    params n ts ht_zero ht_last h_pieces hk_le hzk

/-- **Two chain entry points produce the same value on the corridor.**
The direct chain construction (`ofChainGFAInteriorDisksCoveringSplit`)
and the self-contained chain-via-union construction
(`fromChainGFAInteriorDisks`) yield the same `F` on
`[0, aperyConifoldZ1Poly)` — both equal `aperyGFAReal` there. API
users may pick either entry without observable difference. -/
lemma AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_fromChainGFAInteriorDisks_F_on_corridor
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
