to a geometric majorant; `summable_of_geometric_bound` finishes. -/
lemma aperyConifold_frobenius_Z_summable_tail (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    Summable (fun k : ℕ =>
      frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ (6 + k) * z ^ k) := by
  set K : ℝ := 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| with hKdef
  set C : ℝ := ∑ i ∈ Finset.range (6 + 1),
      |frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 c₀ i| with hCdef
  set r : ℝ := (1 + K) * |z| with hrdef
  have hp_pos : 0 < |Polynomial.eval Number.aperyConifoldZ1Poly
      (Polynomial.derivative Number.aperyPconifold)| :=
    Number.aperyPconifold_deriv_eval_z1_abs_pos
  have hK_nn : 0 ≤ K := by
    rw [hKdef]
    apply div_nonneg
    · positivity
    · exact hp_pos.le
  have hC_nn : 0 ≤ C := Finset.sum_nonneg (fun _ _ => abs_nonneg _)
  have hr_nn : 0 ≤ r := by
    rw [hrdef]; exact mul_nonneg (by linarith) (abs_nonneg _)
  have hr_lt : r < 1 := hz
  have hpw := aperyConifold_frobenius_Z_pointwise c₀
  have hbound : ∀ k,
      |frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 c₀ (6 + k) * z ^ k| ≤ C * r ^ k := by
    intro k
    rw [abs_mul, abs_pow]
    have h_a := hpw k
    have h_zk_nn : 0 ≤ |z| ^ k := pow_nonneg (abs_nonneg _) k
    have hstep1 :
        |frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly 0 c₀ (6 + k)| * |z| ^ k ≤
        (C * (1 + K) ^ k) * |z| ^ k :=
      mul_le_mul_of_nonneg_right h_a h_zk_nn
    have h_eq : (C * (1 + K) ^ k) * |z| ^ k = C * r ^ k := by
      rw [hrdef, mul_pow]; ring
    linarith [hstep1, h_eq.le]
  exact summable_of_geometric_bound _ C r hC_nn hr_nn hr_lt hbound

/-- **Full-series Z-branch summability (ρ = 0).** Promote the
tail summability `Σ_k a^{(0)}_{6+k}·z^k` of
`aperyConifold_frobenius_Z_summable_tail` to the full series
`Σ_n a^{(0)}_n·z^n` via Mathlib's `summable_nat_add_iff` shift. -/
lemma aperyConifold_frobenius_Z_summable (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    Summable (fun n : ℕ =>
      frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ n * z ^ n) := by
  have htail := aperyConifold_frobenius_Z_summable_tail c₀ z hz
  -- Massage `a_{6+k}·z^k` into `(a_n·z^n)_{n = 6+k} / z^6` shape:
  -- multiply by `z^6` (constant) and reshape exponent.
  have hscaled : Summable (fun k : ℕ =>
      frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ (k + 6) * z ^ (k + 6)) := by
    have h_eq : ∀ k,
        frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 c₀ (k + 6) * z ^ (k + 6) =
        z ^ 6 *
          (frobeniusCoeff
            (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
            Number.aperyConifoldZ1Poly 0 c₀ (6 + k) * z ^ k) := by
      intro k
      rw [show k + 6 = 6 + k from by ring, pow_add]; ring
    apply Summable.congr (htail.mul_left (z ^ 6))
    intro k
    rw [(h_eq k).symm]
  exact (summable_nat_add_iff 6).mp hscaled

