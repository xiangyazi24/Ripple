/-- **`γ(m) · D` simplification (ρ=1/2)**: clears denom from γ(m). -/
lemma aperyGammaHalf_mul_denom (m : ℕ) :
    aperyGammaHalf m *
      (((m : ℝ) + 3 / 2) * ((m : ℝ) + 1 / 2) * ((m : ℝ) + 1) *
        (19584 - 13848 * Real.sqrt 2)) =
      (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) * (2 * (m : ℝ) + 5) / 8 := by
  unfold aperyGammaHalf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h2m3_pos : (0 : ℝ) < 2 * (m : ℝ) + 3 := by positivity
  have h2m1_pos : (0 : ℝ) < 2 * (m : ℝ) + 1 := by positivity
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hK_ne' : (19584 - Real.sqrt 2 * 13848 : ℝ) ≠ 0 := by
    rw [show Real.sqrt 2 * 13848 = 13848 * Real.sqrt 2 from by ring]
    exact hK_ne
  field_simp
  ring

/-- **Divided 3-step recurrence form for ρ=1/2**. -/
lemma aperyFrobenius_half_explicit_recurrence {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly (1 / 2) 1
    c (m + 1) =
      aperyAlphaHalf m * c m +
      aperyBetaHalf m * c (m - 1) +
      aperyGammaHalf m * c (m - 2) := by
  intro c
  have h_closed := aperyFrobenius_half_3step_closed_form hm
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm32_pos : (0 : ℝ) < (m : ℝ) + 3 / 2 := by positivity
  have hm12_pos : (0 : ℝ) < (m : ℝ) + 1 / 2 := by positivity
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hmcast1 : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 :=
    by exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  have hmcast2 : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 :=
    by exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  rw [show fallingFactorial (3 / 2 + (m : ℝ)) 2 =
          ((m : ℝ) + 3 / 2) * ((m : ℝ) + 1 / 2) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + (m : ℝ)) 2 =
          (2 * (m : ℝ) + 1) * (2 * (m : ℝ) - 1) / 4 from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + (m : ℝ)) 3 =
          (2 * (m : ℝ) + 1) * (2 * (m : ℝ) - 1) *
            (2 * (m : ℝ) - 3) / 8 from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 2 =
          (2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) / 4 from by
        rw [hmcast1, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 3 =
          (2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) *
            (2 * (m : ℝ) - 5) / 8 from by
        rw [hmcast1, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_succ, fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 2 =
          (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) / 4 from by
        rw [hmcast2, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]
        ring,
      show fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 3 =
          (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) *
            (2 * (m : ℝ) - 7) / 8 from by
        rw [hmcast2, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_succ, fallingFactorial_zero]
        ring] at h_closed
  have h_apery_2Q3P : (5187 - 3672 * Real.sqrt 2 : ℝ) =
      3 * (3458 - 2448 * Real.sqrt 2) / 2 := by ring
  rw [h_apery_2Q3P] at h_closed
  set D := ((m : ℝ) + 3 / 2) * ((m : ℝ) + 1 / 2) * ((m : ℝ) + 1) *
      (19584 - 13848 * Real.sqrt 2) with hD_def
  have hD_ne : D ≠ 0 := by
    rw [hD_def]
    exact mul_ne_zero
      (mul_ne_zero (mul_ne_zero hm32_pos.ne' hm12_pos.ne') hm1_pos.ne') hK_ne
  refine mul_right_cancel₀ hD_ne ?_
  rw [add_mul, add_mul, mul_assoc (aperyAlphaHalf m) (c m) D,
      mul_assoc (aperyBetaHalf m) (c (m - 1)) D,
      mul_assoc (aperyGammaHalf m) (c (m - 2)) D]
  rw [show aperyAlphaHalf m * (c m * D) =
        (aperyAlphaHalf m * D) * c m from by ring,
      show aperyBetaHalf m * (c (m - 1) * D) =
        (aperyBetaHalf m * D) * c (m - 1) from by ring,
      show aperyGammaHalf m * (c (m - 2) * D) =
        (aperyGammaHalf m * D) * c (m - 2) from by ring]
  rw [hD_def, aperyAlphaHalf_mul_denom, aperyBetaHalf_mul_denom,
      aperyGammaHalf_mul_denom]
  rw [h_closed]
  ring

