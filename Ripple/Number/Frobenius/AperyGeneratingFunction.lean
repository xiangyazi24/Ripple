/-! ### Subinterval monotonicity of `aperyGFAReal` image, sSup, sInf -/

/-- **Image inclusion under sub-interval inclusion.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_subset_of_Icc_subset
    {a b a' b' : ℝ} (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    aperyGFAReal '' Set.Icc a b ⊆ aperyGFAReal '' Set.Icc a' b' :=
  Set.image_mono h_sub

/-- **`sSup` of `aperyGFAReal` image is monotone in sub-interval.**
If `Icc a b ⊆ Icc a' b'`, then the sup over the smaller interval is bounded
by the sup over the larger. -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_le_of_subset
    (h : HasCorridorAperyAnalyticExtension)
    {a b a' b' : ℝ} (ha : 0 ≤ a) (hab : a ≤ b)
    (ha' : 0 ≤ a') (hab' : a' ≤ b') (hb' : b' < Number.aperyConifoldZ1Poly)
    (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    sSup (aperyGFAReal '' Set.Icc a b) ≤
      sSup (aperyGFAReal '' Set.Icc a' b') := by
  have hb : b < Number.aperyConifoldZ1Poly :=
    lt_of_le_of_lt (h_sub ⟨hab, le_refl b⟩).2 hb'
  refine csSup_le_csSup
    (h.bddAbove_aperyGFAReal_image_Icc_general ha' hb')
    (Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab))
    ?_
  exact Set.image_mono h_sub

/-- **`sInf` of `aperyGFAReal` image is antitone in sub-interval.**
If `Icc a b ⊆ Icc a' b'`, then the inf over the larger interval is bounded
by the inf over the smaller. -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_le_of_subset
    (h : HasCorridorAperyAnalyticExtension)
    {a b a' b' : ℝ} (ha : 0 ≤ a) (hab : a ≤ b)
    (ha' : 0 ≤ a') (hab' : a' ≤ b') (hb' : b' < Number.aperyConifoldZ1Poly)
    (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    sInf (aperyGFAReal '' Set.Icc a' b') ≤
      sInf (aperyGFAReal '' Set.Icc a b) := by
  have hb : b < Number.aperyConifoldZ1Poly :=
    lt_of_le_of_lt (h_sub ⟨hab, le_refl b⟩).2 hb'
  refine csInf_le_csInf
    (h.bddBelow_aperyGFAReal_image_Icc_general ha' hb')
    (Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab))
    ?_
  exact Set.image_mono h_sub

/-! ### Concrete sub-interval bridges to `Icc 0 (1/64)` -/

/-- **`Icc 0 b ⊆ Icc 0 (1/64)` when `b ≤ 1/64`.** -/
lemma Icc_zero_subset_Icc_zero_one_div_64 {b : ℝ} (hb : b ≤ 1 / 64) :
    Set.Icc (0 : ℝ) b ⊆ Set.Icc (0 : ℝ) (1 / 64) := by
  intro z hz
  exact ⟨hz.1, le_trans hz.2 hb⟩

/-- **`sSup` on `Icc 0 b` is bounded by `sSup` on `Icc 0 (1/64)` when
`0 ≤ b ≤ 1/64`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_zero_b_le_sSup_one_div_64
    (h : HasCorridorAperyAnalyticExtension)
    {b : ℝ} (hb_pos : 0 ≤ b) (hb : b ≤ 1 / 64) :
    sSup (aperyGFAReal '' Set.Icc (0 : ℝ) b) ≤
      sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) := by
  have h_one_lt : (1 : ℝ) / 64 < Number.aperyConifoldZ1Poly :=
    aperyConifoldZ1Poly_gt_one_div_64
  exact h.sSup_aperyGFAReal_image_Icc_le_of_subset
    (le_refl 0) hb_pos
    (le_refl 0) (by norm_num : (0 : ℝ) ≤ 1 / 64) h_one_lt
    (Icc_zero_subset_Icc_zero_one_div_64 hb)

/-- **`sInf` on `Icc 0 (1/64)` is bounded by `sInf` on `Icc 0 b` when
`0 ≤ b ≤ 1/64`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_zero_one_div_64_le_zero_b
    (h : HasCorridorAperyAnalyticExtension)
    {b : ℝ} (hb_pos : 0 ≤ b) (hb : b ≤ 1 / 64) :
    sInf (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) ≤
      sInf (aperyGFAReal '' Set.Icc (0 : ℝ) b) := by
  have h_one_lt : (1 : ℝ) / 64 < Number.aperyConifoldZ1Poly :=
    aperyConifoldZ1Poly_gt_one_div_64
  exact h.sInf_aperyGFAReal_image_Icc_le_of_subset
    (le_refl 0) hb_pos
    (le_refl 0) (by norm_num : (0 : ℝ) ≤ 1 / 64) h_one_lt
    (Icc_zero_subset_Icc_zero_one_div_64 hb)

/-- **Image of `aperyGFAReal` on `Icc 0 b` is contained in image on `Icc 0 (1/64)`
when `0 ≤ b ≤ 1/64`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_zero_b_subset_one_div_64
    {b : ℝ} (hb : b ≤ 1 / 64) :
    aperyGFAReal '' Set.Icc (0 : ℝ) b ⊆ aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) :=
  Set.image_mono (Icc_zero_subset_Icc_zero_one_div_64 hb)

