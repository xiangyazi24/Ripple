          ((PowerSeries.X : PowerSeries ℝ) ^ m)) =
      -((m : ℝ) * ((m : ℝ) + 1) * ((m : ℝ) + 2) / 2) *
        (3458 - 2448 * Real.sqrt 2) := by
  rw [aperyFrobenius_one_w_m_simplified hm]
  rw [show fallingFactorial (1 + (m : ℝ)) 2 = (1 + (m : ℝ)) * (m : ℝ) from by
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  ring

/-- **w_m alpha_explicit form for ρ=0.**
  w_m(ρ=0) = -m(m-1)(m+1)·(3458-2448√2)/2 -/
lemma aperyFrobenius_zero_alpha_explicit_form {m : ℕ} (hm : 1 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 0
          ((PowerSeries.X : PowerSeries ℝ) ^ m)) =
      -((m : ℝ) * ((m : ℝ) - 1) * ((m : ℝ) + 1) / 2) *
        (3458 - 2448 * Real.sqrt 2) := by
  rw [aperyFrobenius_zero_w_m_simplified hm]
  rw [show fallingFactorial (0 + (m : ℝ)) 2 = (m : ℝ) * ((m : ℝ) - 1) from by
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  ring

/-- **β(m)·c(m-1) explicit form for ρ=0 (numerator before /denom).**
For m ≥ 2:
```
β_num(m) = (m-1)(m-2)·[A - (m-3)·B]
```
where A = 153-216√2, B = 48√2-34. -/
lemma aperyFrobenius_zero_beta_explicit_form {m : ℕ} (hm : 2 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 0
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 1))) =
      ((m : ℝ) - 1) * ((m : ℝ) - 2) *
        ((153 - 216 * Real.sqrt 2) - ((m : ℝ) - 3) * (48 * Real.sqrt 2 - 34)) := by
  rw [aperyFrobenius_zero_w_m_minus_one_explicit hm]
  have hmcast : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 := by
    exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  rw [show fallingFactorial (0 + ((m - 1 : ℕ) : ℝ)) 2 =
        ((m : ℝ) - 1) * ((m : ℝ) - 2) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (0 + ((m - 1 : ℕ) : ℝ)) 3 =
        ((m : ℝ) - 1) * ((m : ℝ) - 2) * ((m : ℝ) - 3) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **γ(m)·c(m-2) explicit form for ρ=0 (numerator before /denom).**
For m ≥ 3:
```
γ_num(m) = -(m-2)(m-3)·(m+2)
```
-/
lemma aperyFrobenius_zero_gamma_explicit_form {m : ℕ} (hm : 3 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 0
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 2))) =
      -(((m : ℝ) - 2) * ((m : ℝ) - 3) * ((m : ℝ) + 2)) := by
  rw [aperyFrobenius_zero_w_m_minus_two_explicit hm]
  have hmcast : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 := by
    exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  rw [show fallingFactorial (0 + ((m - 2 : ℕ) : ℝ)) 2 =
        ((m : ℝ) - 2) * ((m : ℝ) - 3) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (0 + ((m - 2 : ℕ) : ℝ)) 3 =
        ((m : ℝ) - 2) * ((m : ℝ) - 3) * ((m : ℝ) - 4) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **β(m)·c(m-1) explicit form for ρ=1 (numerator before /denom).**
For m ≥ 2, the coefficient of `c(m-1)` in the 3-step recurrence numerator is
```
β_num(m) = m(m-1)·[(153-216√2) - (m-2)·(48√2-34)]
```
which has limit `B·m³ + O(m²)` with `B = 48√2 - 34`. After dividing by
`denom(m+1) = (m+2)(m+1)(m+3/2)·K`, the limit is `β∞ = B/K`. -/
lemma aperyFrobenius_one_beta_explicit_form {m : ℕ} (hm : 2 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 1
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 1))) =
      (m : ℝ) * ((m : ℝ) - 1) *
        ((153 - 216 * Real.sqrt 2) - ((m : ℝ) - 2) * (48 * Real.sqrt 2 - 34)) := by
  rw [aperyFrobenius_one_w_m_minus_one_explicit hm]
  have hmcast : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 := by
    exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  rw [show fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 2 = (m : ℝ) * ((m : ℝ) - 1) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 3 =
        (m : ℝ) * ((m : ℝ) - 1) * ((m : ℝ) - 2) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **γ(m)·c(m-2) explicit form for ρ=1 (numerator before /denom).**
For m ≥ 3, the coefficient of `c(m-2)` in the 3-step recurrence numerator is
```
γ_num(m) = -(m-1)(m-2)·(m+3)
```
After dividing by `denom(m+1)`, the limit is `γ∞ = 1/K`. -/
lemma aperyFrobenius_one_gamma_explicit_form {m : ℕ} (hm : 3 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 1
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 2))) =
      -(((m : ℝ) - 1) * ((m : ℝ) - 2) * ((m : ℝ) + 3)) := by
  rw [aperyFrobenius_one_w_m_minus_two_explicit hm]
  have hmcast : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 := by
    exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  rw [show fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 2 =
        ((m : ℝ) - 1) * ((m : ℝ) - 2) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 3 =
        ((m : ℝ) - 1) * ((m : ℝ) - 2) * ((m : ℝ) - 3) from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **Char-poly identity for the dominant eigenvalue 1/z₁ (ρ-independent
algebraic core).**

The discrete eigenvalue equation `α∞ + β∞·z₁ + γ∞·z₁² = z₁⁻¹` for the 3-step
Apéry recurrence becomes (after multiplying by z₁ and clearing K = denom_∞):
```
(K'/2)·z₁ + B·z₁² + z₁³ = K
```
where `K = 19584-13848√2`, `K' = 3458-2448√2`, `B = 48√2-34`, `z₁ = 17-12√2`.

This is the cancellation-essential algebraic fact used in the ratio_bound
bootstrap: the polynomial-growth factor `(m+1)` in `|c(m)| ≤ C·(m+1)·z₁⁻ᵐ`
arises from the double root of the limit characteristic polynomial at `1/z₁`,
which this identity certifies.

**Proof certificate:** `LHS - RHS = (5184·√2 - 2448)·(√2² - 2)`. -/
lemma aperyConifold_charPoly_dominantEv_identity :
    (3458 - 2448 * Real.sqrt 2) * (17 - 12 * Real.sqrt 2) / 2 +
    (48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2 +
    (17 - 12 * Real.sqrt 2) ^ 3 =
      19584 - 13848 * Real.sqrt 2 := by
  have hs : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  linear_combination (5184 * Real.sqrt 2 - 2448) * hs

/-! ## Limit constants for the Apéry 3-step recurrence

The dominant eigenvalue 1/z₁ of the limit characteristic polynomial is
ρ-independent: all three branches (ρ ∈ {0, 1/2, 1}) share the same `α∞`,
`β∞`, `γ∞` because the leading-m³ behavior of α(m)·D, β(m)·D, γ(m)·D
matches asymptotically. We define these constants once and re-use across
all three ratio_bound proofs. -/

/-- **Limit `α∞`** for the Apéry 3-step recurrence (ρ-independent).
`α∞ = K'/(2K)` where `K = 19584-13848√2`, `K' = 3458-2448√2`. -/
noncomputable def aperyAlphaInf : ℝ :=
  (3458 - 2448 * Real.sqrt 2) / (2 * (19584 - 13848 * Real.sqrt 2))

/-- **Limit `β∞`** for the Apéry 3-step recurrence (ρ-independent).
`β∞ = B/K` where `B = 48√2 - 34`. -/
noncomputable def aperyBetaInf : ℝ :=
  (48 * Real.sqrt 2 - 34) / (19584 - 13848 * Real.sqrt 2)

/-- **Limit `γ∞`** for the Apéry 3-step recurrence (ρ-independent).
`γ∞ = 1/K`. -/
noncomputable def aperyGammaInf : ℝ :=
  1 / (19584 - 13848 * Real.sqrt 2)

/-- **Derivative of char-poly vanishes at 1/z₁ (double-root certificate).**

The dominant root 1/z₁ of `λ³ - α∞·λ² - β∞·λ - γ∞ = 0` is a DOUBLE root,
i.e., the derivative `3λ² - 2α∞·λ - β∞` also vanishes at λ = 1/z₁:
```
3·(1/z₁)² - 2α∞·(1/z₁) - β∞ = 0
⇔ 3 = 2α∞·z₁ + β∞·z₁²       (multiplying by z₁²)
⇔ K'·z₁ + B·z₁² = 3·K        (clearing the K denominator)
```

This double-root structure produces the polynomial-growth factor `(m+1)`
in `|c(m)| ≤ C·(m+1)·z₁⁻ᵐ`. Without the double root, the bound would
be just geometric `C·z₁⁻ᵐ`.

**Proof certificate:** `LHS - RHS = (6912·√2 + 4896)·(√2² - 2)`. -/
lemma aperyConifold_charPoly_dominantEv_double_root :
    (3458 - 2448 * Real.sqrt 2) * (17 - 12 * Real.sqrt 2) +
    (48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2 =
      3 * (19584 - 13848 * Real.sqrt 2) := by
  have hs : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  linear_combination (6912 * Real.sqrt 2 + 4896) * hs

/-- **Eigenvalue equation for the dominant double root 1/z₁.**

Restating `aperyConifold_charPoly_dominantEv_identity` in terms of the
named limit constants `α∞, β∞, γ∞`. The dominant eigenvalue 1/z₁ of the
limit char poly λ³ - α∞λ² - β∞λ - γ∞ satisfies:
```
α∞·z₁ + β∞·z₁² + γ∞·z₁³ = 1
```
which is the discrete-eigenvalue identity (multiplied by z₁³). -/
lemma aperyAlphaInf_z1_identity :
    aperyAlphaInf * (17 - 12 * Real.sqrt 2) +
    aperyBetaInf * (17 - 12 * Real.sqrt 2) ^ 2 +
    aperyGammaInf * (17 - 12 * Real.sqrt 2) ^ 3 = 1 := by
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h_id := aperyConifold_charPoly_dominantEv_identity
  unfold aperyAlphaInf aperyBetaInf aperyGammaInf
  have h_step :
      (3458 - 2448 * Real.sqrt 2) / (2 * (19584 - 13848 * Real.sqrt 2)) *
            (17 - 12 * Real.sqrt 2) +
        (48 * Real.sqrt 2 - 34) / (19584 - 13848 * Real.sqrt 2) *
            (17 - 12 * Real.sqrt 2) ^ 2 +
        1 / (19584 - 13848 * Real.sqrt 2) *
            (17 - 12 * Real.sqrt 2) ^ 3 =
      ((3458 - 2448 * Real.sqrt 2) * (17 - 12 * Real.sqrt 2) / 2 +
        (48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2 +
        (17 - 12 * Real.sqrt 2) ^ 3) /
      (19584 - 13848 * Real.sqrt 2) := by
    field_simp
  rw [h_step, h_id, div_self hK_ne]

/-- **Double-root identity in α∞/β∞ form.**
`2·α∞·z₁ + β∞·z₁² = 3` — derivative of char poly vanishes at 1/z₁. -/
lemma aperyAlphaInf_z1_double_root :
    2 * aperyAlphaInf * (17 - 12 * Real.sqrt 2) +
    aperyBetaInf * (17 - 12 * Real.sqrt 2) ^ 2 = 3 := by
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h_id := aperyConifold_charPoly_dominantEv_double_root
  unfold aperyAlphaInf aperyBetaInf
  have h_step :
      2 * ((3458 - 2448 * Real.sqrt 2) /
            (2 * (19584 - 13848 * Real.sqrt 2))) *
          (17 - 12 * Real.sqrt 2) +
        (48 * Real.sqrt 2 - 34) / (19584 - 13848 * Real.sqrt 2) *
          (17 - 12 * Real.sqrt 2) ^ 2 =
      ((3458 - 2448 * Real.sqrt 2) * (17 - 12 * Real.sqrt 2) +
        (48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2) /
      (19584 - 13848 * Real.sqrt 2) := by
    field_simp
  rw [h_step, h_id]
  field_simp

/-- **Third root identity for the limit char polynomial.**

The product of roots of `λ³ - α∞·λ² - β∞·λ - γ∞ = 0` equals `γ∞`.
With dominant double root `1/z₁` and third root `-1/(24√2)`:
```
(1/z₁)² · (-1/(24√2)) = γ∞ = 1/K
⇔ K = -24·√2·z₁²
⇔ 19584 - 13848·√2 = -24·√2·(17 - 12·√2)²
```

This certifies that the third root of the limit char poly is `-1/(24√2)`,
the subdominant eigenvalue. Combined with the double-root structure at
`1/z₁`, this fully determines the eigenvalue spectrum.

**Proof certificate:** `LHS - RHS = (3456·√2 - 9792)·(√2² - 2)`. -/
lemma aperyConifold_charPoly_thirdRoot_identity :
    19584 - 13848 * Real.sqrt 2 =
      -24 * Real.sqrt 2 * (17 - 12 * Real.sqrt 2) ^ 2 := by
  have hs : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  linear_combination (3456 * Real.sqrt 2 - 9792) * hs

/-! ## Recurrence coefficients α(m), β(m), γ(m) for ρ=1

Explicit closed-form expressions for the coefficients in the divided
3-step recurrence. `α m → α∞`, `β m → β∞`, `γ m → γ∞` as `m → ∞`. -/

/-- **`α(m)` for ρ=1**: explicit closed form `m·K' / [(2m+3)·K]`. -/
noncomputable def aperyAlphaOne (m : ℕ) : ℝ :=
  (m : ℝ) * (3458 - 2448 * Real.sqrt 2) /
    ((2 * (m : ℝ) + 3) * (19584 - 13848 * Real.sqrt 2))

/-- **`α(m) - α∞` exact difference** for ρ=1.
```
α(m) - α∞ = -3·K' / [2·(2m+3)·K]
```
Proven by direct algebra: common-denom and rearrange. -/
lemma aperyAlphaOne_sub_alphaInf (m : ℕ) :
    aperyAlphaOne m - aperyAlphaInf =
      -3 * (3458 - 2448 * Real.sqrt 2) /
        (2 * (2 * (m : ℝ) + 3) * (19584 - 13848 * Real.sqrt 2)) := by
  unfold aperyAlphaOne aperyAlphaInf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm_pos : (0 : ℝ) < 2 * (m : ℝ) + 3 := by positivity
  field_simp
  ring

/-- **`β(m)` for ρ=1**: explicit closed form
`-m(m-1)·[A - (m-2)B] / [(m+2)(m+1)(m+3/2)·K]`. -/
noncomputable def aperyBetaOne (m : ℕ) : ℝ :=
  -((m : ℝ) * ((m : ℝ) - 1) *
      ((153 - 216 * Real.sqrt 2) - ((m : ℝ) - 2) * (48 * Real.sqrt 2 - 34))) /
    (((m : ℝ) + 2) * ((m : ℝ) + 1) * ((m : ℝ) + 3 / 2) *
      (19584 - 13848 * Real.sqrt 2))

/-- **`γ(m)` for ρ=1**: explicit closed form
`(m-1)(m-2)(m+3) / [(m+2)(m+1)(m+3/2)·K]`. -/
noncomputable def aperyGammaOne (m : ℕ) : ℝ :=
  ((m : ℝ) - 1) * ((m : ℝ) - 2) * ((m : ℝ) + 3) /
    (((m : ℝ) + 2) * ((m : ℝ) + 1) * ((m : ℝ) + 3 / 2) *
      (19584 - 13848 * Real.sqrt 2))

/-- **`α(m)` for ρ=0**: `(m-1)·K' / [(2m+1)·K]`. -/
noncomputable def aperyAlphaZero (m : ℕ) : ℝ :=
  ((m : ℝ) - 1) * (3458 - 2448 * Real.sqrt 2) /
    ((2 * (m : ℝ) + 1) * (19584 - 13848 * Real.sqrt 2))

/-- **`α(m) - α∞` exact difference** for ρ=1/2.
`α(m) - α∞ = -3·K' / [4(m+1)·K]`. -/
lemma aperyAlphaHalf_sub_alphaInf (m : ℕ) :
    aperyAlphaHalf m - aperyAlphaInf =
      -3 * (3458 - 2448 * Real.sqrt 2) /
        (4 * ((m : ℝ) + 1) * (19584 - 13848 * Real.sqrt 2)) := by
  unfold aperyAlphaHalf aperyAlphaInf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  field_simp
  ring

/-- **`α(m) - α∞` exact difference** for ρ=0.
`α(m) - α∞ = -3·K' / [2(2m+1)·K]`. -/
lemma aperyAlphaZero_sub_alphaInf (m : ℕ) :
    aperyAlphaZero m - aperyAlphaInf =
      -3 * (3458 - 2448 * Real.sqrt 2) /
        (2 * (2 * (m : ℝ) + 1) * (19584 - 13848 * Real.sqrt 2)) := by
  unfold aperyAlphaZero aperyAlphaInf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h2m1_pos : (0 : ℝ) < 2 * (m : ℝ) + 1 := by positivity
  field_simp
  ring

/-- **`β(m) - β∞` exact difference** for ρ=1.
```
β(m) - β∞ = -[2m(m-1)·A + 3B·(5m² + 3m + 2)] / [2·(m+2)(m+1)(m+3/2)·K]
```
where `A = 153 - 216√2`, `B = 48√2 - 34`. Numerator is quadratic in m,
denominator cubic, so `β(m) - β∞ ~ const/m` as `m → ∞`. -/
lemma aperyBetaOne_sub_betaInf (m : ℕ) :
    aperyBetaOne m - aperyBetaInf =
      -(2 * (m : ℝ) * ((m : ℝ) - 1) * (153 - 216 * Real.sqrt 2) +
          3 * (48 * Real.sqrt 2 - 34) *
            (5 * (m : ℝ) ^ 2 + 3 * (m : ℝ) + 2)) /
        (2 * ((m : ℝ) + 2) * ((m : ℝ) + 1) * ((m : ℝ) + 3 / 2) *
          (19584 - 13848 * Real.sqrt 2)) := by
  unfold aperyBetaOne aperyBetaInf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm2_pos : (0 : ℝ) < (m : ℝ) + 2 := by positivity
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hm32_pos : (0 : ℝ) < (m : ℝ) + 3 / 2 := by positivity
  field_simp
  ring

/-- **`γ(m) - γ∞` exact difference** for ρ=1.
```
γ(m) - γ∞ = (m-1)(m-2)(m+3) / D - 1/K
         = [(m-1)(m-2)(m+3) - (m+2)(m+1)(m+3/2)] / D
```
