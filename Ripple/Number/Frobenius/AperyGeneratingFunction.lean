/-- **3step closed-form for ρ=1.** -/
lemma aperyFrobenius_one_3step_closed_form {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly 1 1
    c (m + 1) * (fallingFactorial (2 + (m : ℝ)) 2 * (3 / 2 + (m : ℝ)) *
        (19584 - 13848 * Real.sqrt 2)) =
      -(c (m - 2) * (-6 * fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 2 -
          fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 3) +
        c (m - 1) * (fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 2 *
            (153 - 216 * Real.sqrt 2) -
          fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 3 * (48 * Real.sqrt 2 - 34)) +
        c m * (-fallingFactorial (1 + (m : ℝ)) 2 * (5187 - 3672 * Real.sqrt 2) -
          fallingFactorial (1 + (m : ℝ)) 3 * ((3458 - 2448 * Real.sqrt 2) / 2))) := by
  intro c
  have h_3step := aperyFrobenius_one_3step_recurrence hm
  have h_w_m := aperyFrobenius_one_w_m_explicit (show 1 ≤ m by omega)
  have h_w_m1 := aperyFrobenius_one_w_m_minus_one_explicit (show 2 ≤ m by omega)
  have h_w_m2 := aperyFrobenius_one_w_m_minus_two_explicit hm
  have h_denom := aperyFrobenius_one_denom_explicit m
  rw [← h_denom, h_3step]
  dsimp only
  rw [h_w_m, h_w_m1, h_w_m2]

/-- **3-step recurrence form for ρ=0 (sub-lemma 1 of ρ=0 ratio_bound proof).**
Same structure as ρ=1/2 and ρ=1, with the indicial denom shifted to ρ=0
(but requiring `m ≥ 3` already enforces `m ≥ 1` for non-resonance). -/
lemma aperyFrobenius_zero_3step_recurrence
    {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly 0 1
    let w (i : ℕ) := PowerSeries.coeff (R := ℝ) (m + 1 + 1)
              (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                3 Number.aperyConifoldZ1Poly 0
                ((PowerSeries.X : PowerSeries ℝ) ^ i))
    let denom_val := ((-1 : ℝ) ^ 2) *
              simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
                Number.aperyConifoldZ1Poly 2 ((0 : ℝ) + ((m + 1 : ℕ) : ℝ))
    c (m + 1) * denom_val =
      -(c (m - 2) * w (m - 2) + c (m - 1) * w (m - 1) + c m * w m) := by
  intro c w denom_val
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  have h_rec := frobeniusCoeff_succ_linear_combination
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
    Number.aperyConifoldZ1Poly 0 1 m hP_zero
  have h_3step := aperyFrobenius_three_step_sum hm (0 : ℝ) 1
  have h_denom_ne : denom_val ≠ 0 := aperyFrobenius_zero_denom_ne_zero (by omega : 1 ≤ m)
  have h_eq1 :
      c (m + 1) * denom_val =
        -(∑ i ∈ Finset.range (m + 1), c i * w i) := by
    show frobeniusCoeff _ 2 _ 0 1 (m + 1) * denom_val = _
    rw [h_rec]
    have hps2 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2 =
        Number.aperyQconifold := rfl
    have hps3 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1) =
        Number.aperyPconifold := rfl
    rw [hps2, hps3]
    rw [neg_div, neg_mul, div_mul_cancel₀ _ h_denom_ne]
  rw [h_eq1]
  congr 1
  have h_3step_local :
      ∑ i ∈ Finset.range (m + 1), c i * w i =
      ∑ i ∈ Finset.Ico (m - 2) (m + 1), c i * w i := h_3step
  rw [h_3step_local]
  rw [show Finset.Ico (m - 2) (m + 1) =
        ({m - 2} : Finset ℕ) ∪ {m - 1} ∪ {m} from by
    ext k
    simp only [Finset.mem_Ico, Finset.mem_union, Finset.mem_singleton]
    omega]
  rw [Finset.sum_union (by
    rw [Finset.disjoint_left]
    intro x hx hx'
    simp [Finset.mem_singleton] at hx hx'
    omega)]
  rw [Finset.sum_union (by
    rw [Finset.disjoint_left]
    intro x hx hx'
    simp [Finset.mem_singleton] at hx hx'
    omega)]
  rw [Finset.sum_singleton, Finset.sum_singleton, Finset.sum_singleton]

