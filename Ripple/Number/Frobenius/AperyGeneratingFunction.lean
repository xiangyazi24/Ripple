          (3 * Number.aperyConifoldZ1Poly / 4))
        (aperyCanonicalExtractOne3 (Number.aperyConifoldZ1Poly / 2)
          (2 * Number.aperyConifoldZ1Poly / 3)
          (3 * Number.aperyConifoldZ1Poly / 4)) t :=
  d.GFA_decomposes_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det htC hz
    half_z1_disk_hypothesis two_thirds_z1_disk_hypothesis
    three_quarters_z1_disk_hypothesis

