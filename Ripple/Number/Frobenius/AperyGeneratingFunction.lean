        aperyCanonicalExtractHalf3 ε₁ ε₂ ε₃ * aperyBranchAmplitude_half ε +
        aperyCanonicalExtractOne3 ε₁ ε₂ ε₃ * aperyBranchValue_one ε :=
  (AperyConnectionData.of_witness ext I h0 h).GFA_right_endpoint_via_canonical3_on_disk
