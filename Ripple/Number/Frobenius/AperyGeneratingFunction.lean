/-- **Generic `some.F z ∈ Icc [sInf, sSup]` for `z ∈ Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.some_F_mem_Icc_sInf_sSup_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64)
    {z : ℝ} (hz : z ∈ Set.Icc a b) :
    h.some.F z ∈
      Set.Icc
        (sInf (h.some.F '' Set.Icc a b))
        (sSup (h.some.F '' Set.Icc a b)) :=
  ⟨(h.isGLB_sInf_some_F_image_Icc_sub ha hab hb).1 ⟨z, hz, rfl⟩,
   (h.isLUB_sSup_some_F_image_Icc_sub ha hab hb).1 ⟨z, hz, rfl⟩⟩

/-- **Left endpoint `some.F a ∈ Icc [sInf, sSup]`.** -/
lemma HasAperyAnalyticExtension.some_F_left_mem_Icc_sInf_sSup_sub
