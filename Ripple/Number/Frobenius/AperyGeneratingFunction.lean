/-! ### `HasCorridor` extreme value + norm bound on generic sub-interval -/

/-- **Extreme value (max) for `aperyGFAReal` on `Icc a b` with
`0 ≤ a ≤ b < aperyConifoldZ1Poly` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_isMaxOn_aperyGFAReal_Icc_general
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < Number.aperyConifoldZ1Poly) :
    ∃ x ∈ Set.Icc a b, IsMaxOn aperyGFAReal (Set.Icc a b) x :=
  isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr hab)
    (h.continuousOn_aperyGFAReal_Icc_general ha hb)

/-- **Extreme value (min) for `aperyGFAReal` on `Icc a b` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_isMinOn_aperyGFAReal_Icc_general
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < Number.aperyConifoldZ1Poly) :
    ∃ x ∈ Set.Icc a b, IsMinOn aperyGFAReal (Set.Icc a b) x :=
  isCompact_Icc.exists_isMinOn
    (Set.nonempty_Icc.mpr hab)
    (h.continuousOn_aperyGFAReal_Icc_general ha hb)

/-- **Norm bound for `aperyGFAReal` on `Icc a b` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_norm_bound_aperyGFAReal_Icc_general
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < Number.aperyConifoldZ1Poly) :
    ∃ M : ℝ, ∀ z ∈ Set.Icc a b, |aperyGFAReal z| ≤ M := by
  obtain ⟨xmax, _, hxmax⟩ :=
    h.exists_isMaxOn_aperyGFAReal_Icc_general ha hab hb
  obtain ⟨xmin, _, hxmin⟩ :=
    h.exists_isMinOn_aperyGFAReal_Icc_general ha hab hb
  refine ⟨max (aperyGFAReal xmax) (-aperyGFAReal xmin), ?_⟩
  intro z hz
  have h_le_max : aperyGFAReal z ≤ aperyGFAReal xmax := hxmax hz
  have h_min_le : aperyGFAReal xmin ≤ aperyGFAReal z := hxmin hz
  rw [abs_le]
  refine ⟨?_, ?_⟩
  · have h_le_M : -aperyGFAReal xmin ≤
        max (aperyGFAReal xmax) (-aperyGFAReal xmin) :=
      le_max_right _ _
    linarith
  · have h_le_M : aperyGFAReal xmax ≤
        max (aperyGFAReal xmax) (-aperyGFAReal xmin) :=
      le_max_left _ _
    linarith

