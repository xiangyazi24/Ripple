            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) := by
  have h_full :=
    ext.F_explicit_frobenius_decomp_on_disk h0 h hε₁ hε₂ hdet ht htdisk
  linarith [h_full]

/-- **Ext-layer half-branch extractor on the strict left disk.** -/
lemma AperyAnalyticExtension.F_half_branch_extractor_left_on_disk
