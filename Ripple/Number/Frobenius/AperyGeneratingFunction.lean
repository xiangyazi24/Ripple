      (ext.connectionCoefficients ε₁ ε₂).2.1 +
        t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2)
            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_half_branch_extractor_left_on_disk h0 h hε₁ hε₂ hdet ht htneg
    htdisk

/-- **One-branch isolation on disk.** Subtract the regular and half
contributions from `f(z₁+t)` to leave just the integer-shift one
branch: `f(z₁+t) - regular - half = a₁·t + t²·T_O = t·(a₁ + t·T_O)`.
Pure rearrangement of `decomp_on_frobeniusDisk`. -/
lemma IsAperyConnectionCoeffsOn.one_branch_isolated_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) -
        Real.sqrt (-t) * (a_half + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2) a_half (m + 1) * t ^ m) =
      a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m := by
  have h_full := h.decomp_on_frobeniusDisk ht htdisk
  linarith [h_full]

/-- **One-branch extractor on the strict right disk.** For `t > 0` in
the disk, the half-branch auto-vanishes via `√(-t) = 0`, so subtracting
just the regular and dividing by `t` recovers `a₁ + t·T_O` directly.
This is the right-side analytic extractor (companion of left-side
half-branch extractor). -/
lemma IsAperyConnectionCoeffsOn.one_branch_extractor_right_on_frobeniusDisk
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htpos : 0 < t)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    (f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m)) / t =
      a₁ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m := by
  have h_right := h.decomp_right_on_frobeniusDisk ht htpos.le htdisk
  have h_ne : t ≠ 0 := ne_of_gt htpos
  have h_eq :
      f (Number.aperyConifoldZ1Poly + t) -
        (a₀ + t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) =
      t * (a₁ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) := by
    have := h_right
    nlinarith [h_right, sq_nonneg t]
  rw [h_eq, mul_div_cancel_left₀ _ h_ne]

