/-! #### Indexed-family extendCorridor and chain probe invariance -/

/-- **Indexed-family corridor extension.** Bundles
`has_conn_on_iUnion_of_three_probes` into a `AperyConnectionData` whose
corridor is `d.corridor ∪ ⋃ i, J i`. The chain analog of
`extendCorridor`. -/
noncomputable def AperyConnectionData.extendCorridor_iUnion
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i)) :
    AperyConnectionData where
  toAperyAnalyticExtension := d.toAperyAnalyticExtension
  corridor := d.corridor ∪ ⋃ i, J i
  zero_mem := Or.inl d.zero_mem
  has_conn := d.has_conn_on_iUnion_of_three_probes
    hε₁_d hε₂_d h0 hε₁ hε₂ hdet hJ

