/-- **Image of `aperyGFAReal` on `Icc a b` equals `Icc sInf sSup`
under `HasCorridor` (IVT).** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_general_eq_Icc_sInf_sSup
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < Number.aperyConifoldZ1Poly) :
    aperyGFAReal '' Set.Icc a b =
      Set.Icc
        (sInf (aperyGFAReal '' Set.Icc a b))
        (sSup (aperyGFAReal '' Set.Icc a b)) := by
  apply Set.eq_of_subset_of_subset
  · intro y hy
    obtain ⟨z, hz_mem, hz_eq⟩ := hy
    rw [← hz_eq]
    exact h.aperyGFAReal_mem_Icc_sInf_sSup_general ha hab hb hz_mem
  · have h_cont := h.continuousOn_aperyGFAReal_Icc_general ha hb
    have h_image_nonempty :
        (aperyGFAReal '' Set.Icc a b).Nonempty :=
      Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab)
    have h_compact : IsCompact (aperyGFAReal '' Set.Icc a b) :=
      isCompact_Icc.image_of_continuousOn h_cont
    obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ :=
      h_compact.sInf_mem h_image_nonempty
    obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ :=
      h_compact.sSup_mem h_image_nonempty
    have h_surj := h_cont.surjOn_Icc hzmin_mem hzmax_mem
    rw [hzmin_eq, hzmax_eq] at h_surj
    exact h_surj

/-- **`SurjOn aperyGFAReal (Icc a b) (Icc sInf sSup)` under `HasCorridor`.** -/
