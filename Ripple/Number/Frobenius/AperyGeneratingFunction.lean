/-! ### Bridge pairing: GFA-interior At-disk ↔ ext-side At-disk

The minimal cross-regime identification: a GFA-interior At-disk
(carrying `aperyGFAReal`) and an `ext`-side At-disk (carrying
`ext.F`), declared compatible at the underlying-disk level, agree
at any common point — yielding `aperyGFAReal z = ext.F z` directly. -/

/-- **Two-disk bridge identification.** -/
lemma aperyGFA_eq_ext_via_bridge
    (ext : AperyAnalyticExtension)
    {z₀ : ℝ} (h_pos : 0 < z₀) (h_lt : z₀ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₀ + t)))
    {z_e : ℝ} (h_reg : AperyConifoldRegularPoint z_e)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (ext.F (z_e + t)))
    (h_bridge : AperyRegularDiskAt.Compatible
      (aperyGFAInteriorRegularDiskAt z₀ h_pos h_lt r₁ hr₁ coeffs₁ hs₁)
      (ext.toRegularDiskAt z_e h_reg r₂ hr₂ coeffs₂ hs₂))
    {z : ℝ}
    (hz_GFA : z ∈ (aperyGFAInteriorRegularDiskAt z₀ h_pos h_lt r₁ hr₁
      coeffs₁ hs₁).diskOpen)
    (hz_ext : z ∈ (ext.toRegularDiskAt z_e h_reg r₂ hr₂
      coeffs₂ hs₂).diskOpen) :
    aperyGFAReal z = ext.F z :=
  AperyRegularDiskAt.Compatible.F_eq h_bridge hz_GFA hz_ext

/-- **Three-step capstone via GFA bridge.** Combines:
1. GFA disk ↔ GFA-interior At-disk (automatic via shared `aperyGFAReal`),
2. Bridge: GFA-interior At-disk ↔ ext-side At-disk (hypothesis),
3. ext-side At-disk → ext.F (automatic via projection).

Conclusion: at any common point, `aperyGFAReal z = ext.F z`. The `ds`
position in the geometric chain is fixed at index 0; longer chains
on the ext side go through `aperyGFA_value_via_chain_to_ext`. -/
lemma aperyGFA_eq_ext_via_GFA_bridge_one_step
    (ext : AperyAnalyticExtension)
    {z₀ : ℝ} (h_pos : 0 < z₀) (h_lt : z₀ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₀ + t)))
    {z_e : ℝ} (h_reg : AperyConifoldRegularPoint z_e)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (ext.F (z_e + t)))
    (h_bridge : AperyRegularDiskAt.Compatible
      (aperyGFAInteriorRegularDiskAt z₀ h_pos h_lt r₁ hr₁ coeffs₁ hs₁)
      (ext.toRegularDiskAt z_e h_reg r₂ hr₂ coeffs₂ hs₂))
    {z : ℝ}
    (hz_GFA : z ∈ (aperyGFAInteriorRegularDiskAt z₀ h_pos h_lt r₁ hr₁
      coeffs₁ hs₁).diskOpen)
    (hz_ext : z ∈ (ext.toRegularDiskAt z_e h_reg r₂ hr₂
      coeffs₂ hs₂).diskOpen) :
    aperyGFAReal z = ext.F z :=
  aperyGFA_eq_ext_via_bridge ext h_pos h_lt hr₁ coeffs₁ hs₁ h_reg hr₂
    coeffs₂ hs₂ h_bridge hz_GFA hz_ext

/-! ### GFA-overlap consistency check

When `z` lies in the unconditional overlap `[0, 1/64)`, the chain
machinery reduces to `F_eq_GFA_on_small`. Recording this trivial
case makes explicit that the chain framework is consistent with the
existing direct identification — it generalises the small-disk
agreement to chain-reachable points, but agrees with it where they
overlap. -/

/-- **Direct GFA ↔ ext identification on the unconditional overlap.**
Symmetric form of `F_eq_GFA_on_small` framed in the gap-B direction
`aperyGFAReal z = ext.F z`. -/
lemma aperyGFA_eq_ext_on_overlap
    (ext : AperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal z = ext.F z :=
  (ext.F_eq_GFA_on_small hz).symm

/-- **Trivial-chain consistency.** For `z ∈ [0, 1/64)`, any
all-the-same-`ext` `At`-chain whose first disk is compatible with the
GFA disk and whose every disk contains `z` produces the same
identification as the direct `F_eq_GFA_on_small`. The chain is
therefore not "creating" a new identity at overlap points — it is
reproducing the unconditional one, providing a self-consistent
extension framework. -/
lemma aperyGFA_value_via_chain_consistent_on_overlap
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    (hcompGFA : AperyRegularDisk.Compatible aperyGFARegularDisk
      (ds 0).toAperyRegularDisk)
    {z : ℝ} (hz_overlap : z ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hz : ∀ i, i ≤ n → z ∈ (ds i).diskOpen) :
    aperyGFAReal z = ext.F z := by
  have hzGFA : |z| < 1 / 64 := by
    rw [abs_of_nonneg hz_overlap.1]; exact hz_overlap.2
  exact aperyGFA_value_via_chain_to_ext ext ds n h_ext hcompGFA hzGFA hz

/-! ### Bridge to `AperyAnalyticDiskAt`

One-shot constructor producing the combined analytic + regular-center
disk directly from an `AperyAnalyticExtension`. Composes
`toRegularDiskAt` (geometric + regularity) with
`AperyAnalyticDiskAt.ofSummable` (analyticity from absolute summability),
so downstream gap-B forward-continuation code can build a chain disk
in a single call.

The summability hypothesis is stated in `NNReal` (matching
`AperyAnalyticDisk.le_radius_ofScalars`): for every `r' ∈ [0, radius)`
the absolute series `Σ |coeffs n| · r'^n` converges. -/

/-- **Induced analytic regular-center disk from an analytic extension.**
Bundles `toRegularDiskAt` with `AperyAnalyticDiskAt.ofSummable`. -/
noncomputable def AperyAnalyticExtension.toAnalyticDiskAt
    (ext : AperyAnalyticExtension)
    (center : ℝ) (h_reg : AperyConifoldRegularPoint center)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t)))
    (hSum : ∀ r' : NNReal, (r' : ℝ) < radius →
      Summable (fun n : ℕ => |coeffs n| * (r' : ℝ) ^ n)) :
    AperyAnalyticDiskAt :=
  AperyAnalyticDiskAt.ofSummable
    (ext.toRegularDiskAt center h_reg radius radius_pos coeffs has_sum) hSum

@[simp] lemma AperyAnalyticExtension.toAnalyticDiskAt_F
    (ext : AperyAnalyticExtension) (center : ℝ)
    (h_reg : AperyConifoldRegularPoint center)
    (radius : ℝ) (hr : 0 < radius) (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t)))
    (hSum : ∀ r' : NNReal, (r' : ℝ) < radius →
      Summable (fun n : ℕ => |coeffs n| * (r' : ℝ) ^ n)) :
    (ext.toAnalyticDiskAt center h_reg radius hr coeffs hs hSum).F = ext.F := rfl

