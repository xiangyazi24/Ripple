lemmas. -/
lemma aperyFrobenius_one_explicit_recurrence {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly 1 1
    c (m + 1) =
      aperyAlphaOne m * c m +
      aperyBetaOne m * c (m - 1) +
      aperyGammaOne m * c (m - 2) := by
  intro c
  have h_closed := aperyFrobenius_one_3step_closed_form hm
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm2_pos : (0 : ℝ) < (m : ℝ) + 2 := by positivity
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hm32_pos : (0 : ℝ) < 3 / 2 + (m : ℝ) := by positivity
  have hmcast1 : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 :=
    by exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  have hmcast2 : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 :=
    by exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  rw [show fallingFactorial (2 + (m : ℝ)) 2 = ((m : ℝ) + 2) * ((m : ℝ) + 1) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]; ring,
      show fallingFactorial (1 + (m : ℝ)) 2 = ((m : ℝ) + 1) * (m : ℝ) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]; ring,
      show fallingFactorial (1 + (m : ℝ)) 3 =
          ((m : ℝ) + 1) * (m : ℝ) * ((m : ℝ) - 1) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]; ring,
      show fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 2 =
          (m : ℝ) * ((m : ℝ) - 1) from by
        rw [hmcast1, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]; ring,
      show fallingFactorial (1 + ((m - 1 : ℕ) : ℝ)) 3 =
          (m : ℝ) * ((m : ℝ) - 1) * ((m : ℝ) - 2) from by
        rw [hmcast1, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_succ, fallingFactorial_zero]; ring,
      show fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 2 =
          ((m : ℝ) - 1) * ((m : ℝ) - 2) from by
        rw [hmcast2, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]; ring,
      show fallingFactorial (1 + ((m - 2 : ℕ) : ℝ)) 3 =
          ((m : ℝ) - 1) * ((m : ℝ) - 2) * ((m : ℝ) - 3) from by
        rw [hmcast2, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_succ, fallingFactorial_zero]; ring] at h_closed
  have h_apery_2Q3P : (5187 - 3672 * Real.sqrt 2 : ℝ) =
      3 * (3458 - 2448 * Real.sqrt 2) / 2 := by ring
  rw [h_apery_2Q3P] at h_closed
  set D := ((m : ℝ) + 2) * ((m : ℝ) + 1) * (3 / 2 + (m : ℝ)) *
      (19584 - 13848 * Real.sqrt 2) with hD_def
  have hD_ne : D ≠ 0 := by
    rw [hD_def]
    exact mul_ne_zero (mul_ne_zero (mul_ne_zero hm2_pos.ne' hm1_pos.ne') hm32_pos.ne') hK_ne
  refine mul_right_cancel₀ hD_ne ?_
  -- After mul_right_cancel: c(m+1) * D = (α·c(m) + β·c(m-1) + γ·c(m-2)) * D
  rw [add_mul, add_mul, mul_assoc (aperyAlphaOne m) (c m) D,
      mul_assoc (aperyBetaOne m) (c (m - 1)) D,
      mul_assoc (aperyGammaOne m) (c (m - 2)) D]
  rw [show aperyAlphaOne m * (c m * D) =
        (aperyAlphaOne m * D) * c m from by ring,
      show aperyBetaOne m * (c (m - 1) * D) =
        (aperyBetaOne m * D) * c (m - 1) from by ring,
      show aperyGammaOne m * (c (m - 2) * D) =
        (aperyGammaOne m * D) * c (m - 2) from by ring]
  rw [hD_def, aperyAlphaOne_mul_denom, aperyBetaOne_mul_denom,
      aperyGammaOne_mul_denom]
  rw [h_closed]
  ring

/-- **Birkhoff L∞-cancellation identity** for the limit char polynomial.

The Birkhoff two-term asymptotic `c(m) = (K∞·m + L∞)·z⁻ᵐ + R(m)` requires
that the L∞-coefficient cancellation holds in the limit recurrence:
```
α∞·L∞ + β∞·L∞·z + γ∞·L∞·z² = L∞/z + (correction from K∞)
```
After clearing denoms, this reduces to:
```
β∞·z² + 2γ∞·z³ = -1
```
which (multiplying by K) becomes:
```
B·z₁² + 2·z₁³ = -K
```
where `B = 48√2 - 34`, `z₁ = 17 - 12√2`, `K = 19584 - 13848√2`.

This is implied by the eigenvalue + double-root identities but stated as
a separate lemma for direct use in the Birkhoff bootstrap.

**Proof certificate:** `LHS - RHS = (3456·√2 - 9792)·(√2² - 2)`. -/
lemma aperyConifold_birkhoff_L_cancellation :
    (48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2 +
    2 * (17 - 12 * Real.sqrt 2) ^ 3 =
      -(19584 - 13848 * Real.sqrt 2) := by
  have hs : (Real.sqrt 2) ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  linear_combination (3456 * Real.sqrt 2 - 9792) * hs

/-- **Birkhoff L-cancellation in α∞/β∞/γ∞ form**: β∞·z² + 2γ∞·z³ = -1. -/
lemma aperyBetaInf_z1_birkhoff_L :
    aperyBetaInf * (17 - 12 * Real.sqrt 2) ^ 2 +
    2 * aperyGammaInf * (17 - 12 * Real.sqrt 2) ^ 3 = -1 := by
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h_L := aperyConifold_birkhoff_L_cancellation
  unfold aperyBetaInf aperyGammaInf
  have h_step :
      (48 * Real.sqrt 2 - 34) / (19584 - 13848 * Real.sqrt 2) *
          (17 - 12 * Real.sqrt 2) ^ 2 +
        2 * (1 / (19584 - 13848 * Real.sqrt 2)) *
          (17 - 12 * Real.sqrt 2) ^ 3 =
      ((48 * Real.sqrt 2 - 34) * (17 - 12 * Real.sqrt 2) ^ 2 +
        2 * (17 - 12 * Real.sqrt 2) ^ 3) /
      (19584 - 13848 * Real.sqrt 2) := by
    field_simp
  rw [h_step, h_L]
  rw [neg_div, div_self hK_ne]

/-- **Birkhoff ansatz preservation lemma (limit recurrence form).**

The two-term ansatz `K∞·m + L∞` (for the rescaled coefficients
`c(m)·z₁ᵐ`) is exactly preserved by the LIMIT recurrence using
`α∞, β∞, γ∞`. Equivalently, plugging `s(k) := (K∞·k + L∞)` into
```
α∞·s(m) + β∞·z·s(m-1) + γ∞·z²·s(m-2) = z⁻¹·s(m+1)
```
holds as a free polynomial identity in `K∞, L∞, m`.

This is the algebraic core of why the bootstrap works: leading two
terms exactly cancel (no residual error), so R(m) satisfies the
same recurrence and decays at the subdominant rate. -/
lemma aperyConifold_birkhoff_ansatz_preserved (K_inf L_inf : ℝ) (m : ℝ) :
    aperyAlphaInf * (K_inf * m + L_inf) +
    aperyBetaInf * (17 - 12 * Real.sqrt 2) *
      (K_inf * (m - 1) + L_inf) +
    aperyGammaInf * (17 - 12 * Real.sqrt 2) ^ 2 *
      (K_inf * (m - 2) + L_inf) =
    (K_inf * (m + 1) + L_inf) / (17 - 12 * Real.sqrt 2) := by
  have h_eigen := aperyAlphaInf_z1_identity
  have h_double := aperyAlphaInf_z1_double_root
  have hz_ne : (17 - 12 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have := aperyConifoldZ1Poly_pos
    show Number.aperyConifoldZ1Poly ≠ 0; positivity
  have h_L_α := aperyBetaInf_z1_birkhoff_L
  field_simp
  -- LHS - RHS = (K_inf·m + L_inf)·(eigen) - K_inf·(L_α): coefficients combine
  linear_combination
    (K_inf * m + L_inf) * h_eigen - K_inf * h_L_α

/-- **Birkhoff residual function for ρ=1**.
`R(m) := c(m) - (K∞·m + L∞)·z⁻ᵐ`. Parametric in K∞, L∞. The bootstrap will
choose specific values that make R decay subdominantly. -/
noncomputable def aperyBirkhoffResidualOne (K_inf L_inf : ℝ) (m : ℕ) : ℝ :=
  frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
    2 Number.aperyConifoldZ1Poly 1 1 m
  - (K_inf * (m : ℝ) + L_inf) * (1 / Number.aperyConifoldZ1Poly) ^ m

/-- **Decomposition: c(m) = leading + Birkhoff residual.** -/
lemma aperyFrobenius_one_birkhoff_decomposition (K_inf L_inf : ℝ) (m : ℕ) :
    frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 m =
      (K_inf * (m : ℝ) + L_inf) * (1 / Number.aperyConifoldZ1Poly) ^ m +
      aperyBirkhoffResidualOne K_inf L_inf m := by
  unfold aperyBirkhoffResidualOne
  ring

/-- **Birkhoff perturbation forcing** for ρ=1.
Δ(m) is the residual after substituting `c = leading + R` into the divided
form recurrence. With `α(m) = α∞, β(m) = β∞, γ(m) = γ∞` (limit values) Δ
vanishes (per `aperyConifold_birkhoff_ansatz_preserved`); for actual α(m)
etc, Δ is O(z⁻ᵐ) (perturbation × polynomial-in-m × z⁻ᵐ). -/
noncomputable def aperyBirkhoffForcingOne (K_inf L_inf : ℝ) (m : ℕ) : ℝ :=
  aperyAlphaOne m * (K_inf * (m : ℝ) + L_inf) *
      (1 / Number.aperyConifoldZ1Poly) ^ m
  + aperyBetaOne m * (K_inf * ((m : ℝ) - 1) + L_inf) *
      (1 / Number.aperyConifoldZ1Poly) ^ (m - 1)
  + aperyGammaOne m * (K_inf * ((m : ℝ) - 2) + L_inf) *
      (1 / Number.aperyConifoldZ1Poly) ^ (m - 2)
  - (K_inf * ((m : ℝ) + 1) + L_inf) *
      (1 / Number.aperyConifoldZ1Poly) ^ (m + 1)

/-- **Recurrence for the Birkhoff residual** (ρ=1). For `m ≥ 3`:
```
R(m+1) = α(m)·R(m) + β(m)·R(m-1) + γ(m)·R(m-2) + Δ(m)
```
Direct from divided form: the (K·k+L)·z⁻ᵏ terms cancel pairwise between
the R-expansions and the forcing Δ, leaving just the c-recurrence. -/
lemma aperyBirkhoffResidualOne_recurrence (K_inf L_inf : ℝ) {m : ℕ} (hm : 3 ≤ m) :
    aperyBirkhoffResidualOne K_inf L_inf (m + 1) =
      aperyAlphaOne m * aperyBirkhoffResidualOne K_inf L_inf m +
      aperyBetaOne m * aperyBirkhoffResidualOne K_inf L_inf (m - 1) +
      aperyGammaOne m * aperyBirkhoffResidualOne K_inf L_inf (m - 2) +
      aperyBirkhoffForcingOne K_inf L_inf m := by
  unfold aperyBirkhoffResidualOne aperyBirkhoffForcingOne
  have h_div := aperyFrobenius_one_explicit_recurrence hm
  have hmcast1 : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 :=
    by exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  have hmcast2 : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 :=
    by exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  have hmcast0 : ((m + 1 : ℕ) : ℝ) = (m : ℝ) + 1 := by push_cast; ring
  -- Substitute all nat-sub casts to reals so ring sees consistent atoms
  rw [hmcast0, hmcast1, hmcast2]
  -- (K·k+L)·z⁻ᵏ atoms cancel pairwise; ring residual = h_div.
  linear_combination h_div

/-- **Apéry ρ=1 ratio bound.**

For the unit-seed ρ=1 Frobenius core, every positive-index coefficient
vanishes. The constant term cannot feed any later coefficient because its
`Q` and `P` weights contain `fallingFactorial 1 2` and
`fallingFactorial 1 3`, both zero; all remaining terms vanish by induction.
Thus the requested ratio bound is immediate from `M₀ = 1`. -/
theorem aperyFrobenius_one_ratio_bound :
    ∃ M₀ : ℕ, 1 ≤ M₀ ∧ ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 (m + 1)| ≤
      (1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 1 1 m| := by
  let c := frobeniusCoeff
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
    2 Number.aperyConifoldZ1Poly 1 1
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  have hconst_zero : ∀ k : ℕ,
      PowerSeries.coeff (R := ℝ) (k + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 1
          ((PowerSeries.X : PowerSeries ℝ) ^ 0)) = 0 := by
    intro k
    rw [coeff_succ_substLHSGen_X_pow_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 (k + 1) 0 (by omega)]
    rw [show (2 + 2 : ℕ) = 4 from rfl]
    rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
        Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
    simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
      mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
    simp [fallingFactorial]
  have hzero : ∀ m : ℕ, 1 ≤ m → c m = 0 := by
    intro m hm
    induction m using Nat.strong_induction_on with
    | h m ih =>
      cases m with
      | zero => omega
      | succ k =>
        have h_rec := frobeniusCoeff_succ_linear_combination
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1 1 k hP_zero
        change frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 1 1 (k + 1) = 0
        rw [h_rec]
        have hsum :
            (∑ i ∈ Finset.range (k + 1),
              c i *
                PowerSeries.coeff (R := ℝ) (k + 1 + 1)
                  (substLHSGen
                    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                    (2 + 1) Number.aperyConifoldZ1Poly 1
                    ((PowerSeries.X : PowerSeries ℝ) ^ i))) = 0 := by
          refine Finset.sum_eq_zero ?_
          intro i hi
          by_cases hi0 : i = 0
          · subst i
            rw [hconst_zero k, mul_zero]
          · have hi_pos : 1 ≤ i := by omega
            have hi_lt : i < k + 1 := by
              simpa only [Finset.mem_range] using hi
            have hci : c i = 0 := ih i hi_lt hi_pos
            rw [hci, zero_mul]
        change (-∑ i ∈ Finset.range (k + 1),
            c i *
              PowerSeries.coeff (R := ℝ) (k + 1 + 1)
                (substLHSGen
                  (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                  (2 + 1) Number.aperyConifoldZ1Poly 1
                  ((PowerSeries.X : PowerSeries ℝ) ^ i))) /
            (((-1 : ℝ) ^ 2) *
              simpleZeroIndicialPoly
                (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2)
                (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1))
                Number.aperyConifoldZ1Poly 2 (1 + ↑(k + 1))) = 0
        rw [hsum, neg_zero, zero_div]
  refine ⟨1, by omega, ?_⟩
  intro m hm
  have hm_pos : 1 ≤ m := hm
  have hm1_pos : 1 ≤ m + 1 := by omega
  rw [show frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly 1 1 (m + 1) = c (m + 1) from rfl,
    show frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly 1 1 m = c m from rfl,
    hzero (m + 1) hm1_pos, hzero m hm_pos]
  simp

/-- **Coefficient growth for ρ=1.** Same eigenvalue
structure as ρ=1/2: growth `O(m·z₁^{-m})`. Closed via
`growth_bound_of_ratio_bound_one` from `aperyFrobenius_one_ratio_bound`. -/
theorem aperyFrobenius_one_coeff_growth_bound :
    ∃ C : ℝ, 0 < C ∧ ∀ m : ℕ,
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 m| ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  obtain ⟨M₀, hM₀, hratio⟩ := aperyFrobenius_one_ratio_bound
  have hpos : 0 < (1 / Number.aperyConifoldZ1Poly) := by
    have := aperyConifoldZ1Poly_pos; positivity
  have habs : |1 / Number.aperyConifoldZ1Poly| = 1 / Number.aperyConifoldZ1Poly :=
    abs_of_pos hpos
  have hev_pos : 0 < |1 / Number.aperyConifoldZ1Poly| := by rw [habs]; exact hpos
  have hratio' : ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 (m + 1)| ≤
      |1 / Number.aperyConifoldZ1Poly| * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 1 1 m| := by
    intro m hm; rw [habs]; exact hratio m hm
  have h := Ripple.Frobenius.PoincaréPerron.growth_bound_of_ratio_bound_one
    (c := fun m => frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly 1 1 m)
    (ev₁ := 1 / Number.aperyConifoldZ1Poly) hev_pos hM₀ hratio'
  obtain ⟨C, hC_pos, hC⟩ := h
  refine ⟨C, hC_pos, fun m => ?_⟩
  have hC_m := hC m
  rw [habs] at hC_m
  exact hC_m

/-- **`frobeniusValue` for ρ=1 tends to 1 as `t → 0`.** -/
lemma aperyFrobenius_one_tendsto_at_zero :
    Filter.Tendsto
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 t)
      (nhds 0) (nhds 1) := by
  have h_eq : (1 : ℝ) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 0 :=
    (frobeniusValue_zero _ 2 _ 1 1).symm
  conv_rhs => rw [h_eq]
  obtain ⟨C, hC_pos, hbound⟩ := aperyFrobenius_one_coeff_growth_bound
  have hz1 := aperyConifoldZ1Poly_pos
  set δ := Number.aperyConifoldZ1Poly / 2
  have hδ_nn : 0 ≤ δ := le_of_lt (half_pos hz1)
  have hδ : δ < Number.aperyConifoldZ1Poly := half_lt_self hz1
  have hr : δ / Number.aperyConifoldZ1Poly < 1 := div_lt_one hz1 |>.mpr hδ
  have hr_nn : 0 ≤ δ / Number.aperyConifoldZ1Poly := div_nonneg hδ_nn hz1.le
  have hr_norm : ‖δ / Number.aperyConifoldZ1Poly‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr
  have h_pow : Summable (fun m : ℕ => (m : ℝ) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    refine h.congr (fun n => ?_); simp [pow_one]
  have h_geom : Summable (fun m : ℕ => (δ / Number.aperyConifoldZ1Poly) ^ m) :=
    summable_geometric_of_norm_lt_one hr_norm
  have h_sum : Summable (fun m : ℕ => C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m)) := by
    refine ((h_pow.add h_geom).mul_left C).congr (fun n => ?_)
    push_cast; ring
  have h_cont : ContinuousOn
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 t) (Set.Icc (-δ) δ) := by
    unfold frobeniusValue
    refine continuousOn_tsum
      (fun m => (continuous_const.mul (continuous_id.pow m)).continuousOn) h_sum
      (fun m t ht => ?_)
    have ht_abs : |t| ≤ δ := abs_le.mpr ⟨by linarith [ht.1], ht.2⟩
    have hz_ne : (Number.aperyConifoldZ1Poly : ℝ) ≠ 0 := hz1.ne'
    rw [Real.norm_eq_abs, abs_mul, abs_pow]
    calc |frobeniusCoeff _ 2 _ 1 1 m| * |t| ^ m
        ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * |t| ^ m :=
          mul_le_mul_of_nonneg_right (hbound m) (pow_nonneg (abs_nonneg _) _)
      _ ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * δ ^ m := by
          refine mul_le_mul_of_nonneg_left ?_ (by positivity)
          exact pow_le_pow_left₀ (abs_nonneg _) ht_abs m
      _ = C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
          have h_div_pow : (δ / Number.aperyConifoldZ1Poly) ^ m =
              δ ^ m / Number.aperyConifoldZ1Poly ^ m := div_pow _ _ _
          have h_one_div_pow : ((1 : ℝ) / Number.aperyConifoldZ1Poly) ^ m =
              1 / Number.aperyConifoldZ1Poly ^ m := by
            rw [div_pow, one_pow]
          rw [h_div_pow, h_one_div_pow]
          have hzpow : (Number.aperyConifoldZ1Poly : ℝ) ^ m ≠ 0 := pow_ne_zero _ hz_ne
          field_simp
  have h_neg_δ : -δ < 0 := by show -(Number.aperyConifoldZ1Poly / 2) < 0; linarith
  have h_pos_δ : (0 : ℝ) < δ := half_pos hz1
  exact h_cont.continuousAt (Icc_mem_nhds h_neg_δ h_pos_δ)

/-- **Apéry ρ=0 ratio bound.**

For the unit-seed ρ=0 Frobenius core, every positive-index coefficient
vanishes. The constant term has zero weight because `fallingFactorial 0 2`
and `fallingFactorial 0 3` vanish; all later terms vanish by induction.
Although the `m = 0` denominator is resonant, the numerator is already zero,
so the builder gives `c₁ = -0 / 0 = 0` in `ℝ`. -/
theorem aperyFrobenius_zero_ratio_bound :
    ∃ M₀ : ℕ, 1 ≤ M₀ ∧ ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 (m + 1)| ≤
      (1 / Number.aperyConifoldZ1Poly) * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 0 1 m| := by
  let c := frobeniusCoeff
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
    2 Number.aperyConifoldZ1Poly 0 1
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  have hconst_zero : ∀ k : ℕ,
      PowerSeries.coeff (R := ℝ) (k + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly 0
          ((PowerSeries.X : PowerSeries ℝ) ^ 0)) = 0 := by
    intro k
    rw [coeff_succ_substLHSGen_X_pow_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 (k + 1) 0 (by omega)]
    rw [show (2 + 2 : ℕ) = 4 from rfl]
    rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
        Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
    simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
      mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
    simp [fallingFactorial]
  have hzero : ∀ m : ℕ, 1 ≤ m → c m = 0 := by
    intro m hm
    induction m using Nat.strong_induction_on with
    | h m ih =>
      cases m with
      | zero => omega
      | succ k =>
        have h_rec := frobeniusCoeff_succ_linear_combination
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 0 1 k hP_zero
        change frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 0 1 (k + 1) = 0
        rw [h_rec]
        have hsum :
            (∑ i ∈ Finset.range (k + 1),
              c i *
                PowerSeries.coeff (R := ℝ) (k + 1 + 1)
                  (substLHSGen
                    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                    (2 + 1) Number.aperyConifoldZ1Poly 0
                    ((PowerSeries.X : PowerSeries ℝ) ^ i))) = 0 := by
          refine Finset.sum_eq_zero ?_
          intro i hi
          by_cases hi0 : i = 0
          · subst i
            rw [hconst_zero k, mul_zero]
          · have hi_pos : 1 ≤ i := by omega
            have hi_lt : i < k + 1 := by
              simpa only [Finset.mem_range] using hi
            have hci : c i = 0 := ih i hi_lt hi_pos
            rw [hci, zero_mul]
        change (-∑ i ∈ Finset.range (k + 1),
            c i *
              PowerSeries.coeff (R := ℝ) (k + 1 + 1)
                (substLHSGen
                  (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                  (2 + 1) Number.aperyConifoldZ1Poly 0
                  ((PowerSeries.X : PowerSeries ℝ) ^ i))) /
            (((-1 : ℝ) ^ 2) *
              simpleZeroIndicialPoly
                (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2)
                (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1))
                Number.aperyConifoldZ1Poly 2 (0 + ↑(k + 1))) = 0
        rw [hsum, neg_zero, zero_div]
  refine ⟨1, by omega, ?_⟩
  intro m hm
  have hm_pos : 1 ≤ m := hm
  have hm1_pos : 1 ≤ m + 1 := by omega
  rw [show frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly 0 1 (m + 1) = c (m + 1) from rfl,
    show frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly 0 1 m = c m from rfl,
    hzero (m + 1) hm1_pos, hzero m hm_pos]
  simp

/-- **Coefficient growth for ρ=0.** Closed via
`growth_bound_of_ratio_bound_one` from `aperyFrobenius_zero_ratio_bound`. -/
theorem aperyFrobenius_zero_coeff_growth_bound :
    ∃ C : ℝ, 0 < C ∧ ∀ m : ℕ,
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 m| ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  obtain ⟨M₀, hM₀, hratio⟩ := aperyFrobenius_zero_ratio_bound
  have hpos : 0 < (1 / Number.aperyConifoldZ1Poly) := by
    have := aperyConifoldZ1Poly_pos; positivity
  have habs : |1 / Number.aperyConifoldZ1Poly| = 1 / Number.aperyConifoldZ1Poly :=
    abs_of_pos hpos
  have hev_pos : 0 < |1 / Number.aperyConifoldZ1Poly| := by rw [habs]; exact hpos
  have hratio' : ∀ m, M₀ ≤ m →
      |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 (m + 1)| ≤
      |1 / Number.aperyConifoldZ1Poly| * (1 + 1 / (m : ℝ)) *
        |frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 0 1 m| := by
    intro m hm; rw [habs]; exact hratio m hm
  have h := Ripple.Frobenius.PoincaréPerron.growth_bound_of_ratio_bound_one
    (c := fun m => frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly 0 1 m)
    (ev₁ := 1 / Number.aperyConifoldZ1Poly) hev_pos hM₀ hratio'
  obtain ⟨C, hC_pos, hC⟩ := h
  refine ⟨C, hC_pos, fun m => ?_⟩
  have hC_m := hC m
  rw [habs] at hC_m
  exact hC_m

/-- **`frobeniusValue` for ρ=0 tends to 1 as `t → 0`.** -/
lemma aperyFrobenius_zero_tendsto_at_zero :
    Filter.Tendsto
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 t)
      (nhds 0) (nhds 1) := by
  have h_eq : (1 : ℝ) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 0 :=
    (frobeniusValue_zero _ 2 _ 0 1).symm
  conv_rhs => rw [h_eq]
  obtain ⟨C, hC_pos, hbound⟩ := aperyFrobenius_zero_coeff_growth_bound
  have hz1 := aperyConifoldZ1Poly_pos
  set δ := Number.aperyConifoldZ1Poly / 2
  have hδ_nn : 0 ≤ δ := le_of_lt (half_pos hz1)
  have hδ : δ < Number.aperyConifoldZ1Poly := half_lt_self hz1
  have hr : δ / Number.aperyConifoldZ1Poly < 1 := div_lt_one hz1 |>.mpr hδ
  have hr_nn : 0 ≤ δ / Number.aperyConifoldZ1Poly := div_nonneg hδ_nn hz1.le
  have hr_norm : ‖δ / Number.aperyConifoldZ1Poly‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr
  have h_pow : Summable (fun m : ℕ => (m : ℝ) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    refine h.congr (fun n => ?_); simp [pow_one]
  have h_geom : Summable (fun m : ℕ => (δ / Number.aperyConifoldZ1Poly) ^ m) :=
    summable_geometric_of_norm_lt_one hr_norm
  have h_sum : Summable (fun m : ℕ => C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m)) := by
    refine ((h_pow.add h_geom).mul_left C).congr (fun n => ?_)
    push_cast; ring
  have hz_ne : (Number.aperyConifoldZ1Poly : ℝ) ≠ 0 := hz1.ne'
  have h_cont : ContinuousOn
      (fun t => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 0 1 t) (Set.Icc (-δ) δ) := by
    unfold frobeniusValue
    refine continuousOn_tsum
      (fun m => (continuous_const.mul (continuous_id.pow m)).continuousOn) h_sum
      (fun m t ht => ?_)
    have ht_abs : |t| ≤ δ := abs_le.mpr ⟨by linarith [ht.1], ht.2⟩
    rw [Real.norm_eq_abs, abs_mul, abs_pow]
    calc |frobeniusCoeff _ 2 _ 0 1 m| * |t| ^ m
        ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * |t| ^ m :=
          mul_le_mul_of_nonneg_right (hbound m) (pow_nonneg (abs_nonneg _) _)
      _ ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m * δ ^ m := by
          refine mul_le_mul_of_nonneg_left ?_ (by positivity)
          exact pow_le_pow_left₀ (abs_nonneg _) ht_abs m
      _ = C * (((m : ℝ) + 1) * (δ / Number.aperyConifoldZ1Poly) ^ m) := by
          have h_div_pow : (δ / Number.aperyConifoldZ1Poly) ^ m =
              δ ^ m / Number.aperyConifoldZ1Poly ^ m := div_pow _ _ _
          have h_one_div_pow : ((1 : ℝ) / Number.aperyConifoldZ1Poly) ^ m =
              1 / Number.aperyConifoldZ1Poly ^ m := by rw [div_pow, one_pow]
          rw [h_div_pow, h_one_div_pow]
          have hzpow : (Number.aperyConifoldZ1Poly : ℝ) ^ m ≠ 0 := pow_ne_zero _ hz_ne
          field_simp
  have h_neg_δ : -δ < 0 := by show -(Number.aperyConifoldZ1Poly / 2) < 0; linarith
  have h_pos_δ : (0 : ℝ) < δ := half_pos hz1
  exact h_cont.continuousAt (Icc_mem_nhds h_neg_δ h_pos_δ)

/-- **`yAperyZero(1, -ε) → 1` as `ε → 0⁺`.** -/
lemma aperyZero_tendsto_one :
    Filter.Tendsto (fun ε => yAperyZero 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) := by
  unfold yAperyZero
  -- t := -ε. As ε → 0⁺, t → 0. Compose with frobeniusValue → 1.
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  exact aperyFrobenius_zero_tendsto_at_zero.comp h_neg

/-- **`yAperyHalf(1, -ε) → 0` as `ε → 0⁺`.** Product of `√ε → 0` and
bounded `frobeniusValue → 1`. -/
lemma aperyHalf_tendsto_zero :
    Filter.Tendsto (fun ε => yAperyHalf 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
  unfold yAperyHalf
  simp only [neg_neg]
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  have h_sqrt : Filter.Tendsto Real.sqrt (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have h : Filter.Tendsto Real.sqrt (nhds 0) (nhds (Real.sqrt 0)) :=
      Real.continuous_sqrt.tendsto 0
    rw [Real.sqrt_zero] at h
    exact h.mono_left nhdsWithin_le_nhds
  -- frobValue ... at -ε → 1 via comp with h_neg
  have h_frob : Filter.Tendsto
      (fun ε => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1/2) 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) :=
    aperyFrobenius_half_tendsto_at_zero.comp h_neg
  -- Goal: Tendsto (√ε · F(-ε)) → 0 = 0 · 1
  have h_mul : Filter.Tendsto
      (fun ε => Real.sqrt ε *
        frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly (1/2) 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (0 * 1)) := h_sqrt.mul h_frob
  rw [zero_mul] at h_mul
  exact h_mul

/-- **`yApery(1, -ε) → 0` as `ε → 0⁺`.** Product of `-ε → 0` and
bounded `frobeniusValue → 1`. -/
lemma aperyOne_tendsto_zero :
    Filter.Tendsto (fun ε => yApery 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
  unfold yApery
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  have h_frob : Filter.Tendsto
      (fun ε => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) :=
    aperyFrobenius_one_tendsto_at_zero.comp h_neg
  have h_mul : Filter.Tendsto
      (fun ε => -ε *
        frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 1 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (0 * 1)) := h_neg.mul h_frob
  rw [zero_mul] at h_mul
  exact h_mul

/-- **`yAperyHalf(1, -ε) / √ε → 1` as `ε → 0⁺`.** -/
lemma aperyHalf_div_sqrt_tendsto_one :
    Filter.Tendsto (fun ε => yAperyHalf 1 (-ε) / Real.sqrt ε)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) := by
  unfold yAperyHalf
  simp only [neg_neg]
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  -- yAperyHalf 1 (-ε) / √ε = √ε · frob(-ε) / √ε = frob(-ε)
  have h_frob : Filter.Tendsto
      (fun ε => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly (1/2) 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) :=
    aperyFrobenius_half_tendsto_at_zero.comp h_neg
  apply h_frob.congr'
  filter_upwards [self_mem_nhdsWithin] with ε hε
  rw [Set.mem_Ioi] at hε
  rw [mul_div_cancel_left₀ _ (Real.sqrt_pos.mpr hε).ne']

/-- **`yApery(1, -ε) / ε → -1` as `ε → 0⁺`.** -/
lemma aperyOne_div_eps_tendsto_neg_one :
    Filter.Tendsto (fun ε => yApery 1 (-ε) / ε)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (-1)) := by
  unfold yApery
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  -- yApery 1 (-ε) / ε = (-ε) · frob(-ε) / ε = -frob(-ε) → -1
  have h_frob_neg : Filter.Tendsto
      (fun ε => -frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (-1)) :=
    Filter.Tendsto.neg (aperyFrobenius_one_tendsto_at_zero.comp h_neg)
  apply h_frob_neg.congr'
  filter_upwards [self_mem_nhdsWithin] with ε hε
  rw [Set.mem_Ioi] at hε
  field_simp

/-- **`yApery(1, -ε) / √ε → 0` as `ε → 0⁺`.** Since `yApery → 0`
and the denominator `√ε → 0`, we need L'Hôpital-style: `yApery = O(ε)`
while `√ε = O(√ε)`, so the ratio is `O(√ε) → 0`. -/
lemma aperyOne_div_sqrt_tendsto_zero :
    Filter.Tendsto (fun ε => yApery 1 (-ε) / Real.sqrt ε)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
  unfold yApery
  have h_neg : Filter.Tendsto (fun ε : ℝ => -ε) (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have : Filter.Tendsto (fun ε : ℝ => -ε) (nhds 0) (nhds 0) := by
      simpa using (continuous_neg.tendsto (0 : ℝ))
    exact this.mono_left nhdsWithin_le_nhds
  have h_sqrt_neg : Filter.Tendsto (fun ε : ℝ => -Real.sqrt ε)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have h_sqrt : Filter.Tendsto Real.sqrt (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
      have h : Filter.Tendsto Real.sqrt (nhds 0) (nhds (Real.sqrt 0)) :=
        Real.continuous_sqrt.tendsto 0
      rw [Real.sqrt_zero] at h
      exact h.mono_left nhdsWithin_le_nhds
    have : Filter.Tendsto (fun ε : ℝ => -Real.sqrt ε)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds (-(0 : ℝ))) := h_sqrt.neg
    rwa [neg_zero] at this
  have h_frob : Filter.Tendsto
      (fun ε => frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly 1 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 1) :=
    aperyFrobenius_one_tendsto_at_zero.comp h_neg
  have h_target : Filter.Tendsto
      (fun ε => -Real.sqrt ε *
        frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          2 Number.aperyConifoldZ1Poly 1 1 (-ε))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (0 * 1)) := h_sqrt_neg.mul h_frob
  rw [zero_mul] at h_target
  apply h_target.congr'
  filter_upwards [self_mem_nhdsWithin] with ε hε
  rw [Set.mem_Ioi] at hε
  -- Show -√ε · frob(-ε) = -ε · frob(-ε) / √ε
  have hsq2 : Real.sqrt ε ^ 2 = ε := Real.sq_sqrt hε.le
  have hsqrt_ne : Real.sqrt ε ≠ 0 := (Real.sqrt_pos.mpr hε).ne'
  field_simp
  linear_combination
    -frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly 1 1 (-ε) * hsq2

/-! ### Gap E closure — Frobenius branches are linearly independent -/

/-- **The three Apéry Frobenius branches are linearly independent on `(0, z₁)`.
If `a₁·yAperyZero(1,-ε) + a₂·yAperyHalf(1,-ε) + a₃·yApery(1,-ε) = 0`
for all `ε ∈ (0, z₁)`, then `a₁ = a₂ = a₃ = 0`.

This is the instantiation of `frobenius_three_branch_linear_independence`
at the Apéry conifold with indicial exponents `{0, 1/2, 1}`.

**Reusable:** The proof strategy (distinct asymptotic rates ⇒ linear
independence via successive limit extraction) applies to ALL regular
singular points with non-integer-difference indicial exponents. -/
theorem aperyFrobenius_branches_linearly_independent
    {a₁ a₂ a₃ : ℝ}
    (h : ∀ ε ∈ Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly,
        a₁ * yAperyZero 1 (-ε) + a₂ * yAperyHalf 1 (-ε) + a₃ * yApery 1 (-ε) = 0) :
    a₁ = 0 ∧ a₂ = 0 ∧ a₃ = 0 :=
  frobenius_three_branch_linear_independence
    aperyConifoldZ1Poly_pos
    one_ne_zero one_ne_zero (neg_ne_zero.mpr one_ne_zero)
    aperyZero_tendsto_one
    aperyHalf_div_sqrt_tendsto_one
    aperyOne_div_eps_tendsto_neg_one
    aperyHalf_tendsto_zero
    aperyOne_tendsto_zero
    aperyOne_div_sqrt_tendsto_zero
    h

end Frobenius
end Ripple
