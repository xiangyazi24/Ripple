    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i)) :
    (d.extendCorridor_iUnion hε₁_d hε₂_d h0 hε₁ hε₂ hdet hJ).corridor =
      d.corridor ∪ ⋃ i, J i := rfl

/-- **Chain-extended half-branch probe invariance.** After patching with
an indexed family of overlapping Has-witnesses, the half-branch extract
is invariant under any pair of non-degenerate probes drawn from the
union — including pairs sourced entirely from the family side. -/
lemma AperyConnectionData.extractHalf_probe_invariant_on_iUnion_extended
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i))
    {η₁ η₂ η₁' η₂' : ℝ}
    (hη₁ : (-η₁) ∈ d.corridor ∪ ⋃ i, J i)
    (hη₂ : (-η₂) ∈ d.corridor ∪ ⋃ i, J i)
    (hη₁' : (-η₁') ∈ d.corridor ∪ ⋃ i, J i)
    (hη₂' : (-η₂') ∈ d.corridor ∪ ⋃ i, J i)
    (hdetη : aperyConnectionDet η₁ η₂ ≠ 0)
    (hdetη' : aperyConnectionDet η₁' η₂' ≠ 0) :
    d.extractHalf η₁ η₂ = d.extractHalf η₁' η₂' :=
  (d.extendCorridor_iUnion hε₁_d hε₂_d h0 hε₁ hε₂ hdet hJ).extractHalf_probe_invariant
    hη₁ hη₂ hη₁' hη₂' hdetη hdetη'

/-- **Chain-extended one-branch probe invariance.** -/
lemma AperyConnectionData.extractOne_probe_invariant_on_iUnion_extended
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i))
    {η₁ η₂ η₁' η₂' : ℝ}
    (hη₁ : (-η₁) ∈ d.corridor ∪ ⋃ i, J i)
    (hη₂ : (-η₂) ∈ d.corridor ∪ ⋃ i, J i)
    (hη₁' : (-η₁') ∈ d.corridor ∪ ⋃ i, J i)
    (hη₂' : (-η₂') ∈ d.corridor ∪ ⋃ i, J i)
    (hdetη : aperyConnectionDet η₁ η₂ ≠ 0)
    (hdetη' : aperyConnectionDet η₁' η₂' ≠ 0) :
    d.extractOne η₁ η₂ = d.extractOne η₁' η₂' :=
  (d.extendCorridor_iUnion hε₁_d hε₂_d h0 hε₁ hε₂ hdet hJ).extractOne_probe_invariant
    hη₁ hη₂ hη₁' hη₂' hdetη hdetη'

/-! ### Bridge to `AperyRegularDisk`

An `AperyAnalyticExtension` carries an analytic function `F` on the
corridor; when supplied with a regular center, radius, and local
coefficients, it induces an `AperyRegularDisk` reusing `F`. Two such
induced disks (sharing the same `ext`) are automatically `Compatible`
because they share the underlying analytic function. -/

/-- **Induced regular disk from an analytic extension.** Reuse `ext.F`
as the disk's analytic function; the user supplies a local center,
radius, and coefficient sequence together with the `HasSum` identity. -/
def AperyAnalyticExtension.toRegularDisk
    (ext : AperyAnalyticExtension)
    (center : ℝ) (radius : ℝ) (radius_pos : 0 < radius)
    (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    AperyRegularDisk where
  center := center
  radius := radius
  radius_pos := radius_pos
  F := ext.F
  coeffs := coeffs
  has_sum_in_disk := has_sum

@[simp] lemma AperyAnalyticExtension.toRegularDisk_F
    (ext : AperyAnalyticExtension) (center radius : ℝ) (hr : 0 < radius)
    (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDisk center radius hr coeffs hs).F = ext.F := rfl

@[simp] lemma AperyAnalyticExtension.toRegularDisk_center
    (ext : AperyAnalyticExtension) (center radius : ℝ) (hr : 0 < radius)
    (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDisk center radius hr coeffs hs).center = center := rfl

@[simp] lemma AperyAnalyticExtension.toRegularDisk_radius
    (ext : AperyAnalyticExtension) (center radius : ℝ) (hr : 0 < radius)
    (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDisk center radius hr coeffs hs).radius = radius := rfl

@[simp] lemma AperyAnalyticExtension.toRegularDisk_coeffs
    (ext : AperyAnalyticExtension) (center radius : ℝ) (hr : 0 < radius)
    (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDisk center radius hr coeffs hs).coeffs = coeffs := rfl

/-- **Two induced disks from the same `ext` are compatible.** They share
`ext.F` as their analytic function, so `Compatible.of_F_eq` applies. -/
lemma AperyAnalyticExtension.toRegularDisk_compatible
    (ext : AperyAnalyticExtension)
    {c₁ r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (ext.F (c₁ + t)))
    {c₂ r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (ext.F (c₂ + t))) :
    AperyRegularDisk.Compatible
      (ext.toRegularDisk c₁ r₁ hr₁ coeffs₁ hs₁)
      (ext.toRegularDisk c₂ r₂ hr₂ coeffs₂ hs₂) :=
  AperyRegularDisk.Compatible.of_F_eq rfl

/-! ### Chains of induced disks

When every disk in a sequence comes from the same `ext`, adjacent
compatibility is automatic. The chain F-equality then follows from
`AperyRegularDisk.Compatible.F_eq_chain`. This is the chaining
infrastructure for transferring values across multiple regular-point
disks all sharing the same underlying analytic function. -/

/-- **All-the-same-`ext` disk family is pairwise compatible.** -/
lemma AperyAnalyticExtension.toRegularDisk_pairwise_compatible
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDisk)
    (h_ext : ∀ i, (ds i).F = ext.F) (i j : ℕ) :
    AperyRegularDisk.Compatible (ds i) (ds j) :=
  AperyRegularDisk.Compatible.of_F_eq (by rw [h_ext i, h_ext j])

/-- **Chain F-equality for an all-the-same-`ext` family.** Any two
disks in a sequence whose underlying functions are all `ext.F` agree
on every point lying in the open domain of every disk along the
sequence. -/
lemma AperyAnalyticExtension.toRegularDisk_F_eq_chain
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDisk) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    {z : ℝ} (hz : ∀ i, i ≤ n → z ∈ (ds i).diskOpen) :
    (ds 0).F z = (ds n).F z :=
  AperyRegularDisk.Compatible.F_eq_chain ds n
    (fun i _ => ext.toRegularDisk_pairwise_compatible ds h_ext i (i + 1)) hz

/-- **Endpoint values both equal `ext.F z`.** Specialization recording
that the chain F-equality is really an equality with `ext.F` itself,
since every disk in the family carries `ext.F` as its analytic
function. -/
lemma AperyAnalyticExtension.toRegularDisk_F_eq_ext
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDisk)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) (z : ℝ) :
    (ds n).F z = ext.F z := by
  rw [h_ext n]

/-! ### Bridge to `AperyRegularDiskAt`

Lift the `toRegularDisk` constructor through the regular-point subtype:
given a regular center, the induced `AperyRegularDisk` packages with
the regularity proof to form an `AperyRegularDiskAt`. Two such induced
`AperyRegularDiskAt`s sharing the same `ext` are automatically
compatible. -/

/-- **Induced regular-center disk from an analytic extension.** -/
def AperyAnalyticExtension.toRegularDiskAt
    (ext : AperyAnalyticExtension)
    (center : ℝ) (h_reg : AperyConifoldRegularPoint center)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    AperyRegularDiskAt where
  toAperyRegularDisk := ext.toRegularDisk center radius radius_pos coeffs has_sum
  regular := h_reg

@[simp] lemma AperyAnalyticExtension.toRegularDiskAt_F
    (ext : AperyAnalyticExtension) (center : ℝ)
    (h_reg : AperyConifoldRegularPoint center)
    (radius : ℝ) (hr : 0 < radius) (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDiskAt center h_reg radius hr coeffs hs).F = ext.F := rfl

@[simp] lemma AperyAnalyticExtension.toRegularDiskAt_diskOpen
    (ext : AperyAnalyticExtension) (center : ℝ)
    (h_reg : AperyConifoldRegularPoint center)
    (radius : ℝ) (hr : 0 < radius) (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (ext.F (center + t))) :
    (ext.toRegularDiskAt center h_reg radius hr coeffs hs).diskOpen =
      (ext.toRegularDisk center radius hr coeffs hs).diskOpen := rfl

/-- **Two induced regular-center disks from the same `ext` are
compatible.** -/
lemma AperyAnalyticExtension.toRegularDiskAt_compatible
    (ext : AperyAnalyticExtension)
    {c₁ : ℝ} (h_reg₁ : AperyConifoldRegularPoint c₁)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (ext.F (c₁ + t)))
    {c₂ : ℝ} (h_reg₂ : AperyConifoldRegularPoint c₂)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (ext.F (c₂ + t))) :
    AperyRegularDiskAt.Compatible
      (ext.toRegularDiskAt c₁ h_reg₁ r₁ hr₁ coeffs₁ hs₁)
      (ext.toRegularDiskAt c₂ h_reg₂ r₂ hr₂ coeffs₂ hs₂) :=
  ext.toRegularDisk_compatible hr₁ coeffs₁ hs₁ hr₂ coeffs₂ hs₂

/-! ### Chains of `AperyRegularDiskAt` from a common `ext`

When every disk in an `AperyRegularDiskAt` family has the form
`ext.toRegularDiskAt …`, adjacent compatibility is automatic and the
chain F-equality drops to a one-line invocation of
`AperyRegularDiskAt.Compatible.F_eq_chain`. -/

/-- **All-the-same-`ext` `At`-family is pairwise compatible.** -/
lemma AperyAnalyticExtension.toRegularDiskAt_pairwise_compatible
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (i j : ℕ) :
    AperyRegularDiskAt.Compatible (ds i) (ds j) := by
  have hi : (ds i).toAperyRegularDisk.F = ext.F := h_ext i
  have hj : (ds j).toAperyRegularDisk.F = ext.F := h_ext j
  exact AperyRegularDisk.Compatible.of_F_eq (hi.trans hj.symm)

/-- **Chain F-equality for an all-the-same-`ext` `At`-family.** -/
lemma AperyAnalyticExtension.toRegularDiskAt_F_eq_chain
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    {z : ℝ} (hz : ∀ i, i ≤ n → z ∈ (ds i).diskOpen) :
    (ds 0).F z = (ds n).F z :=
  AperyRegularDiskAt.Compatible.F_eq_chain ds n
    (fun i _ => ext.toRegularDiskAt_pairwise_compatible ds h_ext i (i + 1)) hz

/-- **Endpoint values both equal `ext.F z`** (`At`-family version). -/
lemma AperyAnalyticExtension.toRegularDiskAt_F_eq_ext
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) (z : ℝ) :
    (ds n).F z = ext.F z := by
  rw [h_ext n]

/-! ### Value transfer along an `At`-chain anchored at `ext`

The chain transports any known value of `ext.F` (say at the corridor
endpoint, where `IsAperyConnectionCoeffsOn` machinery has already
identified the value) to any other disk in the family — and
conversely, a value identified at any disk along the chain comes
back as a value of `ext.F`. -/

/-- **Forward value transfer.** A value of `ext.F` propagates to every
disk in an all-the-same-`ext` `At`-family. -/
lemma AperyAnalyticExtension.toRegularDiskAt_value_forward
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) {z : ℝ} {v : ℝ}
    (hv : ext.F z = v) :
    (ds n).F z = v := by
  rw [h_ext n, hv]

/-- **Backward value transfer.** A value identified along the chain
comes back as a value of `ext.F`. -/
lemma AperyAnalyticExtension.toRegularDiskAt_value_backward
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) {z : ℝ} {v : ℝ}
    (hv : (ds n).F z = v) :
    ext.F z = v := by
  rw [← h_ext n, hv]

/-- **Endpoint match against any external function.** If an external
function `g` agrees with the chain's endpoint disk at `z`, then `g z`
equals `ext.F z`. -/
lemma AperyAnalyticExtension.toRegularDiskAt_match_external
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt)
    (h_ext : ∀ i, (ds i).F = ext.F) (n : ℕ) {z : ℝ} {g : ℝ → ℝ}
    (hg : (ds n).F z = g z) :
    ext.F z = g z :=
  ext.toRegularDiskAt_value_backward ds h_ext n hg

/-! ### GFA-side `AperyRegularDisk` instance at the origin

`aperyGFAReal` admits a `HasSum` representation
`∑ n, aperyA n · z^n = aperyGFAReal z` on `|z| < 1/64`. Packaging this
as an `AperyRegularDisk` centered at `0` with radius `1/64` connects
the GFA tsum machinery to the regular-disk infrastructure.

(Note: `0` is *not* a regular point of the conifold ODE — it is a
singular point where the leading polynomial has a double zero — so
this disk lives only at the geometric level, not as an
`AperyRegularDiskAt`.) -/

/-- **`HasSum` form of `aperyGFAReal` on `|z| < 1/64`.** -/
lemma aperyGFAReal_hasSum {z : ℝ} (hz : |z| < 1 / 64) :
    HasSum (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) (aperyGFAReal z) :=
  (aperyGFAReal_summable hz).hasSum

/-- **GFA-side regular disk at the origin.** Center `0`, radius `1/64`,
analytic function `aperyGFAReal`, coefficients `aperyA n`. -/
noncomputable def aperyGFARegularDisk : AperyRegularDisk where
  center := 0
  radius := 1 / 64
  radius_pos := by norm_num
  F := aperyGFAReal
  coeffs := fun n => (Number.aperyA n : ℝ)
  has_sum_in_disk := fun t ht => by
    have hsum := aperyGFAReal_hasSum (z := t) ht
    simpa [zero_add] using hsum

@[simp] lemma aperyGFARegularDisk_F : aperyGFARegularDisk.F = aperyGFAReal := rfl

@[simp] lemma aperyGFARegularDisk_center : aperyGFARegularDisk.center = 0 := rfl

@[simp] lemma aperyGFARegularDisk_radius : aperyGFARegularDisk.radius = 1 / 64 := rfl

@[simp] lemma aperyGFARegularDisk_coeffs (n : ℕ) :
    aperyGFARegularDisk.coeffs n = (Number.aperyA n : ℝ) := rfl

/-- **GFA disk's `diskOpen` is `|z| < 1/64`.** -/
@[simp] lemma aperyGFARegularDisk_mem_diskOpen (z : ℝ) :
    z ∈ aperyGFARegularDisk.diskOpen ↔ |z| < 1 / 64 := by
  simp [AperyRegularDisk.diskOpen, aperyGFARegularDisk]

/-! ### Cross-layer chain: GFA disk → `At`-chain → `ext`

The geometric GFA disk and the regular-center `At`-chain live at
different layers, but `AperyRegularDiskAt.Compatible` is defined as
compatibility of underlying `AperyRegularDisk`s, so they cross-link
cleanly via `AperyRegularDisk.Compatible`. -/

/-- **Cross-layer F-equality at a common point.** If the GFA disk is
compatible (in the underlying-disk sense) with the first `At`-disk in
a chain, and `z` belongs to the GFA disk and every chain disk, then
`aperyGFAReal z = (ds n).F z` for the last chain disk. -/
lemma aperyGFA_to_chain_endpoint
    (ds : ℕ → AperyRegularDiskAt) (n : ℕ)
    (hcompGFA : AperyRegularDisk.Compatible aperyGFARegularDisk
      (ds 0).toAperyRegularDisk)
    (hcomp : ∀ i, i < n → AperyRegularDiskAt.Compatible (ds i) (ds (i + 1)))
    {z : ℝ} (hzGFA : |z| < 1 / 64)
    (hz : ∀ i, i ≤ n → z ∈ (ds i).diskOpen) :
    aperyGFAReal z = (ds n).F z := by
  have hzGFAmem : z ∈ aperyGFARegularDisk.diskOpen := by
    rw [aperyGFARegularDisk_mem_diskOpen]; exact hzGFA
  have hz0 : z ∈ (ds 0).diskOpen := hz 0 (Nat.zero_le _)
  have h0 : aperyGFAReal z = (ds 0).F z := by
    have := hcompGFA z hzGFAmem hz0
    simpa using this
  have hchain := AperyRegularDiskAt.Compatible.F_eq_chain ds n hcomp hz
  exact h0.trans hchain

/-- **Capstone: GFA value via chain to `ext`.** Combine
`aperyGFA_to_chain_endpoint` with `toRegularDiskAt_F_eq_ext` to land
the GFA value as `ext.F z` directly. -/
lemma aperyGFA_value_via_chain_to_ext
    (ext : AperyAnalyticExtension) (ds : ℕ → AperyRegularDiskAt) (n : ℕ)
    (h_ext : ∀ i, (ds i).F = ext.F)
    (hcompGFA : AperyRegularDisk.Compatible aperyGFARegularDisk
      (ds 0).toAperyRegularDisk)
    {z : ℝ} (hzGFA : |z| < 1 / 64)
    (hz : ∀ i, i ≤ n → z ∈ (ds i).diskOpen) :
    aperyGFAReal z = ext.F z := by
  have hcomp : ∀ i, i < n → AperyRegularDiskAt.Compatible (ds i) (ds (i + 1)) :=
    fun i _ => ext.toRegularDiskAt_pairwise_compatible ds h_ext i (i + 1)
  have hchain :=
    aperyGFA_to_chain_endpoint ds n hcompGFA hcomp hzGFA hz
  rw [hchain]
  exact ext.toRegularDiskAt_F_eq_ext ds h_ext n z

/-! ### GFA-interior `AperyRegularDiskAt`

A natural "bridge node" centered at any `z₀ ∈ (0, 1/64)`. Reuses
`aperyGFAReal` as the analytic function (matching `aperyGFARegularDisk`),
so compatibility with the GFA disk is automatic via `of_F_eq`. The
regularity proof is discharged from
`aperyConifoldRegularPoint_of_GFA_interval`. -/

/-- **At-disk at a GFA interior point sharing `aperyGFAReal`.** -/
noncomputable def aperyGFAInteriorRegularDiskAt
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))) :
    AperyRegularDiskAt where
  toAperyRegularDisk :=
    { center := center
      radius := radius
      radius_pos := radius_pos
      F := aperyGFAReal
      coeffs := coeffs
      has_sum_in_disk := has_sum }
  regular := aperyConifoldRegularPoint_of_GFA_interval h_pos h_lt

@[simp] lemma aperyGFAInteriorRegularDiskAt_F
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))) :
    (aperyGFAInteriorRegularDiskAt center h_pos h_lt radius radius_pos
      coeffs has_sum).F = aperyGFAReal := rfl

@[simp] lemma aperyGFAInteriorRegularDiskAt_center
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))) :
    (aperyGFAInteriorRegularDiskAt center h_pos h_lt radius radius_pos
      coeffs has_sum).toAperyRegularDisk.center = center := rfl

@[simp] lemma aperyGFAInteriorRegularDiskAt_radius
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))) :
    (aperyGFAInteriorRegularDiskAt center h_pos h_lt radius radius_pos
      coeffs has_sum).toAperyRegularDisk.radius = radius := rfl

/-- **GFA-interior At-disk is automatically compatible with the GFA
disk.** Both share `aperyGFAReal` as their analytic function. -/
lemma aperyGFAInteriorRegularDiskAt_compatible_with_GFA
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t))) :
    AperyRegularDisk.Compatible aperyGFARegularDisk
      (aperyGFAInteriorRegularDiskAt center h_pos h_lt radius radius_pos
        coeffs has_sum).toAperyRegularDisk :=
  AperyRegularDisk.Compatible.of_F_eq rfl

/-! #### Analytic-At version of the GFA-interior disk

Symmetric to `toAnalyticDiskAt` (which packages an `ext`-anchored
analytic-At disk): build an `AperyAnalyticDiskAt` whose `F = aperyGFAReal`
at any GFA-interior center, given a summability witness on the local
coefficients. Lets gap-B chains start from a GFA-side analytic-At entry
in symmetry with the ext-side entry. -/

/-- **Analytic-At disk at a GFA interior point sharing `aperyGFAReal`.**
Composes `aperyGFAInteriorRegularDiskAt` with
`AperyAnalyticDiskAt.ofSummable`. -/
noncomputable def aperyGFAInteriorAnalyticDiskAt
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (radius_pos : 0 < radius) (coeffs : ℕ → ℝ)
    (has_sum : ∀ t : ℝ, |t| < radius →
      HasSum (fun n => coeffs n * t ^ n) (aperyGFAReal (center + t)))
    (hSum : ∀ r' : NNReal, (r' : ℝ) < radius →
      Summable (fun n : ℕ => |coeffs n| * (r' : ℝ) ^ n)) :
    AperyAnalyticDiskAt :=
  AperyAnalyticDiskAt.ofSummable
    (aperyGFAInteriorRegularDiskAt center h_pos h_lt radius radius_pos
      coeffs has_sum) hSum

@[simp] lemma aperyGFAInteriorAnalyticDiskAt_F
    (center : ℝ) (h_pos : 0 < center) (h_lt : center < 1 / 64)
    (radius : ℝ) (hr : 0 < radius) (coeffs : ℕ → ℝ)
    (hs : ∀ t : ℝ, |t| < radius →
