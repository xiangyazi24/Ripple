/-! ### Generic monotonicity utilities for `AperyAnalyticExtension`

These work for *any* extension, independent of how it was built (chain
route, Frobenius local data, identity-theorem continuation, etc.). The
two underlying invariants are `agrees_on_small` (matching `aperyGFAReal`
on `Ico 0 (1/64)`) and `continuousOn_corridor` (continuity on
`Ico 0 aperyConifoldZ1Poly`). Everything below specializes those by
subsetting. -/

/-- **Subset agreement on the small interval.** Any extension agrees
with `aperyGFAReal` on any subset of `Ico 0 (1/64)`. -/
lemma AperyAnalyticExtension.agrees_on_subset_small
    (ext : AperyAnalyticExtension) {S : Set ℝ}
    (hS : S ⊆ Set.Ico (0 : ℝ) (1 / 64)) :
    Set.EqOn ext.F aperyGFAReal S :=
  ext.agrees_on_small.mono hS

/-- **Continuity on a subset of the corridor.** -/
lemma AperyAnalyticExtension.continuousOn_subset_corridor
    (ext : AperyAnalyticExtension) {S : Set ℝ}
    (hS : S ⊆ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    ContinuousOn ext.F S :=
  ext.continuousOn_corridor.mono hS

/-- **Continuity on `Icc [0, a]` for `a < aperyConifoldZ1Poly`.** -/
lemma AperyAnalyticExtension.continuousOn_Icc_safe
    (ext : AperyAnalyticExtension) {a : ℝ}
    (ha_lt : a < Number.aperyConifoldZ1Poly) :
    ContinuousOn ext.F (Set.Icc (0 : ℝ) a) := by
  refine ext.continuousOn_subset_corridor ?_
  intro z hz
  exact ⟨hz.1, lt_of_le_of_lt hz.2 ha_lt⟩

/-- **Agreement on `Icc [0, a]` for `a < 1/64`.** Inside the small
interval, the extension matches `aperyGFAReal` on the closed
sub-interval too. -/
lemma AperyAnalyticExtension.agrees_on_Icc_small
    (ext : AperyAnalyticExtension) {a : ℝ} (ha_lt : a < 1 / 64) :
    Set.EqOn ext.F aperyGFAReal (Set.Icc (0 : ℝ) a) := by
  refine ext.agrees_on_subset_small ?_
  intro z hz
  exact ⟨hz.1, lt_of_le_of_lt hz.2 ha_lt⟩

/-- **Continuity on `Icc [0, a]` for `a < 1/64`.** -/
lemma AperyAnalyticExtension.continuousOn_Icc_small
    (ext : AperyAnalyticExtension) {a : ℝ} (ha_lt : a < 1 / 64) :
    ContinuousOn ext.F (Set.Icc (0 : ℝ) a) :=
  ext.continuousOn_Icc_safe
    (lt_trans ha_lt aperyConifoldZ1Poly_gt_one_div_64)

/-- **Left endpoint evaluation: `ext.F 0 = aperyGFAReal 0`.** Holds for
*any* `AperyAnalyticExtension`, since `0 ∈ Ico 0 (1/64)`. -/
lemma AperyAnalyticExtension.F_at_zero
    (ext : AperyAnalyticExtension) :
    ext.F 0 = aperyGFAReal 0 := by
  exact ext.agrees_on_small ⟨le_refl 0, by norm_num⟩

/-- **Pointwise continuity inside the corridor.** Restated form of
`continuousOn_corridor` at a single corridor point. -/
lemma AperyAnalyticExtension.continuousWithinAt_corridor
    (ext : AperyAnalyticExtension) {z : ℝ}
    (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    ContinuousWithinAt ext.F (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) z :=
  ext.continuousOn_corridor z hz

/-- **`Ico 0 (1/64) ⊆ Ico 0 aperyConifoldZ1Poly`.** Convenience subset
relating the small interval to the corridor. -/
lemma AperyAnalyticExtension.Ico_one_div_64_subset_corridor :
    Set.Ico (0 : ℝ) (1 / 64) ⊆
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly := by
  intro z hz
  exact ⟨hz.1, lt_trans hz.2 aperyConifoldZ1Poly_gt_one_div_64⟩

/-- **Pointwise continuity inside the small interval.** Specialization
of corridor continuity to `Ico 0 (1/64)`. -/
lemma AperyAnalyticExtension.continuousWithinAt_small
    (ext : AperyAnalyticExtension) {z : ℝ}
    (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ContinuousWithinAt ext.F (Set.Ico (0 : ℝ) (1 / 64)) z := by
  have hzc : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor hz
  exact (ext.continuousWithinAt_corridor hzc).mono
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor

/-- **Right-continuity at the origin within the corridor.** Direct
specialization at `z = 0`; useful for connecting `aperyGFAReal 0` to
the extension via tendsto-style reasoning. -/
lemma AperyAnalyticExtension.continuousWithinAt_zero_corridor
    (ext : AperyAnalyticExtension) :
    ContinuousWithinAt ext.F (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) 0 := by
  have h_z1_pos : (0 : ℝ) < Number.aperyConifoldZ1Poly :=
    lt_trans (by norm_num : (0 : ℝ) < 1 / 64) aperyConifoldZ1Poly_gt_one_div_64
  exact ext.continuousWithinAt_corridor ⟨le_refl 0, h_z1_pos⟩

/-- **Right-continuity at the origin within the small interval.** -/
lemma AperyAnalyticExtension.continuousWithinAt_zero_small
    (ext : AperyAnalyticExtension) :
    ContinuousWithinAt ext.F (Set.Ico (0 : ℝ) (1 / 64)) 0 :=
  ext.continuousWithinAt_small ⟨le_refl 0, by norm_num⟩

/-- **Continuity bridge through `agrees_on_small` (forward direction).**
On any subset of the small interval, the extension's `F` continuity
transfers to `aperyGFAReal` continuity. -/
lemma AperyAnalyticExtension.aperyGFAReal_continuousOn_of_F
    (ext : AperyAnalyticExtension) {S : Set ℝ}
    (hS : S ⊆ Set.Ico (0 : ℝ) (1 / 64))
    (hF : ContinuousOn ext.F S) :
    ContinuousOn aperyGFAReal S :=
  hF.congr (fun z hz => (ext.agrees_on_small (hS hz)).symm)

/-- **Continuity bridge through `agrees_on_small` (backward direction).**
On any subset of the small interval, `aperyGFAReal` continuity
transfers to the extension's `F`. -/
lemma AperyAnalyticExtension.F_continuousOn_of_aperyGFAReal
    (ext : AperyAnalyticExtension) {S : Set ℝ}
    (hS : S ⊆ Set.Ico (0 : ℝ) (1 / 64))
    (hG : ContinuousOn aperyGFAReal S) :
    ContinuousOn ext.F S :=
  hG.congr (fun z hz => ext.agrees_on_small (hS hz))

/-- **Continuity equivalence on the small interval.** Through the
`agrees_on_small` field, `ext.F` and `aperyGFAReal` are
continuity-equivalent on every subset of `Ico 0 (1/64)`. -/
lemma AperyAnalyticExtension.continuousOn_iff_aperyGFAReal
    (ext : AperyAnalyticExtension) {S : Set ℝ}
    (hS : S ⊆ Set.Ico (0 : ℝ) (1 / 64)) :
    ContinuousOn ext.F S ↔ ContinuousOn aperyGFAReal S :=
  ⟨ext.aperyGFAReal_continuousOn_of_F hS,
    ext.F_continuousOn_of_aperyGFAReal hS⟩

/-! ### Tendsto-form right-limits at the origin -/

/-- **Right-limit at 0 within the corridor.** Continuity within the
corridor at 0 unpacks to a `Tendsto` statement targeting
`aperyGFAReal 0` (= `ext.F 0`). -/
lemma AperyAnalyticExtension.tendsto_zero_corridor
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto ext.F
      (nhdsWithin 0 (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (aperyGFAReal 0)) := by
  have h := ext.continuousWithinAt_zero_corridor
  rw [ContinuousWithinAt, ext.F_at_zero] at h
  exact h

/-- **Right-limit at 0 within the small interval.** -/
lemma AperyAnalyticExtension.tendsto_zero_small
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto ext.F
      (nhdsWithin 0 (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal 0)) := by
  have h := ext.continuousWithinAt_zero_small
  rw [ContinuousWithinAt, ext.F_at_zero] at h
  exact h

/-- **Right-limit at 0 to the explicit value `1`.** Combines
`tendsto_zero_corridor` with `aperyGFAReal_zero` to drop in the
explicit endpoint value. -/
lemma AperyAnalyticExtension.tendsto_zero_corridor_one
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto ext.F
      (nhdsWithin 0 (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (1 : ℝ)) := by
  have h := ext.tendsto_zero_corridor
  rwa [aperyGFAReal_zero] at h

/-- **`aperyGFAReal` itself has the same right-limit at 0 within the
corridor.** Through the small-interval agreement and the existence of
the extension's continuity, `aperyGFAReal` inherits the right-limit
behavior from `ext.F` on the small subset (and beyond by congruence). -/
lemma AperyAnalyticExtension.tendsto_zero_aperyGFAReal_small
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin 0 (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal 0)) := by
  have h := ext.tendsto_zero_small
  refine h.congr' ?_
  rw [Filter.EventuallyEq, eventually_nhdsWithin_iff]
  refine Filter.Eventually.of_forall ?_
  intro z hz
  exact ext.agrees_on_small hz

/-- **Tendsto at any corridor point.** Generic right-limit at any
`z₀ ∈ Ico 0 aperyConifoldZ1Poly`: `ext.F z` approaches `ext.F z₀` as
`z → z₀` along the corridor. -/
lemma AperyAnalyticExtension.tendsto_at_corridor
    (ext : AperyAnalyticExtension) {z₀ : ℝ}
    (hz₀ : z₀ ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    Filter.Tendsto ext.F
      (nhdsWithin z₀ (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (ext.F z₀)) :=
  ext.continuousWithinAt_corridor hz₀

/-- **Tendsto at any small-interval point with explicit GFA target.**
For `z₀ ∈ Ico 0 (1/64)`, the right-limit lands at `aperyGFAReal z₀`. -/
lemma AperyAnalyticExtension.tendsto_at_small_aperyGFAReal
    (ext : AperyAnalyticExtension) {z₀ : ℝ}
    (hz₀ : z₀ ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    Filter.Tendsto ext.F
      (nhdsWithin z₀ (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal z₀)) := by
  have h := ext.continuousWithinAt_small hz₀
  rw [ContinuousWithinAt, ext.agrees_on_small hz₀] at h
  exact h

/-- **`aperyGFAReal` Tendsto at any small-interval point.** Through the
extension's small-agreement and continuity, `aperyGFAReal` itself has
the matching right-limit. -/
lemma AperyAnalyticExtension.tendsto_at_small_aperyGFAReal_self
    (ext : AperyAnalyticExtension) {z₀ : ℝ}
    (hz₀ : z₀ ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin z₀ (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal z₀)) := by
  refine (ext.tendsto_at_small_aperyGFAReal hz₀).congr' ?_
  rw [Filter.EventuallyEq, eventually_nhdsWithin_iff]
  refine Filter.Eventually.of_forall ?_
  intro z hz
  exact ext.agrees_on_small hz

/-! ### Corridor-but-not-small region (`[1/64, aperyConifoldZ1Poly)`)

Past the small radius, `ext.F` is no longer constrained to equal
`aperyGFAReal` (since `aperyGFAReal` itself is the formal-power-series
sum, which only converges on `|z| < 1/64`). Only the
`continuousOn_corridor` field carries: `ext.F` remains continuous and
has well-defined right-limits at every point in this stretch. -/

/-- **The "outside-small" half-corridor sits inside the corridor.** -/
lemma AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor :
    Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly ⊆
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly := by
  intro z hz
  exact ⟨le_trans (by norm_num : (0 : ℝ) ≤ 1 / 64) hz.1, hz.2⟩

/-- **Pointwise continuity inside the outside-small region.**
At any `z₀ ∈ Ico (1/64) aperyConifoldZ1Poly`, the extension's `F` is
continuous within the corridor. -/
lemma AperyAnalyticExtension.continuousWithinAt_outside_small
    (ext : AperyAnalyticExtension) {z₀ : ℝ}
    (hz₀ : z₀ ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) :
    ContinuousWithinAt ext.F (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) z₀ :=
  ext.continuousWithinAt_corridor
    (AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor hz₀)

/-- **Right-limit at any outside-small point.** -/
lemma AperyAnalyticExtension.tendsto_at_outside_small
    (ext : AperyAnalyticExtension) {z₀ : ℝ}
    (hz₀ : z₀ ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) :
    Filter.Tendsto ext.F
      (nhdsWithin z₀ (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (ext.F z₀)) :=
  ext.continuousWithinAt_outside_small hz₀

/-- **Continuity restricted to the outside-small half-corridor.** -/
lemma AperyAnalyticExtension.continuousOn_outside_small
    (ext : AperyAnalyticExtension) :
    ContinuousOn ext.F
      (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) :=
  ext.continuousOn_corridor.mono
    AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor

/-! ### Corridor segmentation

The corridor `[0, aperyConifoldZ1Poly)` decomposes into the
small-radius interval `[0, 1/64)` and the outside-small stretch
`[1/64, aperyConifoldZ1Poly)`. The lemmas below give a clean
case-analysis entry point for downstream proofs that need to behave
differently on each side of the GFA radius. -/

/-- **Corridor decomposes into small ∪ outside-small.** -/
lemma corridor_eq_small_union_outside :
    Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly =
      Set.Ico (0 : ℝ) (1 / 64) ∪
        Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly := by
  ext z
  refine ⟨fun hz => ?_, fun hz => ?_⟩
  · rcases lt_or_ge z (1 / 64) with hlt | hge
    · exact Or.inl ⟨hz.1, hlt⟩
    · exact Or.inr ⟨hge, hz.2⟩
  · rcases hz with hsmall | houtside
    · exact ⟨hsmall.1, lt_trans hsmall.2 aperyConifoldZ1Poly_gt_one_div_64⟩
    · exact ⟨le_trans (by norm_num : (0 : ℝ) ≤ 1 / 64) houtside.1, houtside.2⟩

/-- **Corridor membership dichotomy.** Every corridor point lies in
either the small interval or the outside-small stretch. -/
lemma mem_corridor_dichotomy {z : ℝ}
    (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    z ∈ Set.Ico (0 : ℝ) (1 / 64) ∨
      z ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly := by
  rcases lt_or_ge z (1 / 64) with hlt | hge
  · exact Or.inl ⟨hz.1, hlt⟩
  · exact Or.inr ⟨hge, hz.2⟩

/-- **Small interval embeds into corridor.** -/
lemma mem_corridor_of_small {z : ℝ}
    (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
  AperyAnalyticExtension.Ico_one_div_64_subset_corridor hz

/-- **Outside-small stretch embeds into corridor.** -/
lemma mem_corridor_of_outside_small {z : ℝ}
    (hz : z ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) :
    z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
  AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor hz

/-- **Case-analysis combinator for `ext.F` on the corridor.** Given
target predicates on the small interval and the outside-small stretch
that are stable on each, conclude the predicate on the entire
corridor. Useful for proofs that need different reasoning on the two
halves. -/
lemma AperyAnalyticExtension.corridor_cases
    {P : ℝ → Prop}
    (h_small : ∀ z ∈ Set.Ico (0 : ℝ) (1 / 64), P z)
    (h_outside : ∀ z ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly, P z)
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    P z := by
  rcases mem_corridor_dichotomy hz with h | h
  · exact h_small z h
  · exact h_outside z h

/-- **Disjunctive value form on the corridor.** Either `z` lies in the
small interval — and then `ext.F z = aperyGFAReal z` is explicit — or
`z` lies in the outside-small stretch (where the value is whatever the
extension assigns, with no closed form from the structure alone). -/
lemma AperyAnalyticExtension.F_corridor_disjunction
    (ext : AperyAnalyticExtension) {z : ℝ}
    (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    (z ∈ Set.Ico (0 : ℝ) (1 / 64) ∧ ext.F z = aperyGFAReal z) ∨
      z ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly := by
  rcases mem_corridor_dichotomy hz with hsmall | houtside
  · exact Or.inl ⟨hsmall, ext.agrees_on_small hsmall⟩
  · exact Or.inr houtside

/-- **Piecewise form on the corridor against an outside model.** When
an outside model `g : ℝ → ℝ` matches `ext.F` on the outside-small
stretch, `ext.F z` admits a clean piecewise formula on the entire
corridor: equal to `aperyGFAReal z` on the small side and `g z` on the
outside-small side. -/
lemma AperyAnalyticExtension.F_piecewise_corridor
    (ext : AperyAnalyticExtension) {g : ℝ → ℝ}
    (h_outside : Set.EqOn ext.F g
      (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly))
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    ext.F z = (if z < 1 / 64 then aperyGFAReal z else g z) := by
  rcases mem_corridor_dichotomy hz with hsmall | houtside
  · have hlt : z < 1 / 64 := hsmall.2
    rw [if_pos hlt, ext.agrees_on_small hsmall]
  · have hge : ¬ (z < 1 / 64) := not_lt.mpr houtside.1
    rw [if_neg hge, h_outside houtside]

/-- **Continuity gluing utility for an `ext.F`-shaped function.** For a
generic `f : ℝ → ℝ` that equals `ext.F` on the corridor, continuity is
inherited from `ext.continuousOn_corridor`. Useful when `f` is defined
piecewise and one wants to recover continuity from the structural
extension's continuity. -/
lemma AperyAnalyticExtension.continuousOn_corridor_of_eqOn
    (ext : AperyAnalyticExtension) {f : ℝ → ℝ}
    (h_eq : Set.EqOn f ext.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly)) :
    ContinuousOn f (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :=
  ext.continuousOn_corridor.congr (fun z hz => h_eq hz)

/-! ### Boundary point `z = 1/64`

The conventional GFA-radius boundary is the canonical case-split point.
Below are utilities for examining `ext.F` behavior near `1/64`. -/

/-- **`1/64` lies in the corridor.** -/
lemma one_div_64_mem_corridor :
    (1 : ℝ) / 64 ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
  ⟨by norm_num, aperyConifoldZ1Poly_gt_one_div_64⟩

/-- **`1/64` lies in the outside-small stretch.** -/
lemma one_div_64_mem_outside_small :
    (1 : ℝ) / 64 ∈ Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly :=
  ⟨le_refl _, aperyConifoldZ1Poly_gt_one_div_64⟩

/-- **`ext.F` is right-continuous at `1/64` within the corridor.** -/
lemma AperyAnalyticExtension.continuousWithinAt_one_div_64_corridor
    (ext : AperyAnalyticExtension) :
    ContinuousWithinAt ext.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) (1 / 64) :=
  ext.continuousWithinAt_corridor one_div_64_mem_corridor

/-- **`ext.F` Tendsto at `1/64` from corridor.** -/
lemma AperyAnalyticExtension.tendsto_at_one_div_64_corridor
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto ext.F
      (nhdsWithin (1 / 64 : ℝ)
        (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (ext.F (1 / 64))) :=
  ext.continuousWithinAt_one_div_64_corridor

/-- **`ext.F` is right-continuous at `1/64` from inside the
outside-small stretch.** -/
lemma AperyAnalyticExtension.continuousWithinAt_one_div_64_outside_small
    (ext : AperyAnalyticExtension) :
    ContinuousWithinAt ext.F
      (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) (1 / 64) :=
  ext.continuousOn_outside_small (1 / 64) one_div_64_mem_outside_small

/-- **`aperyGFAReal` Tendsto at `1/64` from inside the small interval,
through the extension as a witness.** Combines `tendsto_at_one_div_64_corridor`
with the small-interval restriction; concretely, the inner-limit value
at `1/64` is `ext.F (1/64)`, even though the small-interval values
themselves are pure `aperyGFAReal`. -/
lemma AperyAnalyticExtension.tendsto_aperyGFAReal_at_one_div_64_from_small
    (ext : AperyAnalyticExtension) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin (1 / 64 : ℝ) (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (ext.F (1 / 64))) := by
  have h_corridor := ext.tendsto_at_one_div_64_corridor
  have h_subset :
      Set.Ico (0 : ℝ) (1 / 64) ⊆
        Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor
  have h_mono : Filter.Tendsto ext.F
      (nhdsWithin (1 / 64 : ℝ) (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (ext.F (1 / 64))) :=
    h_corridor.mono_left (nhdsWithin_mono _ h_subset)
  refine h_mono.congr' ?_
  rw [Filter.EventuallyEq, eventually_nhdsWithin_iff]
  refine Filter.Eventually.of_forall ?_
  intro z hz
  exact ext.agrees_on_small hz

/-! ### Uniqueness across two extensions

Without an analyticity hypothesis, two `AperyAnalyticExtension`s
always agree on the small interval (forced by `agrees_on_small`) but
need not agree on the outside-small stretch. The lemmas here surface
the structural agreement obligations explicitly. -/

/-- **Two extensions always agree on the small interval.** Both
extensions are pinned to `aperyGFAReal` on `Ico 0 (1/64)` by the
`agrees_on_small` field, so they coincide there. -/
lemma AperyAnalyticExtension.agree_on_small_universally
    (ext₁ ext₂ : AperyAnalyticExtension) :
    Set.EqOn ext₁.F ext₂.F (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z hz
  rw [ext₁.agrees_on_small hz, ext₂.agrees_on_small hz]

/-- **Corridor-wide agreement reduces to outside-small agreement.**
If two extensions match on the outside-small stretch
`Ico (1/64) aperyConifoldZ1Poly`, they match on the entire corridor
(the small-interval part is automatic). -/
lemma AperyAnalyticExtension.agree_on_corridor_of_agree_on_outside_small
    (ext₁ ext₂ : AperyAnalyticExtension)
    (h_outside : Set.EqOn ext₁.F ext₂.F
      (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly)) :
    Set.EqOn ext₁.F ext₂.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z hz
  rcases mem_corridor_dichotomy hz with hsmall | houtside
  · exact AperyAnalyticExtension.agree_on_small_universally ext₁ ext₂ hsmall
  · exact h_outside houtside

/-- **Equivalence: corridor-wide agreement is exactly outside-small
agreement.** -/
lemma AperyAnalyticExtension.agree_on_corridor_iff_agree_on_outside_small
    (ext₁ ext₂ : AperyAnalyticExtension) :
    Set.EqOn ext₁.F ext₂.F
        (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) ↔
      Set.EqOn ext₁.F ext₂.F
        (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) := by
  refine ⟨fun h z hz => ?_, fun h => ?_⟩
  · exact h (AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor hz)
  · exact AperyAnalyticExtension.agree_on_corridor_of_agree_on_outside_small ext₁ ext₂ h

/-- **`ofChain ↔ fromChain` outside-small agreement.** Both chain
entry points produce extensions whose `F` agree on the outside-small
stretch — direct mono restriction of the corridor-level agreement
established earlier. -/
lemma AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_fromChainGFAInteriorDisks_F_on_outside_small
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.EqOn
      (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
        params n ts ht_zero ht_last h_pieces).F
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      (Set.Ico ((1 : ℝ) / 64) Number.aperyConifoldZ1Poly) :=
  (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_fromChainGFAInteriorDisks_F_on_corridor
    params n ts ht_zero ht_last h_pieces).mono
    AperyAnalyticExtension.Ico_one_div_64_aperyConifoldZ1Poly_subset_corridor

/-- **`ofChain ↔ fromChain` small agreement.** Mono restriction to
small interval. -/
lemma AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_fromChainGFAInteriorDisks_F_on_small
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    Set.EqOn
      (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
        params n ts ht_zero ht_last h_pieces).F
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      (Set.Ico (0 : ℝ) (1 / 64)) :=
  (AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_fromChainGFAInteriorDisks_F_on_corridor
    params n ts ht_zero ht_last h_pieces).mono
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor

/-- **Existence from two GFA-interior disks split.** -/
lemma AperyLocalAnalyticExtension.hasAperyAnalyticExtension_of_two_gfa_interior_disks_split
    (c₀ : ℝ) (h_pos₀ : 0 < c₀) (h_lt₀ : c₀ < 1 / 64)
    (r₀ : ℝ) (hr₀ : 0 < r₀) (coeffs₀ : ℕ → ℝ)
    (hs₀ : ∀ t : ℝ, |t| < r₀ →
      HasSum (fun n => coeffs₀ n * t ^ n) (aperyGFAReal (c₀ + t)))
    (hSum₀ : ∀ r' : NNReal, (r' : ℝ) < r₀ →
      Summable (fun n : ℕ => |coeffs₀ n| * (r' : ℝ) ^ n))
    (c₁ : ℝ) (h_pos₁ : 0 < c₁) (h_lt₁ : c₁ < 1 / 64)
    (r₁ : ℝ) (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (c₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    (t : ℝ)
    (h_left : Set.Ico (0 : ℝ) t ⊆
      (aperyGFAInteriorAnalyticDiskAt c₀ h_pos₀ h_lt₀ r₀ hr₀ coeffs₀ hs₀
        hSum₀).toAperyRegularDisk.diskOpen)
    (h_right : Set.Ico t Number.aperyConifoldZ1Poly ⊆
      (aperyGFAInteriorAnalyticDiskAt c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁
        hSum₁).toAperyRegularDisk.diskOpen) :
    HasAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofTwoGFAInteriorDiskCoveringSplit
    c₀ h_pos₀ h_lt₀ r₀ hr₀ coeffs₀ hs₀ hSum₀
    c₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁
    t h_left h_right⟩

/-! ### Chain glue uniqueness across choices of chain

Different GFA-anchored chains covering the same point yield the same
chain-glue value (both equal `aperyGFAReal` there). Captures canonicity
of the chain glue on its support. -/

/-- **Two GFA-anchored chains agree on their common coverage.** Whenever
`z` lies in some piece of one GFA-anchored chain *and* some piece of
another, the two chain-glue values coincide — both equal `aperyGFAReal z`. -/
lemma aperyGFAInteriorAnalyticDiskAt_chainGlue_canonical
    (ds₁ : ℕ → AperyAnalyticDiskAt) (n₁ : ℕ)
    (h_F₁ : ∀ i, (ds₁ i).F = aperyGFAReal)
    (ds₂ : ℕ → AperyAnalyticDiskAt) (n₂ : ℕ)
    (h_F₂ : ∀ i, (ds₂ i).F = aperyGFAReal)
    {z : ℝ}
    {k₁ : ℕ} (hk₁ : k₁ ≤ n₁) (hz₁ : z ∈ (ds₁ k₁).toAperyRegularDisk.diskOpen)
    {k₂ : ℕ} (hk₂ : k₂ ≤ n₂) (hz₂ : z ∈ (ds₂ k₂).toAperyRegularDisk.diskOpen) :
    AperyAnalyticDiskAt.chainGlue ds₁ n₁ z =
      AperyAnalyticDiskAt.chainGlue ds₂ n₂ z := by
  rw [aperyGFAInteriorAnalyticDiskAt_chainGlue_eq ds₁ n₁ h_F₁ hk₁ hz₁,
      aperyGFAInteriorAnalyticDiskAt_chainGlue_eq ds₂ n₂ h_F₂ hk₂ hz₂]

/-! ### Concrete chain builder

Packages a sequence of GFA-interior anchor data into a single
`ℕ → AperyAnalyticDiskAt`, ready for `chainGlue`. -/

/-- **Build a chain of GFA-interior analytic-at disks.** Given coordinate
sequences (centers in `(0, 1/64)`, radii, coefficient sequences, and the
two pointwise summability hypotheses for each index), produces the
function `ℕ → AperyAnalyticDiskAt` whose `i`-th term is the corresponding
`aperyGFAInteriorAnalyticDiskAt`. -/
noncomputable def aperyGFAInteriorChain
    (center : ℕ → ℝ) (h_pos : ∀ i, 0 < center i) (h_lt : ∀ i, center i < 1 / 64)
    (radius : ℕ → ℝ) (hr : ∀ i, 0 < radius i)
    (coeffs : ℕ → ℕ → ℝ)
    (hs : ∀ i, ∀ t : ℝ, |t| < radius i →
      HasSum (fun n => coeffs i n * t ^ n) (aperyGFAReal (center i + t)))
    (hSum : ∀ i, ∀ r' : NNReal, (r' : ℝ) < radius i →
      Summable (fun n : ℕ => |coeffs i n| * (r' : ℝ) ^ n)) :
    ℕ → AperyAnalyticDiskAt :=
  fun i => aperyGFAInteriorAnalyticDiskAt (center i) (h_pos i) (h_lt i)
    (radius i) (hr i) (coeffs i) (hs i) (hSum i)

@[simp] lemma aperyGFAInteriorChain_F
    (center : ℕ → ℝ) (h_pos : ∀ i, 0 < center i) (h_lt : ∀ i, center i < 1 / 64)
    (radius : ℕ → ℝ) (hr : ∀ i, 0 < radius i)
    (coeffs : ℕ → ℕ → ℝ)
    (hs : ∀ i, ∀ t : ℝ, |t| < radius i →
      HasSum (fun n => coeffs i n * t ^ n) (aperyGFAReal (center i + t)))
    (hSum : ∀ i, ∀ r' : NNReal, (r' : ℝ) < radius i →
      Summable (fun n : ℕ => |coeffs i n| * (r' : ℝ) ^ n))
    (i : ℕ) :
    (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum i).F
      = aperyGFAReal := rfl

/-- **Per-piece equality on the concrete chain.** -/
lemma aperyGFAInteriorChain_chainGlue_eq
    (center : ℕ → ℝ) (h_pos : ∀ i, 0 < center i) (h_lt : ∀ i, center i < 1 / 64)
    (radius : ℕ → ℝ) (hr : ∀ i, 0 < radius i)
    (coeffs : ℕ → ℕ → ℝ)
    (hs : ∀ i, ∀ t : ℝ, |t| < radius i →
      HasSum (fun n => coeffs i n * t ^ n) (aperyGFAReal (center i + t)))
    (hSum : ∀ i, ∀ r' : NNReal, (r' : ℝ) < radius i →
      Summable (fun n : ℕ => |coeffs i n| * (r' : ℝ) ^ n))
    (n : ℕ) {k : ℕ} (hk : k ≤ n) {z : ℝ}
    (hz : z ∈ (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum
      k).toAperyRegularDisk.diskOpen) :
    AperyAnalyticDiskAt.chainGlue
        (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n z
      = aperyGFAReal z :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_eq
    (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n
    (fun _ => rfl) hk hz

/-! #### Bridge to `ext.F` on the small overlap -/

/-- **GFA chain glue equals `ext.F` on the unconditional disk overlap.**
Whenever `z` lies in both a GFA-anchored chain piece and the small disk
`[0, 1/64)`, the chain glue agrees with any `AperyAnalyticExtension`'s
`ext.F` value, since both equal `aperyGFAReal z` there. -/
lemma aperyGFAInteriorAnalyticDiskAt_chainGlue_eq_ext_on_small
    (ext : AperyAnalyticExtension)
    (ds : ℕ → AperyAnalyticDiskAt) (n : ℕ)
    (h_F : ∀ i, (ds i).F = aperyGFAReal)
    {k : ℕ} (hk : k ≤ n) {z : ℝ}
    (hz : z ∈ (ds k).toAperyRegularDisk.diskOpen)
    (h_small : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    AperyAnalyticDiskAt.chainGlue ds n z = ext.F z := by
  rw [aperyGFAInteriorAnalyticDiskAt_chainGlue_eq ds n h_F hk hz]
  exact (ext.F_eq_GFA_on_small h_small).symm

/-- **Concrete-chain version: chain glue equals `ext.F` on the small
overlap.** -/
lemma aperyGFAInteriorChain_chainGlue_eq_ext_on_small
    (ext : AperyAnalyticExtension)
    (center : ℕ → ℝ) (h_pos : ∀ i, 0 < center i) (h_lt : ∀ i, center i < 1 / 64)
    (radius : ℕ → ℝ) (hr : ∀ i, 0 < radius i)
    (coeffs : ℕ → ℕ → ℝ)
    (hs : ∀ i, ∀ t : ℝ, |t| < radius i →
      HasSum (fun n => coeffs i n * t ^ n) (aperyGFAReal (center i + t)))
    (hSum : ∀ i, ∀ r' : NNReal, (r' : ℝ) < radius i →
      Summable (fun n : ℕ => |coeffs i n| * (r' : ℝ) ^ n))
    (n : ℕ) {k : ℕ} (hk : k ≤ n) {z : ℝ}
    (hz : z ∈ (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum
      k).toAperyRegularDisk.diskOpen)
    (h_small : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    AperyAnalyticDiskAt.chainGlue
        (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n z
      = ext.F z :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_eq_ext_on_small ext
    (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n
    (fun _ => rfl) hk hz h_small

/-- **Analyticity of the concrete-chain glue on the union.** -/
lemma aperyGFAInteriorChain_chainGlue_analyticOnNhd
    (center : ℕ → ℝ) (h_pos : ∀ i, 0 < center i) (h_lt : ∀ i, center i < 1 / 64)
    (radius : ℕ → ℝ) (hr : ∀ i, 0 < radius i)
    (coeffs : ℕ → ℕ → ℝ)
    (hs : ∀ i, ∀ t : ℝ, |t| < radius i →
      HasSum (fun n => coeffs i n * t ^ n) (aperyGFAReal (center i + t)))
    (hSum : ∀ i, ∀ r' : NNReal, (r' : ℝ) < radius i →
      Summable (fun n : ℕ => |coeffs i n| * (r' : ℝ) ^ n))
    (n : ℕ) :
    AnalyticOnNhd ℝ
      (AperyAnalyticDiskAt.chainGlue
        (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n)
      (⋃ k ∈ Finset.range (n + 1),
        (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum
          k).toAperyRegularDisk.diskOpen) :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_analyticOnNhd
    (aperyGFAInteriorChain center h_pos h_lt radius hr coeffs hs hSum) n
    (fun _ => rfl)

/-! ### Toy 2-disk chain validation

Smallest non-trivial chain: two GFA-interior anchors. Exercises that the
abstract chainGlue API composes ergonomically on a concrete pair. -/

/-- **2-disk chain.** Index `0` selects disk one; any other index selects
disk two. Useful as the smallest non-degenerate chain to test
chainGlue. -/
noncomputable def aperyGFAInteriorPair
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n)) :
    ℕ → AperyAnalyticDiskAt :=
  fun i =>
    if i = 0 then
      aperyGFAInteriorAnalyticDiskAt z₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁
    else
      aperyGFAInteriorAnalyticDiskAt z₂ h_pos₂ h_lt₂ r₂ hr₂ coeffs₂ hs₂ hSum₂

/-- **Each disk in the 2-pair carries `aperyGFAReal`.** -/
lemma aperyGFAInteriorPair_F
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n))
    (i : ℕ) :
    (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
      h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂ i).F = aperyGFAReal := by
  unfold aperyGFAInteriorPair
  split_ifs <;> rfl

/-- **Pair index 0 picks the first disk.** -/
@[simp] lemma aperyGFAInteriorPair_zero
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n)) :
    aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
        h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂ 0 =
      aperyGFAInteriorAnalyticDiskAt z₁ h_pos₁ h_lt₁ r₁ hr₁ coeffs₁ hs₁ hSum₁ :=
  rfl

/-- **Pair index `i+1` picks the second disk.** -/
@[simp] lemma aperyGFAInteriorPair_succ
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n))
    (i : ℕ) :
    aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
        h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂ (i + 1) =
      aperyGFAInteriorAnalyticDiskAt z₂ h_pos₂ h_lt₂ r₂ hr₂ coeffs₂ hs₂ hSum₂ := by
  unfold aperyGFAInteriorPair
  simp

/-- **chainGlue on the 2-disk pair equals `aperyGFAReal` on either piece.** -/
lemma aperyGFAInteriorPair_chainGlue_eq
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n))
    {k : ℕ} (hk : k ≤ 1) {z : ℝ}
    (hz : z ∈ (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
      h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂ k).toAperyRegularDisk.diskOpen) :
    AperyAnalyticDiskAt.chainGlue
        (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
          h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂) 1 z =
      aperyGFAReal z :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_eq
    (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
      h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂) 1
    (aperyGFAInteriorPair_F h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
      h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂) hk hz

/-- **Analyticity on the union of the 2-disk pair.** Direct application of
`aperyGFAInteriorAnalyticDiskAt_chainGlue_analyticOnNhd` at `n = 1`. -/
lemma aperyGFAInteriorPair_chainGlue_analyticOnNhd
    {z₁ : ℝ} (h_pos₁ : 0 < z₁) (h_lt₁ : z₁ < 1 / 64)
    {r₁ : ℝ} (hr₁ : 0 < r₁) (coeffs₁ : ℕ → ℝ)
    (hs₁ : ∀ t : ℝ, |t| < r₁ →
      HasSum (fun n => coeffs₁ n * t ^ n) (aperyGFAReal (z₁ + t)))
    (hSum₁ : ∀ r' : NNReal, (r' : ℝ) < r₁ →
      Summable (fun n : ℕ => |coeffs₁ n| * (r' : ℝ) ^ n))
    {z₂ : ℝ} (h_pos₂ : 0 < z₂) (h_lt₂ : z₂ < 1 / 64)
    {r₂ : ℝ} (hr₂ : 0 < r₂) (coeffs₂ : ℕ → ℝ)
    (hs₂ : ∀ t : ℝ, |t| < r₂ →
      HasSum (fun n => coeffs₂ n * t ^ n) (aperyGFAReal (z₂ + t)))
    (hSum₂ : ∀ r' : NNReal, (r' : ℝ) < r₂ →
      Summable (fun n : ℕ => |coeffs₂ n| * (r' : ℝ) ^ n)) :
    AnalyticOnNhd ℝ
      (AperyAnalyticDiskAt.chainGlue
        (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
          h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂) 1)
      (⋃ k ∈ Finset.range 2,
        (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
          h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂ k).toAperyRegularDisk.diskOpen) :=
  aperyGFAInteriorAnalyticDiskAt_chainGlue_analyticOnNhd
    (aperyGFAInteriorPair h_pos₁ h_lt₁ hr₁ coeffs₁ hs₁ hSum₁
      h_pos₂ h_lt₂ hr₂ coeffs₂ hs₂ hSum₂) 1
