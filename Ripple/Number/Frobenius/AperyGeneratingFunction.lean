/-- **Predicate-level value at `z₁` equals regular seed.** Specialising
the connection predicate at `t = 0`: `f(z₁) = aperyBranchTriple a₀ a_half a₁ 0
= a₀` (half drops via `√0 = 0`, one drops via `0² = 0`). This is the
direct point-evaluation that pins down `a₀` from `f` alone. -/
lemma IsAperyConnectionCoeffsOn.value_at_z1
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    (h0 : (0 : ℝ) ∈ I) :
    f Number.aperyConifoldZ1Poly = a₀ := by
  have h_app := h 0 h0
  rw [add_zero, aperyBranchTriple_at_zero] at h_app
  exact h_app

/-- **Regular seed identification on ext.** If the connection predicate
holds for `ext.F` on a corridor containing `0`, then the regular seed
`a₀` coincides with `ext.extractRegular = ext.F z₁`. Concrete
computational handle for the regular connection coefficient. -/
lemma AperyAnalyticExtension.regular_seed_eq_extractRegular
    (ext : AperyAnalyticExtension)
    {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I) :
    a₀ = ext.extractRegular := by
  rw [ext.extractRegular_eq]
  exact (h.value_at_z1 h0).symm

/-- **Half seed identification on data (predicate form).** From the
universal predicate on the corridor and two probes `-ε₁, -ε₂`, the
half-branch seed `a_half` coincides with `d.extractHalf ε₁ ε₂` (the
Cramer-rule extract). Specialising the predicate at three points feeds
into the existing `candidate_eq_extractHalf_of_three_points`. -/
lemma AperyConnectionData.half_seed_eq_extractHalf
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a_half = d.extractHalf ε₁ ε₂ := by
  have hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0 := by
    have h_eq := h 0 d.zero_mem
    simpa using h_eq
  have hF₁ := h (-ε₁) hε₁
  have hF₂ := h (-ε₂) hε₂
  exact d.candidate_eq_extractHalf_of_three_points hF₀ hF₁ hF₂ hdet

/-- **One seed identification on data (predicate form).** Companion of
`half_seed_eq_extractHalf`: pins down `a₁ = d.extractOne ε₁ ε₂`. -/
lemma AperyConnectionData.one_seed_eq_extractOne
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₁ = d.extractOne ε₁ ε₂ := by
  have hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0 := by
    have h_eq := h 0 d.zero_mem
    simpa using h_eq
  have hF₁ := h (-ε₁) hε₁
  have hF₂ := h (-ε₂) hε₂
  exact d.candidate_eq_extractOne_of_three_points hF₀ hF₁ hF₂ hdet

/-- **Regular seed identification on data (predicate form).** Companion
of the half/one variants — pins down `a₀ = d.extractRegular`. -/
lemma AperyConnectionData.regular_seed_eq_extractRegular
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor) :
    a₀ = d.extractRegular := by
  rw [d.extractRegular_eq]
  exact (h.value_at_z1 d.zero_mem).symm

/-- **Bundled connection seed-triple identification on data.** Combines
the three component identifications into one statement: from the
predicate on the corridor and two ε-probes, the seed triple equals
`(d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂)`. -/
lemma AperyConnectionData.seed_triple_eq_extracts
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular ∧ a_half = d.extractHalf ε₁ ε₂ ∧
        a₁ = d.extractOne ε₁ ε₂ :=
  ⟨d.regular_seed_eq_extractRegular h,
   d.half_seed_eq_extractHalf h hε₁ hε₂ hdet,
   d.one_seed_eq_extractOne h hε₁ hε₂ hdet⟩

/-- **Half seed identification on ext (predicate form).** Lift through
`AperyConnectionData.of_witness`: the half seed `a_half` is exactly
`ext.extractHalf ε₁ ε₂`. -/
lemma AperyAnalyticExtension.half_seed_eq_extractHalf
    (ext : AperyAnalyticExtension)
    {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a_half = ext.extractHalf ε₁ ε₂ := by
  let d : AperyConnectionData :=
    AperyConnectionData.of_witness ext I h0 ⟨a₀, a_half, a₁, h⟩
  have h' : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor := h
  exact d.half_seed_eq_extractHalf h' hε₁ hε₂ hdet

/-- **One seed identification on ext (predicate form).** -/
lemma AperyAnalyticExtension.one_seed_eq_extractOne
    (ext : AperyAnalyticExtension)
    {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₁ = ext.extractOne ε₁ ε₂ := by
  let d : AperyConnectionData :=
    AperyConnectionData.of_witness ext I h0 ⟨a₀, a_half, a₁, h⟩
  have h' : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor := h
  exact d.one_seed_eq_extractOne h' hε₁ hε₂ hdet

/-- **Bundled connection seed-triple identification on ext.** -/
lemma AperyAnalyticExtension.seed_triple_eq_extracts
    (ext : AperyAnalyticExtension)
    {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = ext.extractRegular ∧ a_half = ext.extractHalf ε₁ ε₂ ∧
        a₁ = ext.extractOne ε₁ ε₂ :=
  ⟨ext.regular_seed_eq_extractRegular h0 h,
   ext.half_seed_eq_extractHalf h0 h hε₁ hε₂ hdet,
   ext.one_seed_eq_extractOne h0 h hε₁ hε₂ hdet⟩

/-- **Seed uniqueness across corridors (transport).** If the same
function `f` carries two connection-coefficient witnesses on (possibly
different) corridors `I₁` and `I₂` — both containing `0` and a common
probe pair `(-ε₁, -ε₂)` with nonzero Cramer determinant — then the
seed triples agree. Uniqueness is enforced by the Cramer-rule extracts
`aperyExtract{Regular,Half,One} f` depending only on `f`, not on the
corridor. This is the corridor-right-endpoint transport: a predicate
established on one neighbourhood pins down the same triple on every
overlapping neighbourhood. -/
lemma IsAperyConnectionCoeffsOn.seeds_unique
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ} {f : ℝ → ℝ} {I₁ I₂ : Set ℝ}
    (h₁ : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I₁)
    (h₂ : IsAperyConnectionCoeffsOn b₀ b_half b₁ f I₂)
    (h0_1 : (0 : ℝ) ∈ I₁) (h0_2 : (0 : ℝ) ∈ I₂)
    {ε₁ ε₂ : ℝ}
    (hε₁_1 : (-ε₁) ∈ I₁) (hε₁_2 : (-ε₁) ∈ I₂)
    (hε₂_1 : (-ε₂) ∈ I₁) (hε₂_2 : (-ε₂) ∈ I₂)
    (hdet : aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
            aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁ ≠ 0) :
    a₀ = b₀ ∧ a_half = b_half ∧ a₁ = b₁ := by
  obtain ⟨hr₁, hh₁, ho₁⟩ := h₁.eq_extract h0_1 hε₁_1 hε₂_1 hdet
  obtain ⟨hr₂, hh₂, ho₂⟩ := h₂.eq_extract h0_2 hε₁_2 hε₂_2 hdet
  exact ⟨hr₁.trans hr₂.symm, hh₁.trans hh₂.symm, ho₁.trans ho₂.symm⟩

/-- **Pointwise evaluation via extracts.** For any `t` in the corridor,
the value `f(z₁ + t)` is computable from three probe values
`f(z₁), f(z₁ - ε₁), f(z₁ - ε₂)` (via the Cramer extracts) and the
universal branch-triple shape. This is the "transport everywhere"
formula: once `f` is known on the three-point probe set, it is
determined on the entire corridor. -/
lemma IsAperyConnectionCoeffsOn.value_via_extracts
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    (h0 : (0 : ℝ) ∈ I) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
            aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁ ≠ 0)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple (aperyExtractRegular f) (aperyExtractHalf f ε₁ ε₂)
        (aperyExtractOne f ε₁ ε₂) t := by
  obtain ⟨hr, hh, ho⟩ := h.eq_extract h0 hε₁ hε₂ hdet
  rw [← hr, ← hh, ← ho]
  exact h t ht

/-- **Bridge: raw `aperyConnectionResidual ext.F` equals
`ext.connectionResidual`.** The data-wrapper form and the function-level
form coincide; this `rfl`-bridge lets downstream code freely move
between the two. -/
@[simp] lemma AperyAnalyticExtension.aperyConnectionResidual_F_eq
    (ext : AperyAnalyticExtension) (ε : ℝ) :
    aperyConnectionResidual ext.F ε = ext.connectionResidual ε := rfl

/-- **Raw `aperyConnectionResidual ext.F` via GFA on small disk.**
Companion to `connectionResidual_via_GFA`, but stated for the raw
function-level residual `aperyConnectionResidual ext.F` (the form that
`aperyExtractHalf`/`aperyExtractOne` consume). When the probe point
lands in the GFA convergence disk, the residual rewrites to
`GFA(z₁ - ε) - F(z₁) · A₀(ε)`. -/
lemma AperyAnalyticExtension.aperyConnectionResidual_F_via_GFA
    (ext : AperyAnalyticExtension) {ε : ℝ}
    (hε : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyConnectionResidual ext.F ε =
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε := by
  rw [ext.aperyConnectionResidual_F_eq, ext.connectionResidual_via_GFA hε]

/-- **`aperyExtractHalf` via GFA at both probes.** When both probe
points `z₁ - ε₁`, `z₁ - ε₂` lie in the GFA convergence disk, the
half-branch Cramer extract opens up into a closed-form expression in
`aperyGFAReal` values and `ext.F z₁`. Together with the future
`extractOne` companion, this gives the full bridge from analytic
extension at `z₁` plus computable series probes to the connection
coefficients. -/
lemma AperyAnalyticExtension.aperyExtractHalf_via_GFA
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyExtractHalf ext.F ε₁ ε₂ =
      ((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₁) *
            aperyBranchValue_one ε₂ -
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₂) *
            aperyBranchValue_one ε₁) /
      (aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
        aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁) := by
  unfold aperyExtractHalf
  rw [ext.aperyConnectionResidual_F_via_GFA hε₁,
      ext.aperyConnectionResidual_F_via_GFA hε₂]

/-- **`aperyExtractOne` via GFA at both probes.** Companion to
`aperyExtractHalf_via_GFA`. -/
lemma AperyAnalyticExtension.aperyExtractOne_via_GFA
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyExtractOne ext.F ε₁ ε₂ =
      (-((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
            ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₁) *
              aperyBranchAmplitude_half ε₂) +
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₂) *
            aperyBranchAmplitude_half ε₁) /
      (aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
        aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁) := by
  unfold aperyExtractOne
  rw [ext.aperyConnectionResidual_F_via_GFA hε₁,
      ext.aperyConnectionResidual_F_via_GFA hε₂]

/-- **`ext.F` at any corridor point as branch-triple anchored at `F z₁`.**
Predicate-level `value_via_extracts` rephrased to expose the
transcendental input directly: `ext.F (z₁ + t) = aperyBranchTriple
(F z₁) (aperyExtractHalf F ε₁ ε₂) (aperyExtractOne F ε₁ ε₂) t`. The
value at any corridor point reduces to a single transcendental
"anchor" `F z₁` plus two Cramer-extracted singular seeds. Combined
with `aperyExtractHalf/One_via_GFA`, the singular seeds are computable
series expressions modulo `F z₁`. -/
lemma AperyAnalyticExtension.F_eq_branchTriple_at_z1_anchor
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
            aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁ ≠ 0)
    {t : ℝ} (ht : t ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple (ext.F Number.aperyConifoldZ1Poly)
        (aperyExtractHalf ext.F ε₁ ε₂) (aperyExtractOne ext.F ε₁ ε₂) t :=
  h.value_via_extracts h0 hε₁ hε₂ hdet ht

/-- **Predicate restated as explicit three-branch sum.** Unfolding
`aperyBranchTriple` exposes the three Frobenius branches:
`f(z₁ + t) = yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t`.
Useful for downstream code that wants the explicit branch shape rather
than the bundled triple. -/
lemma IsAperyConnectionCoeffsOn.eq_branches_sum
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t := by
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  exact h_app

/-- **No-half branch reduces to the two integer-indicial branches Y₀, Y₁.**
When the half-integer connection coefficient `a_half = 0`, the half branch
contributes zero (via `yAperyHalf_smul_c₀` with `c = 0`), leaving
`f(z₁ + t) = yAperyZero a₀ t + yApery a₁ t`. This is the "regular +
one-shift" basis form — the case where the function pulls back to a
real-analytic combination on both sides of the conifold. -/
lemma IsAperyConnectionCoeffsOn.eq_yZero_plus_yOne_of_no_half
    {a₀ a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ 0 a₁ f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) = yAperyZero a₀ t + yApery a₁ t := by
  have h_eq := h.eq_branches_sum ht
  have h_zero : yAperyHalf 0 t = 0 := by
    have := yAperyHalf_smul_c₀ 0 0 t
    simp at this
    exact this
  rw [h_zero, add_zero] at h_eq
  exact h_eq

/-- **No-one branch reduces to Y₀ + Y_½ basis.** When `a₁ = 0` the
one-shift branch vanishes (`yApery 0 t = 0` via `yApery_smul_c₀` at
`c = 0`), leaving `f(z₁ + t) = yAperyZero a₀ t + yAperyHalf a_half t`. -/
lemma IsAperyConnectionCoeffsOn.eq_yZero_plus_yHalf_of_no_one
    {a₀ a_half : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half 0 f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t := by
  have h_eq := h.eq_branches_sum ht
  have h_zero : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 0 t
    simp at this
    exact this
  rw [h_zero, add_zero] at h_eq
  exact h_eq

/-- **Only-regular form (Y₀ alone).** When both singular seeds vanish
(`a_half = a₁ = 0`), the function reduces to a single regular Frobenius
branch: `f(z₁ + t) = yAperyZero a₀ t`. The "pure regular" sub-basis. -/
lemma IsAperyConnectionCoeffsOn.eq_yZero_of_only_regular
    {a₀ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ 0 0 f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) = yAperyZero a₀ t := by
  have h_eq := h.eq_yZero_plus_yOne_of_no_half ht
  have h_zero : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 0 t
    simp at this
    exact this
  rw [h_zero, add_zero] at h_eq
  exact h_eq

/-- **Only-one form (Y₁ alone).** When `a₀ = a_half = 0`,
`f(z₁ + t) = yApery a₁ t`. -/
lemma IsAperyConnectionCoeffsOn.eq_yOne_of_only_one
    {a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 0 a₁ f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) = yApery a₁ t := by
  have h_eq := h.eq_branches_sum ht
  have hZ : yAperyZero 0 t = 0 := by
    have := yAperyZero_smul_c₀ 0 0 t
    simp at this
    exact this
  have hH : yAperyHalf 0 t = 0 := by
    have := yAperyHalf_smul_c₀ 0 0 t
    simp at this
    exact this
  rw [hZ, hH, zero_add, zero_add] at h_eq
  exact h_eq

/-- **Only-half form (Y_½ alone).** When `a₀ = a₁ = 0`,
`f(z₁ + t) = yAperyHalf a_half t`. -/
lemma IsAperyConnectionCoeffsOn.eq_yHalf_of_only_half
    {a_half : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 a_half 0 f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) = yAperyHalf a_half t := by
  have h_eq := h.eq_branches_sum ht
  have hZ : yAperyZero 0 t = 0 := by
    have := yAperyZero_smul_c₀ 0 0 t
    simp at this
    exact this
  have hO : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 0 t
    simp at this
    exact this
  rw [hZ, hO, zero_add, add_zero] at h_eq
  exact h_eq

/-- **Right-side reduces to Y₀ + Y₁ basis automatically.** For `t ≥ 0`,
the half-branch factor `√(-t) = 0` kills any `a_half` contribution
regardless of seed value. So on the right side of the conifold,
`f(z₁ + t) = yAperyZero a₀ t + yApery a₁ t` always — even for nonzero
`a_half`. This is the "real-analytic side" form: on `[z₁, z₁ + ε_R]`
the function lives in the integer-indicial basis spanned by Y₀ and
Y₁. -/
lemma IsAperyConnectionCoeffsOn.eq_yZero_plus_yOne_on_right
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t) :
    f (Number.aperyConifoldZ1Poly + t) = yAperyZero a₀ t + yApery a₁ t := by
  have h_eq := h.eq_branches_sum ht
  have h_sqrt : Real.sqrt (-t) = 0 :=
    Real.sqrt_eq_zero'.mpr (by linarith)
  have h_zero : yAperyHalf a_half t = 0 := by
    unfold yAperyHalf
    rw [h_sqrt, zero_mul]
  rw [h_zero, add_zero] at h_eq
  exact h_eq

/-- **Data-layer right-side Y₀+Y₁ basis form.** Lift through
`is_extract_triple`: the witness function `d.F` on the right side of
the conifold reduces to `yAperyZero d.extractRegular t + yApery
(d.extractOne ε₁ ε₂) t`. -/
lemma AperyConnectionData.F_eq_yZero_plus_yOne_on_right
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htnn : 0 ≤ t) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t + yApery (d.extractOne ε₁ ε₂) t :=
  (d.is_extract_triple hε₁ hε₂ hdet).eq_yZero_plus_yOne_on_right ht htnn

/-- **GFA-layer right-side Y₀+Y₁ basis form.** When the right-side
shift `z₁ + t` lies in the GFA convergence disk, the series value
equals the Y₀ + Y₁ Frobenius combination at the data extracts. -/
lemma AperyConnectionData.GFA_eq_yZero_plus_yOne_on_right
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htnn : 0 ≤ t)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t + yApery (d.extractOne ε₁ ε₂) t := by
  rw [← d.F_shift_eq_GFA hdisk]
  exact d.F_eq_yZero_plus_yOne_on_right hε₁ hε₂ hdet ht htnn

/-- **Ext-layer extract triple represents `ext.F` on the corridor.**
Bridge from any predicate witness on `ext.F` to the canonical extract
triple `(ext.extractRegular, ext.extractHalf ε₁ ε₂, ext.extractOne ε₁
ε₂)`. Uses `seed_triple_eq_extracts` to substitute. -/
lemma AperyAnalyticExtension.is_extract_triple
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn ext.extractRegular (ext.extractHalf ε₁ ε₂)
        (ext.extractOne ε₁ ε₂) ext.F I := by
  obtain ⟨hr, hh, ho⟩ := ext.seed_triple_eq_extracts h0 h hε₁ hε₂ hdet
  rw [← hr, ← hh, ← ho]
  exact h

/-- **Ext-layer right-side Y₀+Y₁ basis form.** -/
lemma AperyAnalyticExtension.F_eq_yZero_plus_yOne_on_right
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero ext.extractRegular t + yApery (ext.extractOne ε₁ ε₂) t :=
  (ext.is_extract_triple h0 h hε₁ hε₂ hdet).eq_yZero_plus_yOne_on_right ht htnn

/-- **GFA-layer ext right-side Y₀+Y₁ basis form.** When `z₁ + t` lies
in the GFA convergence disk, the series value equals the Y₀ + Y₁
Frobenius combination at the ext extracts. -/
lemma AperyAnalyticExtension.GFA_eq_yZero_plus_yOne_on_right
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) (htnn : 0 ≤ t)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      yAperyZero ext.extractRegular t + yApery (ext.extractOne ε₁ ε₂) t := by
  rw [← ext.F_eq_GFA_on_small hdisk]
  exact ext.F_eq_yZero_plus_yOne_on_right h0 h hε₁ hε₂ hdet ht htnn

/-- **Y_½ branch isolated by subtracting Y₀ and Y₁.** Pure algebraic
rearrangement of `eq_branches_sum`: `f(z₁+t) - yAperyZero a₀ t -
yApery a₁ t = yAperyHalf a_half t`. The half branch is exactly the
"residual" obtained after the two integer-indicial branches are
subtracted off. -/
lemma IsAperyConnectionCoeffsOn.yHalf_isolated
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) :
    f (Number.aperyConifoldZ1Poly + t) - yAperyZero a₀ t - yApery a₁ t =
      yAperyHalf a_half t := by
  have h_eq := h.eq_branches_sum ht
  linarith [h_eq]

/-- **Left-side `frobeniusValue` extraction via division by `√(-t)`.**
For `t < 0` the `√(-t)` factor of `yAperyHalf` is strictly positive, so
we can divide the isolated half branch by it and recover the underlying
`frobeniusValue` at indicial root `1/2` directly. -/
lemma IsAperyConnectionCoeffsOn.frobeniusValue_half_via_sqrt_neg_t
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    {t : ℝ} (ht : t ∈ I) (htneg : t < 0) :
    (f (Number.aperyConifoldZ1Poly + t) - yAperyZero a₀ t - yApery a₁ t)
        / Real.sqrt (-t) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2) a_half t := by
  rw [h.yHalf_isolated ht]
  unfold yAperyHalf
  exact mul_div_cancel_left₀ _
    (ne_of_gt (Real.sqrt_pos.mpr (by linarith)))

/-- **Data-layer Y_½ isolation.** Lift `yHalf_isolated` through
`is_extract_triple`: the residual of `d.F` after subtracting the Y₀ and
Y₁ branches at the canonical extracts is exactly the Y_½ branch at
`d.extractHalf ε₁ ε₂`. -/
lemma AperyConnectionData.F_yHalf_isolated
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) :
    d.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t - yApery (d.extractOne ε₁ ε₂) t =
      yAperyHalf (d.extractHalf ε₁ ε₂) t :=
  (d.is_extract_triple hε₁ hε₂ hdet).yHalf_isolated ht

/-- **Data-layer left-side `frobeniusValue` extraction.** For `t < 0`,
divide the isolated half-branch residual by `√(-t)` to obtain the
underlying `frobeniusValue` at indicial root `1/2` with seed
`d.extractHalf ε₁ ε₂`. -/
lemma AperyConnectionData.F_frobeniusValue_half_via_sqrt_neg_t
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor) (htneg : t < 0) :
    (d.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t - yApery (d.extractOne ε₁ ε₂) t)
        / Real.sqrt (-t) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2)
        (d.extractHalf ε₁ ε₂) t :=
  (d.is_extract_triple hε₁ hε₂ hdet).frobeniusValue_half_via_sqrt_neg_t ht htneg

/-- **GFA-layer Y_½ isolation.** When `z₁ + t` lies in the GFA
convergence disk, the half branch with seed `d.extractHalf ε₁ ε₂` is
recovered as the GFA-residual after subtracting Y₀ and Y₁. -/
lemma AperyConnectionData.GFA_yHalf_isolated
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t - yApery (d.extractOne ε₁ ε₂) t =
      yAperyHalf (d.extractHalf ε₁ ε₂) t := by
  rw [← d.F_shift_eq_GFA hdisk]
  exact d.F_yHalf_isolated hε₁ hε₂ hdet ht

/-- **Ext-layer Y_½ isolation.** -/
lemma AperyAnalyticExtension.F_yHalf_isolated
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero ext.extractRegular t - yApery (ext.extractOne ε₁ ε₂) t =
      yAperyHalf (ext.extractHalf ε₁ ε₂) t :=
  (ext.is_extract_triple h0 h hε₁ hε₂ hdet).yHalf_isolated ht

/-- **Ext-layer left-side `frobeniusValue` extraction.** -/
lemma AperyAnalyticExtension.F_frobeniusValue_half_via_sqrt_neg_t
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I) (htneg : t < 0) :
    (ext.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero ext.extractRegular t - yApery (ext.extractOne ε₁ ε₂) t)
        / Real.sqrt (-t) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2)
        (ext.extractHalf ε₁ ε₂) t :=
  (ext.is_extract_triple h0 h hε₁ hε₂ hdet).frobeniusValue_half_via_sqrt_neg_t
    ht htneg

/-- **GFA-layer ext Y_½ isolation.** -/
lemma AperyAnalyticExtension.GFA_yHalf_isolated
    (ext : AperyAnalyticExtension) {a₀ a_half a₁ : ℝ} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t)
        - yAperyZero ext.extractRegular t - yApery (ext.extractOne ε₁ ε₂) t =
      yAperyHalf (ext.extractHalf ε₁ ε₂) t := by
  rw [← ext.F_eq_GFA_on_small hdisk]
  exact ext.F_yHalf_isolated h0 h hε₁ hε₂ hdet ht

/-- **Right-side value depends only on `(a₀, a₁)`.** Capstone for task
A4: on the right-side of the corridor (`t ≥ 0`), the half-seed `a_half`
contributes nothing — two predicates with the same regular and ρ=1
seeds but different ρ=1/2 seeds witness the same value at every
`z₁ + t` in their corridor overlap. The ρ=1/2 branch is invisible at
the right corridor endpoint. -/
lemma IsAperyConnectionCoeffsOn.right_value_independent_of_half
    {a₀ a_half a_half' a₁ : ℝ} {f : ℝ → ℝ} {I I' : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    (h' : IsAperyConnectionCoeffsOn a₀ a_half' a₁ f I')
    {t : ℝ} (ht : t ∈ I) (ht' : t ∈ I') (htnn : 0 ≤ t) :
    f (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yApery a₁ t := by
  exact h.eq_yZero_plus_yOne_on_right ht htnn

/-- **Two right-side basis representations agree.** Direct equality of
the two right-side reductions: any predicate with seeds `(a₀, _, a₁)`
yields `yAperyZero a₀ t + yApery a₁ t` at right-side `t`, so two
predicates with matching regular and ρ=1 seeds give the same value
regardless of their ρ=1/2 seeds. -/
lemma IsAperyConnectionCoeffsOn.right_value_eq_of_seeds_match
    {a₀ a_half a_half' a₁ : ℝ} {f : ℝ → ℝ} {I I' : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I)
    (h' : IsAperyConnectionCoeffsOn a₀ a_half' a₁ f I')
    {t : ℝ} (ht : t ∈ I) (ht' : t ∈ I') (htnn : 0 ≤ t) :
    yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t =
      yAperyZero a₀ t + yAperyHalf a_half' t + yApery a₁ t := by
  have h1 := h.eq_branches_sum ht
  have h2 := h'.eq_branches_sum ht'
  have h_sqrt : Real.sqrt (-t) = 0 :=
    Real.sqrt_eq_zero'.mpr (by linarith)
  have e1 : yAperyHalf a_half t = 0 := by
    unfold yAperyHalf; rw [h_sqrt, zero_mul]
  have e2 : yAperyHalf a_half' t = 0 := by
    unfold yAperyHalf; rw [h_sqrt, zero_mul]
  rw [e1, e2]

/-! ### Corridor patching (A5) -/

/-- **Indexed union.** A family of predicates with shared seeds patches
into a predicate on the union of their corridors. Used downstream when
chaining overlapping Frobenius disks toward a target endpoint. -/
lemma IsAperyConnectionCoeffsOn.iUnion
    {ι : Type*} {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : ι → Set ℝ}
    (h : ∀ i, IsAperyConnectionCoeffsOn a₀ a_half a₁ f (I i)) :
    IsAperyConnectionCoeffsOn a₀ a_half a₁ f (⋃ i, I i) := by
  intro t ht
  obtain ⟨i, hi⟩ := Set.mem_iUnion.mp ht
  exact h i t hi

/-- **Set-equality congruence.** A predicate transports along set
equalities. Useful when normalising `⋃ i ∈ Finset.range n, I i` against
`⋃ i, if i < n then I i else ∅` and similar bookkeeping. -/
lemma IsAperyConnectionCoeffsOn.congr_set
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I J : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) (hIJ : I = J) :
    IsAperyConnectionCoeffsOn a₀ a_half a₁ f J := by
  rw [← hIJ]; exact h

/-- **Biased union (finite indexed).** Specialisation of `iUnion` to a
boolean-indexed family (length-2 chain). Direct corollary of
`iUnion`/`union`, packaged for ergonomic application. -/
lemma IsAperyConnectionCoeffsOn.biUnion_finset
    {α : Type*} {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ}
    (s : Finset α) {I : α → Set ℝ}
    (h : ∀ i ∈ s, IsAperyConnectionCoeffsOn a₀ a_half a₁ f (I i)) :
    IsAperyConnectionCoeffsOn a₀ a_half a₁ f (⋃ i ∈ s, I i) := by
  intro t ht
  obtain ⟨i, his, hti⟩ := Set.mem_iUnion₂.mp ht
  exact h i his t hti

/-- **Merge via three-probe overlap.** Two witnesses on possibly
different corridors with possibly different seeds patch into a single
witness on the union — provided their corridors share three probe
points `{0, -ε₁, -ε₂}` and the Cramer determinant is non-degenerate.
The seed identification from `seeds_unique` forces `(a₀, a_half, a₁) =
(b₀, b_half, b₁)`, after which `union` finishes the job. -/
lemma IsAperyConnectionCoeffsOn.merge_via_three_probes
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ} {f : ℝ → ℝ} {I₁ I₂ : Set ℝ}
    (h₁ : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I₁)
    (h₂ : IsAperyConnectionCoeffsOn b₀ b_half b₁ f I₂)
    (h0_1 : (0 : ℝ) ∈ I₁) (h0_2 : (0 : ℝ) ∈ I₂)
    {ε₁ ε₂ : ℝ}
    (hε₁_1 : (-ε₁) ∈ I₁) (hε₁_2 : (-ε₁) ∈ I₂)
    (hε₂_1 : (-ε₂) ∈ I₁) (hε₂_2 : (-ε₂) ∈ I₂)
    (hdet : aperyBranchAmplitude_half ε₁ * aperyBranchValue_one ε₂ -
            aperyBranchAmplitude_half ε₂ * aperyBranchValue_one ε₁ ≠ 0) :
    IsAperyConnectionCoeffsOn a₀ a_half a₁ f (I₁ ∪ I₂) := by
  obtain ⟨h_a₀, h_a_half, h_a₁⟩ :=
    h₁.seeds_unique h₂ h0_1 h0_2 hε₁_1 hε₁_2 hε₂_1 hε₂_2 hdet
  apply h₁.union
  rw [h_a₀, h_a_half, h_a₁]
  exact h₂

/-- **Data-layer corridor extension via external `Has`-witness.** Given
an `AperyConnectionData` plus a `HasAperyConnectionCoeffsOn` witness on
an external set `J` overlapping `d.corridor` at three probe points
`{0, -ε₁, -ε₂}` (with non-degenerate Cramer determinant), the
`Has`-property extends to `d.corridor ∪ J` at the canonical extracts
`(extractRegular, extractHalf ε₁ ε₂, extractOne ε₁ ε₂)`. -/
lemma AperyConnectionData.has_conn_union_via_three_probes
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    HasAperyConnectionCoeffsOn d.F (d.corridor ∪ J) := by
  have hd : IsAperyConnectionCoeffsOn d.extractRegular (d.extractHalf ε₁ ε₂)
              (d.extractOne ε₁ ε₂) d.F d.corridor :=
    d.is_extract_triple hε₁ hε₂ hdet
  obtain ⟨b₀, b_half, b₁, hJ'⟩ := hJ
  refine ⟨d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂, ?_⟩
  exact hd.merge_via_three_probes hJ'
    d.zero_mem h0J hε₁ hε₁J hε₂ hε₂J hdet

/-- **Extended connection data.** Given a connection data `d` and an
external `Has`-witness on `J` overlapping `d.corridor` at three probes,
build a new `AperyConnectionData` whose corridor is `d.corridor ∪ J`.
The underlying analytic extension (`F`) is preserved; the corridor
strictly enlarges. -/
noncomputable def AperyConnectionData.extendCorridor
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    AperyConnectionData where
  toAperyAnalyticExtension := d.toAperyAnalyticExtension
  corridor := d.corridor ∪ J
  zero_mem := Or.inl d.zero_mem
  has_conn := d.has_conn_union_via_three_probes hε₁ hε₂ h0J hε₁J hε₂J hdet hJ

/-- **Extended corridor preserves the underlying function.** The
analytic-extension layer (`F`) of the extended data equals that of the
original data. -/
@[simp] lemma AperyConnectionData.extendCorridor_F
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).F = d.F := rfl

/-- **Extended corridor enlarges to the union.** -/
@[simp] lemma AperyConnectionData.extendCorridor_corridor
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).corridor =
      d.corridor ∪ J := rfl

/-- **Regular extract invariant under corridor extension.** Since
`extractRegular = aperyExtractRegular F` and `F` is preserved by
`extendCorridor`, the extract is unchanged. -/
@[simp] lemma AperyConnectionData.extendCorridor_extractRegular
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).extractRegular =
      d.extractRegular := rfl

/-- **Half extract invariant under corridor extension.** -/
@[simp] lemma AperyConnectionData.extendCorridor_extractHalf
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    (η₁ η₂ : ℝ) :
    (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).extractHalf η₁ η₂ =
      d.extractHalf η₁ η₂ := rfl

/-- **One extract invariant under corridor extension.** -/
@[simp] lemma AperyConnectionData.extendCorridor_extractOne
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    (η₁ η₂ : ℝ) :
    (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).extractOne η₁ η₂ =
      d.extractOne η₁ η₂ := rfl

/-- **Subset preservation in extension.** The original corridor is
contained in the extended corridor. -/
lemma AperyConnectionData.extendCorridor_corridor_subset
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    d.corridor ⊆
      (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).corridor :=
  Set.subset_union_left

/-- **External corridor preserved in extension.** The added external
set `J` is also contained in the extended corridor. -/
lemma AperyConnectionData.extendCorridor_J_subset
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J) :
    J ⊆ (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).corridor :=
  Set.subset_union_right

/-- **Right-side Y₀+Y₁ basis on the extended corridor.** Capstone
combining `extendCorridor` with `F_eq_yZero_plus_yOne_on_right`: for
any right-side point `t` in the union `d.corridor ∪ J` with `t ≥ 0`,
the value `d.F(z₁+t)` is the Y₀+Y₁ Frobenius combination at the
canonical extracts (which are unchanged by the extension). -/
lemma AperyConnectionData.extendCorridor_F_eq_yZero_plus_yOne_on_right
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    {t : ℝ} (ht : t ∈ d.corridor ∪ J) (htnn : 0 ≤ t) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t + yApery (d.extractOne ε₁ ε₂) t := by
  set d' := d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ with hd'
  have hε₁' : (-ε₁) ∈ d'.corridor := Or.inl hε₁
  have hε₂' : (-ε₂) ∈ d'.corridor := Or.inl hε₂
  have ht' : t ∈ d'.corridor := ht
  exact d'.F_eq_yZero_plus_yOne_on_right hε₁' hε₂' hdet ht' htnn

/-- **Left-side Y_½ isolation on the extended corridor.** Lift of
`F_yHalf_isolated` to the extended data: for any `t ∈ d.corridor ∪ J`,
the residual after subtracting Y₀ and Y₁ at the canonical extracts is
exactly the Y_½ branch at `d.extractHalf ε₁ ε₂`. -/
lemma AperyConnectionData.extendCorridor_F_yHalf_isolated
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    {t : ℝ} (ht : t ∈ d.corridor ∪ J) :
    d.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t - yApery (d.extractOne ε₁ ε₂) t =
      yAperyHalf (d.extractHalf ε₁ ε₂) t := by
  set d' := d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ with hd'
  have hε₁' : (-ε₁) ∈ d'.corridor := Or.inl hε₁
  have hε₂' : (-ε₂) ∈ d'.corridor := Or.inl hε₂
  have ht' : t ∈ d'.corridor := ht
  exact d'.F_yHalf_isolated hε₁' hε₂' hdet ht'

/-- **Left-side `frobeniusValue` extraction on the extended corridor.**
For `t < 0` in the extended corridor, divide the isolated half-branch
residual by `√(-t)` to obtain the underlying `frobeniusValue` at
indicial root `1/2` with seed `d.extractHalf ε₁ ε₂`. -/
lemma AperyConnectionData.extendCorridor_F_frobeniusValue_half_via_sqrt_neg_t
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    {t : ℝ} (ht : t ∈ d.corridor ∪ J) (htneg : t < 0) :
    (d.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t - yApery (d.extractOne ε₁ ε₂) t)
        / Real.sqrt (-t) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2)
        (d.extractHalf ε₁ ε₂) t := by
  set d' := d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ with hd'
  have hε₁' : (-ε₁) ∈ d'.corridor := Or.inl hε₁
  have hε₂' : (-ε₂) ∈ d'.corridor := Or.inl hε₂
  have ht' : t ∈ d'.corridor := ht
  exact d'.F_frobeniusValue_half_via_sqrt_neg_t hε₁' hε₂' hdet ht' htneg

/-- **Ext-layer Has-witness union via three probes.** Given two
`Has`-witnesses for `ext.F` on overlapping sets `I, J` sharing three
probe points `{0, -ε₁, -ε₂}` with non-degenerate Cramer determinant,
the `Has`-property extends to `I ∪ J`. Pure ext-layer convenience
wrapper around `AperyConnectionData.has_conn_union_via_three_probes`. -/
lemma AperyAnalyticExtension.has_conn_union_via_three_probes
    (ext : AperyAnalyticExtension) {I J : Set ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0_J : (0 : ℝ) ∈ J)
    {ε₁ ε₂ : ℝ}
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁_J : (-ε₁) ∈ J) (hε₂_J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : HasAperyConnectionCoeffsOn ext.F J) :
    HasAperyConnectionCoeffsOn ext.F (I ∪ J) :=
  let d := AperyConnectionData.of_witness ext I h0_I hI
  d.has_conn_union_via_three_probes hε₁_I hε₂_I h0_J hε₁_J hε₂_J hdet hJ

/-- **Indexed-family chain extension.** Chain-induction payoff: given a
data object `d` and an indexed family of `Has`-witnesses for `d.F` on
sets `J i`, each containing the global probe triple `{0, -ε₁, -ε₂}`
which is also in `d.corridor` (with non-degenerate Cramer
determinant), the `Has`-property extends to the full union
`d.corridor ∪ ⋃ i, J i` at the canonical extracts. -/
lemma AperyConnectionData.has_conn_on_iUnion_of_three_probes
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hH : ∀ i, HasAperyConnectionCoeffsOn d.F (J i)) :
    HasAperyConnectionCoeffsOn d.F (d.corridor ∪ ⋃ i, J i) := by
  have hd : IsAperyConnectionCoeffsOn d.extractRegular (d.extractHalf ε₁ ε₂)
              (d.extractOne ε₁ ε₂) d.F d.corridor :=
    d.is_extract_triple hε₁_d hε₂_d hdet
  have hi : ∀ i, IsAperyConnectionCoeffsOn d.extractRegular
                  (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) d.F (J i) := by
    intro i
    obtain ⟨a, b, c, hJ⟩ := hH i
    obtain ⟨ha, hb, hc⟩ :=
      hd.seeds_unique hJ d.zero_mem (h0 i) hε₁_d (hε₁ i) hε₂_d (hε₂ i) hdet
    rw [← ha, ← hb, ← hc] at hJ
    exact hJ
  refine ⟨d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂, ?_⟩
  exact hd.union (IsAperyConnectionCoeffsOn.iUnion hi)

/-- **Probe invariance extended to the patched corridor.** After
extending `d.corridor` with `J` (overlapping at three probes), the
half-branch extract is invariant under any pair of probe choices
drawn from the union — including pairs where both probes live in `J`
alone. -/
lemma AperyConnectionData.extractHalf_probe_invariant_on_extended
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    {η₁ η₂ η₁' η₂' : ℝ}
    (hη₁ : (-η₁) ∈ d.corridor ∪ J) (hη₂ : (-η₂) ∈ d.corridor ∪ J)
    (hη₁' : (-η₁') ∈ d.corridor ∪ J) (hη₂' : (-η₂') ∈ d.corridor ∪ J)
    (hdetη : aperyConnectionDet η₁ η₂ ≠ 0)
    (hdetη' : aperyConnectionDet η₁' η₂' ≠ 0) :
    d.extractHalf η₁ η₂ = d.extractHalf η₁' η₂' :=
  (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).extractHalf_probe_invariant
    hη₁ hη₂ hη₁' hη₂' hdetη hdetη'

/-- **One-branch probe invariance extended to the patched corridor.** -/
lemma AperyConnectionData.extractOne_probe_invariant_on_extended
    (d : AperyConnectionData) {J : Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : HasAperyConnectionCoeffsOn d.F J)
    {η₁ η₂ η₁' η₂' : ℝ}
    (hη₁ : (-η₁) ∈ d.corridor ∪ J) (hη₂ : (-η₂) ∈ d.corridor ∪ J)
    (hη₁' : (-η₁') ∈ d.corridor ∪ J) (hη₂' : (-η₂') ∈ d.corridor ∪ J)
    (hdetη : aperyConnectionDet η₁ η₂ ≠ 0)
    (hdetη' : aperyConnectionDet η₁' η₂' ≠ 0) :
    d.extractOne η₁ η₂ = d.extractOne η₁' η₂' :=
  (d.extendCorridor hε₁ hε₂ h0J hε₁J hε₂J hdet hJ).extractOne_probe_invariant
    hη₁ hη₂ hη₁' hη₂' hdetη hdetη'

/-- **Ext-layer chain induction.** Indexed family of Has-witnesses on `J i`
sharing a global probe triple, glued onto a base set `I` carrying the same
probes — yields a Has-witness on `I ∪ ⋃ i, J i`. Mirror of the data-layer
`has_conn_on_iUnion_of_three_probes`; uses `of_witness` to lift `I` into a
`ConnectionData` then dispatches to the data-level chain induction. -/
lemma AperyAnalyticExtension.has_conn_on_iUnion_of_three_probes
    (ext : AperyAnalyticExtension) {ι : Type*} {I : Set ℝ} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn ext.F (J i)) :
    HasAperyConnectionCoeffsOn ext.F (I ∪ ⋃ i, J i) :=
  let d := AperyConnectionData.of_witness ext I h0_I hI
  d.has_conn_on_iUnion_of_three_probes hε₁_I hε₂_I h0 hε₁ hε₂ hdet hJ

/-- **Right-side Y₀+Y₁ basis on the chain-glued corridor.** Given a base
Has-witness on `I` and an indexed family of Has-witnesses on `J i` sharing
the global probe triple, the right-side `f(z₁+t) = Y₀ + Y₁` basis lifts to
all of `I ∪ ⋃ i, J i` (for `t ≥ 0`). -/
lemma AperyAnalyticExtension.F_eq_yZero_plus_yOne_on_right_via_iUnion
    (ext : AperyAnalyticExtension) {ι : Type*} {I : Set ℝ} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn ext.F (J i))
    {t : ℝ} (ht : t ∈ I ∪ ⋃ i, J i) (htnn : 0 ≤ t) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero ext.extractRegular t + yApery (ext.extractOne ε₁ ε₂) t := by
  have hU := ext.has_conn_on_iUnion_of_three_probes h0_I h0
    hε₁_I hε₂_I hε₁ hε₂ hdet hI hJ
  obtain ⟨a₀, a_half, a₁, hUis⟩ := hU
  have h0U : (0 : ℝ) ∈ I ∪ ⋃ i, J i := Or.inl h0_I
  have hε₁U : (-ε₁) ∈ I ∪ ⋃ i, J i := Or.inl hε₁_I
  have hε₂U : (-ε₂) ∈ I ∪ ⋃ i, J i := Or.inl hε₂_I
  exact ext.F_eq_yZero_plus_yOne_on_right h0U hUis hε₁U hε₂U hdet ht htnn

/-- **Left-side Y_½ isolation on the chain-glued corridor.** Companion to
`F_eq_yZero_plus_yOne_on_right_via_iUnion`: on `I ∪ ⋃ i, J i`, subtracting
the Y₀ and Y₁ branches gives the Y_½ branch at the standard ext-extracts. -/
lemma AperyAnalyticExtension.F_yHalf_isolated_via_iUnion
    (ext : AperyAnalyticExtension) {ι : Type*} {I : Set ℝ} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn ext.F (J i))
    {t : ℝ} (ht : t ∈ I ∪ ⋃ i, J i) :
    ext.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero ext.extractRegular t - yApery (ext.extractOne ε₁ ε₂) t =
      yAperyHalf (ext.extractHalf ε₁ ε₂) t := by
  have hU := ext.has_conn_on_iUnion_of_three_probes h0_I h0
    hε₁_I hε₂_I hε₁ hε₂ hdet hI hJ
  obtain ⟨a₀, a_half, a₁, hUis⟩ := hU
  have h0U : (0 : ℝ) ∈ I ∪ ⋃ i, J i := Or.inl h0_I
  have hε₁U : (-ε₁) ∈ I ∪ ⋃ i, J i := Or.inl hε₁_I
  have hε₂U : (-ε₂) ∈ I ∪ ⋃ i, J i := Or.inl hε₂_I
  exact ext.F_yHalf_isolated h0U hUis hε₁U hε₂U hdet ht

/-- **`frobeniusValue` extraction on the chain-glued corridor.** -/
lemma AperyAnalyticExtension.F_frobeniusValue_half_via_sqrt_neg_t_via_iUnion
    (ext : AperyAnalyticExtension) {ι : Type*} {I : Set ℝ} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn ext.F (J i))
    {t : ℝ} (ht : t ∈ I ∪ ⋃ i, J i) (htneg : t < 0) :
    (ext.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero ext.extractRegular t - yApery (ext.extractOne ε₁ ε₂) t)
        / Real.sqrt (-t) =
      frobeniusValue (aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold) 2 Number.aperyConifoldZ1Poly (1 / 2)
        (ext.extractHalf ε₁ ε₂) t := by
  have hU := ext.has_conn_on_iUnion_of_three_probes h0_I h0
    hε₁_I hε₂_I hε₁ hε₂ hdet hI hJ
  obtain ⟨a₀, a_half, a₁, hUis⟩ := hU
  have h0U : (0 : ℝ) ∈ I ∪ ⋃ i, J i := Or.inl h0_I
  have hε₁U : (-ε₁) ∈ I ∪ ⋃ i, J i := Or.inl hε₁_I
  have hε₂U : (-ε₂) ∈ I ∪ ⋃ i, J i := Or.inl hε₂_I
  exact ext.F_frobeniusValue_half_via_sqrt_neg_t h0U hUis hε₁U hε₂U hdet ht htneg

/-! #### Data-layer chain capstones -/

/-- **Data-layer right-side Y₀+Y₁ basis on the chain-glued corridor.**
For an indexed family of Has-witnesses `J i` sharing the global probe
triple `(0, -ε₁, -ε₂)` with the base data's corridor, the right-side
basis lifts to `d.corridor ∪ ⋃ i, J i`. Routes through the ext layer's
`F_eq_yZero_plus_yOne_on_right_via_iUnion` using `d.is_extract_triple`
to produce the base Has-witness on `d.corridor`. -/
lemma AperyConnectionData.F_eq_yZero_plus_yOne_on_right_via_iUnion
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i))
    {t : ℝ} (ht : t ∈ d.corridor ∪ ⋃ i, J i) (htnn : 0 ≤ t) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t + yApery (d.extractOne ε₁ ε₂) t := by
  have hI : HasAperyConnectionCoeffsOn d.F d.corridor :=
    ⟨_, _, _, d.is_extract_triple hε₁_d hε₂_d hdet⟩
  exact d.toAperyAnalyticExtension.F_eq_yZero_plus_yOne_on_right_via_iUnion
    d.zero_mem h0 hε₁_d hε₂_d hε₁ hε₂ hdet hI hJ ht htnn

/-- **Data-layer Y_½ isolation on the chain-glued corridor.** -/
lemma AperyConnectionData.F_yHalf_isolated_via_iUnion
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
