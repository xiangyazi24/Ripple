                (2 * Number.aperyConifoldZ1Poly / 3) ≠ 0)
    (h3det : apery3Det (Number.aperyConifoldZ1Poly / 2)
                (2 * Number.aperyConifoldZ1Poly / 3)
                (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0)
    {t : ℝ} (htC : t ∈ I)
    (hz : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple
        (aperyCanonicalExtractRegular3 (Number.aperyConifoldZ1Poly / 2)
          (2 * Number.aperyConifoldZ1Poly / 3)
          (3 * Number.aperyConifoldZ1Poly / 4))
        (aperyCanonicalExtractHalf3 (Number.aperyConifoldZ1Poly / 2)
          (2 * Number.aperyConifoldZ1Poly / 3)
          (3 * Number.aperyConifoldZ1Poly / 4))
        (aperyCanonicalExtractOne3 (Number.aperyConifoldZ1Poly / 2)
          (2 * Number.aperyConifoldZ1Poly / 3)
          (3 * Number.aperyConifoldZ1Poly / 4)) t :=
  (AperyConnectionData.of_witness ext I h0 h).GFA_decomposes_canonical3_standard_probes
    hε₁ hε₂ hε₃ hdet12 h3det htC hz

/-- **Reduce 4-poly hB bound to Q and P bounds.** Since
`aperyPsSeq 0 0 Q P` is `0` for `j ∈ {0, 1}`, `Q` for `j = 2`, and
`P` for `j = 3`, the universal bound `∀ j ∈ range 4` reduces to two
bounds (`hQ`, `hP`) plus `0 ≤ B` for the trivial j=0,1 cases. -/
lemma aperyPsSeq_taylorShift_coeff_abs_le_of_QP
    (Q P : Polynomial ℝ) (z₁ : ℝ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hQ : ∀ ℓ : ℕ, |Polynomial.coeff (taylorShift Q z₁) ℓ| ≤ B)
    (hP : ∀ ℓ : ℕ, |Polynomial.coeff (taylorShift P z₁) ℓ| ≤ B) :
    ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) j) z₁) ℓ| ≤ B := by
  intro j hj ℓ
  rw [Finset.mem_range] at hj
  interval_cases j
  · show |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) 0) z₁) ℓ| ≤ B
    have h0 : (aperyPsSeq 0 0 Q P) 0 = 0 := rfl
    rw [h0, taylorShift_zero, Polynomial.coeff_zero, abs_zero]
    exact hB_nn
  · show |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) 1) z₁) ℓ| ≤ B
    have h1 : (aperyPsSeq 0 0 Q P) 1 = 0 := rfl
    rw [h1, taylorShift_zero, Polynomial.coeff_zero, abs_zero]
    exact hB_nn
  · show |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) 2) z₁) ℓ| ≤ B
    have h2 : (aperyPsSeq 0 0 Q P) 2 = Q := rfl
    rw [h2]; exact hQ ℓ
  · show |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) 3) z₁) ℓ| ≤ B
    have h3 : (aperyPsSeq 0 0 Q P) 3 = P := rfl
    rw [h3]; exact hP ℓ

/-- **Reduce 4-poly weighted-sum bound to Q and P weighted sums.**
Per-`j` weighted-sum analogue of `aperyPsSeq_taylorShift_coeff_abs_le_of_QP`:
for `j ∈ {0, 1}` the polynomial is `0` so the sum vanishes, leaving Q
and P bounds to discharge. Used to plug per-`j` weighted bounds into a
future Gronwall refactor. -/
lemma aperyPsSeq_taylorShift_weighted_sum_le_of_QP
    (Q P : Polynomial ℝ) (z₁ : ℝ) (N : ℕ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hQ : ∑ ℓ ∈ Finset.range N,
            |Polynomial.coeff (taylorShift Q z₁) ℓ| * (2 : ℝ) ^ ℓ ≤ B)
    (hP : ∑ ℓ ∈ Finset.range N,
            |Polynomial.coeff (taylorShift P z₁) ℓ| * (2 : ℝ) ^ ℓ ≤ B) :
    ∀ j ∈ Finset.range 4,
      ∑ ℓ ∈ Finset.range N,
        |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) j) z₁) ℓ|
            * (2 : ℝ) ^ ℓ ≤ B := by
  intro j hj
  rw [Finset.mem_range] at hj
  interval_cases j
  · have h0 : (aperyPsSeq 0 0 Q P) 0 = 0 := rfl
    rw [h0, taylorShift_zero]
    simp only [Polynomial.coeff_zero, abs_zero, zero_mul, Finset.sum_const_zero]
    exact hB_nn
  · have h1 : (aperyPsSeq 0 0 Q P) 1 = 0 := rfl
    rw [h1, taylorShift_zero]
    simp only [Polynomial.coeff_zero, abs_zero, zero_mul, Finset.sum_const_zero]
    exact hB_nn
  · show ∑ ℓ ∈ Finset.range N,
          |Polynomial.coeff (taylorShift ((aperyPsSeq 0 0 Q P) 2) z₁) ℓ|
              * (2 : ℝ) ^ ℓ ≤ B
    have h2 : (aperyPsSeq 0 0 Q P) 2 = Q := rfl
    rw [h2]; exact hQ
  · have h3 : (aperyPsSeq 0 0 Q P) 3 = P := rfl
    rw [h3]; exact hP

/-- **Concrete per-`j` weighted-sum bound at the Apéry conifold.** For
each `j ∈ range 4`, the weighted sum `Σ_{ℓ < 5} |coeff_ℓ|·2^ℓ` of the
`taylorShift` of `aperyPsSeq j` at `z₁` is bounded by `672`. Tight than
the uniform `4·B·2^(n+1) = 4896` derived from `B = 153`: the per-`j`
bound is `~7×` smaller, which a future sharpened Gronwall step would
exploit to widen the convergence threshold by the same factor. -/
lemma aperyPsSeq_aperyConifold_taylorShift_weighted_sum_le_672 :
    ∀ j ∈ Finset.range 4,
      ∑ ℓ ∈ Finset.range 5,
        |Polynomial.coeff (taylorShift
            ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
            Number.aperyConifoldZ1Poly) ℓ| * (2 : ℝ) ^ ℓ ≤ 672 :=
  aperyPsSeq_taylorShift_weighted_sum_le_of_QP
    Number.aperyQconifold Number.aperyPconifold Number.aperyConifoldZ1Poly 5 672
    (by norm_num)
    aperyQconifold_taylorShift_weighted_sum_5_le
    (le_trans aperyPconifold_taylorShift_weighted_sum_le (by norm_num : (300 : ℝ) ≤ 672))

/-- **Concrete instantiation at the Apéry conifold.** The `aperyPsSeq`
ODE coefficient sequence built from `Q = aperyQconifold` and
`P = aperyPconifold`, taylor-shifted to `z₁ = aperyConifoldZ1Poly`,
admits the uniform coefficient bound `|·| ≤ 153` for all `j ∈ range 4`
and all `ℓ : ℕ`. This is the entry point for plugging the bound into
`hM_eps_conv` (ratio-test convergence) downstream. -/
lemma aperyPsSeq_aperyConifold_taylorShift_coeff_abs_le_153 :
    ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff
            (taylorShift
                ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
                Number.aperyConifoldZ1Poly) ℓ|
          ≤ 153 :=
  aperyPsSeq_taylorShift_coeff_abs_le_of_QP
    Number.aperyQconifold Number.aperyPconifold Number.aperyConifoldZ1Poly 153
    (by norm_num)
    aperyQconifold_taylorShift_coeff_abs_le
    aperyPconifold_taylorShift_coeff_abs_le

/-- **Bridge atom (weighted ⇒ pointwise).** A nonneg-weighted sum bound
`Σ_{ℓ < N} |c_ℓ|·2^ℓ ≤ S` is strictly stronger than the per-coefficient
sup bound `|c_ℓ| ≤ S` for every `ℓ ∈ range N`: the single term `|c_ℓ|·2^ℓ`
is bounded by the full sum, and `2^ℓ ≥ 1` lets us drop the weight. This
atom isolates the inequality so downstream lemmas can refer to a named
fact instead of re-deriving it. -/
lemma abs_coeff_le_of_weighted_sum_le_2pow (N : ℕ) (S : ℝ) (f : ℕ → ℝ)
    (h : ∑ ℓ ∈ Finset.range N, |f ℓ| * (2 : ℝ) ^ ℓ ≤ S) :
    ∀ ℓ ∈ Finset.range N, |f ℓ| ≤ S := by
  intro ℓ hℓ
  have h_nonneg : ∀ k ∈ Finset.range N, 0 ≤ |f k| * (2 : ℝ) ^ k := fun k _ =>
    mul_nonneg (abs_nonneg _) (pow_nonneg (by norm_num) _)
  have h_term : |f ℓ| * (2 : ℝ) ^ ℓ ≤ ∑ k ∈ Finset.range N, |f k| * (2 : ℝ) ^ k :=
    Finset.single_le_sum h_nonneg hℓ
  have h_pow_ge_one : (1 : ℝ) ≤ (2 : ℝ) ^ ℓ :=
    one_le_pow₀ (by norm_num : (1 : ℝ) ≤ 2)
  calc |f ℓ| = |f ℓ| * 1 := (mul_one _).symm
    _ ≤ |f ℓ| * (2 : ℝ) ^ ℓ :=
        mul_le_mul_of_nonneg_left h_pow_ge_one (abs_nonneg _)
    _ ≤ ∑ k ∈ Finset.range N, |f k| * (2 : ℝ) ^ k := h_term
    _ ≤ S := h

/-- **Bridge specialization at the Apéry conifold.** Combining
`aperyPsSeq_aperyConifold_taylorShift_weighted_sum_le_672` with
`abs_coeff_le_of_weighted_sum_le_2pow` yields the per-`(j,ℓ)` bound
`|coeff_ℓ| ≤ 672` for `j ∈ range 4` and `ℓ ∈ range 5`. This is the
weighted-sum-derived counterpart to
`aperyPsSeq_aperyConifold_taylorShift_coeff_abs_le_153` (uniform `153`):
the weighted form is `~4.4×` looser pointwise, but tighter on summed
quantities, which is what a sharpened Gronwall step would consume. -/
lemma aperyPsSeq_aperyConifold_taylorShift_coeff_abs_le_672_lt_5 :
    ∀ j ∈ Finset.range 4, ∀ ℓ ∈ Finset.range 5,
        |Polynomial.coeff
            (taylorShift
                ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
                Number.aperyConifoldZ1Poly) ℓ|
          ≤ 672 := by
  intro j hj
  exact abs_coeff_le_of_weighted_sum_le_2pow 5 672
    (fun k => Polynomial.coeff
        (taylorShift
            ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
            Number.aperyConifoldZ1Poly) k)
    (aperyPsSeq_aperyConifold_taylorShift_weighted_sum_le_672 j hj)

/-- **Reverse bridge (pointwise ⇒ weighted).** A per-coefficient sup
bound `|c_ℓ| ≤ S` (`S ≥ 0`) implies the weighted-sum bound
`Σ_{ℓ < N} |c_ℓ|·2^ℓ ≤ S · (2^N - 1)` via `Σ_{ℓ < N} 2^ℓ = 2^N - 1`.
This is the formal inverse of `abs_coeff_le_of_weighted_sum_le_2pow`,
showing the two bounds carry the same information up to a `(2^N - 1)`
factor and clarifying which form is sharper for given `N` and `S`. -/
lemma weighted_sum_le_of_abs_coeff_le_2pow (N : ℕ) (S : ℝ) (hS : 0 ≤ S)
    (f : ℕ → ℝ) (h : ∀ ℓ ∈ Finset.range N, |f ℓ| ≤ S) :
    ∑ ℓ ∈ Finset.range N, |f ℓ| * (2 : ℝ) ^ ℓ ≤ S * ((2 : ℝ) ^ N - 1) := by
  have h_geo : ∑ ℓ ∈ Finset.range N, (2 : ℝ) ^ ℓ = (2 : ℝ) ^ N - 1 := by
    have h1 : ∑ ℓ ∈ Finset.range N, (2 : ℝ) ^ ℓ = ((2 : ℝ) ^ N - 1) / (2 - 1) :=
      geom_sum_eq (by norm_num : (2 : ℝ) ≠ 1) N
    rw [h1]; ring
  calc ∑ ℓ ∈ Finset.range N, |f ℓ| * (2 : ℝ) ^ ℓ
      ≤ ∑ ℓ ∈ Finset.range N, S * (2 : ℝ) ^ ℓ := by
        apply Finset.sum_le_sum
        intro ℓ hℓ
        exact mul_le_mul_of_nonneg_right (h ℓ hℓ) (pow_nonneg (by norm_num) _)
    _ = S * ∑ ℓ ∈ Finset.range N, (2 : ℝ) ^ ℓ := by
        rw [Finset.mul_sum]
    _ = S * ((2 : ℝ) ^ N - 1) := by rw [h_geo]

/-- **Apéry conifold Z-branch contracted Frobenius bound (ρ = 0).**
Instantiates `abs_frobeniusCoeff_succ_contracted_general` at the Apéry
conifold third-order ODE for the trivial-exponent branch `ρ = 0`,
`n = 2`. The hypothesis bundle decomposes as:
- `hpk` from `aperyPconifold_eval_z1` (ps 3 = P, P(z₁) = 0);
- `hslope` from `aperyPconifold_deriv_eval_z1_ne_zero`;
- threshold from `aperyConifold_threshold_Z` (uses `2|q(z₁)| = 3|p'(z₁)|`);
- B-bound from `aperyPsSeq_aperyConifold_taylorShift_coeff_abs_le_153`.

For `m ≥ 6`, the bound reads
`|a_{m+1}|·|p'(z₁)| ≤ 9792 · Σ_{i ≤ m} |a_i|`. The denominator
`|p'(z₁)| ≈ 0.029` makes the effective Gronwall constant `K_uniform ≈
337,408` (recovered via `aperyConifold_K_uniform_gt_166464` with the
appropriate scaling — the half-strength general bound contributes the
factor of 2 here, so the actual `K_general = 2·K_uniform > 332,928`).
This is the first Apéry-applicable Frobenius recurrence step that
uses the *general* (no `q(z₁) = 0`) indicial lower bound at the
conifold; the simple-zero variant fails because
`Q(z₁) = 29376 − 20772√2 ≠ 0`. -/
lemma aperyConifold_frobenius_Z_contracted (c₀ : ℝ) (m : ℕ) (hm : 6 ≤ m) :
    |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ (m + 1)| *
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)| ≤
      2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) *
        ∑ i ∈ Finset.range (m + 1),
          |frobeniusCoeff
              (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
              Number.aperyConifoldZ1Poly 0 c₀ i| := by
  have h3eq : (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 3 =
      Number.aperyPconifold := rfl
  have h2eq : (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2 =
      Number.aperyQconifold := rfl
  have hpk : (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1)).eval
        Number.aperyConifoldZ1Poly = 0 := by
    rw [show (2 + 1 : ℕ) = 3 from rfl, h3eq]
    exact Number.aperyPconifold_eval_z1
  have hslope : (Polynomial.derivative
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1))).eval
        Number.aperyConifoldZ1Poly ≠ 0 := by
    rw [show (2 + 1 : ℕ) = 3 from rfl, h3eq]
    exact Number.aperyPconifold_deriv_eval_z1_ne_zero
  have hm_small : (|(0 : ℝ)| + ((2 : ℕ) : ℝ)) < (((m + 1 : ℕ) : ℝ)) := by
    have := Number.aperyConifold_small_Z m hm
    push_cast; push_cast at this; linarith
  have hm_large : 3 * |(0 : ℝ)| + 3 * ((2 : ℕ) : ℝ) ≤ (m : ℝ) := by
    have := Number.aperyConifold_large_Z m hm
    push_cast; push_cast at this; linarith
  have h_thresh : 2 * |(aperyPsSeq 0 0 Number.aperyQconifold
        Number.aperyPconifold 2).eval Number.aperyConifoldZ1Poly| ≤
      |(Polynomial.derivative
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1))).eval
          Number.aperyConifoldZ1Poly| *
        (((m + 1 : ℕ) : ℝ) - |(0 : ℝ)| - ((2 : ℕ) : ℝ)) := by
    rw [show (2 + 1 : ℕ) = 3 from rfl, h2eq, h3eq]
    have hZ := Number.aperyConifold_threshold_Z m (by omega)
    push_cast; push_cast at hZ; linarith
  exact abs_frobeniusCoeff_succ_contracted_general
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
    Number.aperyConifoldZ1Poly 0 c₀ m
    hpk hslope hm_small hm_large h_thresh
    153 (by norm_num)
    aperyPsSeq_aperyConifold_taylorShift_coeff_abs_le_153

/-- **Apéry conifold H-branch contracted Frobenius bound (ρ = 1/2).**
Companion of `aperyConifold_frobenius_Z_contracted` for the half-integer
exponent branch. Uses `aperyConifold_threshold_H` (active for `m ≥ 5`)
and `aperyConifold_small_H`/`aperyConifold_large_H` (both active for
`m ≥ 8`, the binding constraint here). For `m ≥ 8`, the bound reads
`|a_{m+1}|·|p'(z₁)| ≤ 9792 · Σ_{i ≤ m} |a_i|` — same constant as the
Z branch since the prefactor `2·(n+2)·B·2^{n+1}` does not depend on
