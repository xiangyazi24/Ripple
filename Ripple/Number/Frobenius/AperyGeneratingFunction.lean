/-- **3-probe det non-vanishing forces pairwise distinct probes.** If
`apery3Det ε₁ ε₂ ε₃ ≠ 0`, then `ε₁ ≠ ε₂`, `ε₁ ≠ ε₃`, and `ε₂ ≠ ε₃`.
Mirrors `aperyConnectionDet_ne_zero_probes_nonzero` and rules out
trivially degenerate witnesses. -/
lemma apery3Det_ne_zero_probes_distinct {ε₁ ε₂ ε₃ : ℝ}
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0) :
    ε₁ ≠ ε₂ ∧ ε₁ ≠ ε₃ ∧ ε₂ ≠ ε₃ := by
  refine ⟨?_, ?_, ?_⟩
  · intro h; subst h; simp at h3det
  · intro h; subst h; simp at h3det
  · intro h; subst h; simp at h3det

/-- **Sharper numerical bound: `z₁ > 1/34`.** Since `z₁ = 17 − 12√2` and
`√2 < 1087/768`, we get `z₁ > 17 − 12·1087/768 = 17 − 1087/64 = 1/64`.
For the tighter `1/34` bound: `√2 < 577/408` (from `577² = 332929 < 332928 + 1`
isn't right — use `√2 < 17/12` gives `z₁ > 0`, but we need more precision).
We use `√2 < 571/404` which gives `z₁ > 17 − 12·571/404 = 17 − 6852/404`. -/
lemma aperyConifoldZ1Poly_gt_one_div_34 :
    (1 / 34 : ℝ) < Number.aperyConifoldZ1Poly := by
  unfold Number.aperyConifoldZ1Poly
  -- Need: 1/34 < 17 - 12√2, i.e., 12√2 < 17 - 1/34 = 577/34
  -- i.e., √2 < 577/408
  -- Check: (577/408)² = 332929/166464 and 2 = 332928/166464, so 577² = 332929 > 332928 = 2·408²
  have hsqrt2_ub : Real.sqrt 2 < 577 / 408 := by
    have h2_pos : (0 : ℝ) ≤ 2 := by norm_num
    have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt h2_pos
    have hnn : 0 ≤ Real.sqrt 2 := Real.sqrt_nonneg _
    nlinarith [hsq, hnn]
  linarith

lemma aperyConifoldZ1Poly_gt_one_div_64 :
    (1 / 64 : ℝ) < Number.aperyConifoldZ1Poly := by
  linarith [aperyConifoldZ1Poly_gt_one_div_34]

/-- **Disk membership of `z₁ − ε` forces `ε > 0`.** Since `z₁ > 1/64`
and `z₁ − ε < 1/64`, we get `ε > z₁ − 1/64 > 0`. Rules out `ε = 0` as
a probe in any disk-based hypothesis. -/
lemma disk_membership_implies_pos_eps {ε : ℝ}
    (h : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    0 < ε := by
  have ⟨_, h2⟩ := h
  have hz1 := aperyConifoldZ1Poly_gt_one_div_64
  linarith

/-- **Disk membership ↔ ε in admissible probe range.** Translates the
geometric `z₁ - ε ∈ [0, 1/64)` constraint into the algebraic
`ε ∈ (z₁ - 1/64, z₁]`. Useful for any explicit probe construction:
the witness (ε₁, ε₂, ε₃) for `apery3Det ≠ 0` must lie in this
half-open interval. -/
lemma disk_membership_iff_eps_in_range {ε : ℝ} :
    Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64) ↔
      ε ∈ Set.Ioc
        (Number.aperyConifoldZ1Poly - 1 / 64) Number.aperyConifoldZ1Poly := by
  constructor
  · rintro ⟨h1, h2⟩
    refine ⟨?_, ?_⟩ <;> linarith
  · rintro ⟨h1, h2⟩
    refine ⟨?_, ?_⟩ <;> linarith

/-- **Numerical bound: `z₁ < 1/32`.** Tightening of
`aperyConifoldZ1Poly_lt_one`. Equivalent to `√2 > 543/384`, since
`543² = 294849 < 294912 = 2·384²` so `(543/384)² < 2`. Implies the
disk-eps range `(z₁ - 1/64, z₁]` has length less than `1/32`. -/
lemma aperyConifoldZ1Poly_lt_one_div_32 :
    Number.aperyConifoldZ1Poly < 1 / 32 := by
  unfold Number.aperyConifoldZ1Poly
  have hsqrt2_lb : 543 / 384 < Real.sqrt 2 := by
    have h2_pos : (0 : ℝ) ≤ 2 := by norm_num
    have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt h2_pos
    have hnn : 0 ≤ Real.sqrt 2 := Real.sqrt_nonneg _
    nlinarith [hsq, hnn]
  linarith

/-- **First concrete disk-admissible probe: `z₁/2`.** From
`z₁ ∈ (1/64, 1/32)` it follows that `z₁/2 ∈ (z₁ - 1/64, z₁)`, hence
the disk hypothesis `z₁ + (-z₁/2) ∈ [0, 1/64)` holds. Provides an
explicit candidate epsilon for the Gap E witness construction. -/
lemma half_z1_in_disk_eps_range :
    Number.aperyConifoldZ1Poly / 2 ∈
      Set.Ioc
        (Number.aperyConifoldZ1Poly - 1 / 64) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · have hz_lt := aperyConifoldZ1Poly_lt_one_div_32
    linarith
  · have hz_pos := aperyConifoldZ1Poly_pos
    linarith

/-- **`z₁/2` satisfies the disk hypothesis directly.** Forward
direction of `disk_membership_iff_eps_in_range` applied to
`half_z1_in_disk_eps_range`. Lets later Gap E witness atoms supply
the disk hypothesis without manual unfolding. -/
lemma half_z1_disk_hypothesis :
    Number.aperyConifoldZ1Poly + (-(Number.aperyConifoldZ1Poly / 2)) ∈
      Set.Ico (0 : ℝ) (1 / 64) :=
  disk_membership_iff_eps_in_range.mpr half_z1_in_disk_eps_range

/-- **Second concrete disk-admissible probe: `2z₁/3`.** From
`z₁ < 1/32` we get `z₁/3 < 1/96 < 1/64`, so `2z₁/3 > z₁ - 1/64`.
Distinct from `z₁/2`. -/
lemma two_thirds_z1_in_disk_eps_range :
    2 * Number.aperyConifoldZ1Poly / 3 ∈
      Set.Ioc
        (Number.aperyConifoldZ1Poly - 1 / 64) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · have hz_lt := aperyConifoldZ1Poly_lt_one_div_32
    linarith
  · have hz_pos := aperyConifoldZ1Poly_pos
    linarith

/-- **`2z₁/3` satisfies the disk hypothesis directly.** -/
lemma two_thirds_z1_disk_hypothesis :
    Number.aperyConifoldZ1Poly + (-(2 * Number.aperyConifoldZ1Poly / 3)) ∈
      Set.Ico (0 : ℝ) (1 / 64) :=
  disk_membership_iff_eps_in_range.mpr two_thirds_z1_in_disk_eps_range

/-- **Third concrete disk-admissible probe: `3z₁/4`.** From
`z₁ < 1/32 < 1/16` we get `z₁/4 < 1/64`, so `3z₁/4 > z₁ - 1/64`.
Distinct from `z₁/2` and `2z₁/3`, completing the three-probe set. -/
lemma three_quarters_z1_in_disk_eps_range :
    3 * Number.aperyConifoldZ1Poly / 4 ∈
      Set.Ioc
        (Number.aperyConifoldZ1Poly - 1 / 64) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · have hz_lt := aperyConifoldZ1Poly_lt_one_div_32
    linarith
  · have hz_pos := aperyConifoldZ1Poly_pos
    linarith

/-- **`3z₁/4` satisfies the disk hypothesis directly.** -/
lemma three_quarters_z1_disk_hypothesis :
    Number.aperyConifoldZ1Poly + (-(3 * Number.aperyConifoldZ1Poly / 4)) ∈
      Set.Ico (0 : ℝ) (1 / 64) :=
  disk_membership_iff_eps_in_range.mpr three_quarters_z1_in_disk_eps_range

/-- **Positivity of the three concrete probes.** Since `z₁ > 0`, the
rational multiples `z₁/2, 2z₁/3, 3z₁/4` are all strictly positive.
Needed for the `Real.sqrt_inj`-based sqrt-distinctness arguments and
for `apery3Det_unit_cores_ne_zero`. -/
lemma standard_three_probes_pos :
    0 < Number.aperyConifoldZ1Poly / 2 ∧
      0 < 2 * Number.aperyConifoldZ1Poly / 3 ∧
        0 < 3 * Number.aperyConifoldZ1Poly / 4 := by
  have hz_pos := aperyConifoldZ1Poly_pos
  refine ⟨by linarith, by linarith, by linarith⟩

/-- **Pairwise distinctness of the three concrete probes.** Since
`z₁ > 0`, the rational multiples `z₁/2, 2z₁/3, 3z₁/4` are mutually
distinct. Necessary precondition for `apery3Det` non-vanishing. -/
lemma standard_three_probes_distinct :
    Number.aperyConifoldZ1Poly / 2 ≠ 2 * Number.aperyConifoldZ1Poly / 3 ∧
      Number.aperyConifoldZ1Poly / 2 ≠ 3 * Number.aperyConifoldZ1Poly / 4 ∧
        2 * Number.aperyConifoldZ1Poly / 3 ≠
          3 * Number.aperyConifoldZ1Poly / 4 := by
  have hz_pos := aperyConifoldZ1Poly_pos
  refine ⟨?_, ?_, ?_⟩
  · intro h; linarith
  · intro h; linarith
  · intro h; linarith

/-- **Vandermonde-of-sqrt non-vanishing at the standard probes.**
Specializes `vandermonde_sqrt_ne_zero` to the concrete probe set
`(z₁/2, 2z₁/3, 3z₁/4)` using `standard_three_probes_pos` and
`standard_three_probes_distinct`. The leading-order non-vanishing
target for `apery3Det` at the standard probes (modulo the unit-core
hypotheses, addressed separately). -/
lemma standard_vandermonde_sqrt_ne_zero :
    (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
        Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
      (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
          Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
      (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
          Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3)) ≠ 0 := by
  have ⟨h1, h2, h3⟩ := standard_three_probes_pos
  have ⟨h12, h13, h23⟩ := standard_three_probes_distinct
  exact vandermonde_sqrt_ne_zero h1.le h2.le h3.le h12 h13 h23

/-- **Strict positivity of the sqrt-Vandermonde at the standard
probes.** Stronger than `standard_vandermonde_sqrt_ne_zero`: each of
the three factors is strictly positive (the larger sqrt minus the
smaller), so the product is strictly positive. Useful for taking the
quantity itself as the lower bound `M` in
`apery3Det_ne_zero_of_near_unit_cores`. -/
lemma standard_vandermonde_sqrt_pos :
    0 <
      (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
          Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3)) := by
  have hz_pos := aperyConifoldZ1Poly_pos
  have h12 : Number.aperyConifoldZ1Poly / 2 < 2 * Number.aperyConifoldZ1Poly / 3 := by
    linarith
  have h13 : Number.aperyConifoldZ1Poly / 2 < 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have h23 : 2 * Number.aperyConifoldZ1Poly / 3 < 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have hp1 : 0 ≤ Number.aperyConifoldZ1Poly / 2 := by linarith
  have hp2 : 0 ≤ 2 * Number.aperyConifoldZ1Poly / 3 := by linarith
  have hf1 : 0 < Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
      Real.sqrt (Number.aperyConifoldZ1Poly / 2) :=
    sub_pos.mpr (Real.sqrt_lt_sqrt hp1 h12)
  have hf2 : 0 < Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
      Real.sqrt (Number.aperyConifoldZ1Poly / 2) :=
    sub_pos.mpr (Real.sqrt_lt_sqrt hp1 h13)
  have hf3 : 0 < Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
      Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) :=
    sub_pos.mpr (Real.sqrt_lt_sqrt hp2 h23)
  exact mul_pos (mul_pos hf1 hf2) hf3

/-- **Absolute value of the sqrt-Vandermonde at the standard probes
equals the value itself.** Direct from `standard_vandermonde_sqrt_pos`
via `abs_of_pos`. The convenience form for plugging into
`apery3Det_ne_zero_of_near_unit_cores` as the lower bound `M`. -/
lemma standard_vandermonde_sqrt_abs_eq :
    |(Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
          Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))| =
      (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
          Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3)) :=
  abs_of_pos standard_vandermonde_sqrt_pos

/-- **`apery3Det` non-vanishing at the standard probes — unit-core
form.** Specializes `apery3Det_unit_cores_ne_zero` to the concrete
probe set `(z₁/2, 2z₁/3, 3z₁/4)`. Under the unit-core hypotheses
(only literally true at `ε = 0`, the leading-order target), the
3-probe det at the standard probes is nonzero. -/
lemma standard_apery3Det_unit_cores_ne_zero
    (hZ1 : aperyBranchAmplitude_zero (Number.aperyConifoldZ1Poly / 2) = 1)
    (hZ2 : aperyBranchAmplitude_zero (2 * Number.aperyConifoldZ1Poly / 3) = 1)
    (hZ3 : aperyBranchAmplitude_zero (3 * Number.aperyConifoldZ1Poly / 4) = 1)
    (hH1 : aperyBranchHalfCore (Number.aperyConifoldZ1Poly / 2) = 1)
    (hH2 : aperyBranchHalfCore (2 * Number.aperyConifoldZ1Poly / 3) = 1)
    (hH3 : aperyBranchHalfCore (3 * Number.aperyConifoldZ1Poly / 4) = 1)
    (hO1 : aperyBranchOneCore (Number.aperyConifoldZ1Poly / 2) = 1)
    (hO2 : aperyBranchOneCore (2 * Number.aperyConifoldZ1Poly / 3) = 1)
    (hO3 : aperyBranchOneCore (3 * Number.aperyConifoldZ1Poly / 4) = 1) :
    apery3Det (Number.aperyConifoldZ1Poly / 2)
        (2 * Number.aperyConifoldZ1Poly / 3)
        (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0 := by
  have ⟨h1, h2, h3⟩ := standard_three_probes_pos
  have ⟨h12, h13, h23⟩ := standard_three_probes_distinct
  exact apery3Det_unit_cores_ne_zero h1 h2 h3 h12 h13 h23
    hZ1 hZ2 hZ3 hH1 hH2 hH3 hO1 hO2 hO3

/-- **`apery3Det` non-vanishing at the standard probes — near-unit
core form.** Specializes `apery3Det_ne_zero_of_near_unit_cores` to the
concrete probe set `(z₁/2, 2z₁/3, 3z₁/4)` with `M` instantiated as
the sqrt-Vandermonde value itself (positive by
`standard_vandermonde_sqrt_pos`). The caller supplies only the
perturbation upper bound `R` and the strict-domination hypothesis
`R < V_standard`. Used to discharge the leading-order non-vanishing
hypothesis of the GFA decomposition without needing exact unit-core
values — the analytic deviation framework supplies `R` from the
nine `_abs_sub_one_le` bounds. -/
lemma standard_apery3Det_ne_zero_of_near_unit_cores
    (R : ℝ)
    (hR : |apery3Det (Number.aperyConifoldZ1Poly / 2)
              (2 * Number.aperyConifoldZ1Poly / 3)
              (3 * Number.aperyConifoldZ1Poly / 4) +
            (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
                Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))| ≤ R)
    (hRV : R <
      (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
          Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))) :
    apery3Det (Number.aperyConifoldZ1Poly / 2)
        (2 * Number.aperyConifoldZ1Poly / 3)
        (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0 := by
  set V : ℝ := (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
        (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
            Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3)) with hV_def
  have hV_pos : 0 < V := standard_vandermonde_sqrt_pos
  have hV_abs : |V| = V := abs_of_pos hV_pos
  exact apery3Det_ne_zero_of_near_unit_cores V hV_pos hV_abs.ge R hR hRV

/-- **`apery3Det` non-vanishing at the standard probes — full deviation
+ probe + Vandermonde form.** Specializes
`apery3Det_ne_zero_of_dev_and_probe_bounds` to the concrete probe set
`(z₁/2, 2z₁/3, 3z₁/4)`. The probe ceiling `M_eps` is the maximum
`3z₁/4`, and the Vandermonde lower bound is the explicit positive
sqrt-Vandermonde value at the standard probes (via
`standard_vandermonde_sqrt_pos`). The caller supplies only the nine
single-core deviation bounds plus the gate inequality. -/
lemma standard_apery3Det_ne_zero_of_dev_and_probe_bounds
    {R : ℝ}
    (hZ₁ : |aperyBranchAmplitude_zero (Number.aperyConifoldZ1Poly / 2) - 1| ≤ R)
    (hZ₂ : |aperyBranchAmplitude_zero (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ R)
    (hZ₃ : |aperyBranchAmplitude_zero (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ R)
    (hH₁ : |aperyBranchHalfCore (Number.aperyConifoldZ1Poly / 2) - 1| ≤ R)
    (hH₂ : |aperyBranchHalfCore (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ R)
    (hH₃ : |aperyBranchHalfCore (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ R)
    (hO₁ : |aperyBranchOneCore (Number.aperyConifoldZ1Poly / 2) - 1| ≤ R)
    (hO₂ : |aperyBranchOneCore (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ R)
    (hO₃ : |aperyBranchOneCore (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ R)
    (hgap : (R * (1 + R) ^ 2 + R * (1 + R) + R) *
              (6 * (3 * Number.aperyConifoldZ1Poly / 4) *
                Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4)) <
            (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
                Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))) :
    apery3Det (Number.aperyConifoldZ1Poly / 2)
        (2 * Number.aperyConifoldZ1Poly / 3)
        (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0 := by
  have ⟨h1, h2, h3⟩ := standard_three_probes_pos
  have hz_pos := aperyConifoldZ1Poly_pos
  have hM₁ : Number.aperyConifoldZ1Poly / 2 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have hM₂ : 2 * Number.aperyConifoldZ1Poly / 3 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have hM₃ : 3 * Number.aperyConifoldZ1Poly / 4 ≤ 3 * Number.aperyConifoldZ1Poly / 4 :=
    le_refl _
  refine apery3Det_ne_zero_of_dev_and_probe_bounds
    h1.le h2.le h3.le hM₁ hM₂ hM₃
    hZ₁ hZ₂ hZ₃ hH₁ hH₂ hH₃ hO₁ hO₂ hO₃
    standard_vandermonde_sqrt_pos
    ?_ hgap
  rw [standard_vandermonde_sqrt_abs_eq]

/-- **Uniform tsum-style deviation bound — monotonicity in the probe.**
Given a positive nondecreasing series `∑ c_m ε^m` (with `c_m ≥ 0`),
the product `ε · ∑' m, c_m · ε^m` is monotone in `ε` on `[0, M]`. The
hypothesis is summability at `M`; summability at any `ε ≤ M` then
follows by termwise comparison. Used to lift per-probe deviation
bounds `|core(ε) − 1| ≤ ε · tsum_at_ε` to the uniform bound
`|core(ε) − 1| ≤ M · tsum_at_M` for all `ε ∈ [0, M]`. -/
lemma dev_bound_le_uniform
    {ε M : ℝ} (hε_nn : 0 ≤ ε) (hε_M : ε ≤ M)
    {c : ℕ → ℝ} (hc_nn : ∀ m, 0 ≤ c m)
    (hsum_M : Summable (fun m => c m * M ^ m)) :
    ε * ∑' m, c m * ε ^ m ≤ M * ∑' m, c m * M ^ m := by
  have hM_nn : 0 ≤ M := hε_nn.trans hε_M
  have hsum_ε : Summable (fun m => c m * ε ^ m) := by
    refine (hsum_M.of_nonneg_of_le (fun m => ?_) (fun m => ?_))
    · exact mul_nonneg (hc_nn m) (pow_nonneg hε_nn m)
    · exact mul_le_mul_of_nonneg_left
        (pow_le_pow_left₀ hε_nn hε_M m) (hc_nn m)
  have htsum_le : ∑' m, c m * ε ^ m ≤ ∑' m, c m * M ^ m := by
    refine hsum_ε.tsum_le_tsum (fun m => ?_) hsum_M
    exact mul_le_mul_of_nonneg_left
      (pow_le_pow_left₀ hε_nn hε_M m) (hc_nn m)
  have htsum_ε_nn : 0 ≤ ∑' m, c m * ε ^ m := by
    refine tsum_nonneg (fun m => ?_)
    exact mul_nonneg (hc_nn m) (pow_nonneg hε_nn m)
  have htsum_M_nn : 0 ≤ ∑' m, c m * M ^ m := by
    refine tsum_nonneg (fun m => ?_)
    exact mul_nonneg (hc_nn m) (pow_nonneg hM_nn m)
  calc ε * ∑' m, c m * ε ^ m
      ≤ M * ∑' m, c m * ε ^ m := by
        exact mul_le_mul_of_nonneg_right hε_M htsum_ε_nn
    _ ≤ M * ∑' m, c m * M ^ m := by
        exact mul_le_mul_of_nonneg_left htsum_le hM_nn

/-- **Trans wrapper for uniform deviation bound.** Given
`y ≤ ε · ∑' m, c_m · ε^m` (a per-probe deviation in tsum form), the
uniform bound `y ≤ M · ∑' m, c_m · M^m` follows directly by
`dev_bound_le_uniform`. Convenience trans-form for chaining the
three branch-specific `abs_sub_one_le` outputs onto the standard
probe ceiling `M_eps`. -/
lemma uniform_dev_of_per_probe
    {x M : ℝ} (hε_nn : 0 ≤ x) (hε_M : x ≤ M)
    {c : ℕ → ℝ} (hc_nn : ∀ m, 0 ≤ c m)
    (hsum_M : Summable (fun m => c m * M ^ m))
    {y : ℝ}
    (h_per_probe : y ≤ x * ∑' m, c m * x ^ m) :
    y ≤ M * ∑' m, c m * M ^ m :=
  h_per_probe.trans (dev_bound_le_uniform hε_nn hε_M hc_nn hsum_M)

/-- **Algebraic restatement of the Frobenius convergence threshold.**
The hypothesis form used downstream,
`M_eps · (1 + 2·4·B·2³/|p'(z₁)|) < 1`, simplifies to the linear bound
`M_eps · (|p'(z₁)| + 64·B) < |p'(z₁)|`, which makes the explicit cap
`M_eps < |p'(z₁)|/(|p'(z₁)| + 64·B)` direct. With `B = 153` and
`|p'(z₁)| = 13848·√2 - 19584 ≈ 0.029`, the cap is `≈ 0.029/9792 ≈ 3·10⁻⁶`.
This documents the gap between the standard probe `3z₁/4 ≈ 0.022`
and the Frobenius tail bound: a future tightening either lowers `B`
to a per-`ℓ` weighted form or replaces the geometric `2³` factor. -/
lemma M_eps_conv_iff_linear (B M_eps : ℝ) :
    M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) < 1 ↔
    M_eps * (|Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| + 64 * B) <
      |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| := by
  have hp_pos := Number.aperyPconifold_deriv_eval_z1_abs_pos
  set p := |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| with hp_def
  have hp_ne : p ≠ 0 := ne_of_gt hp_pos
  have hrewrite :
      M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) / p)
        = M_eps * (p + 64 * B) / p := by
    field_simp; ring
  rw [hrewrite, div_lt_one hp_pos]

/-- **The Frobenius convergence threshold fails at the standard probe `3z₁/4`
with the uniform bound `B = 153`.** Documents the quantitative gap
between the Frobenius tail bound and the corridor right endpoint:
the cap `M_eps < |p'(z₁)|/(|p'(z₁)| + 64·B)` is `≈ 3·10⁻⁶`, while the
standard probe `M_eps = 3z₁/4 ≈ 0.022` is four orders of magnitude
larger. Closing this gap requires either a per-`ℓ` weighted bound
(replacing uniform `B = max_ℓ |coeff_ℓ|` by a position-aware sum) or a
sharper geometric tail. Concretely: with `B = 153`,
`(3z₁/4) · (1 + 64·153/|p'(z₁)|) > 1`. -/
lemma M_eps_conv_fails_at_standard_probe_with_B_153 :
    ¬ ((3 * Number.aperyConifoldZ1Poly / 4) *
        (1 + 2 * (4 : ℝ) * 153 * ((2 : ℝ) ^ 3) /
          |Polynomial.eval Number.aperyConifoldZ1Poly
            (Polynomial.derivative Number.aperyPconifold)|) < 1) := by
  intro h
  rw [M_eps_conv_iff_linear] at h
  rw [Number.aperyPconifold_deriv_eval_z1_abs] at h
  unfold Number.aperyConifoldZ1Poly at h
  have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
  have hsqrt_pos : 0 < Real.sqrt 2 := Real.sqrt_pos.mpr (by norm_num : (0:ℝ) < 2)
  nlinarith [sq_nonneg (250842 * Real.sqrt 2 - 354528), hsq, hsqrt_pos, h]

/-- **Feasibility witness for the threshold.** With `B = 153`, the threshold
`hM_eps_conv` IS satisfied at the microscopic probe `M_eps = |p'(z₁)|/100000`.
Combined with `M_eps_conv_fails_at_standard_probe_with_B_153`, this brackets
the feasible scale: somewhere between `|p'(z₁)|/100000 ≈ 3·10⁻⁷` and
`3z₁/4 ≈ 0.022` lies the actual cap `≈ 3·10⁻⁶`. Establishes that the
gate is solvable — just at a scale four orders of magnitude smaller than
the standard corridor probe. -/
lemma M_eps_conv_holds_at_microscale_with_B_153 :
    (|Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)| / 100000) *
      (1 + 2 * (4 : ℝ) * 153 * ((2 : ℝ) ^ 3) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) < 1 := by
  rw [M_eps_conv_iff_linear]
  have hp_pos := Number.aperyPconifold_deriv_eval_z1_abs_pos
  set p := |Polynomial.eval Number.aperyConifoldZ1Poly
      (Polynomial.derivative Number.aperyPconifold)| with hp_def
  have hkey : p + 64 * 153 < 100000 := by
    rw [hp_def, Number.aperyPconifold_deriv_eval_z1_abs]
    have hsq_eq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
    have hsqrt_nn := Real.sqrt_nonneg (2:ℝ)
    have hsqrt_lt2 : Real.sqrt 2 < 2 := by nlinarith [hsq_eq, hsqrt_nn]
    nlinarith [hsqrt_lt2, hsqrt_nn]
  have h_div_pos : 0 < p / 100000 := by positivity
  calc (p / 100000) * (p + 64 * 153)
      < (p / 100000) * 100000 := by
        exact mul_lt_mul_of_pos_left hkey h_div_pos
    _ = p := by field_simp

/-- **Uniform deviation bound for `aperyBranchAmplitude_zero`.**
Lifts the per-probe `aperyBranchAmplitude_zero_abs_sub_one_le` to a
ceiling `M_eps`: for any `ε ∈ [0, M_eps]`, the deviation is bounded
by the same Frobenius-tsum quantity evaluated at `M_eps`. Caller
supplies the standard `(M₀, B, ...)` parameter pile plus a
convergence hypothesis at `M_eps` and summability of the tsum at
`M_eps`. -/
lemma aperyBranchAmplitude_zero_abs_sub_one_le_uniform
    (M₀ : ℕ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hM0_small : ∀ m, M₀ ≤ m → (|(0 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large : ∀ m, M₀ ≤ m → 3 * |(0 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh : ∀ m', M₀ ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(0 : ℝ)| - (2 : ℝ)))
    (hB : ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff (taylorShift
          ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
          Number.aperyConifoldZ1Poly) ℓ| ≤ B)
    (M_eps : ℝ) (hM_eps_nn : 0 ≤ M_eps)
    (hM_eps_conv : M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) < 1)
    (hsum_M : Summable (fun m => |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 1 (m + 1)| * M_eps ^ m))
    (ε : ℝ) (hε_nn : 0 ≤ ε) (hε_M : ε ≤ M_eps) :
    |aperyBranchAmplitude_zero ε - 1| ≤
      M_eps * ∑' m, |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 1 (m + 1)| * M_eps ^ m := by
  have habs_eq : |ε| = ε := abs_of_nonneg hε_nn
  have hCnn : 0 ≤ 1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)| := by positivity
  have hε_conv : |ε| * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)|) < 1 := by
    rw [habs_eq]
    calc ε * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
            |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)|)
        ≤ M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
            |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)|) :=
          mul_le_mul_of_nonneg_right hε_M hCnn
      _ < 1 := hM_eps_conv
  have h_per_probe := aperyBranchAmplitude_zero_abs_sub_one_le M₀ B hB_nn
    hM0_small hM0_large hM0_thresh hB ε hε_conv
  simp_rw [habs_eq] at h_per_probe
  exact uniform_dev_of_per_probe hε_nn hε_M (fun m => abs_nonneg _) hsum_M h_per_probe

/-- **Uniform deviation bound for `aperyBranchHalfCore`.**
H-branch (ρ = 1/2) analogue of
`aperyBranchAmplitude_zero_abs_sub_one_le_uniform`. Lifts the per-probe
deviation to a corridor ceiling `M_eps`. -/
lemma aperyBranchHalfCore_abs_sub_one_le_uniform
    (M₀ : ℕ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hM0_small : ∀ m, M₀ ≤ m → (|(1 / 2 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large : ∀ m, M₀ ≤ m → 3 * |(1 / 2 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh : ∀ m', M₀ ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(1 / 2 : ℝ)| - (2 : ℝ)))
    (hB : ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff (taylorShift
          ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
          Number.aperyConifoldZ1Poly) ℓ| ≤ B)
    (M_eps : ℝ) (hM_eps_nn : 0 ≤ M_eps)
    (hM_eps_conv : M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) < 1)
    (hsum_M : Summable (fun m => |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| * M_eps ^ m))
    (ε : ℝ) (hε_nn : 0 ≤ ε) (hε_M : ε ≤ M_eps) :
    |aperyBranchHalfCore ε - 1| ≤
      M_eps * ∑' m, |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| * M_eps ^ m := by
  have habs_eq : |ε| = ε := abs_of_nonneg hε_nn
  have hCnn : 0 ≤ 1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)| := by positivity
  have hε_conv : |ε| * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)|) < 1 := by
    rw [habs_eq]
    calc ε * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
            |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)|)
        ≤ M_eps * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
            |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)|) :=
          mul_le_mul_of_nonneg_right hε_M hCnn
      _ < 1 := hM_eps_conv
  have h_per_probe := aperyBranchHalfCore_abs_sub_one_le M₀ B hB_nn
    hM0_small hM0_large hM0_thresh hB ε hε_conv
  simp_rw [habs_eq] at h_per_probe
  exact uniform_dev_of_per_probe hε_nn hε_M (fun m => abs_nonneg _) hsum_M h_per_probe

