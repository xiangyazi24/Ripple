/-- **Generic geometric Gronwall (partial-sum form).** A nonnegative
sequence `s : ℕ → ℝ` satisfying the recurrence
`s (m+1) ≤ K · Σ_{i ≤ m} s i` for all `m ≥ m₀` admits the geometric
upper bound on partial sums:
```
Σ_{i ≤ m₀+k} s i ≤ (Σ_{i ≤ m₀} s i) · (1 + K)^k.
```
This is the standard discrete Gronwall step that converts a
sum-controlled recurrence into an explicit geometric majorant. The
ratio-test convergence radius lower bound `r ≥ 1/(1+K)` then follows
from `S_m^{1/m} → 1+K` and the elementary `(s_m)^{1/m} ≤ S_m^{1/m}`. -/
lemma geometric_gronwall_partial_sum
    (s : ℕ → ℝ) (hs_nn : ∀ i, 0 ≤ s i) (K : ℝ) (hK_nn : 0 ≤ K) (m₀ : ℕ)
    (hrec : ∀ m, m₀ ≤ m →
        s (m + 1) ≤ K * ∑ i ∈ Finset.range (m + 1), s i) :
    ∀ k : ℕ,
      ∑ i ∈ Finset.range (m₀ + k + 1), s i ≤
        (∑ i ∈ Finset.range (m₀ + 1), s i) * (1 + K) ^ k := by
  intro k
  induction k with
  | zero => simp
  | succ k ih =>
      have hm₀_le : m₀ ≤ m₀ + k := Nat.le_add_right _ _
      have hbound : s (m₀ + k + 1) ≤
          K * ∑ i ∈ Finset.range (m₀ + k + 1), s i :=
        hrec (m₀ + k) hm₀_le
      have h1plus_nn : 0 ≤ 1 + K := by linarith
      have hidx : m₀ + (k + 1) + 1 = (m₀ + k + 1) + 1 := by ring
      rw [hidx, Finset.sum_range_succ]
      calc ∑ i ∈ Finset.range (m₀ + k + 1), s i + s (m₀ + k + 1)
          ≤ ∑ i ∈ Finset.range (m₀ + k + 1), s i +
              K * ∑ i ∈ Finset.range (m₀ + k + 1), s i := by linarith
        _ = (1 + K) * ∑ i ∈ Finset.range (m₀ + k + 1), s i := by ring
        _ ≤ (1 + K) *
              ((∑ i ∈ Finset.range (m₀ + 1), s i) * (1 + K) ^ k) :=
              mul_le_mul_of_nonneg_left ih h1plus_nn
        _ = (∑ i ∈ Finset.range (m₀ + 1), s i) * (1 + K) ^ (k + 1) := by ring

/-- **Summability from a geometric majorant.** If a real-valued sequence
`s : ℕ → ℝ` is bounded in absolute value by a convergent geometric
series — i.e., `|s k| ≤ C · r^k` for some `0 ≤ r < 1` and `C ≥ 0` —
then `s` is summable. The geometric series `Σ C·r^k = C/(1-r)` is
the explicit majorant. This is the standard "comparison with geometric
series" criterion needed to convert the pointwise geometric bound
`|a_n| ≤ S₀ · (1+K)^(n-m₀)` into absolute convergence of `Σ a_n z^n`
on the disk `|z| < 1/(1+K)`. -/
lemma summable_of_geometric_bound
    (s : ℕ → ℝ) (C r : ℝ) (hC_nn : 0 ≤ C) (hr_nn : 0 ≤ r) (hr_lt : r < 1)
    (hbound : ∀ k, |s k| ≤ C * r ^ k) : Summable s := by
  have hgeo : Summable (fun k : ℕ => r ^ k) :=
    summable_geometric_of_lt_one hr_nn hr_lt
  have hCgeo : Summable (fun k : ℕ => C * r ^ k) := hgeo.mul_left C
  refine Summable.of_norm_bounded (g := fun k => C * r ^ k) hCgeo ?_
  intro k
  rw [Real.norm_eq_abs]
  exact hbound k

/-- **Generic geometric Gronwall — pointwise corollary.** From the
partial-sum bound `Σ_{i ≤ m₀+k} s i ≤ (Σ_{i ≤ m₀} s i) · (1+K)^k`
extract the single-coefficient bound: for any `k`,
```
s (m₀ + k) ≤ (Σ_{i ≤ m₀} s i) · (1 + K)^k.
```
Uses `Finset.single_le_sum` against the partial-sum bound; valid because
all `s i ≥ 0`. This is what the ratio test consumes: a term-by-term
geometric upper bound gives `r ≥ 1/(1 + K)` directly. -/
lemma geometric_gronwall_pointwise
    (s : ℕ → ℝ) (hs_nn : ∀ i, 0 ≤ s i) (K : ℝ) (hK_nn : 0 ≤ K) (m₀ : ℕ)
    (hrec : ∀ m, m₀ ≤ m →
        s (m + 1) ≤ K * ∑ i ∈ Finset.range (m + 1), s i) :
    ∀ k : ℕ,
      s (m₀ + k) ≤
        (∑ i ∈ Finset.range (m₀ + 1), s i) * (1 + K) ^ k := by
  intro k
  have hsum := geometric_gronwall_partial_sum s hs_nn K hK_nn m₀ hrec k
  have h_member : m₀ + k ∈ Finset.range (m₀ + k + 1) := by
    rw [Finset.mem_range]; omega
  have h_term_le : s (m₀ + k) ≤ ∑ i ∈ Finset.range (m₀ + k + 1), s i :=
    Finset.single_le_sum (f := s) (fun i _ => hs_nn i) h_member
  exact h_term_le.trans hsum

