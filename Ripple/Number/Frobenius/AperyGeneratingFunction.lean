    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    (ext.F Number.aperyConifoldZ1Poly,
        aperyExtractHalf ext.F ε₁ ε₂, aperyExtractOne ext.F ε₁ ε₂) =
      aperyCanonicalTriple3 ε₁ ε₂ ε₃ :=
  (AperyConnectionData.of_witness ext I h0 h).canonicalTriple3_eq_on_disk
    hε₁ hε₂ hε₃ hdet12 h3det hdisk₁ hdisk₂ hdisk₃

/-- **Data-layer GFA right-endpoint via 3-probe canonical extracts
(seedless form).** Three disk probes plus a fourth disk-evaluation
probe `ε`: the GFA value at `z₁ - ε` decomposes purely in terms of
`aperyCanonicalTriple3 ε₁ ε₂ ε₃` and the branch amplitudes — no seed
input. -/
lemma AperyConnectionData.GFA_right_endpoint_via_canonical3_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hε : (-ε) ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃ * aperyBranchAmplitude_zero ε +
        aperyCanonicalExtractHalf3 ε₁ ε₂ ε₃ * aperyBranchAmplitude_half ε +
        aperyCanonicalExtractOne3 ε₁ ε₂ ε₃ * aperyBranchValue_one ε := by
  rw [d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε hdisk,
    d.extractRegular_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃,
    d.extractHalf_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃,
    d.extractOne_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk₁ hdisk₂ hdisk₃]

/-- **Ext-layer mirror: GFA right-endpoint via 3-probe canonical
extracts (seedless form).** One-line `of_witness` delegation. -/
lemma AperyAnalyticExtension.GFA_right_endpoint_via_canonical3_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
