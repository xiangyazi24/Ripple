/-! ### Corridor-level sub-interval bridges `Icc [0, b] ⊂ Icc [0, b']` -/

/-- **`Icc 0 b ⊆ Icc 0 b'` when `b ≤ b'`.** -/
lemma Icc_zero_b_subset_Icc_zero_b' {b b' : ℝ} (hbb' : b ≤ b') :
    Set.Icc (0 : ℝ) b ⊆ Set.Icc (0 : ℝ) b' := by
  intro z hz
  exact ⟨hz.1, le_trans hz.2 hbb'⟩

/-- **`sSup` on `Icc 0 b` ≤ `sSup` on `Icc 0 b'` when `0 ≤ b ≤ b' < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_zero_b_le_zero_b'
    (h : HasCorridorAperyAnalyticExtension)
    {b b' : ℝ} (hb : 0 ≤ b) (hbb' : b ≤ b') (hb' : b' < Number.aperyConifoldZ1Poly) :
    sSup (aperyGFAReal '' Set.Icc (0 : ℝ) b) ≤
      sSup (aperyGFAReal '' Set.Icc (0 : ℝ) b') :=
  h.sSup_aperyGFAReal_image_Icc_le_of_subset
    (le_refl 0) hb
    (le_refl 0) (le_trans hb hbb') hb'
    (Icc_zero_b_subset_Icc_zero_b' hbb')

/-- **`sInf` on `Icc 0 b'` ≤ `sInf` on `Icc 0 b` when `0 ≤ b ≤ b' < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_zero_b'_le_zero_b
    (h : HasCorridorAperyAnalyticExtension)
    {b b' : ℝ} (hb : 0 ≤ b) (hbb' : b ≤ b') (hb' : b' < Number.aperyConifoldZ1Poly) :
    sInf (aperyGFAReal '' Set.Icc (0 : ℝ) b') ≤
      sInf (aperyGFAReal '' Set.Icc (0 : ℝ) b) :=
  h.sInf_aperyGFAReal_image_Icc_le_of_subset
    (le_refl 0) hb
    (le_refl 0) (le_trans hb hbb') hb'
    (Icc_zero_b_subset_Icc_zero_b' hbb')

/-- **Image inclusion `Icc 0 b ⊂ Icc 0 b'` when `b ≤ b'`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_zero_b_subset_zero_b'
    {b b' : ℝ} (hbb' : b ≤ b') :
    aperyGFAReal '' Set.Icc (0 : ℝ) b ⊆ aperyGFAReal '' Set.Icc (0 : ℝ) b' :=
  Set.image_mono (Icc_zero_b_subset_Icc_zero_b' hbb')

/-! ### Right-expansion sub-interval bridges `Icc [a, b] ⊂ Icc [a, b']` -/

/-- **`Icc a b ⊆ Icc a b'` when `b ≤ b'`.** -/
lemma Icc_a_b_subset_Icc_a_b' {a b b' : ℝ} (hbb' : b ≤ b') :
    Set.Icc a b ⊆ Set.Icc a b' := by
  intro z hz
  exact ⟨hz.1, le_trans hz.2 hbb'⟩

/-- **`sSup` on `Icc a b` ≤ `sSup` on `Icc a b'` when `0 ≤ a ≤ b ≤ b' < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_a_b_le_a_b'
    (h : HasCorridorAperyAnalyticExtension)
    {a b b' : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hbb' : b ≤ b')
    (hb' : b' < Number.aperyConifoldZ1Poly) :
    sSup (aperyGFAReal '' Set.Icc a b) ≤
      sSup (aperyGFAReal '' Set.Icc a b') :=
  h.sSup_aperyGFAReal_image_Icc_le_of_subset
    ha hab
    ha (le_trans hab hbb') hb'
    (Icc_a_b_subset_Icc_a_b' hbb')

/-- **`sInf` on `Icc a b'` ≤ `sInf` on `Icc a b` when `0 ≤ a ≤ b ≤ b' < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_a_b'_le_a_b
    (h : HasCorridorAperyAnalyticExtension)
    {a b b' : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hbb' : b ≤ b')
    (hb' : b' < Number.aperyConifoldZ1Poly) :
    sInf (aperyGFAReal '' Set.Icc a b') ≤
      sInf (aperyGFAReal '' Set.Icc a b) :=
  h.sInf_aperyGFAReal_image_Icc_le_of_subset
    ha hab
    ha (le_trans hab hbb') hb'
    (Icc_a_b_subset_Icc_a_b' hbb')

/-- **Image inclusion `Icc a b ⊂ Icc a b'` when `b ≤ b'`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_a_b_subset_a_b'
    {a b b' : ℝ} (hbb' : b ≤ b') :
    aperyGFAReal '' Set.Icc a b ⊆ aperyGFAReal '' Set.Icc a b' :=
  Set.image_mono (Icc_a_b_subset_Icc_a_b' hbb')

/-! ### Left-shrinking sub-interval bridges `Icc [a', b] ⊂ Icc [a, b]` -/

/-- **`Icc a' b ⊆ Icc a b` when `a ≤ a'`.** -/
lemma Icc_a'_b_subset_Icc_a_b {a a' b : ℝ} (haa' : a ≤ a') :
    Set.Icc a' b ⊆ Set.Icc a b := by
  intro z hz
  exact ⟨le_trans haa' hz.1, hz.2⟩

/-- **`sSup` on `Icc a' b` ≤ `sSup` on `Icc a b` when `0 ≤ a ≤ a' ≤ b < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_a'_b_le_a_b
    (h : HasCorridorAperyAnalyticExtension)
    {a a' b : ℝ} (ha : 0 ≤ a) (haa' : a ≤ a') (ha'b : a' ≤ b)
    (hb : b < Number.aperyConifoldZ1Poly) :
    sSup (aperyGFAReal '' Set.Icc a' b) ≤
      sSup (aperyGFAReal '' Set.Icc a b) :=
  h.sSup_aperyGFAReal_image_Icc_le_of_subset
    (le_trans ha haa') ha'b
    ha (le_trans haa' ha'b) hb
    (Icc_a'_b_subset_Icc_a_b haa')

/-- **`sInf` on `Icc a b` ≤ `sInf` on `Icc a' b` when `0 ≤ a ≤ a' ≤ b < z₁`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_a_b_le_a'_b
    (h : HasCorridorAperyAnalyticExtension)
    {a a' b : ℝ} (ha : 0 ≤ a) (haa' : a ≤ a') (ha'b : a' ≤ b)
    (hb : b < Number.aperyConifoldZ1Poly) :
    sInf (aperyGFAReal '' Set.Icc a b) ≤
      sInf (aperyGFAReal '' Set.Icc a' b) :=
  h.sInf_aperyGFAReal_image_Icc_le_of_subset
    (le_trans ha haa') ha'b
    ha (le_trans haa' ha'b) hb
    (Icc_a'_b_subset_Icc_a_b haa')

/-- **Image inclusion `Icc a' b ⊂ Icc a b` when `a ≤ a'`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_a'_b_subset_a_b
    {a a' b : ℝ} (haa' : a ≤ a') :
    aperyGFAReal '' Set.Icc a' b ⊆ aperyGFAReal '' Set.Icc a b :=
  Set.image_mono (Icc_a'_b_subset_Icc_a_b haa')

/-! ### Degenerate singleton `Icc a a` -/

/-- **Image of singleton `Icc a a` is `{aperyGFAReal a}`.** -/
lemma aperyGFAReal_image_Icc_singleton (a : ℝ) :
    aperyGFAReal '' Set.Icc a a = {aperyGFAReal a} := by
  rw [Set.Icc_self, Set.image_singleton]

/-- **`sSup` over singleton `Icc a a` is `aperyGFAReal a`.** -/
lemma sSup_aperyGFAReal_image_Icc_singleton (a : ℝ) :
    sSup (aperyGFAReal '' Set.Icc a a) = aperyGFAReal a := by
  rw [aperyGFAReal_image_Icc_singleton, csSup_singleton]

/-- **`sInf` over singleton `Icc a a` is `aperyGFAReal a`.** -/
lemma sInf_aperyGFAReal_image_Icc_singleton (a : ℝ) :
    sInf (aperyGFAReal '' Set.Icc a a) = aperyGFAReal a := by
  rw [aperyGFAReal_image_Icc_singleton, csInf_singleton]

/-- **Singleton agrees: `sSup = sInf` on `Icc a a`.** -/
lemma sSup_eq_sInf_aperyGFAReal_image_Icc_singleton (a : ℝ) :
    sSup (aperyGFAReal '' Set.Icc a a) = sInf (aperyGFAReal '' Set.Icc a a) := by
  rw [sSup_aperyGFAReal_image_Icc_singleton, sInf_aperyGFAReal_image_Icc_singleton]

/-! ### `HasAperyAnalyticExtension` `some_F` sub-interval monotonicity -/

/-- **`some.F` image is BddAbove on sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.bddAbove_some_F_image_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hb : b ≤ 1 / 64) :
    BddAbove (h.some.F '' Set.Icc a b) :=
  (isCompact_Icc.image_of_continuousOn
    (h.continuousOn_some_F_Icc_sub ha hb)).bddAbove

/-- **`some.F` image is BddBelow on sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.bddBelow_some_F_image_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hb : b ≤ 1 / 64) :
    BddBelow (h.some.F '' Set.Icc a b) :=
  (isCompact_Icc.image_of_continuousOn
    (h.continuousOn_some_F_Icc_sub ha hb)).bddBelow

/-- **`some.F` image inclusion under sub-interval inclusion.** -/
lemma HasAperyAnalyticExtension.some_F_image_subset_of_Icc_subset
    (h : HasAperyAnalyticExtension) {a b a' b' : ℝ}
    (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    h.some.F '' Set.Icc a b ⊆ h.some.F '' Set.Icc a' b' :=
  Set.image_mono h_sub

/-- **`sSup` of `some.F` image is monotone in sub-interval (within `Icc 0 (1/64)`).** -/
lemma HasAperyAnalyticExtension.sSup_some_F_image_Icc_le_of_subset
    (h : HasAperyAnalyticExtension) {a b a' b' : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b)
    (ha' : 0 ≤ a') (hab' : a' ≤ b') (hb' : b' ≤ 1 / 64)
    (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    sSup (h.some.F '' Set.Icc a b) ≤
      sSup (h.some.F '' Set.Icc a' b') := by
  refine csSup_le_csSup
    (h.bddAbove_some_F_image_Icc_sub ha' hb')
    (Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab))
    ?_
  exact Set.image_mono h_sub

/-- **`sInf` of `some.F` image is antitone in sub-interval (within `Icc 0 (1/64)`).** -/
lemma HasAperyAnalyticExtension.sInf_some_F_image_Icc_le_of_subset
    (h : HasAperyAnalyticExtension) {a b a' b' : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b)
    (ha' : 0 ≤ a') (hab' : a' ≤ b') (hb' : b' ≤ 1 / 64)
    (h_sub : Set.Icc a b ⊆ Set.Icc a' b') :
    sInf (h.some.F '' Set.Icc a' b') ≤
      sInf (h.some.F '' Set.Icc a b) := by
  refine csInf_le_csInf
    (h.bddBelow_some_F_image_Icc_sub ha' hb')
    (Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab))
    ?_
  exact Set.image_mono h_sub

/-! ### `HasAperyAnalyticExtension` `some_F` degenerate singleton -/

/-- **Image of singleton `Icc a a` under `some.F` is `{h.some.F a}`.** -/
lemma HasAperyAnalyticExtension.some_F_image_Icc_singleton
    (h : HasAperyAnalyticExtension) (a : ℝ) :
    h.some.F '' Set.Icc a a = {h.some.F a} := by
  rw [Set.Icc_self, Set.image_singleton]

/-- **`sSup` of `some.F` over singleton is `h.some.F a`.** -/
lemma HasAperyAnalyticExtension.sSup_some_F_image_Icc_singleton
    (h : HasAperyAnalyticExtension) (a : ℝ) :
    sSup (h.some.F '' Set.Icc a a) = h.some.F a := by
  rw [h.some_F_image_Icc_singleton, csSup_singleton]

/-- **`sInf` of `some.F` over singleton is `h.some.F a`.** -/
lemma HasAperyAnalyticExtension.sInf_some_F_image_Icc_singleton
    (h : HasAperyAnalyticExtension) (a : ℝ) :
    sInf (h.some.F '' Set.Icc a a) = h.some.F a := by
  rw [h.some_F_image_Icc_singleton, csInf_singleton]

/-- **Singleton agrees: `sSup = sInf` for `some.F` on `Icc a a`.** -/
lemma HasAperyAnalyticExtension.sSup_eq_sInf_some_F_image_Icc_singleton
    (h : HasAperyAnalyticExtension) (a : ℝ) :
    sSup (h.some.F '' Set.Icc a a) = sInf (h.some.F '' Set.Icc a a) := by
  rw [h.sSup_some_F_image_Icc_singleton, h.sInf_some_F_image_Icc_singleton]

/-! ### `HasAperyAnalyticExtension` `some_F` extreme value + norm bound on Icc a b -/

/-- **Extreme value (max) for `some.F` on sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_isMaxOn_some_F_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    ∃ x ∈ Set.Icc a b, IsMaxOn h.some.F (Set.Icc a b) x :=
  isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr hab)
    (h.continuousOn_some_F_Icc_sub ha hb)

/-- **Extreme value (min) for `some.F` on sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_isMinOn_some_F_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    ∃ x ∈ Set.Icc a b, IsMinOn h.some.F (Set.Icc a b) x :=
  isCompact_Icc.exists_isMinOn
    (Set.nonempty_Icc.mpr hab)
    (h.continuousOn_some_F_Icc_sub ha hb)

/-- **Sharp norm bound (using local extrema) for `some.F` on sub-interval
`Icc a b ⊆ Icc 0 (1/64)` — uses local max/min instead of global bound.** -/
lemma HasAperyAnalyticExtension.exists_norm_bound_some_F_Icc_sub_sharp
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    ∃ M : ℝ, ∀ z ∈ Set.Icc a b, |h.some.F z| ≤ M := by
  obtain ⟨xmax, _, hxmax⟩ :=
    h.exists_isMaxOn_some_F_Icc_sub ha hab hb
  obtain ⟨xmin, _, hxmin⟩ :=
    h.exists_isMinOn_some_F_Icc_sub ha hab hb
  refine ⟨max (h.some.F xmax) (-h.some.F xmin), ?_⟩
  intro z hz
  have h_le_max : h.some.F z ≤ h.some.F xmax := hxmax hz
  have h_min_le : h.some.F xmin ≤ h.some.F z := hxmin hz
  rw [abs_le]
  refine ⟨?_, ?_⟩
  · have h_le_M : -h.some.F xmin ≤
        max (h.some.F xmax) (-h.some.F xmin) :=
      le_max_right _ _
    linarith
  · have h_le_M : h.some.F xmax ≤
        max (h.some.F xmax) (-h.some.F xmin) :=
      le_max_left _ _
    linarith

/-- **`sSup` of `some.F` image on sub-interval `Icc a b ⊆ Icc 0 (1/64)`
is attained.** -/
lemma HasAperyAnalyticExtension.sSup_some_F_image_Icc_sub_mem
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sSup (h.some.F '' Set.Icc a b) ∈ h.some.F '' Set.Icc a b := by
  refine IsCompact.sSup_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      (h.continuousOn_some_F_Icc_sub ha hb)
  · exact Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab)

/-- **`sInf` of `some.F` image on sub-interval `Icc a b ⊆ Icc 0 (1/64)`
is attained.** -/
lemma HasAperyAnalyticExtension.sInf_some_F_image_Icc_sub_mem
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sInf (h.some.F '' Set.Icc a b) ∈ h.some.F '' Set.Icc a b := by
  refine IsCompact.sInf_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      (h.continuousOn_some_F_Icc_sub ha hb)
  · exact Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab)

/-- **`IsLUB` for `sSup` of `some.F` image on sub-interval.** -/
lemma HasAperyAnalyticExtension.isLUB_sSup_some_F_image_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    IsLUB (h.some.F '' Set.Icc a b)
      (sSup (h.some.F '' Set.Icc a b)) := by
  refine Real.isLUB_sSup ?_ (h.bddAbove_some_F_image_Icc_sub ha hb)
  exact Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab)

/-- **`IsGLB` for `sInf` of `some.F` image on sub-interval.** -/
lemma HasAperyAnalyticExtension.isGLB_sInf_some_F_image_Icc_sub
