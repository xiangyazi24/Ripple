/-- **Apéry conifold Z-branch value decomposition.** For `z` in the
Frobenius convergence disk, the regular branch decomposes as
`yAperyZero c₀ z = c₀ + z · (tail tsum)`. Direct application of
`Summable.tsum_eq_zero_add` to the Apéry-instance summability witness;
the `m = 0` term reduces to `c₀` by `frobeniusCoeff_zero`. -/
lemma aperyConifold_yAperyZero_eq_c0_add_z_mul_tail (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    yAperyZero c₀ z =
      c₀ + z * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ (m + 1) * z ^ m := by
  have hsum := aperyConifold_frobenius_Z_summable c₀ z hz
  unfold yAperyZero frobeniusValue
  rw [hsum.tsum_eq_zero_add]
  have h0 : frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 0 c₀ 0 * z ^ 0 = c₀ := by
    simp
  rw [h0]
  congr 1
  rw [← tsum_mul_left]
  congr 1
  funext m
  ring

/-- **Apéry conifold O-branch value decomposition (ρ = 1).** For `z` in
the Frobenius convergence disk, the ρ = 1 branch decomposes as
`yApery c₀ z = c₀ · z + z² · (tail tsum)`. The leading `t` factor in
`yApery` shifts the Z-form by one power of `z`. -/
lemma aperyConifold_yApery_eq_c0z_add_z2_mul_tail (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    yApery c₀ z =
      c₀ * z + z ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 c₀ (m + 1) * z ^ m := by
  have hsum := aperyConifold_frobenius_O_summable c₀ z hz
  unfold yApery frobeniusValue
  rw [hsum.tsum_eq_zero_add]
  have h0 : frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 1 c₀ 0 * z ^ 0 = c₀ := by simp
  rw [h0]
  have key : (∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 c₀ (m + 1) * z ^ (m + 1)) =
      z * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 c₀ (m + 1) * z ^ m := by
    rw [← tsum_mul_left]
    congr 1
    funext m
    ring
  rw [key]
  ring

/-- **Apéry conifold H-branch value decomposition (ρ = 1/2).** For `z` in
the Frobenius convergence disk, the half-branch factors as
`yAperyHalf c₀ z = √(-z) · (c₀ + z · tail tsum)`. The leading `√(-t)`
factor of `yAperyHalf` carries through unchanged; the inner Frobenius
series decomposes as in the regular branch. -/
lemma aperyConifold_yAperyHalf_eq_sqrtNeg_mul_decomp (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    yAperyHalf c₀ z =
      Real.sqrt (-z) * (c₀ + z * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) c₀ (m + 1) * z ^ m) := by
  have hsum := aperyConifold_frobenius_H_summable c₀ z hz
  unfold yAperyHalf frobeniusValue
  rw [hsum.tsum_eq_zero_add]
  have h0 : frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly (1 / 2) c₀ 0 * z ^ 0 = c₀ := by simp
  rw [h0]
  congr 1
  congr 1
  rw [← tsum_mul_left]
  congr 1
  funext m
  ring

/-- **Apéry conifold three-branch combined decomposition.** For `z` in
the Frobenius convergence disk, the superposed branch triple
`aperyBranchTriple a₀ a_h a₁ z` decomposes term-by-term as
`(a₀ + z · T_Z) + √(-z) · (a_h + z · T_H) + (a₁ · z + z² · T_O)`,
where `T_Z`, `T_H`, `T_O` are the tail tsums at indicial roots
`{0, 1/2, 1}`. Direct rewriting via the per-branch decompositions. -/
lemma aperyConifold_aperyBranchTriple_decomp
    (a₀ a_h a₁ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    aperyBranchTriple a₀ a_h a₁ z =
      (a₀ + z * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * z ^ m) +
      Real.sqrt (-z) * (a_h + z * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_h (m + 1) * z ^ m) +
      (a₁ * z + z ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * z ^ m) := by
  unfold aperyBranchTriple
  rw [aperyConifold_yAperyZero_eq_c0_add_z_mul_tail a₀ z hz,
      aperyConifold_yAperyHalf_eq_sqrtNeg_mul_decomp a_h z hz,
      aperyConifold_yApery_eq_c0z_add_z2_mul_tail a₁ z hz]

/-- **Connection-coefficient witness decomposition on the Frobenius disk.**
Combines `IsAperyConnectionCoeffsOn` with the three-branch combined value
decomposition: at any `t ∈ I` that also lies in the Frobenius convergence
disk, `f(z₁ + t)` opens into the explicit
`(a₀ + t·T_Z) + √(-t)·(a_h + t·T_H) + (a₁·t + t²·T_O)` form. This
realises `(a₀, a_h, a₁)` as the readable leading coefficients of the
local Frobenius expansion. -/
lemma IsAperyConnectionCoeffsOn.decomp_on_frobeniusDisk
    {a₀ a_h a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_h a₁ f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      (a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) +
      Real.sqrt (-t) * (a_h + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_h (m + 1) * t ^ m) +
      (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) := by
  rw [h t ht, aperyConifold_aperyBranchTriple_decomp a₀ a_h a₁ t htdisk]

/-- **`AperyConnectionData` explicit Frobenius decomposition on the disk.**
For `t` in both the corridor and the Frobenius convergence disk, the
representable function `d.F (z₁ + t)` opens into the explicit
`(extractRegular + t · T_Z) + √(-t) · (extractHalf + t · T_H) +
(extractOne · t + t² · T_O)` form. Couples the corridor-level
`F_decomposes` with the disk-level branch decomposition. -/
lemma AperyConnectionData.F_explicit_frobenius_decomp_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (ht : t ∈ d.corridor)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      (d.extractRegular + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 d.extractRegular (m + 1) * t ^ m) +
      Real.sqrt (-t) * (d.extractHalf ε₁ ε₂ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (d.extractHalf ε₁ ε₂) (m + 1) *
          t ^ m) +
      (d.extractOne ε₁ ε₂ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 (d.extractOne ε₁ ε₂) (m + 1) *
          t ^ m) := by
  have h_dec := d.F_decomposes hε₁ hε₂ hdet t ht
  have h_eq_triple :
      yAperyZero d.extractRegular t + yAperyHalf (d.extractHalf ε₁ ε₂) t +
        yApery (d.extractOne ε₁ ε₂) t =
      aperyBranchTriple d.extractRegular (d.extractHalf ε₁ ε₂)
        (d.extractOne ε₁ ε₂) t := rfl
  rw [h_dec, h_eq_triple,
      aperyConifold_aperyBranchTriple_decomp _ _ _ _ htdisk]

/-- **`AperyAnalyticExtension` explicit Frobenius decomposition on the disk.**
Ext-layer companion of `AperyConnectionData.F_explicit_frobenius_decomp_on_disk`,
using `connectionCoefficients` for the seed triple. Couples
`F_decomposes_via_coefficients_on` (corridor) with the disk-level
branch decomposition. -/
lemma AperyAnalyticExtension.F_explicit_frobenius_decomp_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) +
      Real.sqrt (-t) * ((ext.connectionCoefficients ε₁ ε₂).2.1 +
        t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2)
            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) +
      ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
        ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1
            ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) := by
  have h_dec := ext.F_decomposes_via_coefficients_on h0 h hε₁ hε₂ hdet ht
  have h_eq_triple :
      yAperyZero (ext.connectionCoefficients ε₁ ε₂).1 t +
        yAperyHalf (ext.connectionCoefficients ε₁ ε₂).2.1 t +
        yApery (ext.connectionCoefficients ε₁ ε₂).2.2 t =
      aperyBranchTriple (ext.connectionCoefficients ε₁ ε₂).1
        (ext.connectionCoefficients ε₁ ε₂).2.1
        (ext.connectionCoefficients ε₁ ε₂).2.2 t := rfl
  rw [h_dec, h_eq_triple,
      aperyConifold_aperyBranchTriple_decomp _ _ _ _ htdisk]

/-- **GFA explicit Frobenius decomposition on disk overlap.** On the
intersection of (i) the GFA convergence small disk `[0, 1/64)` near `z₁`,
(ii) a corridor `I` carrying connection-coefficient witness, and
(iii) the Frobenius local convergence disk, the analytic GF
`aperyGFAReal (z₁ + t)` opens into the explicit Frobenius branch series
form with ext-layer extracted seed coefficients. Couples the GFA-side
agreement (`F_eq_GFA_on_small`) with the disk-form ext-layer
decomposition. -/
lemma AperyAnalyticExtension.GFA_explicit_frobenius_decomp_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I)
    (hdisk_GFA : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      ((ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m) +
      Real.sqrt (-t) * ((ext.connectionCoefficients ε₁ ε₂).2.1 +
        t * ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly (1 / 2)
            ((ext.connectionCoefficients ε₁ ε₂).2.1) (m + 1) * t ^ m) +
      ((ext.connectionCoefficients ε₁ ε₂).2.2 * t + t ^ 2 *
        ∑' m, frobeniusCoeff
          (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
          Number.aperyConifoldZ1Poly 1
            ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) := by
  rw [← ext.F_eq_GFA_on_small hdisk_GFA]
  exact ext.F_explicit_frobenius_decomp_on_disk h0 h hε₁ hε₂ hdet ht htdisk

/-- **Z-branch HasSum at Apéry conifold.** The Apéry-instance Frobenius
series for `ρ = 0` `HasSum`s to the regular branch value `yAperyZero c₀ z`
on the Frobenius convergence disk. Direct lift of the Z-branch summability
witness via `Summable.hasSum`, with the value identified through the
definitional `yAperyZero = frobeniusValue ... 0 c₀`. -/
lemma aperyConifold_yAperyZero_hasSum (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    HasSum (fun n : ℕ => frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 c₀ n * z ^ n)
      (yAperyZero c₀ z) := by
  unfold yAperyZero frobeniusValue
  exact (aperyConifold_frobenius_Z_summable c₀ z hz).hasSum

/-- **H-branch HasSum at Apéry conifold (inner Frobenius series).** The
inner `frobeniusValue ... (1/2) c₀ z` in the H-branch decomposition
`HasSum`s on the convergence disk. Note: `yAperyHalf` includes a
`√(-z)` prefactor; this lemma gives the inner sum, not the full
`yAperyHalf` value. -/
lemma aperyConifold_yAperyHalf_inner_hasSum (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    HasSum (fun n : ℕ => frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) c₀ n * z ^ n)
      (frobeniusValue
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) c₀ z) := by
  unfold frobeniusValue
  exact (aperyConifold_frobenius_H_summable c₀ z hz).hasSum

/-- **O-branch HasSum at Apéry conifold (inner Frobenius series).** The
inner `frobeniusValue ... 1 c₀ z` in the O-branch decomposition
`HasSum`s on the convergence disk. Note: `yApery` includes a leading
`z` factor; this lemma gives the inner sum, not the full `yApery`
value. -/
lemma aperyConifold_yApery_inner_hasSum (c₀ z : ℝ)
    (hz : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1) :
    HasSum (fun n : ℕ => frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 c₀ n * z ^ n)
      (frobeniusValue
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 c₀ z) := by
  unfold frobeniusValue
  exact (aperyConifold_frobenius_O_summable c₀ z hz).hasSum

/-- **The Apéry conifold Frobenius disk constant `1 + K_eff` is positive.**
The denominator `|p'(z₁)|` is positive at the conifold, the numerator is
nonneg, so the divided constant is nonneg, and adding `1` makes it
positive. This is the basic lower bound enabling division and inequality
manipulation on the disk constraint. -/
lemma aperyConifold_frobenius_one_plus_K_pos :
    (0 : ℝ) < 1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| := by
  have hp_pos : 0 < |Polynomial.eval Number.aperyConifoldZ1Poly
      (Polynomial.derivative Number.aperyPconifold)| :=
    Number.aperyPconifold_deriv_eval_z1_abs_pos
  have hK_nn : (0 : ℝ) ≤ 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)| := by
    apply div_nonneg
    · positivity
    · exact hp_pos.le
  linarith

/-- **Existence of a non-trivial Apéry-conifold Frobenius disk.** There
is some `δ > 0` such that every `z` with `|z| < δ` satisfies the
disk constraint `(1 + K_eff) · |z| < 1`. Witness: `δ = 1 / (1 + K_eff)`,
which is positive by `aperyConifold_frobenius_one_plus_K_pos`. -/
lemma aperyConifold_frobenius_disk_nonempty :
    ∃ δ > (0 : ℝ), ∀ z : ℝ, |z| < δ →
      (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |z| < 1 := by
  set K1 : ℝ := 1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)| with hK1def
  have hK1_pos : 0 < K1 := aperyConifold_frobenius_one_plus_K_pos
  refine ⟨1 / K1, by positivity, ?_⟩
  intro z hz
  have hzK1 : K1 * |z| < K1 * (1 / K1) :=
    mul_lt_mul_of_pos_left hz hK1_pos
  have h_eq : K1 * (1 / K1) = 1 := by
    field_simp
  linarith

/-- **Pure-singular witness disk decomposition.** When the regular seed
`a₀ = 0`, the disk-form decomposition collapses to just the singular
half-branch and one-branch parts: `f(z₁ + t) = √(-t)·(a_h + t·T_H) +
(a₁·t + t²·T_O)`. The regular tail `T_Z` with seed `0` vanishes
identically by `frobeniusCoeff_zero_seed`. -/
lemma IsAperyConnectionCoeffsOn.decomp_pure_singular_on_frobeniusDisk
    {a_h a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 a_h a₁ f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      Real.sqrt (-t) * (a_h + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_h (m + 1) * t ^ m) +
      (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) := by
  have hpk : ((aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) (2 + 1)).eval
      Number.aperyConifoldZ1Poly = 0 := Number.aperyPconifold_eval_z1
  have h_dec := h.decomp_on_frobeniusDisk ht htdisk
  have hfun : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 0 0 (m + 1) * t ^ m) = (fun _ => 0) := by
    funext m
    rw [frobeniusCoeff_zero_seed _ _ _ _ hpk, zero_mul]
  have h_T_Z_zero : ∑' m, frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 0 0 (m + 1) * t ^ m = 0 := by
    rw [hfun, tsum_zero]
  rw [h_dec, h_T_Z_zero]
  ring

/-- **No-half-branch witness disk decomposition.** When `a_half = 0`, the
half-branch tail with seed `0` vanishes; combined with the leading
`√(-t)` factor, the whole half contribution is zero on the disk. Result:
`f(z₁ + t) = (a₀ + t·T_Z) + (a₁·t + t²·T_O)`. -/
lemma IsAperyConnectionCoeffsOn.decomp_no_half_on_frobeniusDisk
    {a₀ a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ 0 a₁ f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      (a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) +
      (a₁ * t + t ^ 2 * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 a₁ (m + 1) * t ^ m) := by
  have hpk : ((aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) (2 + 1)).eval
      Number.aperyConifoldZ1Poly = 0 := Number.aperyPconifold_eval_z1
  have h_dec := h.decomp_on_frobeniusDisk ht htdisk
  have hfun : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly (1 / 2) 0 (m + 1) * t ^ m) =
        (fun _ => 0) := by
    funext m
    rw [frobeniusCoeff_zero_seed _ _ _ _ hpk, zero_mul]
  have h_T_H_zero : ∑' m, frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly (1 / 2) 0 (m + 1) * t ^ m = 0 := by
    rw [hfun, tsum_zero]
  rw [h_dec, h_T_H_zero]
  ring

/-- **No-one-branch witness disk decomposition.** When `a₁ = 0`, the
one-branch tail with seed `0` vanishes; combined with the leading `t`
factor (and `t²` in the disk-form), the whole one contribution is zero
on the disk. Result: `f(z₁ + t) = (a₀ + t·T_Z) + √(-t)·(a_h + t·T_H)`. -/
lemma IsAperyConnectionCoeffsOn.decomp_no_one_on_frobeniusDisk
    {a₀ a_h : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_h 0 f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      (a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m) +
      Real.sqrt (-t) * (a_h + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_h (m + 1) * t ^ m) := by
  have hpk : ((aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) (2 + 1)).eval
      Number.aperyConifoldZ1Poly = 0 := Number.aperyPconifold_eval_z1
  have h_dec := h.decomp_on_frobeniusDisk ht htdisk
  have hfun : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 1 0 (m + 1) * t ^ m) = (fun _ => 0) := by
    funext m
    rw [frobeniusCoeff_zero_seed _ _ _ _ hpk, zero_mul]
  have h_T_O_zero : ∑' m, frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 1 0 (m + 1) * t ^ m = 0 := by
    rw [hfun, tsum_zero]
  rw [h_dec, h_T_O_zero]
  ring

/-- **Only-regular witness disk decomposition.** When both singular seeds
`a_half = 0` and `a₁ = 0`, only the regular branch survives:
`f(z₁ + t) = a₀ + t·T_Z`. Both half- and one-tails vanish by
`frobeniusCoeff_zero_seed`. -/
lemma IsAperyConnectionCoeffsOn.decomp_only_regular_on_frobeniusDisk
    {a₀ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ 0 0 f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      a₀ + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 a₀ (m + 1) * t ^ m := by
  have hpk : ((aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) (2 + 1)).eval
      Number.aperyConifoldZ1Poly = 0 := Number.aperyPconifold_eval_z1
  have h_dec := h.decomp_on_frobeniusDisk ht htdisk
  have hfunH : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly (1 / 2) 0 (m + 1) * t ^ m) =
        (fun _ => 0) := by
    funext m
    rw [frobeniusCoeff_zero_seed _ _ _ _ hpk, zero_mul]
  have hfunO : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 1 0 (m + 1) * t ^ m) = (fun _ => 0) := by
    funext m
    rw [frobeniusCoeff_zero_seed _ _ _ _ hpk, zero_mul]
  have h_T_H_zero : ∑' m, frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly (1 / 2) 0 (m + 1) * t ^ m = 0 := by
    rw [hfunH, tsum_zero]
  have h_T_O_zero : ∑' m, frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 1 0 (m + 1) * t ^ m = 0 := by
    rw [hfunO, tsum_zero]
  rw [h_dec, h_T_H_zero, h_T_O_zero]
  ring

/-- **Only-half witness disk decomposition.** When both `a₀ = 0` and
`a₁ = 0`, only the half-integer branch survives:
`f(z₁ + t) = √(-t)·(a_h + t·T_H)`. The regular and one-tails vanish. -/
lemma IsAperyConnectionCoeffsOn.decomp_only_half_on_frobeniusDisk
    {a_h : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 a_h 0 f I)
    {t : ℝ} (ht : t ∈ I)
    (htdisk : (1 + 2 * ((2 + 2 : ℕ) : ℝ) * 153 * ((2 : ℝ) ^ (2 + 1)) /
        |Polynomial.eval Number.aperyConifoldZ1Poly
          (Polynomial.derivative Number.aperyPconifold)|) * |t| < 1) :
    f (Number.aperyConifoldZ1Poly + t) =
      Real.sqrt (-t) * (a_h + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) a_h (m + 1) * t ^ m) := by
  have hpk : ((aperyPsSeq 0 0 Number.aperyQconifold
      Number.aperyPconifold) (2 + 1)).eval
      Number.aperyConifoldZ1Poly = 0 := Number.aperyPconifold_eval_z1
  have h_dec := h.decomp_on_frobeniusDisk ht htdisk
  have hfunZ : (fun m => frobeniusCoeff
      (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
      Number.aperyConifoldZ1Poly 0 0 (m + 1) * t ^ m) = (fun _ => 0) := by
    funext m
