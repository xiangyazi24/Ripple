/-- **`apery3Det` non-vanishing at the standard probes — three-branch
deviation form.** Takes one uniform deviation bound per branch
(`RZ` for `Amplitude_zero`, `RH` for `HalfCore`, `RO` for `OneCore`),
each holding at all three standard probes. Reduces to
`standard_apery3Det_ne_zero_of_dev_and_probe_bounds` by setting the
uniform `R := max RZ (max RH RO)`. Caller's gate inequality is stated
in this `R`. -/
lemma standard_apery3Det_ne_zero_of_three_branch_devs
    {RZ RH RO : ℝ}
    (hZ₁ : |aperyBranchAmplitude_zero (Number.aperyConifoldZ1Poly / 2) - 1| ≤ RZ)
    (hZ₂ : |aperyBranchAmplitude_zero (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ RZ)
    (hZ₃ : |aperyBranchAmplitude_zero (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ RZ)
    (hH₁ : |aperyBranchHalfCore (Number.aperyConifoldZ1Poly / 2) - 1| ≤ RH)
    (hH₂ : |aperyBranchHalfCore (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ RH)
    (hH₃ : |aperyBranchHalfCore (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ RH)
    (hO₁ : |aperyBranchOneCore (Number.aperyConifoldZ1Poly / 2) - 1| ≤ RO)
    (hO₂ : |aperyBranchOneCore (2 * Number.aperyConifoldZ1Poly / 3) - 1| ≤ RO)
    (hO₃ : |aperyBranchOneCore (3 * Number.aperyConifoldZ1Poly / 4) - 1| ≤ RO)
    (hgap : (max RZ (max RH RO) * (1 + max RZ (max RH RO)) ^ 2 +
              max RZ (max RH RO) * (1 + max RZ (max RH RO)) +
              max RZ (max RH RO)) *
              (6 * (3 * Number.aperyConifoldZ1Poly / 4) *
                Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4)) <
            (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
                Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))) :
    apery3Det (Number.aperyConifoldZ1Poly / 2)
        (2 * Number.aperyConifoldZ1Poly / 3)
        (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0 := by
  have hZle : RZ ≤ max RZ (max RH RO) := le_max_left _ _
  have hHle : RH ≤ max RZ (max RH RO) :=
    (le_max_left RH RO).trans (le_max_right _ _)
  have hOle : RO ≤ max RZ (max RH RO) :=
    (le_max_right RH RO).trans (le_max_right _ _)
  exact standard_apery3Det_ne_zero_of_dev_and_probe_bounds
    (hZ₁.trans hZle) (hZ₂.trans hZle) (hZ₃.trans hZle)
    (hH₁.trans hHle) (hH₂.trans hHle) (hH₃.trans hHle)
    (hO₁.trans hOle) (hO₂.trans hOle) (hO₃.trans hOle)
    hgap

/-- **`apery3Det` non-vanishing at the standard probes — single
end-to-end wrapper from per-branch frobenius hypotheses.** Threads
the three branch-specific frobenius coefficient hypotheses
(`M₀_Z, M₀_H, M₀_O`, shared bound `B`, three threshold packs,
three summability witnesses) through `aperyBranch{Amplitude_zero,
HalfCore,OneCore}_abs_sub_one_le_uniform` at `M_eps := 3·z₁/4`
applied at each of the three standard probes (where every probe
satisfies `0 ≤ ε ≤ M_eps`), then folds the three branch deviation
bounds via `standard_apery3Det_ne_zero_of_three_branch_devs`. Caller
provides only: `B ≥ 0`, the per-branch thresholds, the shared
`hM_eps_conv`, three summability witnesses, and the final gate
inequality. -/
lemma standard_apery3Det_ne_zero_of_branch_frobenius_hypotheses
    (M₀_Z M₀_H M₀_O : ℕ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hM0_small_Z : ∀ m, M₀_Z ≤ m → (|(0 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_Z : ∀ m, M₀_Z ≤ m → 3 * |(0 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_Z : ∀ m', M₀_Z ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(0 : ℝ)| - (2 : ℝ)))
    (hM0_small_H : ∀ m, M₀_H ≤ m → (|(1 / 2 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_H : ∀ m, M₀_H ≤ m → 3 * |(1 / 2 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_H : ∀ m', M₀_H ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(1 / 2 : ℝ)| - (2 : ℝ)))
    (hM0_small_O : ∀ m, M₀_O ≤ m → (|(1 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_O : ∀ m, M₀_O ≤ m → 3 * |(1 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_O : ∀ m', M₀_O ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(1 : ℝ)| - (2 : ℝ)))
    (hB : ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff (taylorShift
          ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
          Number.aperyConifoldZ1Poly) ℓ| ≤ B)
    (hM_eps_conv : (3 * Number.aperyConifoldZ1Poly / 4) *
        (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
          |Polynomial.eval Number.aperyConifoldZ1Poly
            (Polynomial.derivative Number.aperyPconifold)|) < 1)
    (hsum_Z : Summable (fun m => |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m))
    (hsum_H : Summable (fun m => |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m))
    (hsum_O : Summable (fun m => |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m))
    {RZ RH RO : ℝ}
    (hRZ : RZ = (3 * Number.aperyConifoldZ1Poly / 4) * ∑' m, |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m)
    (hRH : RH = (3 * Number.aperyConifoldZ1Poly / 4) * ∑' m, |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m)
    (hRO : RO = (3 * Number.aperyConifoldZ1Poly / 4) * ∑' m, |frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 1 1 (m + 1)| *
        (3 * Number.aperyConifoldZ1Poly / 4) ^ m)
    (hgap : (max RZ (max RH RO) * (1 + max RZ (max RH RO)) ^ 2 +
              max RZ (max RH RO) * (1 + max RZ (max RH RO)) +
              max RZ (max RH RO)) *
              (6 * (3 * Number.aperyConifoldZ1Poly / 4) *
                Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4)) <
            (Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3) -
                Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (Number.aperyConifoldZ1Poly / 2)) *
              (Real.sqrt (3 * Number.aperyConifoldZ1Poly / 4) -
                  Real.sqrt (2 * Number.aperyConifoldZ1Poly / 3))) :
    apery3Det (Number.aperyConifoldZ1Poly / 2)
        (2 * Number.aperyConifoldZ1Poly / 3)
        (3 * Number.aperyConifoldZ1Poly / 4) ≠ 0 := by
  have hz_pos := aperyConifoldZ1Poly_pos
  have hM_eps_nn : 0 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by linarith
  have hp1_nn : 0 ≤ Number.aperyConifoldZ1Poly / 2 := by linarith
  have hp2_nn : 0 ≤ 2 * Number.aperyConifoldZ1Poly / 3 := by linarith
  have hp3_nn : 0 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by linarith
  have hp1_le : Number.aperyConifoldZ1Poly / 2 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have hp2_le : 2 * Number.aperyConifoldZ1Poly / 3 ≤ 3 * Number.aperyConifoldZ1Poly / 4 := by
    linarith
  have hp3_le : 3 * Number.aperyConifoldZ1Poly / 4 ≤ 3 * Number.aperyConifoldZ1Poly / 4 :=
    le_refl _
  subst hRZ; subst hRH; subst hRO
  have hZ₁ := aperyBranchAmplitude_zero_abs_sub_one_le_uniform
    M₀_Z B hB_nn hM0_small_Z hM0_large_Z hM0_thresh_Z hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_Z
    (Number.aperyConifoldZ1Poly / 2) hp1_nn hp1_le
  have hZ₂ := aperyBranchAmplitude_zero_abs_sub_one_le_uniform
    M₀_Z B hB_nn hM0_small_Z hM0_large_Z hM0_thresh_Z hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_Z
    (2 * Number.aperyConifoldZ1Poly / 3) hp2_nn hp2_le
  have hZ₃ := aperyBranchAmplitude_zero_abs_sub_one_le_uniform
    M₀_Z B hB_nn hM0_small_Z hM0_large_Z hM0_thresh_Z hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_Z
    (3 * Number.aperyConifoldZ1Poly / 4) hp3_nn hp3_le
  have hH₁ := aperyBranchHalfCore_abs_sub_one_le_uniform
    M₀_H B hB_nn hM0_small_H hM0_large_H hM0_thresh_H hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_H
    (Number.aperyConifoldZ1Poly / 2) hp1_nn hp1_le
  have hH₂ := aperyBranchHalfCore_abs_sub_one_le_uniform
    M₀_H B hB_nn hM0_small_H hM0_large_H hM0_thresh_H hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_H
    (2 * Number.aperyConifoldZ1Poly / 3) hp2_nn hp2_le
  have hH₃ := aperyBranchHalfCore_abs_sub_one_le_uniform
    M₀_H B hB_nn hM0_small_H hM0_large_H hM0_thresh_H hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_H
    (3 * Number.aperyConifoldZ1Poly / 4) hp3_nn hp3_le
  have hO₁ := aperyBranchOneCore_abs_sub_one_le_uniform
    M₀_O B hB_nn hM0_small_O hM0_large_O hM0_thresh_O hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_O
    (Number.aperyConifoldZ1Poly / 2) hp1_nn hp1_le
  have hO₂ := aperyBranchOneCore_abs_sub_one_le_uniform
    M₀_O B hB_nn hM0_small_O hM0_large_O hM0_thresh_O hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_O
    (2 * Number.aperyConifoldZ1Poly / 3) hp2_nn hp2_le
  have hO₃ := aperyBranchOneCore_abs_sub_one_le_uniform
    M₀_O B hB_nn hM0_small_O hM0_large_O hM0_thresh_O hB
    (3 * Number.aperyConifoldZ1Poly / 4) hM_eps_nn hM_eps_conv hsum_O
    (3 * Number.aperyConifoldZ1Poly / 4) hp3_nn hp3_le
  exact standard_apery3Det_ne_zero_of_three_branch_devs
    hZ₁ hZ₂ hZ₃ hH₁ hH₂ hH₃ hO₁ hO₂ hO₃ hgap

/-- **GFA decomposition at the standard three probes.** Specializes
`GFA_decomposes_canonical3_on_disk` to the concrete probe set
`(z₁/2, 2z₁/3, 3z₁/4)`, with the three disk hypotheses auto-supplied
from the explicit-probe disk lemmas. Caller supplies only:
corridor memberships, the two non-vanishing det conditions, and a
corridor + disk point `t`. -/
lemma AperyConnectionData.GFA_decomposes_canonical3_standard_probes
    (d : AperyConnectionData)
    (hε₁ : (-(Number.aperyConifoldZ1Poly / 2)) ∈ d.corridor)
