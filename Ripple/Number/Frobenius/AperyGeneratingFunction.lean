    (hSum : ∀ r' : NNReal, (r' : ℝ) < radius →
      Summable (fun n : ℕ => |coeffs n| * (r' : ℝ) ^ n)) :
    (aperyGFAInteriorAnalyticDiskAt center h_pos h_lt radius hr coeffs hs
