/-! ### Gap A tightening: finite-order recurrence structure

The Gronwall bound treats c_{m+1} as depending on ALL previous c_i. But since
the polynomial coefficients have degree ≤ 4, the convolution at index m+2
only involves c_{m-2}, c_{m-1}, c_m — a 3-step recurrence. The effective
ratio drops below 1/z₁ starting from m ≈ 4, giving convergence of the
Frobenius series on the full disk |t| < z₁.

Analysis (ρ=1/2, Apéry conifold):
- denom ~ P'(z₁) · m³ for large m
- c_m contribution: (p_2 · m³ + q_2 · m²) · c_m
- Asymptotic ratio: |p_2/P'(z₁)| + |q_2/(P'(z₁)·m)| ≈ 1.8 + 98/m
- At m=4: ratio ≈ 26 < 34 ≈ 1/z₁ ✓
- The Gronwall K ≈ 1579 was an artifact of summing ALL previous c_i

This section will develop the finite-order recurrence bound. -/

-- Gap A analysis notes (2026-04-28):
--
-- KEY DISCOVERY: The denominator factorizes!
--   denom(m+1) = (m+3/2)(m+1/2) · [Q(z₁) + P'(z₁)·(m-1/2)]
--              = (m+3/2)(m+1/2)(m+1) · P'(z₁)
-- because Q(z₁) + P'(z₁)·(m-1/2) = (m+1)·P'(z₁) (exact algebraic identity,
-- uses Q(z₁) = 29376−20772√2 and P'(z₁) = 19584−13848√2,
-- verified: 29376+19584·(m-1/2) = 19584·(m+1) and similarly for √2 terms).
--
-- CONSEQUENCE: The limiting Frobenius recurrence characteristic polynomial is
--   P'(z₁)·λ³ − P''(z₁)/2·λ² + P'''(z₁)/6·λ + 1 = 0
-- which factors as the cubic of taylorShift(P)(t)/t at t = 1/λ.
-- Since P(z) = z²(z²−34z+1), taylorShift(P)(t) = t(t−z₁)²(t+24√2).
-- The cubic factor has roots: t = z₁ (double), t = −24√2 (single).
-- So eigenvalues: λ = 1/z₁ (double), λ = −1/(24√2) (single).
--
-- Growth: c_m = O(m · (1/z₁)^m). The polynomial factor m comes from the
-- double eigenvalue. Convergence radius = z₁.
--
-- For deviation bound: |HalfCore(ε) − 1| ≤ C·34ε/(1−34ε)² for ε < z₁.
-- At standard probes (ε ≤ 3z₁/4): 34ε ≤ 34·3z₁/4 ≈ 0.75.
-- Deviation ≤ 12C. Manageable if C is explicit.
--
-- Key numerical values (all in ℤ[√2], proved in AperyConifoldIndicial.lean):
--   taylorShift(P)_2 = 1729 − 1224√2 ≈ −2.6
--   taylorShift(P)_3 = −34 + 48√2    ≈ 33.9
--   taylorShift(P)_4 = 1
--   taylorShift(Q)_2 = 153 − 216√2   ≈ −152.5
--   taylorShift(Q)_3 = −6
--   P'(z₁) = 19584 − 13848√2         ≈ 0.029 (≈ z₁, NOT 1.5!)
--
-- The Frobenius recurrence (frobeniusCoeff_succ_linear_combination) sums
-- over i = 0..m. But coeff(m+2)(substLHS(X^i)) = 0 for i < m-2 because
-- the Taylor shift polynomials have degree ≤ 4. This reduces the full
-- Gronwall sum to a 3-step recurrence for m ≥ 2:
--
--   c_{m+1} ∝ p_2·c_m·ff(m+½,3) + q_2·c_m·ff(m+½,2)
--            + p_3·c_{m-1}·ff(m-½,3) + q_3·c_{m-1}·ff(m-½,2)
--            + p_4·c_{m-2}·ff(m-3/2,3)
--
-- Asymptotic ratio (m → ∞): |p_2/P'(z₁)| ≈ 1.7
-- At m = 4: total effective ratio ≈ 27 < 34 ≈ 1/z₁  ✓
-- Threshold: M₀ = 4 for geometric convergence
--
-- Next: ratio bound for m ≥ 4 + explicit c_1..c_4

/-- **Lower vanishing for Apéry Frobenius weights.** For `i + 3 ≤ m`,
the weight `coeff(m+2)(substLHSGen ps 3 z₁ ρ (X^i))` vanishes because
the Taylor shift coefficients of Q (degree 3) and P (degree 4) are zero
beyond their respective degrees. -/
lemma aperyFrobenius_weight_lower_vanish
    {m i : ℕ} (him : i + 3 ≤ m)
    (ρ : ℝ) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
      (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        3 Number.aperyConifoldZ1Poly ρ
        ((PowerSeries.X : PowerSeries ℝ) ^ i)) = 0 := by
  -- Use the explicit formula
  have hi_le : i ≤ m + 1 + 1 := by omega
  rw [coeff_succ_substLHSGen_X_pow_explicit _ 2 _ _ (m + 1) i (by omega)]
  -- Sum over j ∈ {0, 1, 2, 3}
  rw [show (2 + 2 : ℕ) = 4 from rfl, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
  -- j=0: ps 0 = 0
  simp only [aperyPsSeq, show (2 + 1 - 0 : ℕ) = 3 from rfl,
             show (2 + 1 - 1 : ℕ) = 2 from rfl,
             show (2 + 1 - 2 : ℕ) = 1 from rfl,
             show (2 + 1 - 3 : ℕ) = 0 from rfl]
  -- taylorShift 0 z₁ = 0
  simp only [taylorShift, Polynomial.zero_comp, Polynomial.coeff_zero, mul_zero, zero_add]
  -- j=2: Taylor index is (m+1+1-i) - 1 = m+1-i. Need m+1-i > 3 (natDegree Q ≤ 3).
  -- From i+3 ≤ m: m+1-i ≥ 4 > 3.
  have hQ_vanish : Polynomial.coeff
      (taylorShift Number.aperyQconifold Number.aperyConifoldZ1Poly)
      ((m + 1 + 1 - i) - 1) = 0 := by
    refine taylorShift_coeff_eq_zero_of_natDegree_lt _ _ _ ?_
    have := aperyQconifold_natDegree_le
    omega
  -- j=3: Taylor index is m+1+1-i = m+2-i. Need m+2-i > 4 (natDegree P ≤ 4).
  -- From i+3 ≤ m: m+2-i ≥ 5 > 4.
  have hP_vanish : Polynomial.coeff
      (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly)
      (m + 1 + 1 - i) = 0 := by
    refine taylorShift_coeff_eq_zero_of_natDegree_lt _ _ _ ?_
    have := aperyPconifold_natDegree_le
    omega
  -- Now both j=2 and j=3 terms have vanishing Taylor coefficient.
  unfold taylorShift at hQ_vanish hP_vanish
  simp only [Nat.sub_zero, hQ_vanish, hP_vanish, mul_zero, mul_ite, ite_self,
             add_zero, zero_mul]

/-- **3-step recurrence reduction.** For `m ≥ 3`, the full linear
combination `Σ_{i=0}^{m} c_i · weight(i)` reduces to the last 3 terms
`c_{m-2} · w_{m-2} + c_{m-1} · w_{m-1} + c_m · w_m`. -/
lemma aperyFrobenius_three_step_sum
    {m : ℕ} (hm : 3 ≤ m) (ρ : ℝ) (c₀ : ℝ) :
    ∑ i ∈ Finset.range (m + 1),
      frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly ρ c₀ i *
        PowerSeries.coeff (R := ℝ) (m + 1 + 1)
          (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
            3 Number.aperyConifoldZ1Poly ρ
            ((PowerSeries.X : PowerSeries ℝ) ^ i)) =
    ∑ i ∈ Finset.Ico (m - 2) (m + 1),
      frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly ρ c₀ i *
        PowerSeries.coeff (R := ℝ) (m + 1 + 1)
          (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
            3 Number.aperyConifoldZ1Poly ρ
            ((PowerSeries.X : PowerSeries ℝ) ^ i)) := by
  -- Split range(m+1) into range(m-2) ∪ Ico(m-2, m+1)
  have h_split : Finset.range (m + 1) =
      Finset.range (m - 2) ∪ Finset.Ico (m - 2) (m + 1) := by
    rw [Finset.range_eq_Ico, Finset.Ico_union_Ico_eq_Ico (by omega) (by omega)]
  rw [h_split, Finset.sum_union (by
    rw [Finset.disjoint_left]
    intro x hx hx'
    simp [Finset.mem_range] at hx
    simp [Finset.mem_Ico] at hx'
    omega)]
  -- The sum over range(m-2) vanishes term-by-term
  have h_zero : ∑ i ∈ Finset.range (m - 2),
      frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
        2 Number.aperyConifoldZ1Poly ρ c₀ i *
        PowerSeries.coeff (R := ℝ) (m + 1 + 1)
          (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
            3 Number.aperyConifoldZ1Poly ρ
            ((PowerSeries.X : PowerSeries ℝ) ^ i)) = 0 := by
    refine Finset.sum_eq_zero ?_
    intro i hi
    rw [Finset.mem_range] at hi
    rw [aperyFrobenius_weight_lower_vanish (by omega : i + 3 ≤ m) ρ, mul_zero]
  rw [h_zero, zero_add]

-- **Absolute bound on the 3-step sum.** For `m ≥ 3`, the absolute value
-- of the numerator in the Frobenius recurrence is bounded by:
-- `|Σ₃| ≤ |c_m| · W_m + |c_{m-1}| · W_{m-1} + |c_{m-2}| · W_{m-2}`
-- where each weight `W_k` is bounded by explicit falling-factorial
-- expressions times Taylor shift coefficient absolute values.
-- This is the working front. The weights involve:
-- For i = m (c_m): contributions from j=2 (Q) and j=3 (P)
--   j=2: ff(ρ+m, 2) · |taylorShift_Q_{m+1-m}| = ff(ρ+m, 2) · |taylorShift_Q_1|
--         Wait, the index is (m+2-i)-(3-j) = (m+2-m)-(3-2) = 2-1 = 1
--   j=3: ff(ρ+m, 3) · |taylorShift_P_{(m+2-m)-(3-3)}| = ff(ρ+m, 3) · |taylorShift_P_2|
--
-- Actually, let me recompute using the formula from coeff_succ_substLHSGen_X_pow_explicit.
-- With n=2: coeff(m+2)(substLHS(X^i)) = Σ_{j=0}^{3} (-1)^j · ff(ρ+i, j) · Taylor_coeff
-- where Taylor_coeff is at index (m+2-i)-(3-j) when 3-j ≤ m+2-i.
--
-- For i = m: Taylor indices are (2)-(3-j) = j-1
--   j=0: 0-1 → condition 3 ≤ 2 fails, so 0
--   j=1: 1-1 = 0 → condition 2 ≤ 2 holds, Taylor_Q'_0 = Q(z₁) → but ps 1 = 0
--   j=2: 2-1 = 1 → condition 1 ≤ 2 holds, Taylor_Q_1 = -Q'(z₁)
--   j=3: 3-1 = 2 → condition 0 ≤ 2 holds, Taylor_P_2 = P''(z₁)/2
--
-- For i = m-1: Taylor indices are (3)-(3-j) = j
--   j=2: index 2, Taylor_Q_2 = Q''(z₁)/2
--   j=3: index 3, Taylor_P_3 = -P'''(z₁)/6
--
-- For i = m-2: Taylor indices are (4)-(3-j) = j+1
--   j=2: index 3, Taylor_Q_3 = -Q'''(z₁)/6
--   j=3: index 4, Taylor_P_4 = P⁴(z₁)/24 = 1
--
-- The explicit 3-step recurrence (ρ=1/2, Apéry conifold):
-- c_{m+1} · denom = -(c_m · W_m + c_{m-1} · W_{m-1} + c_{m-2} · W_{m-2})
--
-- W_m = ff(m+½,2)·(3672√2-5187) + ff(m+½,3)·(1224√2-1729)
-- W_{m-1} = ff(m-½,2)·(153-216√2) + ff(m-½,3)·(-34+48√2)  [CHECK: sign from (-1)^j]
-- W_{m-2} = ff(m-3/2,2)·(-6)·(-1) + ff(m-3/2,3)·1·(-1)   [j=2,3 contrib]
-- denom = Q(z₁)·ff(m+3/2,2) + P'(z₁)·ff(m+3/2,3)
--
-- Inductive bound: if |c_k| ≤ C·R^k for k ≤ m with R = 1/z₁, need:
--   R²·|W_m| + R·|W_{m-1}| + |W_{m-2}| ≤ R³·|denom|
--
-- At m=4: LHS ≈ 34²·156 + 34·W₃ + W₂ ≈ 180k, RHS ≈ 34³·140 ≈ 5500k.
-- Factor-of-30 margin. Inequality holds easily.
--
-- Remaining formalization steps (see project_gap_a_bottleneck.md):
-- 1. Per-index Taylor shift absolute value bounds
-- 2. Denominator lower bound
-- 3. Polynomial inequality R²|W_m| + R|W_{m-1}| + |W_{m-2}| ≤ R³|denom| for m ≥ 4
-- 4. Explicit c_1, c_2, c_3 computation (for ρ=1/2, 0, 1)
-- 5. Assemble into Frobenius deviation bound → apery3Det ≠ 0 → close Gap E

/-- **Absolute value of `P''(z₁)/2` is bounded by 3.**
`|1729 - 1224√2| = 1224√2 - 1729 < 3`. From `1224² · 2 = 2996352` and
`(1729+3)² = 1732² = 2999824`, so `1224√2 < 1732`. -/
lemma abs_aperyPconifold_taylorShift_coeff_2_le :
    |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative (Polynomial.derivative Number.aperyPconifold)) / 2| ≤ 3 := by
  rw [Number.aperyPconifold_taylorShift_coeff_2]
  rw [show (1729 : ℝ) - 1224 * Real.sqrt 2 = -(1224 * Real.sqrt 2 - 1729) from by ring]
  rw [abs_neg]
  have hsq2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
  have h_pos : (0 : ℝ) < 1224 * Real.sqrt 2 := by positivity
  have h_sq_cmp : (1224 * Real.sqrt 2) ^ 2 ≥ 1729 ^ 2 := by
    rw [mul_pow, hsq2]; norm_num
  have h_ge : 1729 ≤ 1224 * Real.sqrt 2 := by
    nlinarith [h_sq_cmp, h_pos.le, sq_nonneg (1224 * Real.sqrt 2 + 1729)]
  rw [abs_of_nonneg (by linarith)]
  nlinarith [hsq2, h_ge, sq_nonneg (1224 * Real.sqrt 2 - 1732)]

/-- **|Q'(z₁)| ≤ 6.** `|5187 - 3672√2| = 3672√2 - 5187 < 6`.
From `(3672·√2 - 5193)² ≥ 0`, i.e., `3672²·2 ≥ 2·3672·5193·√2 - 5193²`. -/
lemma abs_aperyQconifold_deriv_eval_z1_le :
    |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyQconifold)| ≤ 6 := by
  rw [Number.aperyQconifold_deriv_eval_z1]
  rw [show (5187 : ℝ) - 3672 * Real.sqrt 2 = -(3672 * Real.sqrt 2 - 5187) from by ring]
  have hsq2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
  have hsq2_pos : 0 < Real.sqrt 2 := Real.sqrt_pos.mpr (by norm_num : (0:ℝ) < 2)
  have h_3672sqrt_pos : (0 : ℝ) < 3672 * Real.sqrt 2 := by positivity
  -- Show 3672√2 ≥ 5187 by comparing squares: (3672√2)² = 3672²·2 = 26970368 > 5187² = 26904969
  have h_sq_cmp : (3672 * Real.sqrt 2) ^ 2 ≥ 5187 ^ 2 := by
    rw [mul_pow, hsq2]; norm_num
  have h_5187_pos : (0 : ℝ) < 5187 := by norm_num
  have h_ge : 5187 ≤ 3672 * Real.sqrt 2 := by
    nlinarith [h_sq_cmp, h_3672sqrt_pos.le, h_5187_pos.le,
               sq_nonneg (3672 * Real.sqrt 2 - 5187),
               sq_nonneg (3672 * Real.sqrt 2 + 5187)]
  rw [abs_neg, abs_of_nonneg (by linarith)]
  nlinarith [hsq2, h_ge, sq_nonneg (3672 * Real.sqrt 2 - 5193)]

/-- **|Q''(z₁)/2| ≤ 153.** `|153 - 216√2| = 216√2 - 153 < 153`.
From `216√2 < 306` (since `216²·2 = 93312 < 93636 = 306²`). -/
lemma abs_aperyQconifold_taylorShift_coeff_2_le :
    |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative (Polynomial.derivative Number.aperyQconifold)) / 2| ≤ 153 := by
  rw [Number.aperyQconifold_taylorShift_coeff_2]
  rw [show (153 : ℝ) - 216 * Real.sqrt 2 = -(216 * Real.sqrt 2 - 153) from by ring]
  have hsq2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
  have h_pos : (0 : ℝ) < 216 * Real.sqrt 2 := by positivity
  have h_sq_cmp : (216 * Real.sqrt 2) ^ 2 ≥ 153 ^ 2 := by
    rw [mul_pow, hsq2]; norm_num
  have h_ge : 153 ≤ 216 * Real.sqrt 2 := by
    nlinarith [h_sq_cmp, h_pos.le, sq_nonneg (216 * Real.sqrt 2 + 153)]
  rw [abs_neg, abs_of_nonneg (by linarith)]
  nlinarith [hsq2, h_ge, sq_nonneg (216 * Real.sqrt 2 - 306)]

/-- **|-P'''(z₁)/6| ≤ 34.** `|-34 + 48√2| = 48√2 - 34 < 34`.
From `48√2 < 68` (since `48²·2 = 4608 < 4624 = 68²`). -/
lemma abs_aperyPconifold_taylorShift_coeff_3_le :
    |-(Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative (Polynomial.derivative
            (Polynomial.derivative Number.aperyPconifold)))) / 6| ≤ 34 := by
  rw [Number.aperyPconifold_taylorShift_coeff_3]
  rw [show (-34 : ℝ) + 48 * Real.sqrt 2 = 48 * Real.sqrt 2 - 34 from by ring]
  have hsq2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0:ℝ) ≤ 2)
  have h_pos : (0 : ℝ) < 48 * Real.sqrt 2 := by positivity
  have h_sq_cmp : (48 * Real.sqrt 2) ^ 2 ≥ 34 ^ 2 := by
    rw [mul_pow, hsq2]; norm_num
  have h_ge : 34 ≤ 48 * Real.sqrt 2 := by
    nlinarith [h_sq_cmp, h_pos.le, sq_nonneg (48 * Real.sqrt 2 + 34)]
  rw [abs_of_nonneg (by linarith)]
  nlinarith [hsq2, h_ge, sq_nonneg (48 * Real.sqrt 2 - 68)]

/-- **|-Q'''(z₁)/6| = 6.** Rational coefficient, trivial. -/
lemma abs_aperyQconifold_taylorShift_coeff_3_eq :
    |-(Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative (Polynomial.derivative
            (Polynomial.derivative Number.aperyQconifold)))) / 6| = 6 := by
  rw [Number.aperyQconifold_taylorShift_coeff_3]
  norm_num

/-- **|P⁴(z₁)/24| = 1.** -/
lemma abs_aperyPconifold_taylorShift_coeff_4_eq :
    |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative (Polynomial.derivative
            (Polynomial.derivative (Polynomial.derivative Number.aperyPconifold)))) / 24| = 1 := by
  rw [Number.aperyPconifold_taylorShift_coeff_4]
  norm_num

/-- **Denominator factorization for the Apéry Frobenius recurrence.**
`Q(z₁) + P'(z₁) · x = P'(z₁) · (x + 3/2)` for any `x : ℝ`.
The ratio `Q(z₁)/P'(z₁) = 3/2`. -/
lemma aperyConifold_denom_factor (x : ℝ) :
    Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold +
      Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) * x =
    Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) * (x + 3 / 2) := by
  rw [Number.aperyQconifold_eval_z1, Number.aperyPconifold_deriv_eval_z1]
  ring

/-- **The Apéry indicial polynomial denominator factors through `P'(z₁)`.**
`simpleZeroIndicialPoly = ff(x,2) · (x - 1/2) · P'(z₁)`. -/
lemma aperyConifold_simpleZeroIndicialPoly_factor (x : ℝ) :
    simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
      Number.aperyConifoldZ1Poly 2 x =
    fallingFactorial x 2 * (x - 1 / 2) *
      Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) := by
  unfold simpleZeroIndicialPoly
  rw [show fallingFactorial x 3 = fallingFactorial x 2 * (x - 2) from
    fallingFactorial_succ x 2]
  have h := aperyConifold_denom_factor (x - 2)
  -- h: Q + P' * (x - 2) = P' * ((x - 2) + 3/2) = P' * (x - 1/2)
  -- Goal: Q * ff + P' * (ff * (x - 2)) = ff * (x - 1/2) * P'
  -- LHS = ff * (Q + P' * (x - 2)) = ff * (P' * (x - 1/2)) = RHS
  linear_combination fallingFactorial x 2 * h

/-- **`aperyGFAReal` is strictly positive on `(0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_pos_of_mem_Ioo_z1
    {z : ℝ} (hz : z ∈ Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) :
    0 < aperyGFAReal z :=
  aperyGFAReal_pos_of_nonneg_z1 (le_of_lt hz.1) hz.2

/-- **`aperyGFAReal` is nonzero on `(0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_ne_zero_of_mem_Ioo_z1
    {z : ℝ} (hz : z ∈ Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) :
    aperyGFAReal z ≠ 0 :=
  (aperyGFAReal_pos_of_mem_Ioo_z1 hz).ne'

/-- **The reciprocal `1/aperyGFAReal` is well-defined and continuous on `(0, z₁)`.** -/
lemma aperyGFAReal_inv_continuousOn_Ioo_z1 :
    ContinuousOn (fun z => 1 / aperyGFAReal z)
      (Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  refine ContinuousOn.div continuousOn_const
    (aperyGFAReal_continuousOn_corridor.mono (fun z hz =>
      ⟨le_of_lt hz.1, hz.2⟩))
    (fun z hz => aperyGFAReal_ne_zero_of_mem_Ioo_z1 hz)

/-- **`1/aperyGFAReal` is strictly decreasing on `(0, z₁)`.** -/
lemma aperyGFAReal_inv_strictAntiOn_Ioo_z1 :
    StrictAntiOn (fun z => 1 / aperyGFAReal z)
      (Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z₁' hz1 z₂ hz2 h12
  rw [div_lt_div_iff₀ (aperyGFAReal_pos_of_mem_Ioo_z1 hz2)
      (aperyGFAReal_pos_of_mem_Ioo_z1 hz1)]
  simp [one_mul]
  exact aperyGFAReal_strict_mono_on_nonneg_z1 (le_of_lt hz1.1) h12 hz2.2

/-- **Monotone left bound on full corridor: `GFA(a) ≤ GFA(z)` for `a ≤ z` in `[0, z₁)`.** -/
lemma aperyGFAReal_mono_left_z1
    {a z : ℝ} (ha : 0 ≤ a) (haz : a ≤ z) (hz : z < Number.aperyConifoldZ1Poly) :
    aperyGFAReal a ≤ aperyGFAReal z := by
  rcases eq_or_lt_of_le haz with rfl | hlt
  · exact le_refl _
  · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_z1 ha hlt hz)

/-- **Monotone right bound on full corridor.** -/
lemma aperyGFAReal_mono_right_z1
    {z b : ℝ} (hz : 0 ≤ z) (hzb : z ≤ b) (hb : b < Number.aperyConifoldZ1Poly) :
    aperyGFAReal z ≤ aperyGFAReal b := by
  rcases eq_or_lt_of_le hzb with rfl | hlt
  · exact le_refl _
  · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_z1 hz hlt hb)

/-- **Two-sided monotone bound on full corridor.** -/
lemma aperyGFAReal_mem_Icc_of_mem_Icc_z1
    {a b : ℝ} (ha : 0 ≤ a) (hb : b < Number.aperyConifoldZ1Poly)
    {z : ℝ} (hz : z ∈ Set.Icc a b) :
    aperyGFAReal z ∈ Set.Icc (aperyGFAReal a) (aperyGFAReal b) :=
  ⟨aperyGFAReal_mono_left_z1 ha hz.1 (lt_of_le_of_lt hz.2 hb),
   aperyGFAReal_mono_right_z1 (le_trans ha hz.1) hz.2 hb⟩

/-- **`aperyGFAReal` has a strict lower bound `1 + 5z` on `[0, z₁)`.** Unconditional.
From the partial sum with `a₀ = 1, a₁ = 5`. -/
lemma aperyGFAReal_ge_one_plus_5z_z1 {z : ℝ} (hz : 0 ≤ z)
    (hz1 : z < Number.aperyConifoldZ1Poly) :
    1 + 5 * z ≤ aperyGFAReal z := by
  have hz_abs : |z| < Number.aperyConifoldZ1Poly := by rw [abs_of_nonneg hz]; exact hz1
  have hone := aperyGFAReal_eq_one_add_tail_z1 hz_abs
  have htail_ge : 5 * z ≤
      ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) := by
    have hterm : (Number.aperyA 1 : ℝ) * z ^ 1 = 5 * z := by
      simp [Number.aperyA_one]
    rw [← hterm]
    exact (aperyGFAReal_tail_summable_z1 hz_abs 1).le_tsum 0
      (fun n _ => mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz _))
  linarith

/-- **First Frobenius coefficient for ρ=1/2 at the Apéry conifold.**

`c₁ = -(1729 - 1224√2) / (2·(19584 - 13848√2)) = -P''(z₁)/(4·P'(z₁))`.

Mathematical derivation:
- coeff₂(substLHS(C 1)) at ρ=1/2: by `coeff_substLHSGen_one_explicit` reduces to
  Q'(z₁)/4 - 3P''(z₁)/16 (j=2 and j=3 terms).
- Using `aperyConifold_denom_factor` (Q(z₁) = (3/2)·P'(z₁)) and the identity
  `2Q'(z₁) = 3P''(z₁)` (verifiable: 2(5187-3672√2) = 3(3458-2448√2) = 10374-7344√2),
  we get coeff_2 = 3P''(z₁)/16.
- denom = (-1)²·simpleZero(3/2) = (3/4)·P'(z₁) (by `aperyConifold_simpleZeroIndicialPoly_factor`).
- c₁ = -coeff_2 / denom = -(3P''(z₁)/16) / (3/4·P'(z₁)) = -P''(z₁)/(4·P'(z₁)).

(Earlier comment claimed `c₁ = +P''(z₁)/2 / P'(z₁)` — that was off by factor -2;
this corrected statement matches the actual Frobenius recurrence with c₀=1.) -/
lemma aperyFrobenius_half_c1_eq :
    frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
      2 Number.aperyConifoldZ1Poly (1 / 2) 1 1 =
    -(1729 - 1224 * Real.sqrt 2) / (2 * (19584 - 13848 * Real.sqrt 2)) := by
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  -- Use linear_combination form at m = 0 (so m+1 = 1)
  have h_rec := frobeniusCoeff_succ_linear_combination
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
    Number.aperyConifoldZ1Poly (1/2) 1 0 hP_zero
  -- Cast (0 + 1) to 1 in the goal
  have h_idx : (0 + 1 : ℕ) = 1 := rfl
  rw [h_idx] at h_rec
  rw [h_rec]
  -- Simplify the sum: only j=0 term, c_0 = 1, X^0 = 1
  simp only [Finset.sum_range_one, frobeniusCoeff_zero, one_mul, pow_zero]
  -- coeff_2 (substLHS X^0) = coeff_2 (substLHS 1)
  rw [coeff_substLHSGen_one_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 3
        Number.aperyConifoldZ1Poly (1/2) (0 + 1 + 1)]
  -- Unfold aperyPsSeq for ps_2 = Q, ps_3 = P arguments
  simp only [show (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2) =
              Number.aperyQconifold from rfl,
             show (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1)) =
              Number.aperyPconifold from rfl]
  -- Denom factorization
  rw [aperyConifold_simpleZeroIndicialPoly_factor]
  -- Expand sum over j ∈ {0,1,2,3}
  rw [show (3 + 1 : ℕ) = 4 from rfl]
  rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
  -- ps_0 = ps_1 = 0 ⇒ vanish; ps_2 = Q, ps_3 = P
  simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
             mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
  -- Apply Taylor connectors
  rw [taylorShift_coeff_one, taylorShift_coeff_two]
  rw [Number.aperyQconifold_deriv_eval_z1, Number.aperyPconifold_deriv_eval_z1]
  -- Normalize 1/2 + ↑1 to 3/2
  rw [show ((1 : ℝ)/2 + ((1 : ℕ) : ℝ)) = 3/2 from by push_cast; ring]
  -- Falling factorials at 1/2 and 3/2
  rw [show fallingFactorial ((1:ℝ)/2) 2 = -(1/4) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
        norm_num,
      show fallingFactorial ((1:ℝ)/2) 3 = (3/8) from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
            fallingFactorial_zero]
        norm_num,
      show fallingFactorial ((3:ℝ)/2) 2 = 3/4 from by
        rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
        norm_num]
  -- Bridge P''(z₁) = 2·(1729-1224√2) via existing lemma
  have hP2 : (Polynomial.derivative (Polynomial.derivative Number.aperyPconifold)).eval
      Number.aperyConifoldZ1Poly = 2 * (1729 - 1224 * Real.sqrt 2) := by
    have h := Number.aperyPconifold_taylorShift_coeff_2
    linarith
  rw [hP2]
  -- Resolve the remaining if-conditions (1 ≤ 2 and 0 ≤ 2 are true)
  simp only [show (1 : ℕ) ≤ 2 from by norm_num,
             show (0 : ℕ) ≤ 2 from by norm_num,
             if_true]
  -- Final algebraic close
  have hP'_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) = 19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  field_simp
  ring

/-- **`aperyGFAReal` is continuous on `[0, b]` for `b < z₁`.** Unconditional
and stated without hypotheses. Direct corollary of `HasCorridor` being
unconditionally true. -/
lemma aperyGFAReal_continuousOn_Icc_z1_alt {a b : ℝ} (ha : 0 ≤ a)
    (hb : b < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc a b) :=
  hasCorridorAperyAnalyticExtension_unconditional.continuousOn_aperyGFAReal_Icc_general ha hb

/-- **Partial sums bound `aperyGFAReal` from below on `[0, z₁)`.** Every
truncation is ≤ the full series. Unconditional on the full disk. -/
lemma aperyGFAPartial_le_aperyGFAReal_z1
    {z : ℝ} (hz : 0 ≤ z) (hz1 : z < Number.aperyConifoldZ1Poly) (N : ℕ) :
    aperyGFAPartial N z ≤ aperyGFAReal z := by
  have hz_abs : |z| < Number.aperyConifoldZ1Poly := by rw [abs_of_nonneg hz]; exact hz1
  rw [aperyGFAReal_eq_partial_add_tail_z1 hz_abs N]
  have h_tsum_nn : (0 : ℝ) ≤ ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
    apply tsum_nonneg
    intro n
    refine mul_nonneg ?_ (pow_nonneg hz _)
    exact_mod_cast Nat.zero_le _
  linarith

/-- **Tail of `aperyGFAReal` is positive on `(0, z₁)`.** -/
lemma aperyGFAReal_sub_partial_pos_z1
    {z : ℝ} (hz : 0 < z) (hz1 : z < Number.aperyConifoldZ1Poly) (N : ℕ) :
    0 < aperyGFAReal z - aperyGFAPartial N z := by
  have hz_abs : |z| < Number.aperyConifoldZ1Poly := by rw [abs_of_nonneg hz.le]; exact hz1
  rw [aperyGFAReal_eq_partial_add_tail_z1 hz_abs N]
  have h_tail_nn : (0 : ℝ) ≤ (Number.aperyA N : ℝ) * z ^ N -
      0 := by
    have h1 : (0 : ℝ) ≤ (Number.aperyA N : ℝ) * z ^ N :=
      mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz.le _)
    linarith
  have h_first_pos : (0 : ℝ) < (Number.aperyA N : ℝ) * z ^ N :=
    mul_pos (by exact_mod_cast Number.aperyA_pos N : (0 : ℝ) < _) (pow_pos hz N)
  have h_tsum_ge_first :
      (Number.aperyA (0 + N) : ℝ) * z ^ (0 + N) ≤
        ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
    apply (aperyGFAReal_tail_summable_z1 hz_abs N).le_tsum 0
    intro n _
    refine mul_nonneg ?_ (pow_nonneg hz.le _)
    exact_mod_cast Nat.zero_le _
  have : (Number.aperyA (0 + N) : ℝ) * z ^ (0 + N) =
      (Number.aperyA N : ℝ) * z ^ N := by congr 1 <;> simp
  rw [this] at h_tsum_ge_first
  linarith

/-! ### Frobenius linear independence — reusable theorem

Three functions with distinct asymptotic rates `O(1)`, `O(√t)`, `O(t)` as
`t → 0⁺` are linearly independent on `(0, ε)`. This captures the essence of
Frobenius linear independence for indicial exponents `{0, 1/2, 1}`.

The proof extracts each coefficient by taking limits:
1. `t → 0⁺`: the `O(1)` term dominates → its coefficient is 0
2. Divide by `√t`, `t → 0⁺`: the `O(√t)` term dominates → its coefficient is 0
3. The remaining term is identically zero → its coefficient is 0

This theorem is reusable for ANY regular singular point with indicial exponents
whose differences include non-integers. -/

/-- **Three functions with distinct vanishing rates are linearly independent.**
If `f₁ → L₁ ≠ 0`, `f₂/√t → L₂ ≠ 0`, `f₃/t → L₃ ≠ 0` as `t → 0⁺`,
then `a₁f₁ + a₂f₂ + a₃f₃ = 0` on `(0, ε)` forces `a₁ = a₂ = a₃ = 0`. -/
theorem frobenius_three_branch_linear_independence
    {ε : ℝ} (hε : 0 < ε)
    {f₁ f₂ f₃ : ℝ → ℝ}
    {L₁ L₂ L₃ : ℝ} (hL₁ : L₁ ≠ 0) (hL₂ : L₂ ≠ 0) (hL₃ : L₃ ≠ 0)
    (h₁ : Filter.Tendsto f₁ (nhdsWithin 0 (Set.Ioi 0)) (nhds L₁))
    (h₂ : Filter.Tendsto (fun t => f₂ t / Real.sqrt t)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds L₂))
    (h₃ : Filter.Tendsto (fun t => f₃ t / t)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds L₃))
    (hf₂_zero : Filter.Tendsto f₂ (nhdsWithin 0 (Set.Ioi 0)) (nhds 0))
    (hf₃_zero : Filter.Tendsto f₃ (nhdsWithin 0 (Set.Ioi 0)) (nhds 0))
    (hf₃_div_sqrt_zero : Filter.Tendsto (fun t => f₃ t / Real.sqrt t)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds 0))
    {a₁ a₂ a₃ : ℝ}
    (h_zero : ∀ t ∈ Set.Ioo (0 : ℝ) ε,
        a₁ * f₁ t + a₂ * f₂ t + a₃ * f₃ t = 0) :
    a₁ = 0 ∧ a₂ = 0 ∧ a₃ = 0 := by
  -- Step 1: Take limit as t → 0⁺ to extract a₁
  have h_a1 : a₁ * L₁ = 0 := by
    have h_tendsto := (h₁.const_mul a₁).add
      ((hf₂_zero.const_mul a₂).add (hf₃_zero.const_mul a₃))
    simp only [mul_zero, add_zero] at h_tendsto
    have h_lim : Filter.Tendsto
        (fun t => a₁ * f₁ t + a₂ * f₂ t + a₃ * f₃ t)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds (a₁ * L₁)) := by
      convert h_tendsto using 1; ring
    have h_eq_zero : Filter.Tendsto
        (fun t => a₁ * f₁ t + a₂ * f₂ t + a₃ * f₃ t)
        (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
      rw [tendsto_nhds]
      intro s hs h0s
      rw [mem_nhdsWithin]
      refine ⟨Set.Iio ε, isOpen_Iio, hε, ?_⟩
      intro t ht
      have ht_pos : 0 < t := ht.2
      have ht_lt : t < ε := ht.1
      show a₁ * f₁ t + a₂ * f₂ t + a₃ * f₃ t ∈ s
      rw [h_zero t ⟨ht_pos, ht_lt⟩]
      exact h0s
    have := tendsto_nhds_unique h_lim h_eq_zero
    linarith
  have ha1 : a₁ = 0 := by
    rcases mul_eq_zero.mp h_a1 with h | h
    · exact h
    · exact absurd h hL₁
  -- Step 2: With a₁ = 0, divide by √t to extract a₂
  subst ha1
  simp only [zero_mul, zero_add] at h_zero
  have h_a2 : a₂ * L₂ = 0 := by
    have h_div_sqrt : ∀ t ∈ Set.Ioo (0 : ℝ) ε,
        a₂ * (f₂ t / Real.sqrt t) + a₃ * (f₃ t / Real.sqrt t) = 0 := by
      intro t ht
      have ht_pos := ht.1
      have hsqrt_pos : 0 < Real.sqrt t := Real.sqrt_pos.mpr ht_pos
      have h := h_zero t ht
      have h_div : (a₂ * f₂ t + a₃ * f₃ t) / Real.sqrt t = 0 := by
        rw [h]; exact zero_div _
      rw [add_div, mul_div_assoc, mul_div_assoc] at h_div
      exact h_div
    have h_tendsto := (h₂.const_mul a₂).add (hf₃_div_sqrt_zero.const_mul a₃)
    simp only [mul_zero, add_zero] at h_tendsto
    have h_lim : Filter.Tendsto
        (fun t => a₂ * (f₂ t / Real.sqrt t) + a₃ * (f₃ t / Real.sqrt t))
        (nhdsWithin 0 (Set.Ioi 0)) (nhds (a₂ * L₂)) := by
      convert h_tendsto using 1
    have h_eq_zero : Filter.Tendsto
        (fun t => a₂ * (f₂ t / Real.sqrt t) + a₃ * (f₃ t / Real.sqrt t))
        (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
      rw [tendsto_nhds]
      intro s hs h0s
      rw [mem_nhdsWithin]
      refine ⟨Set.Iio ε, isOpen_Iio, hε, ?_⟩
      intro t ht
      have ht_pos : 0 < t := ht.2
      have ht_lt : t < ε := ht.1
      show a₂ * (f₂ t / Real.sqrt t) + a₃ * (f₃ t / Real.sqrt t) ∈ s
      rw [h_div_sqrt t ⟨ht_pos, ht_lt⟩]
      exact h0s
    have := tendsto_nhds_unique h_lim h_eq_zero
    linarith
  have ha2 : a₂ = 0 := by
    rcases mul_eq_zero.mp h_a2 with h | h
    · exact h
    · exact absurd h hL₂
  -- Step 3: With a₁ = a₂ = 0, extract a₃
  subst ha2
  simp only [zero_mul, zero_add] at h_zero
  have h_a3 : a₃ * L₃ = 0 := by
    have h_div_t : ∀ t ∈ Set.Ioo (0 : ℝ) ε,
        a₃ * (f₃ t / t) = 0 := by
      intro t ht
      have ht_ne : t ≠ 0 := ne_of_gt ht.1
      have h := h_zero t ht
      rw [show a₃ * (f₃ t / t) = a₃ * f₃ t / t from by ring,
          h, zero_div]
    have h_lim : Filter.Tendsto
        (fun t => a₃ * (f₃ t / t))
        (nhdsWithin 0 (Set.Ioi 0)) (nhds (a₃ * L₃)) :=
      h₃.const_mul a₃
    have h_eq_zero : Filter.Tendsto
        (fun t => a₃ * (f₃ t / t))
        (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
      rw [tendsto_nhds]
      intro s hs h0s
      rw [mem_nhdsWithin]
      refine ⟨Set.Iio ε, isOpen_Iio, hε, ?_⟩
      intro t ht
      have ht_pos : 0 < t := ht.2
      have ht_lt : t < ε := ht.1
      show a₃ * (f₃ t / t) ∈ s
      rw [h_div_t t ⟨ht_pos, ht_lt⟩]
      exact h0s
    have := tendsto_nhds_unique h_lim h_eq_zero
    linarith
  have ha3 : a₃ = 0 := by
    rcases mul_eq_zero.mp h_a3 with h | h
    · exact h
    · exact absurd h hL₃
  exact ⟨rfl, rfl, ha3⟩

/-! ### Custom Frobenius coefficient bound for Apéry ρ=1/2

The generic Gronwall bound gives K ≈ 337,655 (convergence radius ≈ 10⁻⁶).
But the 3-step recurrence + denominator factorization gives a MUCH tighter
bound. The effective ratio at each step is:

  |c_{m+1}| ≤ [A(m)·|c_m| + B(m)·|c_{m-1}| + C(m)·|c_{m-2}|] / |D(m)|

where D(m) = (m+3/2)(m+1/2)(m-1/2)·|P'(z₁)| (from factorization)
and A, B, C involve Taylor shift coefficients × falling factorials.

For m ≥ M₀, each ratio term decays as 1/m, giving a total effective
ratio that → |p₂/P'(z₁)| ≈ 1.8 as m → ∞. The series converges
geometrically with ratio < 34 for m ≥ 4.

Strategy: prove the 3-step bound for the SPECIFIC Apéry instance,
then derive summability and continuity. -/

-- Active front: eigenvalue decomposition approach.
-- The characteristic cubic of the limiting 3-step recurrence factors
-- through the Taylor expansion of P at z₁:
--   taylorShift(P)(t) = t·(t - z₁)²·(t + 24√2)
-- giving eigenvalues 1/z₁ (double) and -1/(24√2) (single).
-- The coefficient growth is c_m = O(m·z₁^{-m}).

/-- **Taylor shift of P at z₁ factors as `t·(t-z₁)²·(t+24√2)`.** Since
`P(z) = z²(z²-34z+1)` and `z₁²-34z₁+1 = 0`, the shifted polynomial
`P(z₁-t) = (z₁-t)²·((z₁-t)²-34(z₁-t)+1)`. The quadratic factor
`u²-34u+1` at `u = z₁-t` becomes `(z₁-t-z₁)(z₁-t-z₂) = (-t)(z₁-z₂-t)
= (-t)(-24√2-t) = t(t+24√2)`. Combined with `(z₁-t)²`: the full shift
is `(z₁-t)²·t·(t+24√2)`. In the `taylorShift` convention (polynomial
in `t`): `taylorShift(P)(t) = t·(z₁-t)²·(t+24√2)`. -/
lemma aperyPconifold_taylorShift_factored (t : ℝ) :
    Polynomial.eval t (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly) =
      t * (Number.aperyConifoldZ1Poly - t) ^ 2 * (t + 24 * Real.sqrt 2) := by
  unfold taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly
  simp [Polynomial.eval_comp, Polynomial.eval_add, Polynomial.eval_monomial,
        Polynomial.eval_sub, Polynomial.eval_C, Polynomial.eval_X]
  have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  nlinarith [hsq]

/-- **`taylorShift(P)` vanishes at `t = z₁`.** Direct from the factorization. -/
lemma aperyPconifold_taylorShift_at_z1 :
    Polynomial.eval Number.aperyConifoldZ1Poly
      (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly) = 0 := by
  rw [aperyPconifold_taylorShift_factored]
  ring

/-- **`taylorShift(P)` vanishes at `t = 0`.** Direct from the `t` factor. -/
lemma aperyPconifold_taylorShift_at_zero :
    Polynomial.eval 0
      (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly) = 0 := by
  rw [aperyPconifold_taylorShift_factored]
  ring

-- **`taylorShift(P)` is nonzero at `t = -24√2`.** The other roots are
-- `0` and `z₁` (double), so at `t = -24√2` the value is
-- `(-24√2)·(z₁+24√2)²·0 = 0`... wait, `t+24√2 = 0` at this root!
-- So the value IS zero. This is a ROOT, not a nonzero point.

/-- **`24√2 + z₁` is positive.** From `z₁ > 0` and `24√2 > 0`. -/
lemma twentyfour_sqrt2_add_z1_pos :
    0 < 24 * Real.sqrt 2 + Number.aperyConifoldZ1Poly := by
  have := aperyConifoldZ1Poly_pos
  positivity

/-- **The three roots of `taylorShift(P)` are `0`, `z₁`, `-24√2`.** The
factorization `t·(z₁-t)²·(t+24√2)` vanishes exactly at these values.
Equivalently: `taylorShift(P)(t) ≠ 0` for `t ∈ (0, z₁)`. -/
lemma aperyPconifold_taylorShift_ne_zero_of_Ioo
    {t : ℝ} (ht : t ∈ Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) :
    Polynomial.eval t
      (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly) ≠ 0 := by
  rw [aperyPconifold_taylorShift_factored]
  have ht_pos := ht.1
  have ht_lt := ht.2
  have h_sqrt2_pos : 0 < Real.sqrt 2 := Real.sqrt_pos.mpr (by norm_num : (0 : ℝ) < 2)
  -- t > 0, z₁ - t > 0, (z₁-t)² > 0, t + 24√2 > 0
  have h_pos : 0 < t * (Number.aperyConifoldZ1Poly - t) ^ 2 * (t + 24 * Real.sqrt 2) := by
    apply mul_pos
    · refine mul_pos ht_pos ?_
      have : 0 < Number.aperyConifoldZ1Poly - t := by linarith
      positivity
    · positivity
  exact ne_of_gt h_pos

/-- **Frobenius denominator is nonzero at every step for ρ=1/2.**
Uses the factorization `denom = ff(x,2)·(x-2)·P'(z₁)` with `P'(z₁) ≠ 0`
and the falling factorial factor nonzero for x = m+3/2 (half-integer). -/
lemma aperyFrobenius_half_denom_ne_zero (m : ℕ) :
    ((-1 : ℝ) ^ 2) *
      simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
        Number.aperyConifoldZ1Poly 2 ((1 : ℝ) / 2 + ((m + 1 : ℕ) : ℝ)) ≠ 0 := by
  rw [show (-1 : ℝ) ^ 2 = 1 from by norm_num, one_mul]
  rw [aperyConifold_simpleZeroIndicialPoly_factor]
  -- Need: ff(m+3/2, 2) · (m+3/2 - 2) · P'(z₁) ≠ 0
  -- ff(m+3/2, 2) = (m+3/2)(m+1/2) ≠ 0 (positive for all m : ℕ)
  -- m+3/2 - 2 = m - 1/2 ≠ 0 (half-integer for all m : ℕ)
  -- P'(z₁) ≠ 0 (proved)
  have h_m : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
  refine mul_ne_zero (mul_ne_zero ?_ ?_) (Number.aperyPconifold_deriv_eval_z1_ne_zero)
  · -- ff(1/2 + (m+1), 2) = 1 · (1/2 + (m+1)) · (1/2 + (m+1) - 1) ≠ 0
    rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
    refine mul_ne_zero (mul_ne_zero one_ne_zero ?_) ?_
    · push_cast; linarith  -- 1/2 + (m+1) - 0 ≠ 0
    · push_cast; linarith  -- 1/2 + (m+1) - 1 ≠ 0
  · -- 1/2 + (m+1) - 2 ≠ 0
    push_cast; linarith

/-- **Frobenius denominator is nonzero at every step for ρ=1.** -/
lemma aperyFrobenius_one_denom_ne_zero (m : ℕ) :
    ((-1 : ℝ) ^ 2) *
      simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
        Number.aperyConifoldZ1Poly 2 ((1 : ℝ) + ((m + 1 : ℕ) : ℝ)) ≠ 0 := by
  have h_m : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
  rw [show (-1 : ℝ) ^ 2 = 1 from by norm_num, one_mul]
  rw [aperyConifold_simpleZeroIndicialPoly_factor]
  refine mul_ne_zero (mul_ne_zero ?_ ?_) (Number.aperyPconifold_deriv_eval_z1_ne_zero)
  · rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
    refine mul_ne_zero (mul_ne_zero one_ne_zero ?_) ?_
    · push_cast; linarith
    · push_cast; linarith
  · push_cast; linarith

/-- **Frobenius denominator for ρ=0 is nonzero for m ≥ 1.**
At m=0 the denominator vanishes (resonance), but for m ≥ 1 it's nonzero. -/
lemma aperyFrobenius_zero_denom_ne_zero {m : ℕ} (hm : 1 ≤ m) :
    ((-1 : ℝ) ^ 2) *
      simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
        Number.aperyConifoldZ1Poly 2 ((0 : ℝ) + ((m + 1 : ℕ) : ℝ)) ≠ 0 := by
  have h_m : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
  have h_m_ge_1 : (1 : ℝ) ≤ (m : ℝ) := by exact_mod_cast hm
  rw [show (-1 : ℝ) ^ 2 = 1 from by norm_num, one_mul, zero_add]
  rw [aperyConifold_simpleZeroIndicialPoly_factor]
  refine mul_ne_zero (mul_ne_zero ?_ ?_) (Number.aperyPconifold_deriv_eval_z1_ne_zero)
  · rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
    refine mul_ne_zero (mul_ne_zero one_ne_zero ?_) ?_
    · push_cast; linarith
    · push_cast; linarith
  · push_cast; linarith

/-! ### Characteristic polynomial of the limiting Frobenius recurrence

The 3-step recurrence for the Frobenius coefficients has m-dependent
coefficients that converge to a constant-coefficient recurrence as m → ∞.
The characteristic polynomial of this limiting recurrence is:

    P'(z₁)·λ³ − P''(z₁)/2·λ² + P'''(z₁)/6·λ − P⁴(z₁)/24 = 0

which equals the cubic factor of `taylorShift(P)(t)/t` evaluated at
`t = 1/λ`, scaled by `λ³`. Since `taylorShift(P)(t) = t·(z₁−t)²·(t+24√2)`,
the cubic `(z₁−t)²·(t+24√2)` has roots `t = z₁` (double) and `t = −24√2`.
So the eigenvalues are `λ = 1/z₁` (double) and `λ = −1/(24√2)`.

**Consequence:** The general solution is `c_m = (A+Bm)·(1/z₁)^m + E·(-1/(24√2))^m`.
Each component satisfies `|·| ≤ C·(m+1)·(1/z₁)^m`, giving the growth bound.

**Why triangle inequality fails:** In the rescaled variable `u_m = c_m·z₁^m`,
the limiting recurrence has coefficients α ≈ 2, β ≈ −1, γ ≈ −0.001.
The sum |α|+|β|+|γ| ≈ 3 > 1, so the triangle inequality gives exponential
growth. But the SIGNED sum α+β+γ = 1 (eigenvalue 1), and the solution
is actually O(m). The cancellation is essential. -/

/-- **The cubic factor of `taylorShift(P)/t`.** Evaluating the cubic
`(z₁-t)²·(t+24√2)` at `t = 1/λ` and multiplying by `λ³` gives the
characteristic polynomial of the limiting Frobenius recurrence. -/
lemma aperyPconifold_cubic_factor {t : ℝ} (ht : t ≠ 0) :
    (Number.aperyConifoldZ1Poly - t) ^ 2 * (t + 24 * Real.sqrt 2) =
      Polynomial.eval t (taylorShift Number.aperyPconifold Number.aperyConifoldZ1Poly) / t := by
  rw [aperyPconifold_taylorShift_factored]
  field_simp

/-- **The cubic factor vanishes at `t = z₁` (double root).** -/
lemma aperyPconifold_cubic_at_z1 :
    (Number.aperyConifoldZ1Poly - Number.aperyConifoldZ1Poly) ^ 2 *
      (Number.aperyConifoldZ1Poly + 24 * Real.sqrt 2) = 0 := by ring

/-- **The cubic factor vanishes at `t = -24√2`.** -/
lemma aperyPconifold_cubic_at_neg24sqrt2 :
    (Number.aperyConifoldZ1Poly - (-24 * Real.sqrt 2)) ^ 2 *
      ((-24 * Real.sqrt 2) + 24 * Real.sqrt 2) = 0 := by ring

/-- **The subdominant eigenvalue `|−1/(24√2)| < 1/z₁`.** This ensures
the subdominant Frobenius branch decays relative to the dominant one. -/
lemma subdominant_eigenvalue_lt :
    1 / (24 * Real.sqrt 2) < 1 / Number.aperyConifoldZ1Poly := by
  have h_sqrt2_pos : 0 < Real.sqrt 2 := Real.sqrt_pos.mpr (by norm_num : (0 : ℝ) < 2)
  have h_24sqrt2_pos : 0 < 24 * Real.sqrt 2 := by positivity
  have h_z1_pos : 0 < Number.aperyConifoldZ1Poly := aperyConifoldZ1Poly_pos
  rw [div_lt_div_iff₀ h_24sqrt2_pos h_z1_pos]
  -- Need: z₁ < 24√2, i.e., 17-12√2 < 24√2, i.e., 17 < 36√2
  unfold Number.aperyConifoldZ1Poly
  nlinarith [Real.sq_sqrt (show (0 : ℝ) ≤ 2 from by norm_num),
             sq_nonneg (36 * Real.sqrt 2 - 17)]

/-- **Subdominant branch satisfies the growth bound.** For ANY
`C ≥ 1` and all `m : ℕ`, `(1/(24√2))^m ≤ C · (m+1) · (1/z₁)^m`.
This means the third Frobenius branch (eigenvalue `-1/(24√2)`) automatically
satisfies the required growth bound — only the dominant double-root branch
at `1/z₁` needs serious analysis. -/
lemma subdominant_branch_le_growth_bound {C : ℝ} (hC : 1 ≤ C) (m : ℕ) :
    (1 / (24 * Real.sqrt 2)) ^ m ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  have hz1 := aperyConifoldZ1Poly_pos
  have h24 : 0 < 24 * Real.sqrt 2 := by positivity
  have hle := subdominant_eigenvalue_lt
  calc (1 / (24 * Real.sqrt 2)) ^ m
      ≤ (1 / Number.aperyConifoldZ1Poly) ^ m :=
        pow_le_pow_left₀ (by positivity) hle.le m
    _ ≤ 1 * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
        nlinarith [pow_nonneg (one_div_nonneg.mpr hz1.le) m]
    _ ≤ C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
        refine mul_le_mul_of_nonneg_right ?_ (pow_nonneg (by positivity) _)
        exact mul_le_mul_of_nonneg_right hC (by positivity)

/-- **Dominant branch (simple) satisfies the growth bound.** For `C ≥ 1`,
`(1/z₁)^m ≤ C · (m+1) · (1/z₁)^m`. Trivial since `m+1 ≥ 1`. -/
lemma dominant_simple_branch_le_growth_bound {C : ℝ} (hC : 1 ≤ C) (m : ℕ) :
    (1 / Number.aperyConifoldZ1Poly) ^ m ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  have hpow : 0 ≤ (1 / Number.aperyConifoldZ1Poly) ^ m :=
    pow_nonneg (one_div_nonneg.mpr aperyConifoldZ1Poly_pos.le) m
  have hm1 : (1 : ℝ) ≤ (m : ℝ) + 1 := by
    have : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
    linarith
  nlinarith [hpow, hm1, hC, mul_nonneg (le_trans zero_le_one hC) hpow]

/-- **Dominant branch (generalized, from double root) satisfies the growth bound.**
`m · (1/z₁)^m ≤ C · (m+1) · (1/z₁)^m` for `C ≥ 1`. -/
lemma dominant_gen_branch_le_growth_bound {C : ℝ} (hC : 1 ≤ C) (m : ℕ) :
    (m : ℝ) * (1 / Number.aperyConifoldZ1Poly) ^ m ≤
      C * ((m : ℝ) + 1) * (1 / Number.aperyConifoldZ1Poly) ^ m := by
  have hpow : 0 ≤ (1 / Number.aperyConifoldZ1Poly) ^ m :=
    pow_nonneg (one_div_nonneg.mpr aperyConifoldZ1Poly_pos.le) m
  have hm_nn : (0 : ℝ) ≤ (m : ℝ) := Nat.cast_nonneg m
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by linarith
  have h1 : (m : ℝ) ≤ C * ((m : ℝ) + 1) := by nlinarith [hC, hm_nn]
  exact mul_le_mul_of_nonneg_right h1 hpow

/-- **3-step recurrence form for ρ=1/2 (sub-lemma 1 of ratio_bound roadmap).**
For `m ≥ 3`, the Frobenius coefficient at index `m+1` is determined by
the values at `m`, `m-1`, `m-2` via:
```
c(m+1) · denom(m+1) =
  -(c(m-2)·w_{m-2} + c(m-1)·w_{m-1} + c(m)·w_m)
```
where `denom(m+1) = (-1)²·simpleZeroIndicialPoly(Q, P, z₁, 2, 3/2 + m)`
and each `w_i = coeff (m+2)(substLHSGen ps 3 z₁ (1/2) (X^i))`.

This is purely a rewriting of `frobeniusCoeff_succ_linear_combination`
with the lower-index weights vanishing (per `aperyFrobenius_three_step_sum`). -/
lemma aperyFrobenius_half_3step_recurrence
    {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly (1 / 2) 1
    let w (i : ℕ) := PowerSeries.coeff (R := ℝ) (m + 1 + 1)
              (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
                3 Number.aperyConifoldZ1Poly (1 / 2)
                ((PowerSeries.X : PowerSeries ℝ) ^ i))
    let denom_val := ((-1 : ℝ) ^ 2) *
              simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
                Number.aperyConifoldZ1Poly 2 ((1 : ℝ) / 2 + ((m + 1 : ℕ) : ℝ))
    c (m + 1) * denom_val =
      -(c (m - 2) * w (m - 2) + c (m - 1) * w (m - 1) + c m * w m) := by
  -- From frobeniusCoeff_succ_linear_combination:
  --   c(m+1) = -(Σ_{i ∈ range(m+1)} c i · w i) / denom_val
  -- Multiply by denom_val (nonzero):
  --   c(m+1) · denom_val = -(Σ ... )
  -- By aperyFrobenius_three_step_sum, sum = c(m-2)·w_{m-2} + c(m-1)·w_{m-1} + c m · w_m.
  intro c w denom_val
  have hP_zero : Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyPconifold = 0 :=
    Number.aperyPconifold_eval_z1
  have h_rec := frobeniusCoeff_succ_linear_combination
    (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
    Number.aperyConifoldZ1Poly (1 / 2) 1 m hP_zero
  have h_3step := aperyFrobenius_three_step_sum hm (1 / 2 : ℝ) 1
  have h_denom_ne : denom_val ≠ 0 := aperyFrobenius_half_denom_ne_zero m
  -- c(m+1) = -(Σ c_i · w_i) / denom_val. Rearrange:
  -- c(m+1) · denom_val = -(Σ c_i · w_i)
  have h_eq1 :
      c (m + 1) * denom_val =
        -(∑ i ∈ Finset.range (m + 1), c i * w i) := by
    show frobeniusCoeff _ 2 _ (1 / 2) 1 (m + 1) * denom_val = _
    rw [h_rec]
    -- aperyPsSeq 0 0 Q P 2 = Q and aperyPsSeq 0 0 Q P 3 = P (rfl)
    have hps2 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold 2 =
        Number.aperyQconifold := rfl
    have hps3 : aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold (2 + 1) =
        Number.aperyPconifold := rfl
    rw [hps2, hps3]
    rw [neg_div, neg_mul, div_mul_cancel₀ _ h_denom_ne]
  rw [h_eq1]
  -- Now apply 3-step reduction
  congr 1
  have h_3step_local :
      ∑ i ∈ Finset.range (m + 1), c i * w i =
      ∑ i ∈ Finset.Ico (m - 2) (m + 1), c i * w i := h_3step
  rw [h_3step_local]
  -- Expand Finset.Ico (m-2) (m+1) as {m-2} ∪ {m-1} ∪ {m}
  rw [show Finset.Ico (m - 2) (m + 1) =
        ({m - 2} : Finset ℕ) ∪ {m - 1} ∪ {m} from by
    ext k
    simp only [Finset.mem_Ico, Finset.mem_union, Finset.mem_singleton]
    omega]
  rw [Finset.sum_union (by
    rw [Finset.disjoint_left]
    intro x hx hx'
    simp [Finset.mem_union, Finset.mem_singleton] at hx hx'
    omega)]
  rw [Finset.sum_union (by
    rw [Finset.disjoint_left]
    intro x hx hx'
    simp [Finset.mem_singleton] at hx hx'
    omega)]
  rw [Finset.sum_singleton, Finset.sum_singleton, Finset.sum_singleton]

/-- **w_m explicit form for ρ=1/2 (sub-lemma 2a of ratio_bound roadmap).**
The weight at index `i = m` in the 3-step recurrence:
```
w_m = -ff(1/2+m, 2)·Q'(z₁) - ff(1/2+m, 3)·(P''(z₁)/2)
```

After algebraic simplification using `2Q'(z₁) = 3P''(z₁)`:
```
w_m = -ff(1/2+m, 2)·(P''(z₁)/2) · [3 + (m - 3/2)]
    = -ff(1/2+m, 2)·(P''(z₁)/2) · (m + 3/2)
```
(used in subsequent sub-lemmas for limit and ratio computations) -/
lemma aperyFrobenius_half_w_m_explicit {m : ℕ} (hm : 1 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ m)) =
      -fallingFactorial (1 / 2 + (m : ℝ)) 2 * (5187 - 3672 * Real.sqrt 2) -
      fallingFactorial (1 / 2 + (m : ℝ)) 3 * ((3458 - 2448 * Real.sqrt 2) / 2) := by
  rw [coeff_succ_substLHSGen_X_pow_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (m + 1) m (by omega)]
  rw [show (2 + 2 : ℕ) = 4 from rfl]
  rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
  simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
             mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
  simp only [show (3 : ℕ) - 2 ≤ m + 1 + 1 - m from by omega,
             show (3 : ℕ) - 3 ≤ m + 1 + 1 - m from by omega,
             if_true]
  rw [show (m + 1 + 1 - m : ℕ) - (3 - 2) = 1 from by omega,
      show (m + 1 + 1 - m : ℕ) - (3 - 3) = 2 from by omega]
  rw [taylorShift_coeff_one, taylorShift_coeff_two]
  rw [Number.aperyQconifold_deriv_eval_z1]
  -- Bridge P''(z₁) = 3458 - 2448√2 (from taylorShift_coeff_2)
  have hP2 : (Polynomial.derivative (Polynomial.derivative Number.aperyPconifold)).eval
      Number.aperyConifoldZ1Poly = 3458 - 2448 * Real.sqrt 2 :=
    Number.aperyPconifold_deriv2_eval_z1
  rw [hP2]
  ring

/-- **w_{m-1} explicit form for ρ=1/2 (sub-lemma 2b of ratio_bound roadmap).**
The weight at index `i = m-1` in the 3-step recurrence:
```
w_{m-1} = ff(m-1/2, 2)·(Q''(z₁)/2) - ff(m-1/2, 3)·(-P'''(z₁)/6)·(-1)
       = ff(m-1/2, 2)·(153 - 216√2) - ff(m-1/2, 3)·(-34 + 48√2)
       = ff(m-1/2, 2)·(153 - 216√2) - ff(m-1/2, 3)·(48√2 - 34)
```
(numerical: ff(m-1/2, 2)·(153 - 216√2) - ff(m-1/2, 3)·(48√2 - 34))

Sign comes from taylorShift_coeff_three giving `coeff_3 = -p'''(z₁)/6`
plus (-1)^3 = -1 from the j=3 term in coeff_substLHSGen_one_explicit. -/
lemma aperyFrobenius_half_w_m_minus_one_explicit {m : ℕ} (hm : 2 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 1))) =
      fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 2 * (153 - 216 * Real.sqrt 2) -
      fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 3 * (48 * Real.sqrt 2 - 34) := by
  rw [coeff_succ_substLHSGen_X_pow_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (m + 1) (m - 1) (by omega)]
  rw [show (2 + 2 : ℕ) = 4 from rfl]
  rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
  simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
             mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
  simp only [show (3 : ℕ) - 2 ≤ m + 1 + 1 - (m - 1) from by omega,
             show (3 : ℕ) - 3 ≤ m + 1 + 1 - (m - 1) from by omega,
             if_true]
  rw [show (m + 1 + 1 - (m - 1) : ℕ) - (3 - 2) = 2 from by omega,
      show (m + 1 + 1 - (m - 1) : ℕ) - (3 - 3) = 3 from by omega]
  rw [taylorShift_coeff_two, taylorShift_coeff_three]
  -- taylor_coeff_2(Q) = Q''(z₁)/2 = 153 - 216√2 (Apéry value)
  -- taylor_coeff_3(P) = -P'''(z₁)/6 = -(204-288√2)/6 = -34 + 48√2 = 48√2 - 34
  rw [show (Polynomial.derivative (Polynomial.derivative Number.aperyQconifold)).eval
        Number.aperyConifoldZ1Poly / 2 = 153 - 216 * Real.sqrt 2 from
        Number.aperyQconifold_taylorShift_coeff_2]
  rw [Number.aperyPconifold_deriv3_eval_z1]
  ring

/-- **w_{m-2} explicit form for ρ=1/2 (sub-lemma 2c of ratio_bound roadmap).**
The weight at index `i = m-2` in the 3-step recurrence:
```
w_{m-2} = -6·ff(m-3/2, 2) - ff(m-3/2, 3)
```
(comes from -ff(m-3/2, 2)·Q'''(z₁)/6 - ff(m-3/2, 3)·P^(4)(z₁)/24, with
Q'''(z₁)/6 = 6 and P^(4)(z₁)/24 = 1 — both rational since
Q'''(z₁) = 36 and P^(4)(z₁) = 24.) -/
lemma aperyFrobenius_half_w_m_minus_two_explicit {m : ℕ} (hm : 3 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 2))) =
      -6 * fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 2 -
      fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 3 := by
  rw [coeff_succ_substLHSGen_X_pow_explicit
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly (1 / 2) (m + 1) (m - 2) (by omega)]
  rw [show (2 + 2 : ℕ) = 4 from rfl]
  rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_succ, Finset.sum_range_zero, zero_add]
  simp only [aperyPsSeq, taylorShift_zero, Polynomial.coeff_zero,
             mul_zero, zero_mul, mul_ite, ite_self, add_zero, zero_add]
  -- Conditions: 3-2=1 ≤ (m+1)+1-(m-2) = 4 ✓, 3-3=0 ≤ 4 ✓
  simp only [show (3 : ℕ) - 2 ≤ m + 1 + 1 - (m - 2) from by omega,
             show (3 : ℕ) - 3 ≤ m + 1 + 1 - (m - 2) from by omega,
             if_true]
  -- Indices: ((m+1)+1-(m-2)) - (3-2) = 4 - 1 = 3; ((m+1)+1-(m-2)) - (3-3) = 4 - 0 = 4
  rw [show (m + 1 + 1 - (m - 2) : ℕ) - (3 - 2) = 3 from by omega,
      show (m + 1 + 1 - (m - 2) : ℕ) - (3 - 3) = 4 from by omega]
  -- We need taylor_coeff at index 3 (Q) and index 4 (P).
  -- taylor_coeff_three is in Substitution.lean; for index 4 we use natDegree bound.
  -- Q has natDegree 3, so taylor Q at index 4 vanishes... wait we need P here, not Q.
  -- For j=2 we have aperyQconifold (= ps_2), at index 3.
  -- For j=3 we have aperyPconifold (= ps_3), at index 4.
  rw [taylorShift_coeff_three]
  -- For j=2 contribution: taylor_coeff_three(Q) = -Q'''(z₁)/6 = -36/6 = -6.
  rw [Number.aperyQconifold_deriv3_eval_z1]
  -- For j=3: taylor coeff at index 4 of P. Use taylorShift_coeff_four-like fact.
  -- For Apéry P (z⁴-34z³+z²) with leading coeff 1, taylorShift P z₁ has leading coeff
  -- = (-1)^4 · 1 = 1. We bridge via P^(4)(z₁)/24 = 1.
  rw [taylorShift_coeff_four, Number.aperyPconifold_deriv4_eval_z1]
  ring

/-- **denom(m+1) explicit form for ρ=1/2 (sub-lemma 3 of ratio_bound roadmap).**
The denominator at step `m+1` for the ρ=1/2 Frobenius recurrence:
```
denom(m+1) = (m+3/2)(m+1/2)(m+1)·P'(z₁)
           = (m+3/2)(m+1/2)(m+1)·(19584-13848√2)
```
Comes from `aperyConifold_simpleZeroIndicialPoly_factor` at x = m+3/2. -/
lemma aperyFrobenius_half_denom_explicit (m : ℕ) :
    ((-1 : ℝ) ^ 2) *
      simpleZeroIndicialPoly Number.aperyQconifold Number.aperyPconifold
        Number.aperyConifoldZ1Poly 2 ((1 : ℝ) / 2 + ((m + 1 : ℕ) : ℝ)) =
    fallingFactorial (3 / 2 + (m : ℝ)) 2 * ((m : ℝ) + 1) *
      (19584 - 13848 * Real.sqrt 2) := by
  rw [show (-1 : ℝ) ^ 2 = 1 from by norm_num, one_mul]
  rw [aperyConifold_simpleZeroIndicialPoly_factor]
  rw [Number.aperyPconifold_deriv_eval_z1]
  -- simpleZero = ff(x, 2)·(x - 1/2)·P'(z₁) at x = 1/2 + (m+1) = 3/2 + m
  -- (x - 1/2) at x = 3/2 + m equals m + 1
  have hx_eq : (1 : ℝ) / 2 + ((m + 1 : ℕ) : ℝ) = 3 / 2 + (m : ℝ) := by push_cast; ring
  rw [hx_eq]
  have hx_sub : (3 : ℝ) / 2 + (m : ℝ) - 1 / 2 = (m : ℝ) + 1 := by ring
  rw [hx_sub]

/-- **Apéry ρ=1/2 closed-form 3-step recurrence (sub-lemma 4 of ratio_bound roadmap).**

For `m ≥ 3`, combining sub-lemmas 1, 2a, 2b, 2c, 3 yields:
```
c(m+1) · ff(3/2+m, 2)·(m+1)·(19584-13848√2) =
  -[c(m)·(-ff(1/2+m, 2)·(5187-3672√2) - ff(1/2+m, 3)·((3458-2448√2)/2))
    + c(m-1)·(ff(m-1/2, 2)·(153-216√2) - ff(m-1/2, 3)·(48√2-34))
    + c(m-2)·(-6·ff(m-3/2, 2) - ff(m-3/2, 3))]
```

This is the FULLY EXPLICIT 3-step Frobenius recurrence at the Apéry conifold
ρ=1/2 branch. From here, ratio_bound proof is bootstrap induction on m. -/
lemma aperyFrobenius_half_3step_closed_form {m : ℕ} (hm : 3 ≤ m) :
    let c := frobeniusCoeff (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
              2 Number.aperyConifoldZ1Poly (1 / 2) 1
    c (m + 1) * (fallingFactorial (3 / 2 + (m : ℝ)) 2 * ((m : ℝ) + 1) *
        (19584 - 13848 * Real.sqrt 2)) =
      -(c (m - 2) * (-6 * fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 2 -
          fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 3) +
        c (m - 1) * (fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 2 *
            (153 - 216 * Real.sqrt 2) -
          fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 3 *
            (48 * Real.sqrt 2 - 34)) +
        c m * (-fallingFactorial (1 / 2 + (m : ℝ)) 2 *
            (5187 - 3672 * Real.sqrt 2) -
          fallingFactorial (1 / 2 + (m : ℝ)) 3 *
            ((3458 - 2448 * Real.sqrt 2) / 2))) := by
  intro c
  have h_3step := aperyFrobenius_half_3step_recurrence hm
  have h_w_m := aperyFrobenius_half_w_m_explicit (show 1 ≤ m by omega)
  have h_w_m1 := aperyFrobenius_half_w_m_minus_one_explicit (show 2 ≤ m by omega)
  have h_w_m2 := aperyFrobenius_half_w_m_minus_two_explicit hm
  have h_denom := aperyFrobenius_half_denom_explicit m
  rw [← h_denom, h_3step]
  -- Beta-reduce the `let w := fun i => ...` introduced by h_3step
  dsimp only
  rw [h_w_m, h_w_m1, h_w_m2]

/-- **w_m simplified form for ρ=1/2 (using 2Q'(z₁)=3P''(z₁) Apéry identity).**

Using `2Q'(z₁) = 3P''(z₁)` (verified: 2(5187-3672√2)=3(3458-2448√2)=10374-7344√2),
the weight `w_m` simplifies to:
```
w_m = -ff(1/2+m, 2) · ((2m+3)/4) · P''(z₁)
    = -ff(1/2+m, 2) · ((2m+3)/4) · (3458 - 2448√2)
```

This is a clean factored form for use in the ratio_bound proof. -/
lemma aperyFrobenius_half_w_m_simplified {m : ℕ} (hm : 1 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ m)) =
      -fallingFactorial (1 / 2 + (m : ℝ)) 2 * ((2 * (m : ℝ) + 3) / 4) *
        (3458 - 2448 * Real.sqrt 2) := by
  rw [aperyFrobenius_half_w_m_explicit hm]
  rw [show fallingFactorial (1 / 2 + (m : ℝ)) 3 =
        fallingFactorial (1 / 2 + (m : ℝ)) 2 * (1/2 + (m : ℝ) - 2) from
      fallingFactorial_succ _ 2]
  ring

/-- **α(m)·c(m) closed-form for ρ=1/2.**

The coefficient of `c(m)` in the recurrence for `c(m+1)` is:
```
α(m) = -w_m / denom(m+1)
```
After substituting the simplified w_m and explicit denom and cancelling
the `ff(2m+1)/4` and `(2m+3)/4` factors, we get:
```
α(m) = (2m-1) · (3458-2448√2) / [4·(m+1)·(19584-13848√2)]
```
This is a clean rational function in m. Note `(2m-1)/(4(m+1)) → 1/2` as m → ∞,
giving α∞ = (1/2)·(3458-2448√2)/(19584-13848√2) = (1729-1224√2)/(19584-13848√2).

This lemma provides `c(m+1)·denom(m+1)` written with α-term factored out,
useful for the ratio_bound bootstrap. -/
lemma aperyFrobenius_half_alpha_explicit_form {m : ℕ} (hm : 1 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ m)) =
      -((2 * (m : ℝ) + 1) * (2 * (m : ℝ) - 1) * (2 * (m : ℝ) + 3) / 16) *
        (3458 - 2448 * Real.sqrt 2) := by
  rw [aperyFrobenius_half_w_m_simplified hm]
  -- ff(1/2+m, 2) = (1/2+m)(1/2+m-1) = (1/2+m)(m-1/2) = (2m+1)(2m-1)/4
  rw [show fallingFactorial (1 / 2 + (m : ℝ)) 2 =
        (2 * (m : ℝ) + 1) * (2 * (m : ℝ) - 1) / 4 from by
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  ring

/-- **β(m)·c(m-1) explicit form for ρ=1/2 (numerator before /denom).**
For m ≥ 2:
```
β_num(m) = (2m-1)(2m-3)/8 · [2A - (2m-5)·B]
```
where A = 153-216√2, B = 48√2-34. -/
lemma aperyFrobenius_half_beta_explicit_form {m : ℕ} (hm : 2 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 1))) =
      (2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) / 8 *
        (2 * (153 - 216 * Real.sqrt 2) -
          (2 * (m : ℝ) - 5) * (48 * Real.sqrt 2 - 34)) := by
  rw [aperyFrobenius_half_w_m_minus_one_explicit hm]
  have hmcast : ((m - 1 : ℕ) : ℝ) = (m : ℝ) - 1 := by
    exact_mod_cast Nat.cast_sub (by omega : (1 : ℕ) ≤ m)
  rw [show fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 2 =
        (2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) / 4 from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (1 / 2 + ((m - 1 : ℕ) : ℝ)) 3 =
        (2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) / 8 from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **γ(m)·c(m-2) explicit form for ρ=1/2 (numerator before /denom).**
For m ≥ 3:
```
γ_num(m) = -(2m-3)(2m-5)(2m+5)/8
```
-/
lemma aperyFrobenius_half_gamma_explicit_form {m : ℕ} (hm : 3 ≤ m) :
    PowerSeries.coeff (R := ℝ) (m + 1 + 1)
        (substLHSGen (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold)
          3 Number.aperyConifoldZ1Poly (1 / 2)
          ((PowerSeries.X : PowerSeries ℝ) ^ (m - 2))) =
      -((2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) * (2 * (m : ℝ) + 5) / 8) := by
  rw [aperyFrobenius_half_w_m_minus_two_explicit hm]
  have hmcast : ((m - 2 : ℕ) : ℝ) = (m : ℝ) - 2 := by
    exact_mod_cast Nat.cast_sub (by omega : (2 : ℕ) ≤ m)
  rw [show fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 2 =
        (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) / 4 from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_zero]
      ring]
  rw [show fallingFactorial (1 / 2 + ((m - 2 : ℕ) : ℝ)) 3 =
        (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) * (2 * (m : ℝ) - 7) / 8 from by
      rw [hmcast]
      rw [fallingFactorial_succ, fallingFactorial_succ, fallingFactorial_succ,
          fallingFactorial_zero]
      ring]
  ring

/-- **`α(m)` for ρ=1/2**: `(2m-1)·K' / [4(m+1)·K]`. -/
noncomputable def aperyAlphaHalf (m : ℕ) : ℝ :=
  (2 * (m : ℝ) - 1) * (3458 - 2448 * Real.sqrt 2) /
    (4 * ((m : ℝ) + 1) * (19584 - 13848 * Real.sqrt 2))
/-- **`β(m)` for ρ=1/2**: `-(2m-1)(2m-3)·[2A - (2m-5)B] / [2(2m+3)(2m+1)(m+1)·K]`. -/
noncomputable def aperyBetaHalf (m : ℕ) : ℝ :=
  -((2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) *
      (2 * (153 - 216 * Real.sqrt 2) -
        (2 * (m : ℝ) - 5) * (48 * Real.sqrt 2 - 34))) /
    (2 * (2 * (m : ℝ) + 3) * (2 * (m : ℝ) + 1) * ((m : ℝ) + 1) *
      (19584 - 13848 * Real.sqrt 2))

/-- **`γ(m)` for ρ=1/2**: `(2m-3)(2m-5)(2m+5) / [2(2m+3)(2m+1)(m+1)·K]`. -/
noncomputable def aperyGammaHalf (m : ℕ) : ℝ :=
  (2 * (m : ℝ) - 3) * (2 * (m : ℝ) - 5) * (2 * (m : ℝ) + 5) /
    (2 * (2 * (m : ℝ) + 3) * (2 * (m : ℝ) + 1) * ((m : ℝ) + 1) *
      (19584 - 13848 * Real.sqrt 2))
/-- **`α(m) · D` simplification (ρ=1/2)**: clears denom from α(m). -/
lemma aperyAlphaHalf_mul_denom (m : ℕ) :
    aperyAlphaHalf m *
      (((m : ℝ) + 3 / 2) * ((m : ℝ) + 1 / 2) * ((m : ℝ) + 1) *
        (19584 - 13848 * Real.sqrt 2)) =
      (2 * (m : ℝ) + 1) * (2 * (m : ℝ) - 1) * (2 * (m : ℝ) + 3) *
        (3458 - 2448 * Real.sqrt 2) / 16 := by
  unfold aperyAlphaHalf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hK_ne' : (19584 - Real.sqrt 2 * 13848 : ℝ) ≠ 0 := by
    rw [show Real.sqrt 2 * 13848 = 13848 * Real.sqrt 2 from by ring]
    exact hK_ne
  field_simp
  ring

/-- **`β(m) · D` simplification (ρ=1/2)**: clears denom from β(m). -/
lemma aperyBetaHalf_mul_denom (m : ℕ) :
    aperyBetaHalf m *
      (((m : ℝ) + 3 / 2) * ((m : ℝ) + 1 / 2) * ((m : ℝ) + 1) *
        (19584 - 13848 * Real.sqrt 2)) =
      -((2 * (m : ℝ) - 1) * (2 * (m : ℝ) - 3) *
        (2 * (153 - 216 * Real.sqrt 2) -
          (2 * (m : ℝ) - 5) * (48 * Real.sqrt 2 - 34)) / 8) := by
  unfold aperyBetaHalf
  have hK_ne : (19584 - 13848 * Real.sqrt 2 : ℝ) ≠ 0 := by
    have h_eq : Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold) =
        19584 - 13848 * Real.sqrt 2 :=
      Number.aperyPconifold_deriv_eval_z1
    have h_ne := Number.aperyPconifold_deriv_eval_z1_ne_zero
    rw [h_eq] at h_ne
    exact h_ne
  have h2m3_pos : (0 : ℝ) < 2 * (m : ℝ) + 3 := by positivity
  have h2m1_pos : (0 : ℝ) < 2 * (m : ℝ) + 1 := by positivity
  have hm1_pos : (0 : ℝ) < (m : ℝ) + 1 := by positivity
  have hK_ne' : (19584 - Real.sqrt 2 * 13848 : ℝ) ≠ 0 := by
    rw [show Real.sqrt 2 * 13848 = 13848 * Real.sqrt 2 from by ring]
    exact hK_ne
  field_simp
