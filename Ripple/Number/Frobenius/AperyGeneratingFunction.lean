/-- **Data-layer GFA decomposition at arbitrary corridor `t` via 3-probe
canonical extracts (seedless form).** Generalizes
`GFA_right_endpoint_via_canonical3_on_disk` from `t = -ε` to any
corridor + disk point `t`. The full Frobenius decomposition uses
`aperyBranchTriple` evaluated at the seedless triple3. -/
lemma AperyConnectionData.GFA_decomposes_canonical3_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    {t : ℝ} (htC : t ∈ d.corridor)
    (hz : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple
        (aperyCanonicalExtractRegular3 ε₁ ε₂ ε₃)
        (aperyCanonicalExtractHalf3 ε₁ ε₂ ε₃)
        (aperyCanonicalExtractOne3 ε₁ ε₂ ε₃) t := by
  rw [d.GFA_decomposes_canonical_on_disk hε₁ hε₂ hdet12 htC hz
        hdisk_ε₁ hdisk_ε₂,
    d.extractRegular_eq_canonical3_on_disk hε₁ hε₂ hε₃ hdet12 h3det
      hdisk_ε₁ hdisk_ε₂ hdisk_ε₃]
  rfl

/-- **Ext-layer mirror: full GFA decomposition at arbitrary corridor `t`
via 3-probe canonical extracts (seedless form).** One-line `of_witness`
