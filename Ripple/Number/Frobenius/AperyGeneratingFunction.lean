/-- **`MapsTo some.F (Icc a b) (Icc sInf sSup)` for `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.mapsTo_some_F_Icc_sub_to_sInf_sSup
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    Set.MapsTo h.some.F (Set.Icc a b)
      (Set.Icc
        (sInf (h.some.F '' Set.Icc a b))
        (sSup (h.some.F '' Set.Icc a b))) :=
  fun _ hz => h.some_F_mem_Icc_sInf_sSup_sub ha hab hb hz

/-- **Image of `some.F` on sub-interval `Icc a b ⊆ Icc 0 (1/64)` equals
`Icc sInf sSup` (IVT).** -/
lemma HasAperyAnalyticExtension.some_F_image_Icc_sub_eq_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    h.some.F '' Set.Icc a b =
      Set.Icc
        (sInf (h.some.F '' Set.Icc a b))
        (sSup (h.some.F '' Set.Icc a b)) := by
  apply Set.eq_of_subset_of_subset
  · intro y hy
    obtain ⟨z, hz_mem, hz_eq⟩ := hy
    rw [← hz_eq]
    exact h.some_F_mem_Icc_sInf_sSup_sub ha hab hb hz_mem
  · have h_cont := h.continuousOn_some_F_Icc_sub ha hb
    have h_image_nonempty :
        (h.some.F '' Set.Icc a b).Nonempty :=
      Set.Nonempty.image _ (Set.nonempty_Icc.mpr hab)
    have h_compact : IsCompact (h.some.F '' Set.Icc a b) :=
      isCompact_Icc.image_of_continuousOn h_cont
    obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ :=
      h_compact.sInf_mem h_image_nonempty
    obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ :=
      h_compact.sSup_mem h_image_nonempty
    have h_surj := h_cont.surjOn_Icc hzmin_mem hzmax_mem
    rw [hzmin_eq, hzmax_eq] at h_surj
    exact h_surj

/-- **`SurjOn some.F (Icc a b) (Icc sInf sSup)` for `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.surjOn_some_F_Icc_sub_to_sInf_sSup
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    Set.SurjOn h.some.F (Set.Icc a b)
      (Set.Icc
        (sInf (h.some.F '' Set.Icc a b))
        (sSup (h.some.F '' Set.Icc a b))) := by
  rw [← h.some_F_image_Icc_sub_eq_Icc_sInf_sSup ha hab hb]
  exact Set.surjOn_image _ _

/-- **IVT realizer for `some.F`: every `y ∈ Icc [sInf, sSup]` is realized
by some `z ∈ Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_some_F_eq_of_mem_Icc_sInf_sSup_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64)
    {y : ℝ}
    (hy : y ∈ Set.Icc
      (sInf (h.some.F '' Set.Icc a b))
      (sSup (h.some.F '' Set.Icc a b))) :
    ∃ z ∈ Set.Icc a b, h.some.F z = y := by
  have h_surj := h.surjOn_some_F_Icc_sub_to_sInf_sSup ha hab hb hy
  obtain ⟨z, hz_mem, hz_eq⟩ := h_surj
  exact ⟨z, hz_mem, hz_eq⟩

/-! ### Cross-link: `HasCorridor` `some.F` vs `aperyGFAReal` on `Icc 0 (1/64)` -/

/-- **Under `HasCorridor`, `some.F` (from underlying `HasApery`) agrees with
`aperyGFAReal` on `Icc 0 (1/64)`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_eqOn_aperyGFAReal_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    Set.EqOn h.toHasAperyAnalyticExtension.some.F aperyGFAReal
      (Set.Icc (0 : ℝ) (1 / 64)) := by
  intro z hz
  have h_eq_choose :
      h.toHasAperyAnalyticExtension.some.F z = h.choose.F z :=
    h.toHasAperyAnalyticExtension.some_F_eqOn_ext_F_Icc_one_div_64 h.choose hz
  have h_choose_eq : h.choose.F z = aperyGFAReal z := by
    refine h.choose_spec ?_
    exact ⟨hz.1, lt_of_le_of_lt hz.2 aperyConifoldZ1Poly_gt_one_div_64⟩
  rw [h_eq_choose, h_choose_eq]

/-- **Under `HasCorridor`, image of `some.F` on `Icc 0 (1/64)` equals
image of `aperyGFAReal` on `Icc 0 (1/64)`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_image_Icc_eq_aperyGFAReal_image
    (h : HasCorridorAperyAnalyticExtension) :
    h.toHasAperyAnalyticExtension.some.F '' Set.Icc (0 : ℝ) (1 / 64) =
      aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) :=
  Set.image_congr h.some_F_eqOn_aperyGFAReal_Icc_one_div_64

/-- **Under `HasCorridor`, `sSup` of `some.F` image equals `sSup` of `aperyGFAReal` image.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_some_F_image_eq_aperyGFAReal_image
    (h : HasCorridorAperyAnalyticExtension) :
    sSup (h.toHasAperyAnalyticExtension.some.F '' Set.Icc (0 : ℝ) (1 / 64)) =
      sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) := by
  rw [h.some_F_image_Icc_eq_aperyGFAReal_image]

/-- **Under `HasCorridor`, `sInf` of `some.F` image equals `sInf` of `aperyGFAReal` image.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_some_F_image_eq_aperyGFAReal_image
    (h : HasCorridorAperyAnalyticExtension) :
