/-! #### Ext-layer binary union capstones -/

/-- **Ext-layer right-side basis via binary union.** Direct two-set
counterpart of `F_eq_yZero_plus_yOne_on_right_via_iUnion`: from
Has-witnesses on `I, J` sharing the global probe triple, the right-side
basis lifts to `I ∪ J`. -/
lemma AperyAnalyticExtension.F_eq_yZero_plus_yOne_on_right_via_union
    (ext : AperyAnalyticExtension) {I J : Set ℝ} {ε₁ ε₂ : ℝ}
    (h0_I : (0 : ℝ) ∈ I) (h0_J : (0 : ℝ) ∈ J)
    (hε₁_I : (-ε₁) ∈ I) (hε₂_I : (-ε₂) ∈ I)
    (hε₁_J : (-ε₁) ∈ J) (hε₂_J : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hI : HasAperyConnectionCoeffsOn ext.F I)
    (hJ : HasAperyConnectionCoeffsOn ext.F J)
    {t : ℝ} (ht : t ∈ I ∪ J) (htnn : 0 ≤ t) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero ext.extractRegular t + yApery (ext.extractOne ε₁ ε₂) t := by
  have hU := ext.has_conn_union_via_three_probes h0_I h0_J
    hε₁_I hε₂_I hε₁_J hε₂_J hdet hI hJ
  obtain ⟨a₀, a_half, a₁, hUis⟩ := hU
  have h0U : (0 : ℝ) ∈ I ∪ J := Or.inl h0_I
  have hε₁U : (-ε₁) ∈ I ∪ J := Or.inl hε₁_I
  have hε₂U : (-ε₂) ∈ I ∪ J := Or.inl hε₂_I
  exact ext.F_eq_yZero_plus_yOne_on_right h0U hUis hε₁U hε₂U hdet ht htnn

