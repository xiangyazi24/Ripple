/-! ### Stronger corridor-wide EqOn predicate

`HasAperyAnalyticExtension` only forces equality on the small interval
(via the structural `agrees_on_small` field). To get corridor-wide
equality with `aperyGFAReal` (and hence corridor-wide continuity of
`aperyGFAReal` itself), promote to a stronger predicate that asserts
the existence of a *corridor-pinned* extension. -/

/-- **Stronger predicate:** there exists an `AperyAnalyticExtension`
whose `F` agrees with `aperyGFAReal` on the entire corridor (not just
the small interval). All chain-route constructions automatically
provide such a witness. -/
def HasCorridorAperyAnalyticExtension : Prop :=
  ∃ ext : AperyAnalyticExtension,
    Set.EqOn ext.F aperyGFAReal (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly)

/-- **Strong predicate downgrades to weak.** -/
lemma HasCorridorAperyAnalyticExtension.toHasAperyAnalyticExtension
    (h : HasCorridorAperyAnalyticExtension) : HasAperyAnalyticExtension :=
  ⟨h.choose⟩

/-- **`fromChain` provides a corridor-pinned witness.** -/
lemma AperyLocalAnalyticExtension.hasCorridorAperyAnalyticExtension_of_fromChain
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    HasCorridorAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
      params n ts ht_zero ht_last h_pieces,
    AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_F_eq_aperyGFAReal_on_corridor
      params n ts ht_zero ht_last h_pieces⟩

/-- **`ofChain` provides a corridor-pinned witness.** -/
lemma AperyLocalAnalyticExtension.hasCorridorAperyAnalyticExtension_of_ofChain
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (ts : ℕ → ℝ)
    (ht_zero : ts 0 = 0)
    (ht_last : ts (n + 1) = Number.aperyConifoldZ1Poly)
    (h_pieces : ∀ k ≤ n,
      Set.Ico (ts k) (ts (k + 1)) ⊆
        (params k).toAnalyticDiskAt.toAperyRegularDisk.diskOpen) :
    HasCorridorAperyAnalyticExtension :=
  ⟨AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit
      params n ts ht_zero ht_last h_pieces,
    AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_corridor
      params n ts ht_zero ht_last h_pieces⟩

/-- **Corridor predicate forces `aperyGFAReal` continuous on corridor.** -/
lemma HasCorridorAperyAnalyticExtension.continuousOn_aperyGFAReal
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousOn aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  obtain ⟨ext, h_eq⟩ := h
  exact ext.continuousOn_corridor.congr h_eq.symm

/-- **Corridor predicate forces `aperyGFAReal` continuous on `Icc 0 a`,
`a < aperyConifoldZ1Poly`.** -/
lemma HasCorridorAperyAnalyticExtension.continuousOn_aperyGFAReal_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {a : ℝ} (ha_lt : a < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc (0 : ℝ) a) := by
  refine h.continuousOn_aperyGFAReal.mono ?_
  intro z hz
  exact ⟨hz.1, lt_of_le_of_lt hz.2 ha_lt⟩

/-- **`unionRange` provides a corridor-pinned witness.** Direct
construction without chain params: the union-route F is pinned to
`aperyGFAReal` on its domain, so a corridor inclusion gives the
corridor-EqOn directly. -/
lemma AperyLocalAnalyticExtension.hasCorridorAperyAnalyticExtension_of_unionRange
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
    (h_corridor :
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly ⊆
        (AperyLocalAnalyticExtension.unionRangeFromParams params n).domain) :
    HasCorridorAperyAnalyticExtension := by
  refine ⟨AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
            params n h_corridor, ?_⟩
  intro z hz
  unfold AperyLocalAnalyticExtension.unionRangeFromParams_toAperyAnalyticExtension
  exact (AperyLocalAnalyticExtension.unionRangeFromParams params n).F_eq_aperyGFAReal
    (h_corridor hz)

/-! ### Canonical left-limit re-expressed via `HasCorridor`

Given the stronger `HasCorridor` witness, the canonical left-limit
collapses to the literal `aperyGFAReal (1/64)` value: the witness's
`F (1/64) = aperyGFAReal (1/64)` directly, since `1/64 ∈ corridor`. -/

/-- **Canonical left-limit equals `aperyGFAReal (1/64)` under the
strong corridor predicate.** -/
lemma aperyGFAReal_left_limit_at_one_div_64_eq_aperyGFAReal_of_corridor
    (h : HasCorridorAperyAnalyticExtension) :
    aperyGFAReal_left_limit_at_one_div_64 h.toHasAperyAnalyticExtension =
      aperyGFAReal (1 / 64) := by
  rw [aperyGFAReal_left_limit_at_one_div_64_eq h.toHasAperyAnalyticExtension h.choose]
  exact h.choose_spec ⟨by norm_num, aperyConifoldZ1Poly_gt_one_div_64⟩

/-- **Under `HasCorridor`, `aperyGFAReal` Tendsto its own value at `1/64⁻`.** -/
lemma HasCorridorAperyAnalyticExtension.tendsto_aperyGFAReal_at_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin (1 / 64 : ℝ) (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal (1 / 64))) := by
  have h_tendsto :=
    tendsto_aperyGFAReal_left_limit_at_one_div_64 h.toHasAperyAnalyticExtension
  rw [aperyGFAReal_left_limit_at_one_div_64_eq_aperyGFAReal_of_corridor h] at h_tendsto
  exact h_tendsto

/-- **Under `HasCorridor`, `aperyGFAReal` is left-continuous at `1/64`.** -/
lemma HasCorridorAperyAnalyticExtension.continuousWithinAt_aperyGFAReal_at_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousWithinAt aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) (1 / 64) :=
  h.tendsto_aperyGFAReal_at_one_div_64

/-- **Under `HasCorridor`, `aperyGFAReal` is continuous on the closed
small interval `Icc 0 (1/64)`.** -/
lemma HasCorridorAperyAnalyticExtension.continuousOn_aperyGFAReal_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) :=
  h.continuousOn_aperyGFAReal_Icc aperyConifoldZ1Poly_gt_one_div_64

/-! ### Cross-witness corridor uniqueness under `HasCorridor`

Any two `HasCorridor` witnesses pin to the *same* function `aperyGFAReal`
on the entire corridor, so their underlying extensions agree there
pointwise. Stronger than the generic `agree_on_Icc_one_div_64_universally`
(which only forced agreement on the small closed interval). -/

/-- **Two corridor-pinned witnesses agree on the entire corridor.** -/
lemma HasCorridorAperyAnalyticExtension.witnesses_agree_on_corridor
    (h₁ h₂ : HasCorridorAperyAnalyticExtension) :
    Set.EqOn h₁.choose.F h₂.choose.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z hz
  rw [h₁.choose_spec hz, ← h₂.choose_spec hz]

/-- **Witness extension's `F` equals `aperyGFAReal` on corridor (named).** -/
lemma HasCorridorAperyAnalyticExtension.choose_F_eq_aperyGFAReal
    (h : HasCorridorAperyAnalyticExtension) :
    Set.EqOn h.choose.F aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :=
  h.choose_spec

/-- **Witness `F (1/64) = aperyGFAReal (1/64)`.** -/
lemma HasCorridorAperyAnalyticExtension.choose_F_at_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    h.choose.F (1 / 64) = aperyGFAReal (1 / 64) :=
  h.choose_spec ⟨by norm_num, aperyConifoldZ1Poly_gt_one_div_64⟩

/-! ### `HasCorridor` z=0 endpoint API -/

/-- **Witness `F (0) = aperyGFAReal (0)`.** -/
lemma HasCorridorAperyAnalyticExtension.choose_F_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    h.choose.F 0 = aperyGFAReal 0 := by
  have h_z1_pos : (0 : ℝ) < Number.aperyConifoldZ1Poly := by
    have := aperyConifoldZ1Poly_gt_one_div_64
    linarith [show (0 : ℝ) < 1 / 64 by norm_num]
  exact h.choose_spec ⟨le_refl 0, h_z1_pos⟩

/-- **Witness `F` Tendsto `aperyGFAReal 0` from inside corridor at `0`.** -/
lemma HasCorridorAperyAnalyticExtension.tendsto_choose_F_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    Filter.Tendsto h.choose.F
      (nhdsWithin (0 : ℝ) (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (aperyGFAReal 0)) := by
  exact h.choose.tendsto_zero_corridor

/-- **Under `HasCorridor`, `aperyGFAReal` Tendsto `aperyGFAReal 0` from
the right at `0`.** -/
lemma HasCorridorAperyAnalyticExtension.tendsto_aperyGFAReal_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin (0 : ℝ) (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly))
      (nhds (aperyGFAReal 0)) := by
  have h_tendsto := h.tendsto_choose_F_at_zero
  refine h_tendsto.congr' ?_
  rw [Filter.EventuallyEq, eventually_nhdsWithin_iff]
  refine Filter.Eventually.of_forall ?_
  intro z hz
  exact h.choose_spec hz

/-- **Under `HasCorridor`, the witness `F` is right-continuous at `0`
within the corridor.** -/
lemma HasCorridorAperyAnalyticExtension.continuousWithinAt_choose_F_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousWithinAt h.choose.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) 0 :=
  h.choose.continuousWithinAt_zero_corridor

/-- **Under `HasCorridor`, `aperyGFAReal` is right-continuous at `0`
within the corridor.** -/
lemma HasCorridorAperyAnalyticExtension.continuousWithinAt_aperyGFAReal_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousWithinAt aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) 0 :=
  h.tendsto_aperyGFAReal_at_zero

/-- **Under `HasCorridor`, `aperyGFAReal` is right-continuous at `0`
within the small interval `Ico 0 (1/64)`.** -/
lemma HasCorridorAperyAnalyticExtension.continuousWithinAt_aperyGFAReal_at_zero_small
    (h : HasCorridorAperyAnalyticExtension) :
    ContinuousWithinAt aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) 0 :=
  h.continuousWithinAt_aperyGFAReal_at_zero.mono
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor

/-! ### `HasCorridor` ContinuousOn packaging -/

/-- **Under `HasCorridor`, `aperyGFAReal` is continuous on any closed
sub-interval `Icc a b` with `0 ≤ a` and `b < aperyConifoldZ1Poly`.** -/
lemma HasCorridorAperyAnalyticExtension.continuousOn_aperyGFAReal_Icc_general
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hb : b < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc a b) := by
  refine h.continuousOn_aperyGFAReal.mono ?_
  intro z hz
  exact ⟨le_trans ha hz.1, lt_of_le_of_lt hz.2 hb⟩

/-- **Under `HasCorridor`, `aperyGFAReal` is continuous at every interior
point of the corridor.** -/
lemma HasCorridorAperyAnalyticExtension.continuousAt_aperyGFAReal_of_Ioo
    (h : HasCorridorAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly) :
    ContinuousAt aperyGFAReal z := by
  have h_mem : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly :=
    ⟨le_of_lt hz.1, hz.2⟩
  refine (h.continuousOn_aperyGFAReal z h_mem).continuousAt ?_
  rw [mem_nhds_iff]
  refine ⟨Set.Ioo (0 : ℝ) Number.aperyConifoldZ1Poly, ?_, isOpen_Ioo, hz⟩
  intro w hw
  exact ⟨le_of_lt hw.1, hw.2⟩

/-! ### `HasAperyAnalyticExtension` choice-witness packaging on `Icc 0 (1/64)`

At the `HasAperyAnalyticExtension` level (without corridor pinning),
`aperyGFAReal (1/64)` need not equal the left-limit value, so
`ContinuousOn aperyGFAReal (Icc 0 (1/64))` is *not* available. What
**is** canonical: pick `h.some.F`, which is continuous on `Icc 0 (1/64)`,
agrees with `aperyGFAReal` on `Ico 0 (1/64)`, and at `1/64` returns the
canonical left-limit `aperyGFAReal_left_limit_at_one_div_64`. -/

/-- **Choice witness `F` is continuous on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.continuousOn_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ContinuousOn h.some.F (Set.Icc (0 : ℝ) (1 / 64)) :=
  h.some.continuousOn_Icc_safe aperyConifoldZ1Poly_gt_one_div_64

/-- **Choice witness `F` agrees with `aperyGFAReal` on `Ico 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.some_F_eqOn_aperyGFAReal_Ico_one_div_64
    (h : HasAperyAnalyticExtension) :
    Set.EqOn h.some.F aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) :=
  h.some.agrees_on_small

/-- **Choice witness `F` at `1/64` equals the canonical left-limit.**
Holds by definition of `aperyGFAReal_left_limit_at_one_div_64`. -/
lemma HasAperyAnalyticExtension.some_F_at_one_div_64_eq_left_limit
    (h : HasAperyAnalyticExtension) :
    h.some.F (1 / 64) = aperyGFAReal_left_limit_at_one_div_64 h := rfl

/-- **Choice invariance on `Icc 0 (1/64)`:** for *any*
`AperyAnalyticExtension`, the chosen `h.some.F` agrees with `ext.F`
pointwise on the closed small interval. Specialization of
`agree_on_Icc_one_div_64_universally`. -/
lemma HasAperyAnalyticExtension.some_F_eqOn_ext_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension) (ext : AperyAnalyticExtension) :
    Set.EqOn h.some.F ext.F (Set.Icc (0 : ℝ) (1 / 64)) :=
  AperyAnalyticExtension.agree_on_Icc_one_div_64_universally h.some ext

/-- **Direct continuity packaging at `Icc 0 (1/64)`:** any
`AperyAnalyticExtension`'s `F` is continuous on the closed small
interval. -/
lemma AperyAnalyticExtension.continuousOn_F_Icc_one_div_64
    (ext : AperyAnalyticExtension) :
    ContinuousOn ext.F (Set.Icc (0 : ℝ) (1 / 64)) :=
  ext.continuousOn_Icc_safe aperyConifoldZ1Poly_gt_one_div_64

/-- **Choice witness on sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.continuousOn_some_F_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hb : b ≤ 1 / 64) :
    ContinuousOn h.some.F (Set.Icc a b) := by
  refine h.continuousOn_some_F_Icc_one_div_64.mono ?_
  intro z hz
  exact ⟨le_trans ha hz.1, le_trans hz.2 hb⟩

/-- **Choice witness `F` is right-continuous at `1/64` within the
corridor.** -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_one_div_64_corridor
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) (1 / 64) :=
  h.some.continuousWithinAt_one_div_64_corridor

/-- **Choice witness `F` is left-continuous at `1/64` within the small
interval `Ico 0 (1/64)`.** Value at `1/64` is the canonical left-limit. -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_one_div_64_small
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F (Set.Ico (0 : ℝ) (1 / 64)) (1 / 64) :=
  h.continuousWithinAt_some_F_at_one_div_64_corridor.mono
    AperyAnalyticExtension.Ico_one_div_64_subset_corridor

/-- **Choice witness `F` is left-continuous at `1/64` within the closed
small interval `Icc 0 (1/64)`.** Direct corollary of the closed
`ContinuousOn` packaging. -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_one_div_64_Icc
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F (Set.Icc (0 : ℝ) (1 / 64)) (1 / 64) :=
  h.continuousOn_some_F_Icc_one_div_64 (1 / 64)
    ⟨by norm_num, le_refl _⟩

/-- **Choice witness `F` is right-continuous at `0` within the
corridor.** -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_zero_corridor
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) 0 :=
  h.some.continuousWithinAt_zero_corridor

/-- **Choice witness `F` is right-continuous at `0` within the small
interval `Ico 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_zero_small
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F (Set.Ico (0 : ℝ) (1 / 64)) 0 :=
  h.some.continuousWithinAt_zero_small

/-- **Choice witness `F` is right-continuous at `0` within the closed
small interval `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.continuousWithinAt_some_F_at_zero_Icc
    (h : HasAperyAnalyticExtension) :
    ContinuousWithinAt h.some.F (Set.Icc (0 : ℝ) (1 / 64)) 0 :=
  h.continuousOn_some_F_Icc_one_div_64 0 ⟨le_refl _, by norm_num⟩

/-! ### `HasAperyAnalyticExtension` boundedness packaging on `Icc 0 (1/64)` -/

/-- **`ContinuousOn` of choice witness on the half-open small interval.** -/
lemma HasAperyAnalyticExtension.continuousOn_some_F_Ico_one_div_64
    (h : HasAperyAnalyticExtension) :
    ContinuousOn h.some.F (Set.Ico (0 : ℝ) (1 / 64)) := by
  refine h.continuousOn_some_F_Icc_one_div_64.mono ?_
  intro z hz
  exact ⟨hz.1, le_of_lt hz.2⟩

/-- **Image of the choice witness on `Icc 0 (1/64)` is bounded above.**
Continuous image of a compact set is compact, hence bounded. -/
lemma HasAperyAnalyticExtension.bddAbove_some_F_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    BddAbove (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  (isCompact_Icc.image_of_continuousOn
    h.continuousOn_some_F_Icc_one_div_64).bddAbove

/-- **Image of the choice witness on `Icc 0 (1/64)` is bounded below.** -/
lemma HasAperyAnalyticExtension.bddBelow_some_F_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    BddBelow (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  (isCompact_Icc.image_of_continuousOn
    h.continuousOn_some_F_Icc_one_div_64).bddBelow

/-- **Extreme value theorem (max) on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_isMaxOn_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      IsMaxOn h.some.F (Set.Icc (0 : ℝ) (1 / 64)) x :=
  isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))
    h.continuousOn_some_F_Icc_one_div_64

/-- **Extreme value theorem (min) on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_isMinOn_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      IsMinOn h.some.F (Set.Icc (0 : ℝ) (1 / 64)) x :=
  isCompact_Icc.exists_isMinOn
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))
    h.continuousOn_some_F_Icc_one_div_64

/-- **Explicit `|F z| ≤ M` norm bound on `Icc 0 (1/64)`.** Useful for
estimates against the analytic extension when integrating or analytically
continuing. -/
lemma HasAperyAnalyticExtension.exists_norm_bound_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ M : ℝ, ∀ z ∈ Set.Icc (0 : ℝ) (1 / 64), |h.some.F z| ≤ M := by
  obtain ⟨xmax, _, hxmax⟩ := h.exists_isMaxOn_some_F_Icc_one_div_64
  obtain ⟨xmin, _, hxmin⟩ := h.exists_isMinOn_some_F_Icc_one_div_64
  refine ⟨max (h.some.F xmax) (-h.some.F xmin), ?_⟩
  intro z hz
  have h_le_max : h.some.F z ≤ h.some.F xmax := hxmax hz
  have h_min_le : h.some.F xmin ≤ h.some.F z := hxmin hz
  rw [abs_le]
  refine ⟨?_, ?_⟩
  · have h_le_M : -h.some.F xmin ≤
        max (h.some.F xmax) (-h.some.F xmin) :=
      le_max_right _ _
    linarith
  · have h_le_M : h.some.F xmax ≤
        max (h.some.F xmax) (-h.some.F xmin) :=
      le_max_left _ _
    linarith

/-- **Norm bound mono to half-open small interval.** -/
lemma HasAperyAnalyticExtension.exists_norm_bound_some_F_Ico_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ M : ℝ, ∀ z ∈ Set.Ico (0 : ℝ) (1 / 64), |h.some.F z| ≤ M := by
  obtain ⟨M, hM⟩ := h.exists_norm_bound_some_F_Icc_one_div_64
  refine ⟨M, ?_⟩
  intro z hz
  exact hM z ⟨hz.1, le_of_lt hz.2⟩

/-- **Norm bound mono to any sub-interval `Icc a b ⊆ Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.exists_norm_bound_some_F_Icc_sub
    (h : HasAperyAnalyticExtension) {a b : ℝ}
    (ha : 0 ≤ a) (hb : b ≤ 1 / 64) :
    ∃ M : ℝ, ∀ z ∈ Set.Icc a b, |h.some.F z| ≤ M := by
  obtain ⟨M, hM⟩ := h.exists_norm_bound_some_F_Icc_one_div_64
  refine ⟨M, ?_⟩
  intro z hz
  exact hM z ⟨le_trans ha hz.1, le_trans hz.2 hb⟩

/-- **`sSup` is a least upper bound of the image on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.isLUB_sSup_some_F_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    IsLUB (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))
      (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) := by
  refine Real.isLUB_sSup ?_ h.bddAbove_some_F_image_Icc_one_div_64
  exact Set.Nonempty.image _
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **`sInf` is a greatest lower bound of the image on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.isGLB_sInf_some_F_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    IsGLB (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))
      (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) := by
  refine Real.isGLB_sInf ?_ h.bddBelow_some_F_image_Icc_one_div_64
  exact Set.Nonempty.image _
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **`sSup` of the image is attained.** Compact + non-empty → sup is in
the set. -/
lemma HasAperyAnalyticExtension.sSup_some_F_image_Icc_one_div_64_mem
    (h : HasAperyAnalyticExtension) :
    sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ∈
      h.some.F '' Set.Icc (0 : ℝ) (1 / 64) := by
  refine IsCompact.sSup_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      h.continuousOn_some_F_Icc_one_div_64
  · exact Set.Nonempty.image _
      (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **`sInf` of the image is attained.** -/
lemma HasAperyAnalyticExtension.sInf_some_F_image_Icc_one_div_64_mem
    (h : HasAperyAnalyticExtension) :
    sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ∈
      h.some.F '' Set.Icc (0 : ℝ) (1 / 64) := by
  refine IsCompact.sInf_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      h.continuousOn_some_F_Icc_one_div_64
  · exact Set.Nonempty.image _
      (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **Some `x ∈ Icc 0 (1/64)` realizes `sSup` of the image.** -/
lemma HasAperyAnalyticExtension.exists_some_F_eq_sSup_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      h.some.F x = sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) := by
  obtain ⟨x, hx_mem, hx_eq⟩ := h.sSup_some_F_image_Icc_one_div_64_mem
  exact ⟨x, hx_mem, hx_eq⟩

/-- **Some `x ∈ Icc 0 (1/64)` realizes `sInf` of the image.** -/
lemma HasAperyAnalyticExtension.exists_some_F_eq_sInf_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      h.some.F x = sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) := by
  obtain ⟨x, hx_mem, hx_eq⟩ := h.sInf_some_F_image_Icc_one_div_64_mem
  exact ⟨x, hx_mem, hx_eq⟩

/-- **`sSup`-realizer is an `IsMaxOn` point.** Bridge between
extreme value theorem and `sSup`. -/
lemma HasAperyAnalyticExtension.isMaxOn_at_sSup_realizer_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension)
    {x : ℝ} (hx_mem : x ∈ Set.Icc (0 : ℝ) (1 / 64))
    (hx_eq : h.some.F x = sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) :
    IsMaxOn h.some.F (Set.Icc (0 : ℝ) (1 / 64)) x := by
  intro y hy
  rw [hx_eq]
  exact h.isLUB_sSup_some_F_image_Icc_one_div_64.1 ⟨y, hy, rfl⟩

/-- **`sInf`-realizer is an `IsMinOn` point.** -/
lemma HasAperyAnalyticExtension.isMinOn_at_sInf_realizer_some_F_Icc_one_div_64
    (h : HasAperyAnalyticExtension)
    {x : ℝ} (hx_mem : x ∈ Set.Icc (0 : ℝ) (1 / 64))
    (hx_eq : h.some.F x = sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) :
    IsMinOn h.some.F (Set.Icc (0 : ℝ) (1 / 64)) x := by
  intro y hy
  show h.some.F x ≤ h.some.F y
  rw [hx_eq]
  exact h.isGLB_sInf_some_F_image_Icc_one_div_64.1 ⟨y, hy, rfl⟩

/-! ### Endpoint comparisons of `sSup` / `sInf` against the boundary
values `F 0` and `F (1/64)`. -/

/-- **Endpoint `F 0` is below the supremum.** -/
lemma HasAperyAnalyticExtension.some_F_zero_le_sSup_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    h.some.F 0 ≤ sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  h.isLUB_sSup_some_F_image_Icc_one_div_64.1
    ⟨0, ⟨le_refl _, by norm_num⟩, rfl⟩

/-- **Endpoint `F (1/64)` is below the supremum.** -/
lemma HasAperyAnalyticExtension.some_F_one_div_64_le_sSup_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    h.some.F (1 / 64) ≤ sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  h.isLUB_sSup_some_F_image_Icc_one_div_64.1
    ⟨1 / 64, ⟨by norm_num, le_refl _⟩, rfl⟩

/-- **Endpoint `F 0` is above the infimum.** -/
lemma HasAperyAnalyticExtension.sInf_image_Icc_one_div_64_le_some_F_zero
    (h : HasAperyAnalyticExtension) :
    sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ≤ h.some.F 0 :=
  h.isGLB_sInf_some_F_image_Icc_one_div_64.1
    ⟨0, ⟨le_refl _, by norm_num⟩, rfl⟩

/-- **Endpoint `F (1/64)` is above the infimum.** -/
lemma HasAperyAnalyticExtension.sInf_image_Icc_one_div_64_le_some_F_one_div_64
    (h : HasAperyAnalyticExtension) :
    sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ≤ h.some.F (1 / 64) :=
  h.isGLB_sInf_some_F_image_Icc_one_div_64.1
    ⟨1 / 64, ⟨by norm_num, le_refl _⟩, rfl⟩

/-- **`aperyGFAReal 0 ≤ sSup` of the choice-witness image on `Icc 0 (1/64)`.**
Rewrite of the `F 0`-form using `F_at_zero`. -/
lemma HasAperyAnalyticExtension.aperyGFAReal_zero_le_sSup_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal 0 ≤ sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) := by
  have := h.some_F_zero_le_sSup_image_Icc_one_div_64
  rwa [h.some.F_at_zero] at this

/-- **Canonical left-limit at `1/64 ≤ sSup` of the choice-witness image
on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.left_limit_le_sSup_image_Icc_one_div_64
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal_left_limit_at_one_div_64 h ≤
      sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  h.some_F_one_div_64_le_sSup_image_Icc_one_div_64

/-- **`sInf ≤ aperyGFAReal 0` of the choice-witness image on `Icc 0 (1/64)`.** -/
lemma HasAperyAnalyticExtension.sInf_image_Icc_one_div_64_le_aperyGFAReal_zero
    (h : HasAperyAnalyticExtension) :
    sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ≤ aperyGFAReal 0 := by
  have := h.sInf_image_Icc_one_div_64_le_some_F_zero
  rwa [h.some.F_at_zero] at this

/-- **`sInf ≤` canonical left-limit at `1/64`.** -/
lemma HasAperyAnalyticExtension.sInf_image_Icc_one_div_64_le_left_limit
    (h : HasAperyAnalyticExtension) :
    sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) ≤
      aperyGFAReal_left_limit_at_one_div_64 h :=
  h.sInf_image_Icc_one_div_64_le_some_F_one_div_64

/-- **Canonical left-limit at `1/64` lies in `[sInf, sSup]` of the
choice-witness image.** -/
lemma HasAperyAnalyticExtension.left_limit_mem_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal_left_limit_at_one_div_64 h ∈
      Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) :=
  ⟨h.sInf_image_Icc_one_div_64_le_left_limit,
   h.left_limit_le_sSup_image_Icc_one_div_64⟩

/-- **`aperyGFAReal 0` lies in `[sInf, sSup]` of the choice-witness image.** -/
lemma HasAperyAnalyticExtension.aperyGFAReal_zero_mem_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal 0 ∈
      Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) :=
  ⟨h.sInf_image_Icc_one_div_64_le_aperyGFAReal_zero,
   h.aperyGFAReal_zero_le_sSup_image_Icc_one_div_64⟩

/-- **Choice-witness `F z` lies in `[sInf, sSup]` for any `z ∈ Icc 0 (1/64)`.**
General membership form. -/
lemma HasAperyAnalyticExtension.some_F_mem_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Icc (0 : ℝ) (1 / 64)) :
    h.some.F z ∈
      Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) :=
  ⟨h.isGLB_sInf_some_F_image_Icc_one_div_64.1 ⟨z, hz, rfl⟩,
   h.isLUB_sSup_some_F_image_Icc_one_div_64.1 ⟨z, hz, rfl⟩⟩

/-- **Choice-witness `F` maps `Icc 0 (1/64)` into `[sInf, sSup]`.** Set
form of `some_F_mem_Icc_sInf_sSup`. -/
lemma HasAperyAnalyticExtension.mapsTo_some_F_Icc_one_div_64_to_sInf_sSup
    (h : HasAperyAnalyticExtension) :
    Set.MapsTo h.some.F (Set.Icc (0 : ℝ) (1 / 64))
      (Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))) :=
  fun _ hz => h.some_F_mem_Icc_sInf_sSup hz

/-- **Choice-witness `F` is surjective onto its own image.** Trivial
restatement; useful pre-form for `IntermediateValueTheorem`-flavored
applications. -/
lemma HasAperyAnalyticExtension.surjOn_some_F_Icc_one_div_64_image
    (h : HasAperyAnalyticExtension) :
    Set.SurjOn h.some.F (Set.Icc (0 : ℝ) (1 / 64))
      (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)) :=
  Set.surjOn_image _ _

/-- **IVT upgrade:** the choice-witness image on `Icc 0 (1/64)`
*equals* (as a set) the closed interval `[sInf, sSup]`. Continuous +
order-connected domain → preserves Icc structure of image. -/
lemma HasAperyAnalyticExtension.surjOn_some_F_Icc_one_div_64_to_sInf_sSup
    (h : HasAperyAnalyticExtension) :
    Set.SurjOn h.some.F (Set.Icc (0 : ℝ) (1 / 64))
      (Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))) := by
  obtain ⟨xmin, hxmin_mem, hxmin_eq⟩ :=
    h.exists_some_F_eq_sInf_image_Icc_one_div_64
  obtain ⟨xmax, hxmax_mem, hxmax_eq⟩ :=
    h.exists_some_F_eq_sSup_image_Icc_one_div_64
  have h_surj :=
    h.continuousOn_some_F_Icc_one_div_64.surjOn_Icc hxmin_mem hxmax_mem
  rw [hxmin_eq, hxmax_eq] at h_surj
  exact h_surj

/-- **Image equals closed interval `[sInf, sSup]`.** Combines `MapsTo`
direction (image ⊆ Icc) with `SurjOn` direction (Icc ⊆ image). -/
lemma HasAperyAnalyticExtension.some_F_image_Icc_one_div_64_eq_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension) :
    h.some.F '' Set.Icc (0 : ℝ) (1 / 64) =
      Set.Icc
        (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64))) := by
  apply Set.eq_of_subset_of_subset
  · rintro y ⟨z, hz, rfl⟩
    exact h.some_F_mem_Icc_sInf_sSup hz
  · exact h.surjOn_some_F_Icc_one_div_64_to_sInf_sSup

/-- **IVT consequence:** every `y ∈ [sInf, sSup]` of the choice-witness
image has a preimage in `Icc 0 (1/64)`. -/
lemma HasAperyAnalyticExtension.exists_some_F_eq_of_mem_Icc_sInf_sSup
    (h : HasAperyAnalyticExtension)
    {y : ℝ}
    (hy : y ∈ Set.Icc
      (sInf (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))
      (sSup (h.some.F '' Set.Icc (0 : ℝ) (1 / 64)))) :
    ∃ z ∈ Set.Icc (0 : ℝ) (1 / 64), h.some.F z = y :=
  h.surjOn_some_F_Icc_one_div_64_to_sInf_sSup hy

/-- **`aperyGFAReal 0` is realized at `z = 0`.** -/
lemma HasAperyAnalyticExtension.aperyGFAReal_zero_eq_some_F_at_zero
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal 0 = h.some.F 0 :=
  (h.some.F_at_zero).symm

/-- **Canonical left-limit at `1/64` is realized at `z = 1/64`.** -/
lemma HasAperyAnalyticExtension.left_limit_eq_some_F_at_one_div_64
    (h : HasAperyAnalyticExtension) :
    aperyGFAReal_left_limit_at_one_div_64 h = h.some.F (1 / 64) := rfl

/-! ### `HasCorridor` mirror: `aperyGFAReal` itself realizes `Icc [sInf, sSup]`

Under the stronger `HasCorridor` hypothesis, `aperyGFAReal` is continuous
on `Icc 0 (1/64)` directly (no choice-witness detour), so its image on
that interval is the closed interval `[sInf, sSup]`. -/

/-- **Image of `aperyGFAReal` on `Icc 0 (1/64)` under `HasCorridor`
equals `[sInf, sSup]`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_one_div_64_eq_Icc_sInf_sSup
    (h : HasCorridorAperyAnalyticExtension) :
    aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) =
      Set.Icc
        (sInf (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)))
        (sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64))) := by
  have h_cont := h.continuousOn_aperyGFAReal_Icc_one_div_64
  have h_compact : IsCompact (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) :=
    isCompact_Icc.image_of_continuousOn h_cont
  have h_nonempty : (Set.Icc (0 : ℝ) (1 / 64)).Nonempty :=
    Set.nonempty_Icc.mpr (by norm_num)
  have h_image_nonempty := h_nonempty.image aperyGFAReal
  apply Set.eq_of_subset_of_subset
  · rintro y ⟨z, hz, rfl⟩
    refine ⟨?_, ?_⟩
    · exact (Real.isGLB_sInf h_image_nonempty h_compact.bddBelow).1 ⟨z, hz, rfl⟩
    · exact (Real.isLUB_sSup h_image_nonempty h_compact.bddAbove).1 ⟨z, hz, rfl⟩
  · obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ :=
      h_compact.sInf_mem h_image_nonempty
    obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ :=
      h_compact.sSup_mem h_image_nonempty
    have h_surj := h_cont.surjOn_Icc hzmin_mem hzmax_mem
    rw [hzmin_eq, hzmax_eq] at h_surj
    exact h_surj

/-- **Extreme value (max) for `aperyGFAReal` on `Icc 0 (1/64)` under
`HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_isMaxOn_aperyGFAReal_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      IsMaxOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) x :=
  isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))
    h.continuousOn_aperyGFAReal_Icc_one_div_64

/-- **Extreme value (min) for `aperyGFAReal` on `Icc 0 (1/64)` under
`HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_isMinOn_aperyGFAReal_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    ∃ x ∈ Set.Icc (0 : ℝ) (1 / 64),
      IsMinOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) x :=
  isCompact_Icc.exists_isMinOn
    (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))
    h.continuousOn_aperyGFAReal_Icc_one_div_64

/-- **Norm bound for `aperyGFAReal` on `Icc 0 (1/64)` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_norm_bound_aperyGFAReal_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    ∃ M : ℝ, ∀ z ∈ Set.Icc (0 : ℝ) (1 / 64), |aperyGFAReal z| ≤ M := by
  obtain ⟨xmax, _, hxmax⟩ :=
    h.exists_isMaxOn_aperyGFAReal_Icc_one_div_64
  obtain ⟨xmin, _, hxmin⟩ :=
    h.exists_isMinOn_aperyGFAReal_Icc_one_div_64
  refine ⟨max (aperyGFAReal xmax) (-aperyGFAReal xmin), ?_⟩
  intro z hz
  have h_le_max : aperyGFAReal z ≤ aperyGFAReal xmax := hxmax hz
  have h_min_le : aperyGFAReal xmin ≤ aperyGFAReal z := hxmin hz
  rw [abs_le]
  refine ⟨?_, ?_⟩
  · have h_le_M : -aperyGFAReal xmin ≤
        max (aperyGFAReal xmax) (-aperyGFAReal xmin) :=
      le_max_right _ _
    linarith
  · have h_le_M : aperyGFAReal xmax ≤
        max (aperyGFAReal xmax) (-aperyGFAReal xmin) :=
      le_max_left _ _
    linarith

/-- **Image of `aperyGFAReal` on `Icc 0 (1/64)` is bounded above under
`HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.bddAbove_aperyGFAReal_image_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    BddAbove (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) :=
  (isCompact_Icc.image_of_continuousOn
    h.continuousOn_aperyGFAReal_Icc_one_div_64).bddAbove

/-- **Image of `aperyGFAReal` on `Icc 0 (1/64)` is bounded below under
`HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.bddBelow_aperyGFAReal_image_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    BddBelow (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) :=
  (isCompact_Icc.image_of_continuousOn
    h.continuousOn_aperyGFAReal_Icc_one_div_64).bddBelow

/-- **`sSup` of `aperyGFAReal` image on `Icc 0 (1/64)` is attained.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_one_div_64_mem
    (h : HasCorridorAperyAnalyticExtension) :
    sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) ∈
      aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) := by
  refine IsCompact.sSup_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      h.continuousOn_aperyGFAReal_Icc_one_div_64
  · exact Set.Nonempty.image _
      (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **`sInf` of `aperyGFAReal` image on `Icc 0 (1/64)` is attained.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_one_div_64_mem
    (h : HasCorridorAperyAnalyticExtension) :
    sInf (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) ∈
      aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) := by
  refine IsCompact.sInf_mem ?_ ?_
  · exact isCompact_Icc.image_of_continuousOn
      h.continuousOn_aperyGFAReal_Icc_one_div_64
  · exact Set.Nonempty.image _
      (Set.nonempty_Icc.mpr (by norm_num : (0 : ℝ) ≤ 1 / 64))

/-- **`IsLUB` for `sSup` of `aperyGFAReal` image on `Icc 0 (1/64)`
under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.isLUB_sSup_aperyGFAReal_image_Icc_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    IsLUB (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64))
      (sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64))) := by
  refine Real.isLUB_sSup ?_ h.bddAbove_aperyGFAReal_image_Icc_one_div_64
  exact Set.Nonempty.image _
