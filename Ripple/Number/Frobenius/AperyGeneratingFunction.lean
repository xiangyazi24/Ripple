            Number.aperyConifoldZ1Poly 1
              ((ext.connectionCoefficients ε₁ ε₂).2.2) (m + 1) * t ^ m) =
      (ext.connectionCoefficients ε₁ ε₂).1 + t * ∑' m, frobeniusCoeff
        (aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) 2
        Number.aperyConifoldZ1Poly 0
          ((ext.connectionCoefficients ε₁ ε₂).1) (m + 1) * t ^ m := by
