/-! ### Endpoint uniqueness across all extensions

Two `AperyAnalyticExtension`s need not agree on the outside-small
stretch in general, but at the boundary radius `1/64` they *must*
coincide: both are continuous on the corridor (which contains `1/64`)
and pin to `aperyGFAReal` on `Ico 0 (1/64)`, so both equal the limit of
`aperyGFAReal` from the left at `1/64`. -/

/-- **Uniqueness of `F (1/64)` across extensions.** -/
lemma AperyAnalyticExtension.F_at_one_div_64_unique
    (ext₁ ext₂ : AperyAnalyticExtension) :
    ext₁.F (1 / 64) = ext₂.F (1 / 64) := by
  haveI : (nhdsWithin (1 / 64 : ℝ) (Set.Ico (0 : ℝ) (1 / 64))).NeBot :=
    right_nhdsWithin_Ico_neBot (by norm_num : (0 : ℝ) < 1 / 64)
  exact tendsto_nhds_unique
    ext₁.tendsto_aperyGFAReal_at_one_div_64_from_small
    ext₂.tendsto_aperyGFAReal_at_one_div_64_from_small

/-- **Two extensions agree on the closed small interval `Icc 0 (1/64)`.**
On `Ico 0 (1/64)` both equal `aperyGFAReal`; at `1/64` both equal the
common left-limit of `aperyGFAReal`. -/
lemma AperyAnalyticExtension.agree_on_Icc_one_div_64_universally
    (ext₁ ext₂ : AperyAnalyticExtension) :
    Set.EqOn ext₁.F ext₂.F (Set.Icc (0 : ℝ) (1 / 64)) := by
  intro z hz
  rcases lt_or_eq_of_le hz.2 with hlt | heq
  · exact AperyAnalyticExtension.agree_on_small_universally ext₁ ext₂ ⟨hz.1, hlt⟩
  · subst heq
    exact AperyAnalyticExtension.F_at_one_div_64_unique ext₁ ext₂

/-! ### Canonical left-limit value at `1/64`

`F_at_one_div_64_unique` shows the value at the boundary radius is
forced by the structure fields alone, independent of which extension
witness is chosen. Package this as a canonical real number depending
only on `HasAperyAnalyticExtension`. -/

/-- **The canonical left-limit of `aperyGFAReal` at `1/64`.** Defined
through any `AperyAnalyticExtension` witness; well-defined by
`F_at_one_div_64_unique`. -/
noncomputable def aperyGFAReal_left_limit_at_one_div_64
    (h : HasAperyAnalyticExtension) : ℝ :=
  h.some.F (1 / 64)

/-- **Independence of witness:** `aperyGFAReal_left_limit_at_one_div_64
h = ext.F (1/64)` for any `AperyAnalyticExtension`. -/
lemma aperyGFAReal_left_limit_at_one_div_64_eq
    (h : HasAperyAnalyticExtension) (ext : AperyAnalyticExtension) :
    aperyGFAReal_left_limit_at_one_div_64 h = ext.F (1 / 64) :=
  AperyAnalyticExtension.F_at_one_div_64_unique h.some ext

/-- **`aperyGFAReal` Tendsto its canonical left-limit value at `1/64`
from inside `Ico 0 (1/64)`.** -/
lemma tendsto_aperyGFAReal_left_limit_at_one_div_64
    (h : HasAperyAnalyticExtension) :
    Filter.Tendsto aperyGFAReal
      (nhdsWithin (1 / 64 : ℝ) (Set.Ico (0 : ℝ) (1 / 64)))
      (nhds (aperyGFAReal_left_limit_at_one_div_64 h)) :=
  h.some.tendsto_aperyGFAReal_at_one_div_64_from_small

/-- **Chain extension F at `1/64` equals the canonical left-limit.** -/
lemma AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_F_at_one_div_64_eq_canonical
    (params : ℕ → AperyGFAInteriorDiskParams) (n : ℕ)
