import Mathlib.Analysis.SpecificLimits.Basic
import Mathlib.Analysis.SpecificLimits.Normed
import Mathlib.Analysis.Normed.Group.InfiniteSum
import Mathlib.Analysis.Normed.Group.FunctionSeries
import Mathlib.Topology.Algebra.InfiniteSum.Basic
import Mathlib.Data.Nat.Choose.Bounds
import Ripple.Number.AperySequences
import Ripple.Number.Frobenius.AperyInstance
import Ripple.Number.Frobenius.RegularDisk
import Ripple.Number.Frobenius.PoincaréPerron

/-!
# Apéry generating function as a real-valued function

The formal power series `aperyGFA : PowerSeries ℚ` from
`Ripple.Number.AperySequences` records the sequence `aₙ = Σ_k C(n,k)²
C(n+k,k)²` as coefficients. Here we promote it to a real-valued
function `aperyGFAReal : ℝ → ℝ` defined by the corresponding `tsum`.

This is the analytic-side bridge needed for the connection-coefficient
extraction at the conifold `z₁ = 17 − 12√2`. The eventual goal is to
realise `aperyGFAReal` as a concrete `f` for which
`IsAperyConnectionCoeffsOn (a₀, a_½, a₁) f I` holds on a neighbourhood
of `0` (extending to `−ε` for small `ε > 0`) — with the triple
`(a₀, a_½, a₁)` ultimately identifying the transcendental
ζ-evaluation at `z₁`.

Convergence of the `tsum` requires the radius bound `|z| < z₁`; that
analytic step (involving the asymptotic `aₙ ∼ (17 + 12√2)^n / n^{3/2}`)
is **not** treated here. We record only the algebraic skeleton.
-/

namespace Ripple
namespace Frobenius

open Ripple.Number

/-- **Real-valued Apéry generating function.** Defined by the formal
`tsum` of `aₙ · z^n`. Outside the convergence disk this returns Mathlib's
default `0` for non-summable series; inside, it agrees with the analytic
sum. -/
noncomputable def aperyGFAReal (z : ℝ) : ℝ :=
  ∑' n, (Number.aperyA n : ℝ) * z ^ n

/-- **Value at `z = 0`.** All `n ≥ 1` terms vanish; the `n = 0` term
is `aperyA 0 = 1`. -/
@[simp] lemma aperyGFAReal_zero : aperyGFAReal 0 = 1 := by
  unfold aperyGFAReal
  rw [tsum_eq_single 0]
  · simp [Number.aperyA_zero]
  · intro m hm
    rw [zero_pow hm, mul_zero]

/-- **Crude growth bound on the Apéry numbers.** A combinatorial upper
bound: `aₙ ≤ (n+1) · 64ⁿ`. Each summand `C(n,k)² · C(n+k,k)²` is at most
`(2ⁿ)² · (2^{2n})² = 2^{6n} = 64ⁿ`, and the sum has `n+1` terms. The
true asymptotic is `aₙ ∼ (17 + 12√2)ⁿ / n^{3/2}` (so the radius of
convergence is exactly `z₁ = 17 − 12√2`); this crude bound only secures
convergence on `|z| < 1/64` but is enough infrastructure for the
analytic-side bridge. -/
lemma aperyA_le_pow (n : ℕ) : Number.aperyA n ≤ (n + 1) * 64 ^ n := by
  unfold Number.aperyA
  have hterm : ∀ k ∈ Finset.range (n + 1),
      (Nat.choose n k) ^ 2 * (Nat.choose (n + k) k) ^ 2 ≤ 64 ^ n := by
    intro k hk
    rw [Finset.mem_range] at hk
    have h1 : Nat.choose n k ≤ 2 ^ n := Nat.choose_le_two_pow n k
    have h2 : Nat.choose (n + k) k ≤ 2 ^ (n + k) := Nat.choose_le_two_pow (n + k) k
    have hk' : k ≤ n := Nat.le_of_lt_succ hk
    have h2' : Nat.choose (n + k) k ≤ 2 ^ (2 * n) := by
      refine h2.trans ?_
      exact Nat.pow_le_pow_right (by norm_num) (by omega)
    have h1sq : (Nat.choose n k) ^ 2 ≤ (2 ^ n) ^ 2 := Nat.pow_le_pow_left h1 2
    have h2sq : (Nat.choose (n + k) k) ^ 2 ≤ (2 ^ (2 * n)) ^ 2 :=
      Nat.pow_le_pow_left h2' 2
    have hmul :
        (Nat.choose n k) ^ 2 * (Nat.choose (n + k) k) ^ 2
          ≤ (2 ^ n) ^ 2 * (2 ^ (2 * n)) ^ 2 := Nat.mul_le_mul h1sq h2sq
    refine hmul.trans (le_of_eq ?_)
    have h64 : (64 : ℕ) = 2 ^ 6 := by norm_num
    rw [h64, ← pow_mul, ← pow_mul, ← pow_mul, ← pow_add]
    congr 1; ring
  calc (∑ k ∈ Finset.range (n + 1),
            (Nat.choose n k) ^ 2 * (Nat.choose (n + k) k) ^ 2)
      ≤ ∑ _k ∈ Finset.range (n + 1), 64 ^ n := Finset.sum_le_sum hterm
    _ = (n + 1) * 64 ^ n := by
        rw [Finset.sum_const, Finset.card_range, smul_eq_mul]

/-- **Sharper growth bound: `aₙ ≤ 34ⁿ`.** Uses the three-term recurrence
`(n+1)³ aₙ₊₁ = (2n+1)(17n²+17n+5) aₙ − n³ aₙ₋₁`. Since `aₙ₋₁ ≥ 0`, the
recurrence gives `(n+1)³ aₙ₊₁ ≤ (2n+1)(17n²+17n+5) aₙ`. The key
algebraic fact `(2n+1)(17n²+17n+5) ≤ 34(n+1)³` (difference = 51n²+75n+29 > 0)
then yields `aₙ₊₁ ≤ 34 aₙ`, and induction gives `aₙ ≤ 34ⁿ`.

This improves the crude `aₙ ≤ (n+1)·64ⁿ` bound and secures convergence
on `|z| < 1/34 ≈ 0.0294`, nearly matching the true radius `z₁ ≈ 0.0294`. -/
lemma aperyA_le_pow_34 (n : ℕ) : Number.aperyA n ≤ 34 ^ n := by
  match n with
  | 0 => simp [Number.aperyA_zero]
  | 1 => simp [Number.aperyA_one]
  | n + 2 =>
    -- From recurrence at index n+1 (≥ 1):
    -- (n+2)³ · a(n+2) = coeff · a(n+1) − (n+1)³ · a(n)
    have h_rec := Number.aperyA_recurrence (n + 1) (by omega)
    -- In ℤ: (n+2)³ · a(n+2) ≤ coeff · a(n+1) since a(n) ≥ 0
    have h_an_nn : (0 : ℤ) ≤ (Number.aperyA n : ℤ) := Int.natCast_nonneg _
    have h_cube_nn : (0 : ℤ) ≤ ((n : ℤ) + 1) ^ 3 := by positivity
    have h_drop : ((n + 1 + 1 : ℤ)) ^ 3 * (Number.aperyA (n + 1 + 1) : ℤ)
        ≤ (2 * ((n : ℤ) + 1) + 1) * (17 * ((n : ℤ) + 1) ^ 2
          + 17 * ((n : ℤ) + 1) + 5) * (Number.aperyA (n + 1) : ℤ) := by
      have : (n + 1 : ℕ) - 1 = n := by omega
      rw [this] at h_rec
      push_cast at h_rec
      nlinarith [mul_nonneg h_cube_nn h_an_nn]
    -- Algebraic: coeff ≤ 34 · (n+2)³
    have h_coeff : (2 * ((n : ℤ) + 1) + 1) * (17 * ((n : ℤ) + 1) ^ 2
        + 17 * ((n : ℤ) + 1) + 5) ≤ 34 * ((n : ℤ) + 1 + 1) ^ 3 := by
      nlinarith
    -- Combine: (n+2)³ · a(n+2) ≤ 34 · (n+2)³ · a(n+1)
    have h_an1_nn : (0 : ℤ) ≤ (Number.aperyA (n + 1) : ℤ) := Int.natCast_nonneg _
    have h_bound : ((n + 1 + 1 : ℤ)) ^ 3 * (Number.aperyA (n + 1 + 1) : ℤ)
        ≤ ((n + 1 + 1 : ℤ)) ^ 3 * (34 * (Number.aperyA (n + 1) : ℤ)) := by
      calc ((n + 1 + 1 : ℤ)) ^ 3 * (Number.aperyA (n + 1 + 1) : ℤ)
          ≤ (2 * ((n : ℤ) + 1) + 1) * (17 * ((n : ℤ) + 1) ^ 2
            + 17 * ((n : ℤ) + 1) + 5) * (Number.aperyA (n + 1) : ℤ) := h_drop
        _ ≤ 34 * ((n : ℤ) + 1 + 1) ^ 3 * (Number.aperyA (n + 1) : ℤ) :=
            mul_le_mul_of_nonneg_right h_coeff h_an1_nn
        _ = ((n + 1 + 1 : ℤ)) ^ 3 * (34 * (Number.aperyA (n + 1) : ℤ)) := by ring
    -- Divide by (n+2)³ > 0
    have h_pos : (0 : ℤ) < ((n + 1 + 1 : ℤ)) ^ 3 := by positivity
    have h_ratio : (Number.aperyA (n + 1 + 1) : ℤ) ≤
        34 * (Number.aperyA (n + 1) : ℤ) :=
      le_of_mul_le_mul_left h_bound h_pos
    -- Cast back to ℕ
    have h_nat : Number.aperyA (n + 2) ≤ 34 * Number.aperyA (n + 1) := by
      exact_mod_cast h_ratio
    -- Apply IH
    calc Number.aperyA (n + 2)
        ≤ 34 * Number.aperyA (n + 1) := h_nat
      _ ≤ 34 * 34 ^ (n + 1) := Nat.mul_le_mul_left 34 (aperyA_le_pow_34 (n + 1))
      _ = 34 ^ (n + 2) := by ring

/-- **Summability on the improved disk `|z| < 1/34`.** Direct geometric
comparison using `aₙ ≤ 34ⁿ`. The radius `1/34 ≈ 0.0294` is very close
to the true convergence radius `z₁ = 17 − 12√2 ≈ 0.0294`. -/
lemma aperyGFAReal_summable_34 {z : ℝ} (hz : |z| < 1 / 34) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) := by
  have hr_nn : (0 : ℝ) ≤ 34 * |z| := mul_nonneg (by norm_num) (abs_nonneg z)
  have hr_lt : (34 : ℝ) * |z| < 1 := by linarith [mul_lt_mul_of_pos_left hz (by norm_num : (0:ℝ) < 34)]
  have hr_norm : ‖(34 : ℝ) * |z|‖ < 1 := by rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  refine Summable.of_norm_bounded
    (summable_geometric_of_norm_lt_one hr_norm) (fun n => ?_)
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by exact_mod_cast Nat.zero_le _
  have hAn : (Number.aperyA n : ℝ) ≤ (34 : ℝ) ^ n := by exact_mod_cast aperyA_le_pow_34 n
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn]
  calc (Number.aperyA n : ℝ) * |z| ^ n
      ≤ (34 : ℝ) ^ n * |z| ^ n := mul_le_mul_of_nonneg_right hAn (pow_nonneg (abs_nonneg z) n)
    _ = ((34 : ℝ) * |z|) ^ n := by rw [mul_pow]

/-! ### Sharp bound `aₙ ≤ (17 + 12√2)ⁿ` — closing Gap F

The true growth rate of the Apéry numbers is `(17+12√2)ⁿ`, matching the
dominant root of the characteristic polynomial `x² − 34x + 1 = 0` of the
three-term recurrence. We prove `(aperyA n : ℝ) ≤ R^n` where
`R = 17 + 12√2` via a ratio-bound induction using the recurrence.

Key algebraic identity: `R² = 34R − 1`. -/

/-- The dominant eigenvalue of the Apéry recurrence. -/
private noncomputable def aperyR : ℝ := 17 + 12 * Real.sqrt 2

private lemma aperyR_pos : 0 < aperyR := by
  unfold aperyR; positivity

private lemma aperyR_ge_one : 1 ≤ aperyR := by
  unfold aperyR; linarith [Real.sqrt_nonneg 2]

private lemma aperyR_ne_zero : aperyR ≠ 0 := aperyR_pos.ne'

/-- **Characteristic equation:** `R² = 34R − 1`. -/
private lemma aperyR_sq : aperyR ^ 2 = 34 * aperyR - 1 := by
  unfold aperyR
  have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  nlinarith [hsq]

/-- **`5 ≤ R`.** Base case for the ratio bound. -/
private lemma five_le_aperyR : (5 : ℝ) ≤ aperyR := by
  unfold aperyR; linarith [Real.sqrt_nonneg 2]

/-- **Ratio bound: `aₙ₊₁ ≤ R · aₙ` for all `n`.** Two-level induction
using the recurrence. At `n ≥ 1`, the inductive hypothesis
`aₙ ≤ R · aₙ₋₁` gives the lower bound `aₙ₋₁ ≥ aₙ/R`, so the subtracted
term `−n³·aₙ₋₁` in the recurrence reduces `aₙ₊₁` enough to stay below
`R·aₙ`. The key inequality `(51n²+75n+29)·R ≥ 3n²+3n+1` closes via
`R ≥ 1` and `48n²+72n+28 ≥ 0`. -/
private lemma aperyA_ratio_le_R (n : ℕ) :
    (Number.aperyA (n + 1) : ℝ) ≤ aperyR * (Number.aperyA n : ℝ) := by
  match n with
  | 0 =>
    simp [Number.aperyA_zero, Number.aperyA_one]
    exact five_le_aperyR
  | n + 1 =>
    -- From recurrence at n+1 ≥ 1:
    -- (n+2)³ · a(n+2) = coeff · a(n+1) - (n+1)³ · a(n)
    have h_rec := Number.aperyA_recurrence (n + 1) (by omega)
    have h_sub_simp : (n + 1 : ℕ) - 1 = n := by omega
    rw [h_sub_simp] at h_rec
    -- Cast to ℝ
    have h_rec_real : ((n + 2 : ℝ)) ^ 3 * (Number.aperyA (n + 2) : ℝ)
        = (2 * ((n : ℝ) + 1) + 1) * (17 * ((n : ℝ) + 1) ^ 2
          + 17 * ((n : ℝ) + 1) + 5) * (Number.aperyA (n + 1) : ℝ)
          - ((n : ℝ) + 1) ^ 3 * (Number.aperyA n : ℝ) := by
      exact_mod_cast h_rec
    -- IH: a(n+1) ≤ R · a(n), so a(n) ≥ a(n+1)/R
    have h_ih := aperyA_ratio_le_R n
    have h_an_pos : (0 : ℝ) < (Number.aperyA n : ℝ) := by
      exact_mod_cast Number.aperyA_pos n
    have h_an1_pos : (0 : ℝ) < (Number.aperyA (n + 1) : ℝ) := by
      exact_mod_cast Number.aperyA_pos (n + 1)
    -- a(n) ≥ a(n+1) / R
    have h_lower : (Number.aperyA (n + 1) : ℝ) / aperyR ≤
        (Number.aperyA n : ℝ) := by
      rw [div_le_iff₀ aperyR_pos]
      linarith [h_ih]
    -- From recurrence:
    -- (n+2)³ · a(n+2) = coeff · a(n+1) - (n+1)³ · a(n)
    --                  ≤ coeff · a(n+1) - (n+1)³ · a(n+1)/R
    --                  = a(n+1) · (coeff - (n+1)³/R)
    -- We need: a(n+1) · (coeff - (n+1)³/R) ≤ (n+2)³ · R · a(n+1)
    -- i.e.: coeff - (n+1)³/R ≤ (n+2)³ · R
    -- i.e.: coeff · R - (n+1)³ ≤ (n+2)³ · R²
    -- Using R² = 34R - 1:
    -- coeff · R - (n+1)³ ≤ 34(n+2)³ · R - (n+2)³
    -- [coeff - 34(n+2)³] · R ≤ (n+1)³ - (n+2)³
    -- -(51n²+75n+29) · R ≤ -(3n²+3n+1)  (... wait let me recompute)
    -- Actually the indices shifted. Let me redo with m = n+1.
    -- Recurrence at m ≥ 1: (m+1)³ a(m+1) = C(m) a(m) - m³ a(m-1)
    -- C(m) = (2m+1)(17m²+17m+5)
    -- We want a(m+1) ≤ R · a(m), i.e., (m+1)³ R a(m) ≥ (m+1)³ a(m+1)
    -- Sufficient: (m+1)³ R a(m) ≥ C(m) a(m) - m³ a(m-1)
    -- with a(m-1) ≥ a(m)/R (from IH), the subtracted term ≥ m³ a(m)/R
    -- so: C(m) a(m) - m³ a(m)/R ≤ (m+1)³ R a(m)
    -- Dividing by a(m) > 0: C(m) - m³/R ≤ (m+1)³ R
    -- C(m) R - m³ ≤ (m+1)³ R²
    -- Using R² = 34R - 1:
    -- C(m) R - m³ ≤ 34(m+1)³ R - (m+1)³
    -- [C(m) - 34(m+1)³] R ≤ m³ - (m+1)³
    -- C(m) - 34(m+1)³ = (2m+1)(17m²+17m+5) - 34(m+1)³ = -(51m²+75m+29)
    -- m³ - (m+1)³ = -(3m²+3m+1)
    -- So: -(51m²+75m+29) R ≤ -(3m²+3m+1)
    -- i.e.: (51m²+75m+29) R ≥ 3m²+3m+1
    -- Here m = n+1 ≥ 1.
    set m := n + 1
    set coeff := (2 * (m : ℝ) + 1) * (17 * (m : ℝ) ^ 2 + 17 * m + 5) with hcoeff_def
    -- Goal: a(m+1) ≤ R · a(m)
    -- From recurrence: (m+1)³ a(m+1) = coeff · a(m) - m³ · a(m-1)
    -- where m-1 = n, m = n+1, m+1 = n+2
    -- Use lower bound on a(m-1) = a(n) ≥ a(m)/R = a(n+1)/R
    have h_key : coeff * (Number.aperyA m : ℝ) - (m : ℝ) ^ 3 *
        ((Number.aperyA m : ℝ) / aperyR) ≤
        ((m : ℝ) + 1) ^ 3 * (aperyR * (Number.aperyA m : ℝ)) := by
      -- Divide by a(m) > 0, reduce to: coeff - m³/R ≤ (m+1)³ R
      have h_am_pos : (0 : ℝ) < (Number.aperyA m : ℝ) := by
        exact_mod_cast Number.aperyA_pos m
      rw [show ((m : ℝ) + 1) ^ 3 * (aperyR * (Number.aperyA m : ℝ)) =
        (Number.aperyA m : ℝ) * (((m : ℝ) + 1) ^ 3 * aperyR) from by ring]
      rw [show coeff * (Number.aperyA m : ℝ) - (m : ℝ) ^ 3 *
        ((Number.aperyA m : ℝ) / aperyR) =
        (Number.aperyA m : ℝ) * (coeff - (m : ℝ) ^ 3 / aperyR) from by
          rw [mul_div_assoc']; ring]
      refine mul_le_mul_of_nonneg_left ?_ h_am_pos.le
      -- Need: coeff - m³/R ≤ (m+1)³ · R
      rw [sub_div' aperyR_ne_zero]
      rw [div_le_iff₀ aperyR_pos]
      -- Need: coeff · R - m³ ≤ (m+1)³ · R · R
      -- Rewrite R·R to R² then use R² = 34R - 1
      have : (↑m + 1) ^ 3 * aperyR * aperyR =
          (↑m + 1) ^ 3 * (34 * aperyR - 1) := by
        rw [← aperyR_sq]; ring
      rw [this]
      -- Now need: coeff · R - m³ ≤ (m+1)³ · (34R - 1)
      nlinarith [aperyR_ge_one, sq_nonneg (m : ℝ)]
    -- Now close: from recurrence + lower bound
    have h_upper : ((m : ℝ) + 1) ^ 3 * (Number.aperyA (m + 1) : ℝ) ≤
        ((m : ℝ) + 1) ^ 3 * (aperyR * (Number.aperyA m : ℝ)) := by
      calc ((m : ℝ) + 1) ^ 3 * (Number.aperyA (m + 1) : ℝ)
          = coeff * (Number.aperyA m : ℝ) - (m : ℝ) ^ 3 * (Number.aperyA n : ℝ) := by
            -- m = n + 1, m + 1 = n + 2; coeff = (2m+1)(17m²+17m+5).
            -- h_rec_real exactly states this once both sides are normalized.
            have h_m_eq : (↑m : ℝ) + 1 = ↑n + 2 := by show (↑(n + 1) : ℝ) + 1 = ↑n + 2; push_cast; ring
            have h_m_eq_nat : m + 1 = n + 2 := by show (n + 1) + 1 = n + 2; omega
            rw [h_m_eq, h_m_eq_nat]
            rw [hcoeff_def]
            show (↑n + 2) ^ 3 * (Number.aperyA (n + 2) : ℝ) =
              (2 * ↑m + 1) * (17 * ↑m ^ 2 + 17 * ↑m + 5) * (Number.aperyA m : ℝ) -
                ↑m ^ 3 * (Number.aperyA n : ℝ)
            have hm_eq_real : (↑m : ℝ) = ↑n + 1 := by
              show (↑(n + 1) : ℝ) = ↑n + 1; push_cast; ring
            rw [hm_eq_real]
            -- Now goal: (↑n + 2)^3 * ↑(aperyA (n+2)) = (2(↑n+1)+1)(17(↑n+1)²+17(↑n+1)+5) * ↑(aperyA (n+1)) - (↑n+1)^3 * ↑(aperyA n)
            -- which is exactly h_rec_real
            exact h_rec_real
        _ ≤ coeff * (Number.aperyA m : ℝ) - (m : ℝ) ^ 3 *
            ((Number.aperyA m : ℝ) / aperyR) := by
            refine sub_le_sub_left ?_ _
            refine mul_le_mul_of_nonneg_left h_lower ?_
            positivity
        _ ≤ ((m : ℝ) + 1) ^ 3 * (aperyR * (Number.aperyA m : ℝ)) := h_key
    have h_pos_cube : (0 : ℝ) < ((m : ℝ) + 1) ^ 3 := by positivity
    exact le_of_mul_le_mul_left h_upper h_pos_cube

/-- **Sharp growth bound: `aₙ ≤ (17+12√2)ⁿ`.** Matches the true growth
rate and gives convergence radius exactly `z₁ = 1/(17+12√2) = 17−12√2`.
Closes Gap F. -/
lemma aperyA_le_pow_conifold (n : ℕ) :
    (Number.aperyA n : ℝ) ≤ (17 + 12 * Real.sqrt 2) ^ n := by
  change (Number.aperyA n : ℝ) ≤ aperyR ^ n
  induction n with
  | zero => simp [Number.aperyA_zero]
  | succ n ih =>
    calc (Number.aperyA (n + 1) : ℝ)
        ≤ aperyR * (Number.aperyA n : ℝ) := aperyA_ratio_le_R n
      _ ≤ aperyR * aperyR ^ n :=
          mul_le_mul_of_nonneg_left ih aperyR_pos.le
      _ = aperyR ^ (n + 1) := by rw [pow_succ]; ring

/-- **Summability on the full disk `|z| < z₁`.** Since `z₁ = 1/(17+12√2)`,
this is the true convergence radius. -/
lemma aperyGFAReal_summable_conifold {z : ℝ}
    (hz : |z| < 1 / (17 + 12 * Real.sqrt 2)) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) := by
  have hR_pos := aperyR_pos
  have hr_nn : (0 : ℝ) ≤ aperyR * |z| := mul_nonneg hR_pos.le (abs_nonneg z)
  have hr_lt : aperyR * |z| < 1 := by
    have : |z| < 1 / aperyR := hz
    calc aperyR * |z| < aperyR * (1 / aperyR) := by
            exact mul_lt_mul_of_pos_left this hR_pos
      _ = 1 := by rw [mul_one_div_cancel aperyR_ne_zero]
  have hr_norm : ‖aperyR * |z|‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  refine Summable.of_norm_bounded
    (summable_geometric_of_norm_lt_one hr_norm) (fun n => ?_)
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by exact_mod_cast Nat.zero_le _
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn]
  calc (Number.aperyA n : ℝ) * |z| ^ n
      ≤ aperyR ^ n * |z| ^ n :=
        mul_le_mul_of_nonneg_right (aperyA_le_pow_conifold n) (pow_nonneg (abs_nonneg z) n)
    _ = (aperyR * |z|) ^ n := by rw [mul_pow]

/-- **`z₁ = 1/R`:** the conifold point is the reciprocal of the dominant
eigenvalue. From `(17+12√2)(17−12√2) = 289 − 288 = 1`. -/
lemma aperyConifoldZ1Poly_eq_inv_R :
    Number.aperyConifoldZ1Poly = 1 / (17 + 12 * Real.sqrt 2) := by
  unfold Number.aperyConifoldZ1Poly
  have hsq : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2)
  have hR_pos : (0 : ℝ) < 17 + 12 * Real.sqrt 2 := by positivity
  rw [eq_div_iff hR_pos.ne']
  nlinarith [hsq]

/-- **Summability on the full disk in `z₁` notation.**
Direct corollary of `aperyGFAReal_summable_conifold`. -/
lemma aperyGFAReal_summable_z1 {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) := by
  rw [aperyConifoldZ1Poly_eq_inv_R] at hz
  exact aperyGFAReal_summable_conifold hz

/-! ### Full-disk `[0, z₁)` unconditional atoms from Gap F closure

With `aₙ ≤ (17+12√2)ⁿ` and `z₁ = 1/(17+12√2)`, the series converges on the
full disk `|z| < z₁`. All previous results restricted to `[0, 1/64)` or
`[0, 1/34)` now extend unconditionally to `[0, z₁)`. -/

/-- **Truncated Apéry generating function (forward declaration for z₁ lemmas).**
Partial sum up to (but not including) index `N`. -/
noncomputable def aperyGFAPartial (N : ℕ) (z : ℝ) : ℝ :=
  ∑ n ∈ Finset.range N, (Number.aperyA n : ℝ) * z ^ n

/-- **Empty truncation.** -/
@[simp] lemma aperyGFAPartial_zero (z : ℝ) : aperyGFAPartial 0 z = 0 := by
  unfold aperyGFAPartial
  rw [Finset.range_zero, Finset.sum_empty]

/-- **Truncation at `N = 1`.** Only the constant term `aperyA 0 = 1`. -/
@[simp] lemma aperyGFAPartial_one (z : ℝ) : aperyGFAPartial 1 z = 1 := by
  unfold aperyGFAPartial
  rw [Finset.range_one, Finset.sum_singleton]
  simp [Number.aperyA_zero]

/-- **Successor truncation.** Adds the `N`-th term. -/
lemma aperyGFAPartial_succ (N : ℕ) (z : ℝ) :
    aperyGFAPartial (N + 1) z =
      aperyGFAPartial N z + (Number.aperyA N : ℝ) * z ^ N := by
  unfold aperyGFAPartial
  rw [Finset.sum_range_succ]

/-- **Tail summability on the full disk.** -/
lemma aperyGFAReal_tail_summable_z1 {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) (N : ℕ) :
    Summable (fun n : ℕ => (Number.aperyA (n + N) : ℝ) * z ^ (n + N)) :=
  (summable_nat_add_iff N).2 (aperyGFAReal_summable_z1 hz)

/-- **Partial sum + tail on the full disk.** -/
lemma aperyGFAReal_eq_partial_add_tail_z1 {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) (N : ℕ) :
    aperyGFAReal z = aperyGFAPartial N z +
      ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
  unfold aperyGFAReal aperyGFAPartial
  exact ((aperyGFAReal_summable_z1 hz).sum_add_tsum_nat_add N).symm

/-- **One-step expansion on the full disk.** -/
lemma aperyGFAReal_eq_one_add_tail_z1 {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) :
    aperyGFAReal z = 1 + ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) := by
  rw [aperyGFAReal_eq_partial_add_tail_z1 hz 1, aperyGFAPartial_one]

/-- **`1 ≤ aperyGFAReal z` on `[0, z₁)`.** -/
lemma aperyGFAReal_ge_one_of_nonneg_z1 {z : ℝ} (hz : 0 ≤ z)
    (hz1 : z < Number.aperyConifoldZ1Poly) :
    1 ≤ aperyGFAReal z := by
  have hone := aperyGFAReal_eq_one_add_tail_z1
    (show |z| < _ by rw [abs_of_nonneg hz]; exact hz1)
  have htail_nn : (0 : ℝ) ≤ ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) :=
    tsum_nonneg (fun n => mul_nonneg
      (by exact_mod_cast Nat.zero_le _ : (0 : ℝ) ≤ (Number.aperyA (n + 1) : ℝ))
      (pow_nonneg hz (n + 1)))
  linarith

/-- **Strict positivity on `[0, z₁)`.** -/
lemma aperyGFAReal_pos_of_nonneg_z1 {z : ℝ} (hz : 0 ≤ z)
    (hz1 : z < Number.aperyConifoldZ1Poly) :
    0 < aperyGFAReal z :=
  lt_of_lt_of_le zero_lt_one (aperyGFAReal_ge_one_of_nonneg_z1 hz hz1)

/-- **Strict `1 < aperyGFAReal z` for `0 < z < z₁`.** -/
lemma aperyGFAReal_gt_one_of_pos_z1 {z : ℝ} (hz : 0 < z)
    (hz1 : z < Number.aperyConifoldZ1Poly) :
    1 < aperyGFAReal z := by
  have hz_abs : |z| < Number.aperyConifoldZ1Poly := by
    rw [abs_of_nonneg hz.le]; exact hz1
  have hone := aperyGFAReal_eq_one_add_tail_z1 hz_abs
  have hterm : 0 < (Number.aperyA 1 : ℝ) * z ^ 1 := by
    refine mul_pos ?_ (pow_pos hz 1)
    simp [Number.aperyA_one]
  have h_ge_term := (aperyGFAReal_tail_summable_z1 hz_abs 1).le_tsum 0
    (fun n _ => mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz.le _))
  -- h_ge_term has 0+1; normalize to 1
  simp only [Nat.zero_add] at h_ge_term
  linarith

/-- **Strict monotonicity on `[0, z₁)`.** -/
lemma aperyGFAReal_strict_mono_on_nonneg_z1
    {z₁ z₂ : ℝ} (h1 : 0 ≤ z₁) (h12 : z₁ < z₂)
    (hz2 : z₂ < Number.aperyConifoldZ1Poly) :
    aperyGFAReal z₁ < aperyGFAReal z₂ := by
  have hz1_abs : |z₁| < Number.aperyConifoldZ1Poly := by
    rw [abs_of_nonneg h1]; linarith
  have hz2_abs : |z₂| < Number.aperyConifoldZ1Poly := by
    rw [abs_of_nonneg (h1.trans h12.le)]; exact hz2
  have heq1 := aperyGFAReal_eq_partial_add_tail_z1 hz1_abs 2
  have heq2 := aperyGFAReal_eq_partial_add_tail_z1 hz2_abs 2
  have hpart1 : aperyGFAPartial 2 z₁ = 1 + 5 * z₁ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have hpart2 : aperyGFAPartial 2 z₂ = 1 + 5 * z₂ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have htail_le :
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₁ ^ (n + 2) ≤
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₂ ^ (n + 2) := by
    refine (aperyGFAReal_tail_summable_z1 hz1_abs 2).tsum_le_tsum (fun n => ?_)
      (aperyGFAReal_tail_summable_z1 hz2_abs 2)
    exact mul_le_mul_of_nonneg_left (pow_le_pow_left₀ h1 h12.le (n + 2))
      (by exact_mod_cast Nat.zero_le _)
  rw [heq1, heq2, hpart1, hpart2]
  linarith

/-- **Injectivity on `[0, z₁)`.** -/
lemma aperyGFAReal_injOn_nonneg_z1 :
    Set.InjOn aperyGFAReal (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z₁ hz1 z₂ hz2 hf
  rcases lt_trichotomy z₁ z₂ with h | h | h
  · exact absurd hf (aperyGFAReal_strict_mono_on_nonneg_z1 hz1.1 h hz2.2).ne
  · exact h
  · exact absurd hf.symm (aperyGFAReal_strict_mono_on_nonneg_z1 hz2.1 h hz1.2).ne

/-- **Unconditional `ContinuousOn` on `[0, b]` for `b < z₁`.** -/
lemma aperyGFAReal_continuousOn_Icc_z1 {b : ℝ} (hb_nn : 0 ≤ b)
    (hb : b < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc 0 b) := by
  have hR_pos := aperyR_pos
  have hb_R : aperyR * b < 1 := by
    rw [aperyConifoldZ1Poly_eq_inv_R] at hb
    calc aperyR * b < aperyR * (1 / aperyR) :=
          mul_lt_mul_of_pos_left hb hR_pos
      _ = 1 := by rw [mul_one_div_cancel aperyR_ne_zero]
  have hr_nn : 0 ≤ aperyR * b := mul_nonneg hR_pos.le hb_nn
  have hr_norm : ‖aperyR * b‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hb_R
  unfold aperyGFAReal
  refine continuousOn_tsum
    (fun n => (continuous_const.mul (continuous_pow n)).continuousOn)
    (summable_geometric_of_norm_lt_one hr_norm) (fun n z hz => ?_)
  have hz_nn : 0 ≤ z := hz.1
  have hz_le : z ≤ b := hz.2
  have hAn : (Number.aperyA n : ℝ) ≤ aperyR ^ n := aperyA_le_pow_conifold n
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by exact_mod_cast Nat.zero_le _
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn, abs_of_nonneg hz_nn]
  calc (Number.aperyA n : ℝ) * z ^ n
      ≤ aperyR ^ n * z ^ n := mul_le_mul_of_nonneg_right hAn (pow_nonneg hz_nn n)
    _ ≤ aperyR ^ n * b ^ n :=
        mul_le_mul_of_nonneg_left (pow_le_pow_left₀ hz_nn hz_le n) (by positivity)
    _ = (aperyR * b) ^ n := by rw [mul_pow]

/-- **Unconditional `ContinuousOn` on sub-intervals `[a, b] ⊆ [0, z₁)`.** -/
lemma aperyGFAReal_continuousOn_Icc_sub_z1 {a b : ℝ} (ha : 0 ≤ a)
    (hb : b < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc a b) := by
  by_cases hab : a ≤ b
  · exact (aperyGFAReal_continuousOn_Icc_z1 (le_trans ha hab) hb).mono
      (Set.Icc_subset_Icc_left ha)
  · rw [Set.Icc_eq_empty hab]
    exact continuousOn_empty _

/-- **Unconditional strict mono on closed `[0, b]` for `0 < b < z₁`.** -/
lemma aperyGFAReal_strictMonoOn_Icc_z1
    {b : ℝ} (hb_pos : 0 < b) (hb : b < Number.aperyConifoldZ1Poly) :
    StrictMonoOn aperyGFAReal (Set.Icc 0 b) := by
  intro z₁' hz1 z₂ hz2 h12
  by_cases hz2' : z₂ < b
  · exact aperyGFAReal_strict_mono_on_nonneg_z1 hz1.1 h12 (lt_trans hz2' hb)
  · have hz2_eq : z₂ = b := le_antisymm hz2.2 (not_lt.mp hz2')
    subst hz2_eq  -- eliminates b in favor of z₂
    have h_mid : z₁' < (z₁' + z₂) / 2 := by linarith
    have h_mid_lt : (z₁' + z₂) / 2 < z₂ := by linarith
    have h_step1 := aperyGFAReal_strict_mono_on_nonneg_z1 hz1.1 h_mid (lt_trans h_mid_lt hb)
    have h_cont_sub : ContinuousOn aperyGFAReal (Set.Icc ((z₁' + z₂) / 2) z₂) :=
      (aperyGFAReal_continuousOn_Icc_z1 (le_of_lt hb_pos) hb).mono
        (Set.Icc_subset_Icc_left (by have h := hz1.1; linarith))
    have h_preimage_closed :
        IsClosed (Set.Icc ((z₁' + z₂) / 2) z₂ ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁' + z₂) / 2)))) :=
      h_cont_sub.preimage_isClosed_of_isClosed isClosed_Icc isClosed_Ici
    have h_sub : Set.Ico ((z₁' + z₂) / 2) z₂ ⊆
        Set.Icc ((z₁' + z₂) / 2) z₂ ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁' + z₂) / 2))) := by
      intro w hw
      exact ⟨⟨hw.1, le_of_lt hw.2⟩, show aperyGFAReal _ ≤ aperyGFAReal w from by
        rcases eq_or_lt_of_le hw.1 with rfl | hmw
        · exact le_refl _
        · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_z1
            (by have h := hz1.1; linarith) hmw (lt_trans hw.2 hb))⟩
    have h_step2 : aperyGFAReal ((z₁' + z₂) / 2) ≤ aperyGFAReal z₂ := by
      have h_contains := closure_minimal h_sub h_preimage_closed
      rw [closure_Ico (by linarith : (z₁' + z₂) / 2 ≠ z₂)] at h_contains
      exact Set.mem_Ici.mp (h_contains ⟨by linarith, le_refl _⟩).2
    exact lt_of_lt_of_le h_step1 h_step2

/-- **Unconditional `sInf = 1` on `[0, b]` for `0 < b < z₁`.** -/
lemma aperyGFAReal_sInf_image_Icc_eq_one_z1
    {b : ℝ} (hb_pos : 0 < b) (hb : b < Number.aperyConifoldZ1Poly) :
    sInf (aperyGFAReal '' Set.Icc 0 b) = 1 := by
  have hmem : (1 : ℝ) ∈ aperyGFAReal '' Set.Icc 0 b :=
    ⟨0, ⟨le_refl _, le_of_lt hb_pos⟩, aperyGFAReal_zero⟩
  have hlb : ∀ y ∈ aperyGFAReal '' Set.Icc 0 b, (1 : ℝ) ≤ y := by
    rintro y ⟨z, hz, rfl⟩
    rcases eq_or_lt_of_le hz.1 with rfl | hpos
    · simp
    · have : aperyGFAReal 0 < aperyGFAReal z :=
        aperyGFAReal_strict_mono_on_nonneg_z1 (le_refl _) hpos (lt_of_le_of_lt hz.2 hb)
      rw [aperyGFAReal_zero] at this
      exact le_of_lt this
  exact (IsLeast.csInf_eq ⟨hmem, hlb⟩)

/-- **Unconditional `sSup = GFA(b)` on `[0, b]` for `0 < b < z₁`.** -/
lemma aperyGFAReal_sSup_image_Icc_eq_right_z1
    {b : ℝ} (hb_pos : 0 < b) (hb : b < Number.aperyConifoldZ1Poly) :
    sSup (aperyGFAReal '' Set.Icc 0 b) = aperyGFAReal b := by
  have hmem : aperyGFAReal b ∈ aperyGFAReal '' Set.Icc 0 b :=
    ⟨b, ⟨le_of_lt hb_pos, le_refl _⟩, rfl⟩
  have hub : ∀ y ∈ aperyGFAReal '' Set.Icc 0 b, y ≤ aperyGFAReal b := by
    rintro y ⟨z, hz, rfl⟩
    rcases lt_or_eq_of_le hz.2 with hlt | rfl
    · exact le_of_lt ((aperyGFAReal_strictMonoOn_Icc_z1 hb_pos hb) hz
        ⟨le_of_lt hb_pos, le_refl _⟩ hlt)
    · exact le_refl _
  exact (IsGreatest.csSup_eq ⟨hmem, hub⟩)

/-- **Upper bound on the full disk: `GFA(z) ≤ 1/(1 - Rz)` where `R = 17+12√2`.** -/
lemma aperyGFAReal_le_inv_one_sub_Rz {z : ℝ} (hz : 0 ≤ z)
    (hz1 : z < Number.aperyConifoldZ1Poly) :
    aperyGFAReal z ≤ 1 / (1 - (17 + 12 * Real.sqrt 2) * z) := by
  have hR := aperyR_pos
  have hz_abs : |z| < Number.aperyConifoldZ1Poly := by rw [abs_of_nonneg hz]; exact hz1
  rw [aperyConifoldZ1Poly_eq_inv_R] at hz_abs
  have hr_lt : aperyR * z < 1 := by
    have : z < 1 / aperyR := by rwa [abs_of_nonneg hz] at hz_abs
    calc aperyR * z < aperyR * (1 / aperyR) := mul_lt_mul_of_pos_left this hR
      _ = 1 := mul_one_div_cancel aperyR_ne_zero
  have hr_nn : 0 ≤ aperyR * z := mul_nonneg hR.le hz
  have hsum_geo := tsum_geometric_of_lt_one hr_nn hr_lt
  have hle : aperyGFAReal z ≤ ∑' n : ℕ, (aperyR * z) ^ n := by
    unfold aperyGFAReal
    have hz_z1 : |z| < Number.aperyConifoldZ1Poly := by
      rw [aperyConifoldZ1Poly_eq_inv_R]; exact hz_abs
    refine (aperyGFAReal_summable_z1 hz_z1).tsum_le_tsum
      (fun n => ?_) (summable_geometric_of_norm_lt_one (by
        rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt))
    calc (Number.aperyA n : ℝ) * z ^ n
        ≤ aperyR ^ n * z ^ n :=
          mul_le_mul_of_nonneg_right (aperyA_le_pow_conifold n) (pow_nonneg hz n)
      _ = (aperyR * z) ^ n := by rw [mul_pow]
  have hgeo_eq : ∑' n : ℕ, (aperyR * z) ^ n = 1 / (1 - aperyR * z) := by
    rw [tsum_geometric_of_lt_one hr_nn hr_lt]; ring
  show aperyGFAReal z ≤ 1 / (1 - aperyR * z)
  rw [← hgeo_eq]; exact hle

/-- **Unconditional `ContinuousOn aperyGFAReal (Ico 0 z₁)`.** Extends the
closed-interval continuity to the half-open corridor. For each `x ∈ Ico 0 z₁`,
pick `b = (x + z₁)/2 < z₁`; then `ContinuousOn` on `Icc 0 b` gives
`ContinuousAt` at interior points and `ContinuousWithinAt` at `x = 0`. -/
lemma aperyGFAReal_continuousOn_corridor :
    ContinuousOn aperyGFAReal (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro x hx
  -- Pick b = (x + z₁)/2, so x < b < z₁
  set b := (x + Number.aperyConifoldZ1Poly) / 2 with hb_def
  have hx_lt := hx.2
  have hx_nn := hx.1
  have hb_lt : b < Number.aperyConifoldZ1Poly := by
    show (x + Number.aperyConifoldZ1Poly) / 2 < Number.aperyConifoldZ1Poly; linarith
  have hx_lt_b : x < b := by
    show x < (x + Number.aperyConifoldZ1Poly) / 2; linarith
  have hb_nn : 0 ≤ b := by
    show 0 ≤ (x + Number.aperyConifoldZ1Poly) / 2; linarith [aperyConifoldZ1Poly_pos]
  have h_cont := aperyGFAReal_continuousOn_Icc_z1 hb_nn hb_lt
  -- x ∈ Icc 0 b
  have hx_mem : x ∈ Set.Icc 0 b := ⟨hx_nn, le_of_lt hx_lt_b⟩
  -- ContinuousWithinAt on Icc 0 b at x
  have h_cwat := h_cont x hx_mem
  -- Icc 0 b ⊆ Ico 0 z₁
  have h_sub : Set.Icc 0 b ⊆ Set.Ico 0 Number.aperyConifoldZ1Poly :=
    fun z hz => ⟨hz.1, lt_of_le_of_lt hz.2 hb_lt⟩
  -- ContinuousWithinAt on Ico 0 z₁ follows from ContinuousWithinAt on subset
  -- via mono (larger set has weaker filter, but we go from smaller to larger)
  -- For x in interior of Icc 0 b: ContinuousAt, hence ContinuousWithinAt on any set
  by_cases hx_zero : x = 0
  · -- At x = 0: locally Icc 0 b and Ico 0 z₁ agree (both contain Ico 0 b').
    -- Use ContinuousWithinAt.mono_of_mem with the inclusion Icc 0 b ⊇ ... actually
    -- need different approach: show nhdsWithin 0 (Ico 0 z₁) ≤ nhdsWithin 0 (Icc 0 b).
    subst hx_zero
    refine h_cwat.mono_of_mem_nhdsWithin ?_
    -- Show Icc 0 b ∈ nhdsWithin 0 (Ico 0 z₁)
    refine mem_nhdsWithin.mpr ⟨Set.Iio b, isOpen_Iio, ?_, ?_⟩
    · -- 0 ∈ Iio b: 0 < b
      exact hb_nn.lt_of_ne (Ne.symm (by intro h; rw [← h] at hx_lt_b; exact absurd hx_lt_b (lt_irrefl _)))
    · -- (Iio b ∩ Ico 0 z₁) ⊆ Icc 0 b
      intro y ⟨hy_lt, hy_mem⟩
      exact ⟨hy_mem.1, le_of_lt hy_lt⟩
  · -- x > 0, so x ∈ Ioo 0 b (interior of Icc 0 b)
    have hx_pos : 0 < x := lt_of_le_of_ne hx_nn (Ne.symm hx_zero)
    have hx_interior : x ∈ Set.Ioo 0 b := ⟨hx_pos, hx_lt_b⟩
    -- Icc 0 b ∈ nhds x (since x is in interior)
    have h_nhds : Set.Icc 0 b ∈ nhds x :=
      Icc_mem_nhds hx_pos hx_lt_b
    -- ContinuousWithinAt on a neighborhood set = ContinuousAt
    have h_cat : ContinuousAt aperyGFAReal x :=
      h_cwat.continuousAt h_nhds
    exact h_cat.continuousWithinAt

/-- **Summability of the Apéry GF on the small disk `|z| < 1/64`.**
Comparison test against `(n+1) · (64|z|)^n`, which is summable since
`64|z| < 1`. The crude bound `aperyA n ≤ (n+1) · 64^n` carries the
estimate; the true radius of convergence is `z₁ = 17 − 12√2 ≈ 0.0294`,
much larger than `1/64 ≈ 0.0156`, but the larger radius requires the
sharp asymptotic. -/
lemma aperyGFAReal_summable {z : ℝ} (hz : |z| < 1 / 64) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) := by
  have hr_nn : (0 : ℝ) ≤ 64 * |z| :=
    mul_nonneg (by norm_num) (abs_nonneg z)
  have hr_lt : (64 : ℝ) * |z| < 1 := by
    have h := mul_lt_mul_of_pos_left hz (by norm_num : (0 : ℝ) < 64)
    linarith
  have hr_norm : ‖(64 : ℝ) * |z|‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  have hsum_n : Summable (fun n : ℕ => (n : ℝ) * (64 * |z|) ^ n) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    simpa using h
  have hsum_geo : Summable (fun n : ℕ => ((64 : ℝ) * |z|) ^ n) :=
    summable_geometric_of_norm_lt_one hr_norm
  have hsum_bound :
      Summable (fun n : ℕ => ((n : ℝ) + 1) * (64 * |z|) ^ n) := by
    have h := hsum_n.add hsum_geo
    simpa [add_mul, one_mul] using h
  refine Summable.of_norm_bounded hsum_bound (fun n => ?_)
  have hpow_nn : (0 : ℝ) ≤ |z| ^ n := pow_nonneg (abs_nonneg _) n
  have hAn : (Number.aperyA n : ℝ) ≤ ((n : ℝ) + 1) * 64 ^ n := by
    exact_mod_cast aperyA_le_pow n
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by
    exact_mod_cast Nat.zero_le _
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn]
  calc (Number.aperyA n : ℝ) * |z| ^ n
      ≤ ((n : ℝ) + 1) * 64 ^ n * |z| ^ n :=
        mul_le_mul_of_nonneg_right hAn hpow_nn
    _ = ((n : ℝ) + 1) * (64 * |z|) ^ n := by ring

/-- **Decomposition into truncation + tail.** On the convergence disk
`|z| < 1/64`, the full sum splits as the partial polynomial plus the
remaining tail. Direct application of Mathlib's `sum_add_tsum_nat_add`. -/
lemma aperyGFAReal_eq_partial_add_tail {z : ℝ} (hz : |z| < 1 / 64) (N : ℕ) :
    aperyGFAReal z =
      aperyGFAPartial N z +
        ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
  unfold aperyGFAReal aperyGFAPartial
  exact ((aperyGFAReal_summable hz).sum_add_tsum_nat_add N).symm

/-- **Tail summability.** Tail series of `aperyGFAReal` are summable
whenever the head is. Direct restatement via `summable_nat_add_iff`. -/
lemma aperyGFAReal_tail_summable {z : ℝ} (hz : |z| < 1 / 64) (N : ℕ) :
    Summable (fun n : ℕ => (Number.aperyA (n + N) : ℝ) * z ^ (n + N)) :=
  (summable_nat_add_iff N).2 (aperyGFAReal_summable hz)

/-- **One-step expansion.** `aperyGFAReal z = 1 + (the tail from `n ≥ 1`)`.
Specialization of `aperyGFAReal_eq_partial_add_tail` at `N = 1`. -/
lemma aperyGFAReal_eq_one_add_tail {z : ℝ} (hz : |z| < 1 / 64) :
    aperyGFAReal z =
      1 + ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) := by
  rw [aperyGFAReal_eq_partial_add_tail hz 1, aperyGFAPartial_one]

/-- **Linear-in-`z` expansion.** Pulls the factor `z` out of the tail:
`aperyGFAReal z − 1 = z · ∑' n, aperyA(n+1) · z^n`. Useful for the
`aperyGFAReal(z) → 1 = z · O(1)` behaviour near `z = 0`. -/
lemma aperyGFAReal_sub_one_eq_z_mul_tail {z : ℝ} (hz : |z| < 1 / 64) :
    aperyGFAReal z - 1 =
      z * ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ n := by
  have h := aperyGFAReal_eq_one_add_tail hz
  have hsum : ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) =
      z * ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ n := by
    rw [← tsum_mul_left]
    congr 1
    funext n
    rw [pow_succ]; ring
  linarith [h.trans (by rw [hsum])]

/-- **Continuity on the small closed disk `[-1/128, 1/128]`.**
Each summand `(aperyA n : ℝ) · z^n` is continuous, and on
`|z| ≤ 1/128` the bound `|aperyA n · z^n| ≤ (n+1) · (1/2)^n` is
uniformly summable. Apply `continuousOn_tsum`. -/
lemma aperyGFAReal_continuousOn_small :
    ContinuousOn aperyGFAReal (Set.Icc (-(1 / 128 : ℝ)) (1 / 128)) := by
  have hhalf : ‖(1 / 2 : ℝ)‖ < 1 := by
    rw [Real.norm_eq_abs]; norm_num
  have hgeom : Summable (fun n : ℕ => ((n : ℝ) + 1) * (1 / 2) ^ n) := by
    have h1 := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hhalf
    have h2 := summable_geometric_of_norm_lt_one hhalf
    have h3 := h1.add h2
    simpa [add_mul, one_mul] using h3
  unfold aperyGFAReal
  refine continuousOn_tsum
    (fun n => (continuous_const.mul (continuous_pow n)).continuousOn) hgeom
    (fun n z hz => ?_)
  obtain ⟨h1, h2⟩ := hz
  have hz_abs : |z| ≤ 1 / 128 := abs_le.mpr ⟨h1, h2⟩
  have hAn : (Number.aperyA n : ℝ) ≤ ((n : ℝ) + 1) * 64 ^ n := by
    exact_mod_cast aperyA_le_pow n
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by
    exact_mod_cast Nat.zero_le _
  have hpow_nn : (0 : ℝ) ≤ |z| ^ n := pow_nonneg (abs_nonneg z) n
  have hpow_le : |z| ^ n ≤ (1 / 128 : ℝ) ^ n :=
    pow_le_pow_left₀ (abs_nonneg z) hz_abs n
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn]
  calc (Number.aperyA n : ℝ) * |z| ^ n
      ≤ ((n : ℝ) + 1) * 64 ^ n * |z| ^ n :=
        mul_le_mul_of_nonneg_right hAn hpow_nn
    _ ≤ ((n : ℝ) + 1) * 64 ^ n * (1 / 128 : ℝ) ^ n :=
        mul_le_mul_of_nonneg_left hpow_le (by positivity)
    _ = ((n : ℝ) + 1) * (1 / 2) ^ n := by
        rw [mul_assoc, ← mul_pow]
        congr 2; norm_num

/-- **Continuity at the origin.** Specialization of the small-disk
continuity. Used to anchor the value `aperyGFAReal 0 = 1`. -/
lemma aperyGFAReal_continuousAt_zero : ContinuousAt aperyGFAReal 0 :=
  aperyGFAReal_continuousOn_small.continuousAt
    (Icc_mem_nhds (by norm_num) (by norm_num))

/-- **Convergence of partial sums to the full series.** On the convergence
disk `|z| < 1/64`, the polynomial truncations `aperyGFAPartial N z` tend
to `aperyGFAReal z` as `N → ∞`. Direct from `HasSum.tendsto_sum_nat`. -/
lemma tendsto_aperyGFAPartial {z : ℝ} (hz : |z| < 1 / 64) :
    Filter.Tendsto (fun N => aperyGFAPartial N z) Filter.atTop
      (nhds (aperyGFAReal z)) := by
  unfold aperyGFAPartial aperyGFAReal
  exact (aperyGFAReal_summable hz).hasSum.tendsto_sum_nat

/-- **Truncation at `z = 0`.** All higher-order terms vanish; the partial
sum collapses to `1` for any `N ≥ 1`. -/
lemma aperyGFAPartial_at_zero (N : ℕ) (hN : 0 < N) :
    aperyGFAPartial N 0 = 1 := by
  unfold aperyGFAPartial
  rw [Finset.sum_eq_single (0 : ℕ)]
  · simp [Number.aperyA_zero]
  · intro b hb hb0
    rw [zero_pow hb0, mul_zero]
  · intro h
    exact absurd (Finset.mem_range.mpr hN) h

/-- **Lower bound on the convergence disk for non-negative `z`.** Since
`aperyA n ≥ 0` and `z^n ≥ 0` for `0 ≤ z`, every term of the series is
non-negative, so the full sum dominates the constant term `aperyA 0 = 1`.
This is a useful anchor: `aperyGFAReal` does not vanish on `[0, 1/64)`. -/
lemma aperyGFAReal_ge_one_of_nonneg {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    1 ≤ aperyGFAReal z := by
  have hz_abs : |z| < 1 / 64 := by rw [abs_of_nonneg hz]; exact hz64
  have hone : aperyGFAReal z =
      1 + ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) :=
    aperyGFAReal_eq_one_add_tail hz_abs
  have htail_nn :
      0 ≤ ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) := by
    refine tsum_nonneg (fun n => ?_)
    have hAn_nn : (0 : ℝ) ≤ (Number.aperyA (n + 1) : ℝ) := by
      exact_mod_cast Nat.zero_le _
    exact mul_nonneg hAn_nn (pow_nonneg hz _)
  linarith

/-- **Strict positivity on `[0, 1/64)`.** Immediate corollary of the lower
bound `1 ≤ aperyGFAReal z`. -/
lemma aperyGFAReal_pos_of_nonneg {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    0 < aperyGFAReal z :=
  lt_of_lt_of_le zero_lt_one (aperyGFAReal_ge_one_of_nonneg hz hz64)

/-! ### Extended disk `[0, 1/34)` atoms from `aperyA_le_pow_34` -/

/-- **Partial sum + tail on the extended disk `|z| < 1/34`.** -/
lemma aperyGFAReal_eq_partial_add_tail_34 {z : ℝ} (hz : |z| < 1 / 34) (N : ℕ) :
    aperyGFAReal z =
      aperyGFAPartial N z +
        ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
  unfold aperyGFAReal aperyGFAPartial
  exact ((aperyGFAReal_summable_34 hz).sum_add_tsum_nat_add N).symm

/-- **Tail summability on the extended disk.** -/
lemma aperyGFAReal_tail_summable_34 {z : ℝ} (hz : |z| < 1 / 34) (N : ℕ) :
    Summable (fun n : ℕ => (Number.aperyA (n + N) : ℝ) * z ^ (n + N)) :=
  (summable_nat_add_iff N).2 (aperyGFAReal_summable_34 hz)

/-- **One-step expansion on the extended disk.** -/
lemma aperyGFAReal_eq_one_add_tail_34 {z : ℝ} (hz : |z| < 1 / 34) :
    aperyGFAReal z =
      1 + ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) := by
  rw [aperyGFAReal_eq_partial_add_tail_34 hz 1, aperyGFAPartial_one]

/-- **Lower bound `1 ≤ aperyGFAReal z` on `[0, 1/34)`.** Extends the
`1/64` version to the full improved disk. -/
lemma aperyGFAReal_ge_one_of_nonneg_34 {z : ℝ} (hz : 0 ≤ z) (hz34 : z < 1 / 34) :
    1 ≤ aperyGFAReal z := by
  have hz_abs : |z| < 1 / 34 := by rw [abs_of_nonneg hz]; exact hz34
  have hone := aperyGFAReal_eq_one_add_tail_34 hz_abs
  have htail_nn :
      0 ≤ ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) :=
    tsum_nonneg (fun n => mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz _))
  linarith

/-- **Strict positivity on `[0, 1/34)`.** -/
lemma aperyGFAReal_pos_of_nonneg_34 {z : ℝ} (hz : 0 ≤ z) (hz34 : z < 1 / 34) :
    0 < aperyGFAReal z :=
  lt_of_lt_of_le zero_lt_one (aperyGFAReal_ge_one_of_nonneg_34 hz hz34)

/-- **Strict `1 < aperyGFAReal z` for `0 < z < 1/34`.** -/
lemma aperyGFAReal_gt_one_of_pos_34 {z : ℝ} (hz : 0 < z) (hz34 : z < 1 / 34) :
    1 < aperyGFAReal z := by
  have hz_abs : |z| < 1 / 34 := by rw [abs_of_nonneg hz.le]; exact hz34
  have hone := aperyGFAReal_eq_one_add_tail_34 hz_abs
  have hterm : 0 < (Number.aperyA 1 : ℝ) * z ^ 1 := by
    refine mul_pos ?_ (pow_pos hz 1)
    simp [Number.aperyA_one]
  have htail_nn :
      0 ≤ ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ (n + 1) :=
    tsum_nonneg (fun n => mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz.le _))
  -- The tail sum is ≥ the n=0 term which is a₁·z > 0
  have h_ge_term := (aperyGFAReal_tail_summable_34 hz_abs 1).le_tsum 0
    (fun n _ => mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hz.le _))
  simp only [Nat.zero_add] at h_ge_term
  linarith

/-- **Strict monotonicity on `[0, 1/34)`.** The proof is identical to the
`1/64` version but uses the extended summability. -/
lemma aperyGFAReal_strict_mono_on_nonneg_34
    {z₁ z₂ : ℝ} (h1 : 0 ≤ z₁) (h12 : z₁ < z₂) (hz2 : z₂ < 1 / 34) :
    aperyGFAReal z₁ < aperyGFAReal z₂ := by
  have hz1_abs : |z₁| < 1 / 34 := by rw [abs_of_nonneg h1]; linarith
  have hz2_abs : |z₂| < 1 / 34 := by rw [abs_of_nonneg (h1.trans h12.le)]; exact hz2
  -- Split: GFA = partial(2) + tail
  have heq1 := aperyGFAReal_eq_partial_add_tail_34 hz1_abs 2
  have heq2 := aperyGFAReal_eq_partial_add_tail_34 hz2_abs 2
  have hpart1 : aperyGFAPartial 2 z₁ = 1 + 5 * z₁ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have hpart2 : aperyGFAPartial 2 z₂ = 1 + 5 * z₂ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have htail_le :
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₁ ^ (n + 2) ≤
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₂ ^ (n + 2) := by
    refine (aperyGFAReal_tail_summable_34 hz1_abs 2).tsum_le_tsum (fun n => ?_)
      (aperyGFAReal_tail_summable_34 hz2_abs 2)
    exact mul_le_mul_of_nonneg_left (pow_le_pow_left₀ h1 h12.le (n + 2))
      (by exact_mod_cast Nat.zero_le _)
  rw [heq1, heq2, hpart1, hpart2]
  linarith

/-- **Upper bound on `[0, 1/34)`.** Since `aₙ ≤ 34ⁿ`, the GF is bounded
by the geometric series `∑ (34z)ⁿ = 1/(1 − 34z)`. -/
lemma aperyGFAReal_le_inv_one_sub_34z {z : ℝ} (hz : 0 ≤ z) (hz34 : z < 1 / 34) :
    aperyGFAReal z ≤ 1 / (1 - 34 * z) := by
  have hz_abs : |z| < 1 / 34 := by rw [abs_of_nonneg hz]; exact hz34
  have hr_lt : (34 : ℝ) * z < 1 := by linarith
  have hr_nn : (0 : ℝ) ≤ 34 * z := mul_nonneg (by norm_num) hz
  have hr_norm : ‖(34 : ℝ) * z‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  have hsum_geo := tsum_geometric_of_lt_one hr_nn hr_lt
  -- aperyGFAReal z ≤ ∑ 34ⁿ zⁿ = ∑ (34z)ⁿ = 1/(1-34z)
  have hle : aperyGFAReal z ≤ ∑' n : ℕ, ((34 : ℝ) * z) ^ n := by
    unfold aperyGFAReal
    refine (aperyGFAReal_summable_34 hz_abs).tsum_le_tsum (fun n => ?_)
      (summable_geometric_of_norm_lt_one hr_norm)
    have hAn : (Number.aperyA n : ℝ) ≤ (34 : ℝ) ^ n := by exact_mod_cast aperyA_le_pow_34 n
    calc (Number.aperyA n : ℝ) * z ^ n
        ≤ (34 : ℝ) ^ n * z ^ n := mul_le_mul_of_nonneg_right hAn (pow_nonneg hz n)
      _ = ((34 : ℝ) * z) ^ n := by rw [mul_pow]
  -- hsum_geo : ∑ = (1 - 34z)⁻¹; goal: aperyGFAReal z ≤ 1 / (1 - 34z)
  rw [show (1 : ℝ) / (1 - 34 * z) = (1 - 34 * z)⁻¹ from by ring]
  linarith [hsum_geo]

/-- **Unconditional `ContinuousOn` on `[0, b]` for `b < 1/34`.** Uses
the Weierstrass M-test with bound `|aₙ z^n| ≤ (34b)^n` from `aₙ ≤ 34ⁿ`.
No `HasCorridor` or `HasAperyAnalyticExtension` hypothesis needed. -/
lemma aperyGFAReal_continuousOn_Icc_34 {b : ℝ} (hb_nn : 0 ≤ b) (hb : b < 1 / 34) :
    ContinuousOn aperyGFAReal (Set.Icc 0 b) := by
  have hr_nn : (0 : ℝ) ≤ 34 * b := mul_nonneg (by norm_num) hb_nn
  have hr_lt : (34 : ℝ) * b < 1 := by
    linarith [mul_lt_mul_of_pos_left hb (by norm_num : (0 : ℝ) < 34)]
  have hr_norm : ‖(34 : ℝ) * b‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  unfold aperyGFAReal
  refine continuousOn_tsum
    (fun n => (continuous_const.mul (continuous_pow n)).continuousOn)
    (summable_geometric_of_norm_lt_one hr_norm) (fun n z hz => ?_)
  have hz_nn : 0 ≤ z := hz.1
  have hz_le : z ≤ b := hz.2
  have hAn : (Number.aperyA n : ℝ) ≤ (34 : ℝ) ^ n := by exact_mod_cast aperyA_le_pow_34 n
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by exact_mod_cast Nat.zero_le _
  rw [Real.norm_eq_abs, abs_mul, abs_pow, abs_of_nonneg hAn_nn, abs_of_nonneg hz_nn]
  calc (Number.aperyA n : ℝ) * z ^ n
      ≤ (34 : ℝ) ^ n * z ^ n := mul_le_mul_of_nonneg_right hAn (pow_nonneg hz_nn n)
    _ ≤ (34 : ℝ) ^ n * b ^ n :=
        mul_le_mul_of_nonneg_left (pow_le_pow_left₀ hz_nn hz_le n) (by positivity)
    _ = ((34 : ℝ) * b) ^ n := by rw [mul_pow]

/-- **Unconditional `ContinuousOn` on any sub-interval `[a, b] ⊆ [0, 1/34)`.** -/
lemma aperyGFAReal_continuousOn_Icc_sub_34 {a b : ℝ} (ha : 0 ≤ a) (hb : b < 1 / 34) :
    ContinuousOn aperyGFAReal (Set.Icc a b) := by
  by_cases hab : a ≤ b
  · exact (aperyGFAReal_continuousOn_Icc_34 (le_trans ha hab) hb).mono
      (Set.Icc_subset_Icc_left ha)
  · rw [Set.Icc_eq_empty hab]
    exact continuousOn_empty _

/-- **Unconditional strict mono on closed `[0, b]` for `0 < b < 1/34`.**
On `[0, b)` this is `aperyGFAReal_strict_mono_on_nonneg_34`. At `z₂ = b`,
the closure follows from unconditional `ContinuousOn` via the same
midpoint + closure argument as the `HasCorridor` version. -/
lemma aperyGFAReal_strictMonoOn_Icc_34
    {b : ℝ} (hb_pos : 0 < b) (hb : b < 1 / 34) :
    StrictMonoOn aperyGFAReal (Set.Icc 0 b) := by
  intro z₁ hz1 z₂ hz2 h12
  by_cases hz2' : z₂ < b
  · exact aperyGFAReal_strict_mono_on_nonneg_34 hz1.1 h12 (lt_of_lt_of_le hz2' (le_of_lt hb))
  · have hz2_eq : z₂ = b := le_antisymm hz2.2 (not_lt.mp hz2')
    subst hz2_eq  -- eliminates b in favor of z₂
    -- midpoint argument
    have h_mid : z₁ < (z₁ + z₂) / 2 := by linarith
    have h_mid_lt : (z₁ + z₂) / 2 < z₂ := by linarith
    have h_step1 := aperyGFAReal_strict_mono_on_nonneg_34 hz1.1 h_mid
      (lt_trans h_mid_lt hb)
    -- closure: aperyGFAReal m ≤ aperyGFAReal z₂ via ContinuousOn + preimage_closed
    have h_mid_nn : 0 ≤ (z₁ + z₂) / 2 := by have h := hz1.1; linarith
    have h_cont := aperyGFAReal_continuousOn_Icc_34 (le_of_lt hb_pos) hb
    have h_cont_sub : ContinuousOn aperyGFAReal
        (Set.Icc ((z₁ + z₂) / 2) z₂) :=
      h_cont.mono (Set.Icc_subset_Icc_left h_mid_nn)
    have h_preimage_closed :
        IsClosed (Set.Icc ((z₁ + z₂) / 2) z₂ ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + z₂) / 2)))) :=
      h_cont_sub.preimage_isClosed_of_isClosed isClosed_Icc isClosed_Ici
    have h_sub : Set.Ico ((z₁ + z₂) / 2) z₂ ⊆
        Set.Icc ((z₁ + z₂) / 2) z₂ ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + z₂) / 2))) := by
      intro w hw
      refine ⟨⟨hw.1, le_of_lt hw.2⟩, ?_⟩
      show aperyGFAReal ((z₁ + z₂) / 2) ≤ aperyGFAReal w
      rcases eq_or_lt_of_le hw.1 with rfl | hmw
      · exact le_refl _
      · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_34 h_mid_nn hmw
          (lt_trans hw.2 hb))
    have h_closure : closure (Set.Ico ((z₁ + z₂) / 2) z₂) =
        Set.Icc ((z₁ + z₂) / 2) z₂ :=
      closure_Ico (by linarith : (z₁ + z₂) / 2 ≠ z₂)
    have h_step2 : aperyGFAReal ((z₁ + z₂) / 2) ≤ aperyGFAReal z₂ := by
      have h_contains : Set.Icc ((z₁ + z₂) / 2) z₂ ⊆
          Set.Icc ((z₁ + z₂) / 2) z₂ ∩
            aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + z₂) / 2))) := by
        have := closure_minimal h_sub h_preimage_closed
        rwa [h_closure] at this
      exact Set.mem_Ici.mp (h_contains ⟨by linarith, le_refl _⟩).2
    exact lt_of_lt_of_le h_step1 h_step2

/-- **Unconditional injectivity on closed `[0, b]` for `0 < b < 1/34`.** -/
lemma aperyGFAReal_injOn_Icc_34
    {b : ℝ} (hb_pos : 0 < b) (hb : b < 1 / 34) :
    Set.InjOn aperyGFAReal (Set.Icc 0 b) :=
  (aperyGFAReal_strictMonoOn_Icc_34 hb_pos hb).injOn

/-- **Unconditional `1 ≤ aperyGFAReal z` on closed `[0, b]` for `b < 1/34`.** -/
lemma aperyGFAReal_ge_one_of_mem_Icc_34 {b : ℝ} (hb_nn : 0 ≤ b) (hb : b < 1 / 34)
    {z : ℝ} (hz : z ∈ Set.Icc 0 b) :
    1 ≤ aperyGFAReal z := by
  by_cases hz' : z < 1 / 34
  · exact aperyGFAReal_ge_one_of_nonneg_34 hz.1 hz'
  · -- z = b (which must equal z since b < 1/34 and z ≤ b)
    linarith [hz.2]

/-- **Unconditional positivity on closed `[0, b]` for `b < 1/34`.** -/
lemma aperyGFAReal_pos_of_mem_Icc_34 {b : ℝ} (hb_nn : 0 ≤ b) (hb : b < 1 / 34)
    {z : ℝ} (hz : z ∈ Set.Icc 0 b) :
    0 < aperyGFAReal z :=
  lt_of_lt_of_le zero_lt_one (aperyGFAReal_ge_one_of_mem_Icc_34 hb_nn hb hz)

/-- **Unconditional `sInf` pinning: `sInf (GFA '' [0, b]) = 1` for `0 < b < 1/34`.** -/
lemma aperyGFAReal_sInf_image_Icc_eq_one_34
    {b : ℝ} (hb_pos : 0 < b) (hb : b < 1 / 34) :
    sInf (aperyGFAReal '' Set.Icc 0 b) = 1 := by
  have h_isLeast : IsLeast (aperyGFAReal '' Set.Icc 0 b)
      (aperyGFAReal 0) := by
    constructor
    · exact ⟨0, ⟨le_refl _, le_of_lt hb_pos⟩, rfl⟩
    · rintro y ⟨z, hz, rfl⟩
      rcases eq_or_lt_of_le hz.1 with rfl | hpos
      · exact le_refl _
      · exact le_of_lt ((aperyGFAReal_strictMonoOn_Icc_34 hb_pos hb)
          ⟨le_refl _, le_of_lt hb_pos⟩ hz hpos)
  rw [h_isLeast.csInf_eq, aperyGFAReal_zero]

/-- **Unconditional `sSup` pinning: `sSup (GFA '' [0, b]) = GFA(b)` for `0 < b < 1/34`.** -/
lemma aperyGFAReal_sSup_image_Icc_eq_right_34
    {b : ℝ} (hb_pos : 0 < b) (hb : b < 1 / 34) :
    sSup (aperyGFAReal '' Set.Icc 0 b) = aperyGFAReal b := by
  have h_isGreatest : IsGreatest (aperyGFAReal '' Set.Icc 0 b)
      (aperyGFAReal b) := by
    constructor
    · exact ⟨b, ⟨le_of_lt hb_pos, le_refl _⟩, rfl⟩
    · rintro y ⟨z, hz, rfl⟩
      rcases lt_or_eq_of_le hz.2 with hlt | rfl
      · exact le_of_lt ((aperyGFAReal_strictMonoOn_Icc_34 hb_pos hb) hz
          ⟨le_of_lt hb_pos, le_refl _⟩ hlt)
      · exact le_refl _
  exact h_isGreatest.csSup_eq

/-- **Unconditional image characterization: `GFA '' [0, b] = [1, GFA(b)]`
for `0 < b < 1/34`.** -/
lemma aperyGFAReal_image_Icc_eq_concrete_34
    {b : ℝ} (hb_pos : 0 < b) (hb : b < 1 / 34) :
    aperyGFAReal '' Set.Icc 0 b = Set.Icc 1 (aperyGFAReal b) := by
  -- image = [sInf, sSup] by IVT from ContinuousOn
  have h_cont := aperyGFAReal_continuousOn_Icc_34 (le_of_lt hb_pos) hb
  have h_compact : IsCompact (aperyGFAReal '' Set.Icc 0 b) :=
    isCompact_Icc.image_of_continuousOn h_cont
  have h_nonempty : (Set.Icc (0 : ℝ) b).Nonempty :=
    Set.nonempty_Icc.mpr (le_of_lt hb_pos)
  have h_image_nonempty := h_nonempty.image aperyGFAReal
  -- image = [sInf, sSup]
  have h_eq_sInf_sSup : aperyGFAReal '' Set.Icc 0 b =
      Set.Icc (sInf (aperyGFAReal '' Set.Icc 0 b))
        (sSup (aperyGFAReal '' Set.Icc 0 b)) := by
    apply Set.eq_of_subset_of_subset
    · rintro y ⟨z, hz, rfl⟩
      exact ⟨(Real.isGLB_sInf h_image_nonempty h_compact.bddBelow).1 ⟨z, hz, rfl⟩,
             (Real.isLUB_sSup h_image_nonempty h_compact.bddAbove).1 ⟨z, hz, rfl⟩⟩
    · obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ := h_compact.sInf_mem h_image_nonempty
      obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ := h_compact.sSup_mem h_image_nonempty
      have h_surj := h_cont.surjOn_Icc hzmin_mem hzmax_mem
      rw [hzmin_eq, hzmax_eq] at h_surj
      exact h_surj
  rw [h_eq_sInf_sSup,
      aperyGFAReal_sInf_image_Icc_eq_one_34 hb_pos hb,
      aperyGFAReal_sSup_image_Icc_eq_right_34 hb_pos hb]

/-- **Unconditional `sInf` pinning on generic `[a, b] ⊆ [0, 1/34)`:
`sInf = GFA(a)`.** -/
lemma aperyGFAReal_sInf_image_Icc_sub_eq_left_34
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < 1 / 34) :
    sInf (aperyGFAReal '' Set.Icc a b) = aperyGFAReal a := by
  by_cases hab' : a = b
  · subst hab'; simp
  · have hab_lt : a < b := lt_of_le_of_ne hab hab'
    have hmem : aperyGFAReal a ∈ aperyGFAReal '' Set.Icc a b :=
      ⟨a, ⟨le_refl _, hab⟩, rfl⟩
    have hlb : ∀ y ∈ aperyGFAReal '' Set.Icc a b, aperyGFAReal a ≤ y := by
      rintro y ⟨z, hz, rfl⟩
      rcases eq_or_lt_of_le hz.1 with rfl | hpos
      · exact le_refl _
      · exact le_of_lt ((aperyGFAReal_strictMonoOn_Icc_34 (lt_of_le_of_lt ha hab_lt) hb)
          ⟨ha, hab⟩
          ⟨le_trans ha (le_of_lt hpos), hz.2⟩ hpos)
    exact IsLeast.csInf_eq ⟨hmem, hlb⟩

/-- **Unconditional `sSup` pinning on generic `[a, b] ⊆ [0, 1/34)`:
`sSup = GFA(b)`.** -/
lemma aperyGFAReal_sSup_image_Icc_sub_eq_right_34
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < 1 / 34) :
    sSup (aperyGFAReal '' Set.Icc a b) = aperyGFAReal b := by
  by_cases hab' : a = b
  · subst hab'; simp
  · have hab_lt : a < b := lt_of_le_of_ne hab hab'
    have hmem : aperyGFAReal b ∈ aperyGFAReal '' Set.Icc a b :=
      ⟨b, ⟨hab, le_refl _⟩, rfl⟩
    have hub : ∀ y ∈ aperyGFAReal '' Set.Icc a b, y ≤ aperyGFAReal b := by
      rintro y ⟨z, hz, rfl⟩
      rcases lt_or_eq_of_le hz.2 with hlt | rfl
      · exact le_of_lt ((aperyGFAReal_strictMonoOn_Icc_34 (lt_of_le_of_lt ha hab_lt) hb)
          ⟨le_trans ha hz.1, le_of_lt hlt⟩
          ⟨le_trans ha hab, le_refl _⟩ hlt)
      · exact le_refl _
    exact IsGreatest.csSup_eq ⟨hmem, hub⟩

/-- **Unconditional image on generic `[a, b] ⊆ [0, 1/34)`:
`image = [GFA(a), GFA(b)]`.** -/
lemma aperyGFAReal_image_Icc_sub_eq_concrete_34
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b < 1 / 34) :
    aperyGFAReal '' Set.Icc a b =
      Set.Icc (aperyGFAReal a) (aperyGFAReal b) := by
  have h_cont := aperyGFAReal_continuousOn_Icc_sub_34 ha hb
  have h_compact := isCompact_Icc.image_of_continuousOn h_cont
  have h_nonempty := (Set.nonempty_Icc.mpr hab).image aperyGFAReal
  apply Set.eq_of_subset_of_subset
  · rintro y ⟨z, hz, rfl⟩
    rw [← aperyGFAReal_sInf_image_Icc_sub_eq_left_34 ha hab hb,
        ← aperyGFAReal_sSup_image_Icc_sub_eq_right_34 ha hab hb]
    exact ⟨(Real.isGLB_sInf h_nonempty h_compact.bddBelow).1 ⟨z, hz, rfl⟩,
           (Real.isLUB_sSup h_nonempty h_compact.bddAbove).1 ⟨z, hz, rfl⟩⟩
  · obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ := h_compact.sInf_mem h_nonempty
    obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ := h_compact.sSup_mem h_nonempty
    rw [← aperyGFAReal_sInf_image_Icc_sub_eq_left_34 ha hab hb,
        ← aperyGFAReal_sSup_image_Icc_sub_eq_right_34 ha hab hb,
        ← hzmin_eq, ← hzmax_eq]
    exact h_cont.surjOn_Icc hzmin_mem hzmax_mem

/-- **Unconditional monotone bounds: `GFA(a) ≤ GFA(z) ≤ GFA(b)` for
`z ∈ [a, b] ⊆ [0, 1/34)`.** -/
lemma aperyGFAReal_mem_Icc_of_mem_Icc_34
    {a b : ℝ} (ha : 0 ≤ a) (hb : b < 1 / 34)
    {z : ℝ} (hz : z ∈ Set.Icc a b) :
    aperyGFAReal z ∈ Set.Icc (aperyGFAReal a) (aperyGFAReal b) := by
  constructor
  · rcases eq_or_lt_of_le hz.1 with rfl | hlt
    · exact le_refl _
    · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_34 ha hlt
        (lt_of_le_of_lt hz.2 hb))
  · rcases eq_or_lt_of_le hz.2 with rfl | hlt
    · exact le_refl _
    · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg_34
        (le_trans ha hz.1) hlt hb)

/-- **Injectivity on `[0, 1/34)`.** -/
lemma aperyGFAReal_injOn_nonneg_34 :
    Set.InjOn aperyGFAReal (Set.Ico (0 : ℝ) (1 / 34)) := by
  intro z₁ hz1 z₂ hz2 hf
  rcases lt_trichotomy z₁ z₂ with h | h | h
  · exact absurd hf (aperyGFAReal_strict_mono_on_nonneg_34 hz1.1 h hz2.2).ne
  · exact h
  · exact absurd hf.symm (aperyGFAReal_strict_mono_on_nonneg_34 hz2.1 h hz1.2).ne

/-- **Explicit upper bound on `[0, 1/64)`.** Each summand is dominated
by `(n+1) · (64z)^n`, so the tsum is dominated by the corresponding
summable series. -/
lemma aperyGFAReal_le_bound {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    aperyGFAReal z ≤ ∑' n : ℕ, ((n : ℝ) + 1) * (64 * z) ^ n := by
  have hz_abs : |z| < 1 / 64 := by rw [abs_of_nonneg hz]; exact hz64
  have hr_nn : (0 : ℝ) ≤ 64 * z := mul_nonneg (by norm_num) hz
  have hr_lt : (64 : ℝ) * z < 1 := by linarith
  have hr_norm : ‖(64 : ℝ) * z‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  have hsum_n : Summable (fun n : ℕ => (n : ℝ) * (64 * z) ^ n) := by
    have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
    simpa using h
  have hsum_geo : Summable (fun n : ℕ => ((64 : ℝ) * z) ^ n) :=
    summable_geometric_of_norm_lt_one hr_norm
  have hsum_bound :
      Summable (fun n : ℕ => ((n : ℝ) + 1) * (64 * z) ^ n) := by
    have h := hsum_n.add hsum_geo
    simpa [add_mul, one_mul] using h
  unfold aperyGFAReal
  refine (aperyGFAReal_summable hz_abs).tsum_le_tsum
    (fun n => ?_) hsum_bound
  have hAn : (Number.aperyA n : ℝ) ≤ ((n : ℝ) + 1) * 64 ^ n := by
    exact_mod_cast aperyA_le_pow n
  have hpow_nn : (0 : ℝ) ≤ z ^ n := pow_nonneg hz n
  calc (Number.aperyA n : ℝ) * z ^ n
      ≤ ((n : ℝ) + 1) * 64 ^ n * z ^ n :=
        mul_le_mul_of_nonneg_right hAn hpow_nn
    _ = ((n : ℝ) + 1) * (64 * z) ^ n := by ring

/-- **Non-vanishing on `[0, 1/64)`.** Immediate from strict positivity. -/
lemma aperyGFAReal_ne_zero_of_nonneg {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    aperyGFAReal z ≠ 0 :=
  (aperyGFAReal_pos_of_nonneg hz hz64).ne'

/-- **Monotonicity on the small disk.** Since every coefficient
`aperyA n ≥ 0`, the generating function is non-decreasing in `z` on
`[0, 1/64)`. -/
lemma aperyGFAReal_mono_on_nonneg
    {z₁ z₂ : ℝ} (h1 : 0 ≤ z₁) (h12 : z₁ ≤ z₂) (hz2 : z₂ < 1 / 64) :
    aperyGFAReal z₁ ≤ aperyGFAReal z₂ := by
  have hz1_abs : |z₁| < 1 / 64 := by
    rw [abs_of_nonneg h1]; linarith
  have hz2_abs : |z₂| < 1 / 64 := by
    rw [abs_of_nonneg (h1.trans h12)]; exact hz2
  unfold aperyGFAReal
  refine (aperyGFAReal_summable hz1_abs).tsum_le_tsum
    (fun n => ?_) (aperyGFAReal_summable hz2_abs)
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA n : ℝ) := by
    exact_mod_cast Nat.zero_le _
  have hpow_le : z₁ ^ n ≤ z₂ ^ n :=
    pow_le_pow_left₀ h1 h12 n
  exact mul_le_mul_of_nonneg_left hpow_le hAn_nn

/-- **Closed-form upper bound.** On `[0, 1/64)`, `aperyGFAReal z ≤
1/(1 − 64z)²`. Combines `aperyGFAReal_le_bound` with Mathlib's closed
form `∑' (n+1) x^n = 1/(1−x)²`. -/
lemma aperyGFAReal_le_inv_one_sub_64z_sq
    {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    aperyGFAReal z ≤ 1 / (1 - 64 * z) ^ 2 := by
  have hr_nn : (0 : ℝ) ≤ 64 * z := mul_nonneg (by norm_num) hz
  have hr_lt : (64 : ℝ) * z < 1 := by linarith
  have hr_norm : ‖(64 : ℝ) * z‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  have hclosed :
      ∑' n : ℕ, ((n + 1).choose 1 : ℝ) * (64 * z) ^ n =
        1 / (1 - 64 * z) ^ (1 + 1) :=
    tsum_choose_mul_geometric_of_norm_lt_one 1 hr_norm
  have hcoeff : ∀ n : ℕ,
      (((n + 1).choose 1 : ℕ) : ℝ) = ((n : ℝ) + 1) := by
    intro n; push_cast [Nat.choose_one_right]; ring
  have hsum_eq :
      ∑' n : ℕ, ((n : ℝ) + 1) * (64 * z) ^ n =
        1 / (1 - 64 * z) ^ 2 := by
    have := hclosed
    simp only [hcoeff] at this
    convert this using 2
  rw [← hsum_eq]
  exact aperyGFAReal_le_bound hz hz64

/-- **Partial sums lower-bound the full sum on `[0, 1/64)`.** Every truncation
`aperyGFAPartial N z` is ≤ `aperyGFAReal z` whenever `0 ≤ z < 1/64`, since
the tail consists of non-negative summands. -/
lemma aperyGFAPartial_le_aperyGFAReal {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) (N : ℕ) :
    aperyGFAPartial N z ≤ aperyGFAReal z := by
  have hz_abs : |z| < 1 / 64 := by rw [abs_of_nonneg hz]; exact hz64
  rw [aperyGFAReal_eq_partial_add_tail hz_abs N]
  have htail_nn : 0 ≤ ∑' n : ℕ, (Number.aperyA (n + N) : ℝ) * z ^ (n + N) := by
    refine tsum_nonneg (fun n => ?_)
    have hAn_nn : (0 : ℝ) ≤ (Number.aperyA (n + N) : ℝ) := by
      exact_mod_cast Nat.zero_le _
    exact mul_nonneg hAn_nn (pow_nonneg hz _)
  linarith

/-- **Lower bound `1 + 5z`.** Specialisation of
`aperyGFAPartial_le_aperyGFAReal` at `N = 2`, using the explicit values
`aperyA 0 = 1` and `aperyA 1 = 5`. Sharper than the trivial `aperyGFAReal z ≥ 1`. -/
lemma aperyGFAReal_ge_one_plus_5z {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    1 + 5 * z ≤ aperyGFAReal z := by
  have hpartial : aperyGFAPartial 2 z = 1 + 5 * z := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have hle := aperyGFAPartial_le_aperyGFAReal hz hz64 2
  linarith [hle, hpartial.symm.le]

/-- **Strict positivity gap from 1 at positive `z`.** Combines the `1+5z`
lower bound with `5z > 0` for `z > 0`. So `aperyGFAReal z > 1` strictly,
not just `≥ 1`, anywhere `z` is positive in the convergence disk. -/
lemma aperyGFAReal_gt_one_of_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    1 < aperyGFAReal z := by
  have hbase := aperyGFAReal_ge_one_plus_5z hz.le hz64
  have h5z_pos : 0 < 5 * z := by positivity
  linarith

/-- **Reciprocal less than one at positive `z`.** Since `aperyGFAReal z > 1`
on `(0, 1/64)`, its reciprocal lies in `(0, 1)`. Useful for bridging to
generating-function inverses. -/
lemma aperyGFAReal_inv_lt_one_of_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    (aperyGFAReal z)⁻¹ < 1 := by
  have h1 : 1 < aperyGFAReal z := aperyGFAReal_gt_one_of_pos hz hz64
  have hpos : 0 < aperyGFAReal z := lt_trans zero_lt_one h1
  rw [inv_lt_one_iff₀]
  exact Or.inr h1

/-- **Reciprocal positive at positive `z`.** -/
lemma aperyGFAReal_inv_pos_of_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    0 < (aperyGFAReal z)⁻¹ := by
  have hpos := aperyGFAReal_pos_of_nonneg hz.le hz64
  exact inv_pos.mpr hpos

/-- **Strict monotonicity on `[0, 1/64)`.** The Apéry generating function
strictly increases on the small disk: `0 ≤ z₁ < z₂ < 1/64 ⇒
aperyGFAReal z₁ < aperyGFAReal z₂`. Strategy: split the sum at `N = 2`,
linear part contributes `5·(z₂ − z₁) > 0`, tail is monotone. -/
lemma aperyGFAReal_strict_mono_on_nonneg
    {z₁ z₂ : ℝ} (h1 : 0 ≤ z₁) (h12 : z₁ < z₂) (hz2 : z₂ < 1 / 64) :
    aperyGFAReal z₁ < aperyGFAReal z₂ := by
  have hz1_abs : |z₁| < 1 / 64 := by
    rw [abs_of_nonneg h1]; linarith
  have hz2_abs : |z₂| < 1 / 64 := by
    rw [abs_of_nonneg (h1.trans h12.le)]; exact hz2
  have hpart1 : aperyGFAPartial 2 z₁ = 1 + 5 * z₁ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have hpart2 : aperyGFAPartial 2 z₂ = 1 + 5 * z₂ := by
    rw [show (2 : ℕ) = 1 + 1 from rfl, aperyGFAPartial_succ, aperyGFAPartial_one]
    simp [Number.aperyA_one]
  have heq1 := aperyGFAReal_eq_partial_add_tail hz1_abs 2
  have heq2 := aperyGFAReal_eq_partial_add_tail hz2_abs 2
  have htail_le :
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₁ ^ (n + 2) ≤
      ∑' n : ℕ, (Number.aperyA (n + 2) : ℝ) * z₂ ^ (n + 2) := by
    have hs1 := aperyGFAReal_tail_summable hz1_abs 2
    have hs2 := aperyGFAReal_tail_summable hz2_abs 2
    refine hs1.tsum_le_tsum (fun n => ?_) hs2
    have hAn_nn : (0 : ℝ) ≤ (Number.aperyA (n + 2) : ℝ) := by
      exact_mod_cast Nat.zero_le _
    have hpow_le : z₁ ^ (n + 2) ≤ z₂ ^ (n + 2) :=
      pow_le_pow_left₀ h1 h12.le (n + 2)
    exact mul_le_mul_of_nonneg_left hpow_le hAn_nn
  rw [heq1, heq2, hpart1, hpart2]
  linarith

/-- **Injectivity on `[0, 1/64)`.** Strict monotonicity gives injectivity. -/
lemma aperyGFAReal_injOn_nonneg :
    Set.InjOn aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 hf
  rcases lt_trichotomy z₁ z₂ with h | h | h
  · exact absurd hf
      (aperyGFAReal_strict_mono_on_nonneg hz1.1 h hz2.2).ne
  · exact h
  · exact absurd hf.symm
      (aperyGFAReal_strict_mono_on_nonneg hz2.1 h hz1.2).ne

/-- **Image lower bound.** Image of `[0, 1/64)` under `aperyGFAReal` lies
in `[1, ∞)`. -/
lemma aperyGFAReal_image_Ico_subset_Ici_one :
    aperyGFAReal '' Set.Ico (0 : ℝ) (1 / 64) ⊆ Set.Ici (1 : ℝ) := by
  rintro y ⟨z, ⟨hz, hz64⟩, rfl⟩
  exact aperyGFAReal_ge_one_of_nonneg hz hz64

/-- **Image upper bound.** Image of `[0, 1/64)` under `aperyGFAReal` is
bounded above by `1/(1 − 64z)²` evaluated at the right endpoint —
formally, every value lies below `1/(1 − 64·z)²` for the corresponding `z`. -/
lemma aperyGFAReal_le_inv_sq_of_mem {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal z ≤ 1 / (1 - 64 * z) ^ 2 :=
  aperyGFAReal_le_inv_one_sub_64z_sq hz.1 hz.2

/-- **Strict lower bound `1 + 5z + 73z²`.** Specialisation of
`aperyGFAPartial_le_aperyGFAReal` at `N = 3`, using `aperyA 2 = 73`. -/
lemma aperyGFAReal_ge_quadratic_partial {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    1 + 5 * z + 73 * z ^ 2 ≤ aperyGFAReal z := by
  have hpartial : aperyGFAPartial 3 z = 1 + 5 * z + 73 * z ^ 2 := by
    have h3 := aperyGFAPartial_succ 2 z
    have h2 := aperyGFAPartial_succ 1 z
    have h1 := aperyGFAPartial_one z
    change aperyGFAPartial (2 + 1) z = _
    rw [h3]
    change aperyGFAPartial (1 + 1) z + _ = _
    rw [h2, h1]
    simp [Number.aperyA_one, Number.aperyA_two]
  have hle := aperyGFAPartial_le_aperyGFAReal hz hz64 3
  linarith [hle, hpartial.symm.le]

/-- **Strict lower bound `1 + 5z + 73z² + 1445z³`.** Specialisation of
`aperyGFAPartial_le_aperyGFAReal` at `N = 4`, using `aperyA 3 = 1445`. -/
lemma aperyGFAReal_ge_cubic_partial {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 ≤ aperyGFAReal z := by
  have hpartial : aperyGFAPartial 4 z = 1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 := by
    have h4 := aperyGFAPartial_succ 3 z
    have h3 := aperyGFAPartial_succ 2 z
    have h2 := aperyGFAPartial_succ 1 z
    have h1 := aperyGFAPartial_one z
    change aperyGFAPartial (3 + 1) z = _
    rw [h4]
    change aperyGFAPartial (2 + 1) z + _ = _
    rw [h3]
    change aperyGFAPartial (1 + 1) z + _ + _ = _
    rw [h2, h1]
    simp [Number.aperyA_one, Number.aperyA_two, Number.aperyA_three]
  have hle := aperyGFAPartial_le_aperyGFAReal hz hz64 4
  linarith [hle, hpartial.symm.le]

/-- **Divided difference at zero.** `(aperyGFAReal z − 1) / z = ∑' n, a_{n+1} z^n`
for nonzero `z` in the convergence disk. -/
lemma aperyGFAReal_div_form {z : ℝ} (hz : |z| < 1 / 64) (hz0 : z ≠ 0) :
    (aperyGFAReal z - 1) / z =
      ∑' n : ℕ, (Number.aperyA (n + 1) : ℝ) * z ^ n := by
  rw [aperyGFAReal_sub_one_eq_z_mul_tail hz]
  field_simp

/-- **Monotone-on packaging.** `aperyGFAReal` is `MonotoneOn` on
`[0, 1/64)`, the standard Mathlib API form of `aperyGFAReal_mono_on_nonneg`. -/
lemma aperyGFAReal_monotoneOn_Ico :
    MonotoneOn aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 h12
  exact aperyGFAReal_mono_on_nonneg hz1.1 h12 hz2.2

/-- **StrictMonoOn packaging.** `aperyGFAReal` is `StrictMonoOn` on
`[0, 1/64)`. -/
lemma aperyGFAReal_strictMonoOn_Ico :
    StrictMonoOn aperyGFAReal (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 h12
  exact aperyGFAReal_strict_mono_on_nonneg hz1.1 h12 hz2.2

/-- **Strict quadratic-partial lower bound.** For `0 < z < 1/64`, the
quadratic partial sum is *strictly* below `aperyGFAReal z` since
`aperyA 3 = 1445 > 0` contributes a positive `z^3` term in the next partial.
Direct corollary of `aperyGFAReal_ge_cubic_partial`. -/
lemma aperyGFAReal_gt_quadratic_partial_of_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    1 + 5 * z + 73 * z ^ 2 < aperyGFAReal z := by
  have hcube := aperyGFAReal_ge_cubic_partial hz.le hz64
  have hz3 : 0 < z ^ 3 := by positivity
  nlinarith [hcube, hz3]

/-- **Strict cubic-partial lower bound.** For `0 < z < 1/64`, the cubic
partial sum is *strictly* below `aperyGFAReal z`, since `aperyA 4 = 33001 > 0`
contributes a positive `z^4` term in the next partial. Effectively this
combines `aperyGFAReal_ge_cubic_partial` with the fact that `a₄ > 0`. -/
lemma aperyGFAReal_gt_cubic_partial_of_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 < aperyGFAReal z := by
  have hquint : 1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 + 33001 * z ^ 4 ≤ aperyGFAReal z := by
    have hpartial : aperyGFAPartial 5 z =
        1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 + 33001 * z ^ 4 := by
      have h5 := aperyGFAPartial_succ 4 z
      have h4 := aperyGFAPartial_succ 3 z
      have h3 := aperyGFAPartial_succ 2 z
      have h2 := aperyGFAPartial_succ 1 z
      have h1 := aperyGFAPartial_one z
      change aperyGFAPartial (4 + 1) z = _
      rw [h5]
      change aperyGFAPartial (3 + 1) z + _ = _
      rw [h4]
      change aperyGFAPartial (2 + 1) z + _ + _ = _
      rw [h3]
      change aperyGFAPartial (1 + 1) z + _ + _ + _ = _
      rw [h2, h1]
      simp [Number.aperyA_one, Number.aperyA_two, Number.aperyA_three,
            Number.aperyA_four]
    have hle := aperyGFAPartial_le_aperyGFAReal hz.le hz64 5
    linarith [hle, hpartial.symm.le]
  have hz4 : 0 < z ^ 4 := by positivity
  nlinarith [hquint, hz4]

/-- **Divided-difference lower bound.** For `0 < z < 1/64`,
`5 ≤ (aperyGFAReal z − 1) / z`. Direct from the affine lower bound
`1 + 5z ≤ aperyGFAReal z` and division by `z > 0`. -/
lemma aperyGFAReal_div_diff_ge_five {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    5 ≤ (aperyGFAReal z - 1) / z := by
  have h := aperyGFAReal_ge_one_plus_5z hz.le hz64
  exact (le_div_iff₀ hz).mpr (by linarith)

/-- **Divided-difference strict lower bound.** For `0 < z < 1/64`,
`5 + 73 * z < (aperyGFAReal z − 1) / z`. Direct from
`aperyGFAReal_gt_quadratic_partial_of_pos`. -/
lemma aperyGFAReal_div_diff_gt_linear {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) :
    5 + 73 * z < (aperyGFAReal z - 1) / z := by
  have h := aperyGFAReal_gt_quadratic_partial_of_pos hz hz64
  have hineq : (5 + 73 * z) * z < aperyGFAReal z - 1 := by nlinarith [h]
  exact (lt_div_iff₀ hz).mpr hineq

/-- **Constant upper bound on a smaller disk.** For `z ∈ [0, 1/256]`,
`aperyGFAReal z ≤ 2`. Combines `aperyGFAReal_le_inv_one_sub_64z_sq` with
`(1 - 64z)² ≥ (3/4)² = 9/16` on this restricted disk, giving
`1/(1−64z)² ≤ 16/9 ≤ 2`. -/
lemma aperyGFAReal_le_two_of_small {z : ℝ} (hz : 0 ≤ z) (hz256 : z ≤ 1 / 256) :
    aperyGFAReal z ≤ 2 := by
  have hz64 : z < 1 / 64 := by linarith
  have hbound := aperyGFAReal_le_inv_one_sub_64z_sq hz hz64
  have h64z : 64 * z ≤ 1 / 4 := by linarith
  have hone_minus : 3 / 4 ≤ 1 - 64 * z := by linarith
  have hpos : (0 : ℝ) < 1 - 64 * z := by linarith
  have hsq : (3 / 4 : ℝ) ^ 2 ≤ (1 - 64 * z) ^ 2 :=
    pow_le_pow_left₀ (by norm_num) hone_minus 2
  have hsq_pos : (0 : ℝ) < (1 - 64 * z) ^ 2 := by positivity
  have hinv : 1 / (1 - 64 * z) ^ 2 ≤ 1 / (3 / 4 : ℝ) ^ 2 :=
    one_div_le_one_div_of_le (by norm_num) hsq
  have hnum : (1 : ℝ) / (3 / 4) ^ 2 = 16 / 9 := by norm_num
  have hle_two : (16 / 9 : ℝ) ≤ 2 := by norm_num
  linarith [hbound, hinv, hnum, hle_two]

/-- **Strict tail positivity.** For `0 < z < 1/64` and any partial-sum
truncation level `N`, the tail `aperyGFAReal z − aperyGFAPartial N z` is
strictly positive. Strategy: bound the tail below by the single term
`aperyA N · z^N ≥ z^N > 0`. -/
lemma aperyGFAReal_sub_partial_pos {z : ℝ} (hz : 0 < z) (hz64 : z < 1 / 64) (N : ℕ) :
    0 < aperyGFAReal z - aperyGFAPartial N z := by
  have hz_abs : |z| < 1 / 64 := by rw [abs_of_nonneg hz.le]; exact hz64
  have hpartial1 := aperyGFAPartial_le_aperyGFAReal hz.le hz64 (N + 1)
  have hsucc : aperyGFAPartial (N + 1) z =
      aperyGFAPartial N z + (Number.aperyA N : ℝ) * z ^ N :=
    aperyGFAPartial_succ N z
  have hAN_pos : (0 : ℝ) < (Number.aperyA N : ℝ) := by
    exact_mod_cast Number.aperyA_pos N
  have hzN_pos : (0 : ℝ) < z ^ N := pow_pos hz N
  have hterm_pos : 0 < (Number.aperyA N : ℝ) * z ^ N := mul_pos hAN_pos hzN_pos
  linarith [hpartial1, hsucc.le, hsucc.symm.le]

/-- **Quartic-partial lower bound `1 + 5z + 73z² + 1445z³ + 33001z⁴`.**
Specialisation of `aperyGFAPartial_le_aperyGFAReal` at `N = 5`, using
`aperyA 4 = 33001`. Matches the partial used inside the strict cubic
proof but exposed as a standalone atom for downstream use. -/
lemma aperyGFAReal_ge_quartic_partial {z : ℝ} (hz : 0 ≤ z) (hz64 : z < 1 / 64) :
    1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 + 33001 * z ^ 4 ≤ aperyGFAReal z := by
  have hpartial : aperyGFAPartial 5 z =
      1 + 5 * z + 73 * z ^ 2 + 1445 * z ^ 3 + 33001 * z ^ 4 := by
    have h5 := aperyGFAPartial_succ 4 z
    have h4 := aperyGFAPartial_succ 3 z
    have h3 := aperyGFAPartial_succ 2 z
    have h2 := aperyGFAPartial_succ 1 z
    have h1 := aperyGFAPartial_one z
    change aperyGFAPartial (4 + 1) z = _
    rw [h5]
    change aperyGFAPartial (3 + 1) z + _ = _
    rw [h4]
    change aperyGFAPartial (2 + 1) z + _ + _ = _
    rw [h3]
    change aperyGFAPartial (1 + 1) z + _ + _ + _ = _
    rw [h2, h1]
    simp [Number.aperyA_one, Number.aperyA_two, Number.aperyA_three,
          Number.aperyA_four]
  have hle := aperyGFAPartial_le_aperyGFAReal hz hz64 5
  linarith [hle, hpartial.symm.le]

/-- **Strict anti-monotonicity of the reciprocal.** On `[0, 1/64)`,
`z ↦ 1 / aperyGFAReal z` is strictly decreasing, since `aperyGFAReal`
is strictly increasing and positive. -/
lemma aperyGFAReal_inv_strict_anti_on_Ico
    {z₁ z₂ : ℝ} (h1 : 0 ≤ z₁) (h12 : z₁ < z₂) (hz2 : z₂ < 1 / 64) :
    1 / aperyGFAReal z₂ < 1 / aperyGFAReal z₁ := by
  have hpos1 : 0 < aperyGFAReal z₁ :=
    aperyGFAReal_pos_of_nonneg h1 (lt_trans h12 hz2)
  have hmono := aperyGFAReal_strict_mono_on_nonneg h1 h12 hz2
  exact one_div_lt_one_div_of_lt hpos1 hmono

/-- **Disk-extension hypothesis (Gap F).** The crude bound
`aₙ ≤ (n+1)·64ⁿ` only secures convergence on `|z| < 1/64`, but the sharp
asymptotic `aₙ ~ z₁⁻ⁿ / n^{3/2}` (Birch's lemma / G-function asymptotics)
gives the true radius `z₁`. Encoded as a hypothesis here so downstream
lemmas can be stated unconditionally on the bridge while leaving the
asymptotic estimate as the open analytic ingredient. -/
def AperyGFASummableOnFullDisk : Prop :=
  ∀ z : ℝ, |z| < Number.aperyConifoldZ1Poly →
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n)

/-- **`AperyGFASummableOnFullDisk` is unconditionally true.** Gap F closure
gives summability on `|z| < z₁` for free. -/
lemma aperyGFASummableOnFullDisk_unconditional : AperyGFASummableOnFullDisk :=
  fun z hz => aperyGFAReal_summable_z1 hz

/-- **Bridge consumer.** From the disk-extension hypothesis, summability
on the full disk follows pointwise. -/
lemma aperyGFAReal_summable_of_bridge
    (h : AperyGFASummableOnFullDisk) {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) := h z hz

/-- **Crude bridge fragment.** Already established: summability holds
unconditionally on `|z| < 1/64`. Provides the consistency check that
the bridge hypothesis is *consistent*: any extension of the trivial disk
to the full disk only adds new instances. -/
lemma aperyGFAReal_summable_bridge_consistent {z : ℝ} (hz : |z| < 1 / 64) :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) * z ^ n) :=
  aperyGFAReal_summable hz

/-- **Apéry analytic extension to the full disk.** A function `F` that
agrees with `aperyGFAReal` on the small disk `|z| < 1/64` and remains
analytic on the open disk `|z| < z₁`. Bundles the analytic-side bridge
to the conifold corridor: `F` has well-defined values on `[0, z₁)` even
though the raw `aperyGFAReal` definition only converges on `|z| < 1/64`.

This is the abstract interface; constructing a concrete `F` requires
the disk-extension hypothesis (Gap F). -/
structure AperyAnalyticExtension where
  /-- The extended function. -/
  F : ℝ → ℝ
  /-- Agreement with `aperyGFAReal` on the small unconditional disk. -/
  agrees_on_small : Set.EqOn F aperyGFAReal
    (Set.Ico (0 : ℝ) (1 / 64))
  /-- Continuity on the half-open corridor `[0, z₁)`. -/
  continuousOn_corridor : ContinuousOn F
    (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly)

/-- **Existence of an Apéry analytic extension.** Predicate form:
some `AperyAnalyticExtension` exists. Encoded as a `Prop` so downstream
code can use `obtain ⟨ext, _, _⟩ := h` after assuming this hypothesis. -/
def HasAperyAnalyticExtension : Prop := Nonempty AperyAnalyticExtension

/-- **Apéry connection data at the conifold.** Bundles an analytic
extension with a `HasAperyConnectionCoeffsOn` witness on a non-trivial
corridor of shifts `I` near zero (i.e. real points near `z₁`). The
corridor must contain the origin `0` (the right endpoint itself, where
`F z₁` is the regular seed). -/
structure AperyConnectionData extends AperyAnalyticExtension where
  /-- Corridor of shifts `t ∈ I` such that `F (z₁ + t)` matches the
  Frobenius branch superposition. -/
  corridor : Set ℝ
  /-- Origin in corridor (so the regular seed `F z₁` is captured). -/
  zero_mem : (0 : ℝ) ∈ corridor
  /-- The Has-level connection-coefficient property on the corridor. -/
  has_conn : HasAperyConnectionCoeffsOn F corridor

/-- **Existence of Apéry connection data.** Bundle existence as a Prop. -/
def HasAperyConnectionData : Prop := Nonempty AperyConnectionData

/-- **Has-level connection extraction from connection data.** Direct
unpacking: a `AperyConnectionData` provides a representable function on
a corridor — exactly the input shape expected by the extract interface. -/
lemma AperyConnectionData.hasConnectionCoeffs (d : AperyConnectionData) :
    HasAperyConnectionCoeffsOn d.F d.corridor := d.has_conn

/-- **Regular extract value of an `AperyConnectionData`.** The
`a₀`-coefficient: the function value at the right endpoint `z₁`. -/
noncomputable def AperyConnectionData.extractRegular
    (d : AperyConnectionData) : ℝ :=
  aperyExtractRegular d.F

/-- **Half-branch extract value of an `AperyConnectionData`.** The
`a_½`-coefficient via two probes. Independent of probe choice (under
non-degenerate Δ) by `extractHalf_probe_invariant`. -/
noncomputable def AperyConnectionData.extractHalf
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) : ℝ :=
  aperyExtractHalf d.F ε₁ ε₂

/-- **One-branch extract value of an `AperyConnectionData`.** The
`a₁`-coefficient via two probes. Independent of probe choice (under
non-degenerate Δ) by `extractOne_probe_invariant`. -/
noncomputable def AperyConnectionData.extractOne
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) : ℝ :=
  aperyExtractOne d.F ε₁ ε₂

/-- **Probe invariance lifted to connection data.** Half-branch extract
on connection data is independent of probe choice. -/
lemma AperyConnectionData.extractHalf_probe_invariant
    (d : AperyConnectionData) {ε₁ ε₂ ε₁' ε₂' : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₁' : (-ε₁') ∈ d.corridor) (hε₂' : (-ε₂') ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdet' : aperyConnectionDet ε₁' ε₂' ≠ 0) :
    d.extractHalf ε₁ ε₂ = d.extractHalf ε₁' ε₂' :=
  d.has_conn.extractHalf_probe_invariant d.zero_mem
    hε₁ hε₂ hε₁' hε₂' hdet hdet'

/-- **Probe invariance lifted to connection data.** One-branch extract
on connection data is independent of probe choice. -/
lemma AperyConnectionData.extractOne_probe_invariant
    (d : AperyConnectionData) {ε₁ ε₂ ε₁' ε₂' : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₁' : (-ε₁') ∈ d.corridor) (hε₂' : (-ε₂') ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdet' : aperyConnectionDet ε₁' ε₂' ≠ 0) :
    d.extractOne ε₁ ε₂ = d.extractOne ε₁' ε₂' :=
  d.has_conn.extractOne_probe_invariant d.zero_mem
    hε₁ hε₂ hε₁' hε₂' hdet hdet'

/-- **Reconstruction theorem.** Under non-degenerate Δ, the function
`F` from connection data is reconstructed pointwise on the corridor by
the `aperyBranchTriple` superposition built from the three extract
seeds. The intrinsic statement:
`F (z₁ + t) = a₀·yAperyZero(t) + a_½·yAperyHalf(t) + a₁·yApery(t)`. -/
lemma AperyConnectionData.shifted_eq_extract
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
      (fun t => aperyBranchTriple (d.extractRegular)
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) t) d.corridor :=
  d.has_conn.shifted_eq_extract d.zero_mem hε₁ hε₂ hdet

/-- **Regular extract value via direct evaluation.** `d.extractRegular`
is just `d.F z₁`, the right-endpoint value. -/
lemma AperyConnectionData.extractRegular_eq (d : AperyConnectionData) :
    d.extractRegular = d.F Number.aperyConifoldZ1Poly := rfl

/-- **Connection data agreement on small disk.** For `z` in
`[0, 1/64) ∩ corridor-shift` (equivalently `z ∈ Set.Ico 0 (1/64)` and
`z − z₁ ∈ corridor` if the corridor is large enough), `d.F z = aperyGFAReal z`. -/
lemma AperyConnectionData.F_eq_GFA_on_small {d : AperyConnectionData}
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.F z = aperyGFAReal z :=
  d.agrees_on_small hz

/-- **Two connection data agree on small disk.** Any two
`AperyConnectionData` instances agree on the small disk where both
restrict to `aperyGFAReal`. (Outside the small disk they may diverge if
the analytic continuation is not unique a priori — uniqueness on the
full disk requires identity-of-analytic-functions, separate ingredient.) -/
lemma AperyConnectionData.F_unique_on_small
    (d₁ d₂ : AperyConnectionData) :
    Set.EqOn d₁.F d₂.F (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z hz
  rw [d₁.F_eq_GFA_on_small hz, d₂.F_eq_GFA_on_small hz]

/-- **Shift-version: corridor point sitting inside small disk.** If a
corridor shift `t` makes `z₁ + t` land in the unconditional disk
`[0, 1/64)`, then `F (z₁ + t) = aperyGFAReal (z₁ + t)`. The natural
shift bridge for points where the GFA series and the analytic extension
both compute the same value. -/
lemma AperyConnectionData.F_shift_eq_GFA {d : AperyConnectionData}
    {t : ℝ} (hz : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      aperyGFAReal (Number.aperyConifoldZ1Poly + t) :=
  d.F_eq_GFA_on_small hz

/-- **Candidate-triple verification.** Given a `AperyConnectionData d`
and a candidate triple `(a₀, a_½, a₁)`, if the candidate matches `F` on
the corridor (pointwise), then under non-degenerate Δ the extract triple
agrees with the candidate. This is the *positive verification path*:
guess a triple, check it on corridor, then know it's *the* extract. -/
lemma AperyConnectionData.candidate_eq_extract
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hcand : Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) d.corridor)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular ∧
    a_half = d.extractHalf ε₁ ε₂ ∧
    a₁ = d.extractOne ε₁ ε₂ := by
  have ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor :=
    IsAperyConnectionCoeffsOn.of_shifted_eqOn _ _ _ _ _ hcand
  exact ha.eq_extract d.zero_mem hε₁ hε₂ hdet

/-- **Candidate uniqueness.** Any two candidate triples both matching
`F` on the corridor coincide componentwise (under non-degenerate Δ). -/
lemma AperyConnectionData.candidate_unique
    (d : AperyConnectionData) {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (ha : Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) d.corridor)
    (hb : Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple b₀ b_half b₁ t) d.corridor)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = b₀ ∧ a_half = b_half ∧ a₁ = b₁ := by
  obtain ⟨ha0, hah, ha1⟩ := d.candidate_eq_extract ha hε₁ hε₂ hdet
  obtain ⟨hb0, hbh, hb1⟩ := d.candidate_eq_extract hb hε₁ hε₂ hdet
  exact ⟨ha0.trans hb0.symm, hah.trans hbh.symm, ha1.trans hb1.symm⟩

/-- **GFA equals branch superposition on overlap.** The grand combined
identity: on shifts `t` lying in `corridor` AND such that `z₁ + t` is
in the unconditional small disk, the raw Apéry generating function
`aperyGFAReal (z₁ + t)` equals the Frobenius `aperyBranchTriple`
superposition built from extract seeds. This is the main *empirical*
constraint that the extract triple can be tested against — for any
overlap shift `t`, both sides are computable real numbers and their
equality is checkable. -/
lemma AperyConnectionData.GFA_eq_branchTriple_on_overlap
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (htC : t ∈ d.corridor)
    (hz : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple (d.extractRegular)
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) t := by
  rw [← d.F_shift_eq_GFA hz]
  exact d.shifted_eq_extract hε₁ hε₂ hdet htC

/-- **Overlap shifts.** The set of corridor shifts `t` such that
`z₁ + t` lies in the unconditional small disk `[0, 1/64)`. On this
set, both `aperyGFAReal` and `d.F` evaluate, and they must agree. -/
def AperyConnectionData.overlapShifts (d : AperyConnectionData) : Set ℝ :=
  d.corridor ∩ {t : ℝ | Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)}

/-- **`overlapShifts` membership unfold.** -/
lemma AperyConnectionData.mem_overlapShifts {d : AperyConnectionData}
    {t : ℝ} :
    t ∈ d.overlapShifts ↔
      t ∈ d.corridor ∧
        Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64) :=
  Iff.rfl

/-- **GFA = branch superposition on overlap shifts (set form).** Pure
`Set.EqOn` packaging: the two functions agree on the entire overlap
set. -/
lemma AperyConnectionData.GFA_eqOn_overlapShifts
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    Set.EqOn (fun t => aperyGFAReal (Number.aperyConifoldZ1Poly + t))
      (fun t => aperyBranchTriple (d.extractRegular)
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) t)
      d.overlapShifts := by
  intro t ht
  obtain ⟨htC, htDisk⟩ := ht
  exact d.GFA_eq_branchTriple_on_overlap hε₁ hε₂ hdet htC htDisk

/-- **Restrict an `AperyConnectionData` to a sub-corridor.** Given a
subset `J ⊆ d.corridor` containing `0`, get a new `AperyConnectionData`
with corridor `J`. The analytic extension stays the same. Useful when
downstream code needs to work on a smaller set (e.g. `overlapShifts` or
a probe-pair-tailored sub-interval). -/
def AperyConnectionData.restrictCorridor (d : AperyConnectionData)
    {J : Set ℝ} (hJ : J ⊆ d.corridor) (h0 : (0 : ℝ) ∈ J) :
    AperyConnectionData where
  toAperyAnalyticExtension := d.toAperyAnalyticExtension
  corridor := J
  zero_mem := h0
  has_conn := d.has_conn.mono hJ

/-- **`restrictCorridor` preserves the underlying analytic extension.** -/
@[simp] lemma AperyConnectionData.restrictCorridor_F
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) :
    (d.restrictCorridor hJ h0).F = d.F := rfl

/-- **`restrictCorridor` corridor projection.** -/
@[simp] lemma AperyConnectionData.restrictCorridor_corridor
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) :
    (d.restrictCorridor hJ h0).corridor = J := rfl

/-- **`restrictCorridor` preserves `extractRegular`.** Both equal `F z₁`
by definition. -/
@[simp] lemma AperyConnectionData.restrictCorridor_extractRegular
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) :
    (d.restrictCorridor hJ h0).extractRegular = d.extractRegular := rfl

/-- **`restrictCorridor` preserves `extractHalf`.** Same `F`, same
formula. -/
@[simp] lemma AperyConnectionData.restrictCorridor_extractHalf
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) (ε₁ ε₂ : ℝ) :
    (d.restrictCorridor hJ h0).extractHalf ε₁ ε₂ =
      d.extractHalf ε₁ ε₂ := rfl

/-- **`restrictCorridor` preserves `extractOne`.** Same `F`, same formula. -/
@[simp] lemma AperyConnectionData.restrictCorridor_extractOne
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) (ε₁ ε₂ : ℝ) :
    (d.restrictCorridor hJ h0).extractOne ε₁ ε₂ =
      d.extractOne ε₁ ε₂ := rfl

/-- **`overlapShifts` is contained in the corridor.** -/
lemma AperyConnectionData.overlapShifts_subset_corridor
    (d : AperyConnectionData) :
    d.overlapShifts ⊆ d.corridor := fun _ ht => ht.1

/-- **GFA inherits the connection-coefficient property on overlap
shifts (Is-form).** Since on `overlapShifts` we have
`aperyGFAReal (z₁ + t) = aperyBranchTriple (extract triple) t`, the
extract triple represents `aperyGFAReal` in the
`IsAperyConnectionCoeffsOn` sense. Note: `0 ∈ overlapShifts` is *not*
required (and in fact fails since `z₁ > 1/64`); the
`IsAperyConnectionCoeffsOn` predicate is purely pointwise. -/
lemma AperyConnectionData.GFA_isAperyConnectionCoeffsOn_overlapShifts
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn (d.extractRegular)
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂)
        aperyGFAReal d.overlapShifts := by
  intro t ht
  exact d.GFA_eqOn_overlapShifts hε₁ hε₂ hdet ht

/-- **GFA inherits the Has-level connection-coefficient property on
overlap shifts.** Existential wrapper of the Is-form. -/
lemma AperyConnectionData.GFA_hasAperyConnectionCoeffsOn_overlapShifts
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    HasAperyConnectionCoeffsOn aperyGFAReal d.overlapShifts :=
  ⟨_, _, _, d.GFA_isAperyConnectionCoeffsOn_overlapShifts hε₁ hε₂ hdet⟩

/-- **`F` at `z₁` matches the regular extract.** Direct from
`extractRegular_eq` (definitional). Stated for downstream use as a
`simp`-friendly identity. -/
@[simp] lemma AperyConnectionData.F_at_z1
    (d : AperyConnectionData) :
    d.F Number.aperyConifoldZ1Poly = d.extractRegular := rfl

/-- **`F` at `z₁` matches the branchTriple at `t = 0`.** A specialised
form of `shifted_eq_extract` at `t = 0` (which lies in the corridor by
`zero_mem`). Combines `extractRegular_eq` and `aperyBranchTriple_at_zero`. -/
lemma AperyConnectionData.F_at_z1_eq_branchTriple_at_zero
    (d : AperyConnectionData) (a_half a₁ : ℝ) :
    d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple d.extractRegular a_half a₁ 0 := by
  rw [aperyBranchTriple_at_zero]
  rfl

/-- **Constructor: build `AperyConnectionData` from an analytic extension
and a Has-witness on a corridor.** A useful "ctor": instead of
unpacking the structure directly, supply the four pieces in a single
call. -/
def AperyConnectionData.of_witness
    (ext : AperyAnalyticExtension)
    (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) :
    AperyConnectionData where
  toAperyAnalyticExtension := ext
  corridor := I
  zero_mem := h0
  has_conn := h

/-- **`of_witness` projection: F.** -/
@[simp] lemma AperyConnectionData.of_witness_F
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) :
    (AperyConnectionData.of_witness ext I h0 h).F = ext.F := rfl

/-- **`of_witness` projection: corridor.** -/
@[simp] lemma AperyConnectionData.of_witness_corridor
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) :
    (AperyConnectionData.of_witness ext I h0 h).corridor = I := rfl

/-- **`of_witness` projection: extractRegular.** -/
@[simp] lemma AperyConnectionData.of_witness_extractRegular
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) :
    (AperyConnectionData.of_witness ext I h0 h).extractRegular =
      ext.F Number.aperyConifoldZ1Poly := rfl

/-- **`of_witness` projection: extractHalf.** -/
@[simp] lemma AperyConnectionData.of_witness_extractHalf
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) (ε₁ ε₂ : ℝ) :
    (AperyConnectionData.of_witness ext I h0 h).extractHalf ε₁ ε₂ =
      aperyExtractHalf ext.F ε₁ ε₂ := rfl

/-- **`of_witness` projection: extractOne.** -/
@[simp] lemma AperyConnectionData.of_witness_extractOne
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) (ε₁ ε₂ : ℝ) :
    (AperyConnectionData.of_witness ext I h0 h).extractOne ε₁ ε₂ =
      aperyExtractOne ext.F ε₁ ε₂ := rfl

/-- **GFA-side ↔ F-side candidate matching on overlap shifts.** Since
`d.F (z₁ + t) = aperyGFAReal (z₁ + t)` whenever `z₁ + t ∈ [0, 1/64)`
(and `t ∈ overlapShifts` ensures both `t ∈ corridor` and the disk
condition), a candidate triple matches `aperyGFAReal` on `overlapShifts`
iff it matches `d.F` on the same set. Useful for converting numeric
GFA-side data into corridor-side data. -/
lemma AperyConnectionData.candidate_GFA_iff_F_on_overlapShifts
    (d : AperyConnectionData) (a₀ a_half a₁ : ℝ) :
    Set.EqOn (fun t => aperyGFAReal (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) d.overlapShifts ↔
      Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) d.overlapShifts := by
  constructor
  · intro h t ht
    have hFGFA : d.F (Number.aperyConifoldZ1Poly + t) =
        aperyGFAReal (Number.aperyConifoldZ1Poly + t) :=
      d.F_shift_eq_GFA ht.2
    have hGFAt := h ht
    change d.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple a₀ a_half a₁ t
    rw [hFGFA]
    exact hGFAt
  · intro h t ht
    have hFGFA : d.F (Number.aperyConifoldZ1Poly + t) =
        aperyGFAReal (Number.aperyConifoldZ1Poly + t) :=
      d.F_shift_eq_GFA ht.2
    have hFt := h ht
    change aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple a₀ a_half a₁ t
    rw [← hFGFA]
    exact hFt

/-- **F-side equality on overlap shifts from extract triple.** Direct
restriction of `shifted_eq_extract` (corridor) to `overlapShifts`
(subset of corridor). -/
lemma AperyConnectionData.F_eqOn_extractTriple_on_overlapShifts
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple (d.extractRegular)
          (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) t) d.overlapShifts :=
  (d.shifted_eq_extract hε₁ hε₂ hdet).mono d.overlapShifts_subset_corridor

/-- **`overlapShifts` membership in shift-bound form.** Equivalent
characterisation: `t ∈ overlapShifts ↔ t ∈ corridor ∧ -z₁ ≤ t ∧
t < 1/64 - z₁`. Useful for downstream reasoning where the shift is
bounded explicitly rather than via the disk-membership predicate. -/
lemma AperyConnectionData.mem_overlapShifts_iff_bounds
    {d : AperyConnectionData} {t : ℝ} :
    t ∈ d.overlapShifts ↔
      t ∈ d.corridor ∧
        -Number.aperyConifoldZ1Poly ≤ t ∧
        t < 1 / 64 - Number.aperyConifoldZ1Poly := by
  rw [AperyConnectionData.mem_overlapShifts, Set.mem_Ico]
  constructor
  · rintro ⟨hC, h1, h2⟩
    refine ⟨hC, ?_, ?_⟩ <;> linarith
  · rintro ⟨hC, h1, h2⟩
    refine ⟨hC, ?_, ?_⟩ <;> linarith

/-- **Upper shift bound on `overlapShifts`.** Direct corollary; useful
when downstream code needs to know that all overlap shifts are
strictly negative (because `1/64 - z₁ < 0`, since `z₁ ≈ 0.029 > 1/64`). -/
lemma AperyConnectionData.overlapShifts_subset_neg_shifts
    (d : AperyConnectionData) :
    d.overlapShifts ⊆ {t : ℝ | t < 1 / 64 - Number.aperyConifoldZ1Poly} :=
  fun _ ht => (AperyConnectionData.mem_overlapShifts_iff_bounds.mp ht).2.2

/-- **`overlapShifts` is a half-open interval when the corridor contains
the full bound interval.** When `[-z₁, 1/64 - z₁) ⊆ corridor`,
`overlapShifts = [-z₁, 1/64 - z₁)`. Useful for downstream code that
wants to integrate or sum over the overlap region as an explicit
interval. -/
lemma AperyConnectionData.overlapShifts_eq_Ico
    (d : AperyConnectionData)
    (hI : Set.Ico (-Number.aperyConifoldZ1Poly)
        (1 / 64 - Number.aperyConifoldZ1Poly) ⊆ d.corridor) :
    d.overlapShifts =
      Set.Ico (-Number.aperyConifoldZ1Poly)
        (1 / 64 - Number.aperyConifoldZ1Poly) := by
  apply Set.eq_of_subset_of_subset
  · intro t ht
    rw [AperyConnectionData.mem_overlapShifts_iff_bounds] at ht
    exact Set.mem_Ico.mpr ⟨ht.2.1, ht.2.2⟩
  · intro t ht
    rw [Set.mem_Ico] at ht
    rw [AperyConnectionData.mem_overlapShifts_iff_bounds]
    exact ⟨hI (Set.mem_Ico.mpr ht), ht.1, ht.2⟩

/-- **`overlapShifts` is empty if `1/64 - z₁ ≤ -z₁`.** Currently
`1/64 - z₁ < -z₁` is FALSE numerically (`1/64 ≈ 0.0156`, so
`1/64 - z₁ ≈ -0.014` and `-z₁ ≈ -0.029`; we have `-0.029 < -0.014`),
so the bound interval is non-empty. This lemma is the abstract version:
if the bound interval `[-z₁, 1/64 - z₁)` is empty, so is `overlapShifts`. -/
lemma AperyConnectionData.overlapShifts_eq_empty_of_bound_empty
    (d : AperyConnectionData)
    (h : 1 / 64 - Number.aperyConifoldZ1Poly ≤ -Number.aperyConifoldZ1Poly) :
    d.overlapShifts = ∅ := by
  ext t
  refine ⟨?_, ?_⟩
  · intro ht
    rw [AperyConnectionData.mem_overlapShifts_iff_bounds] at ht
    linarith [ht.2.1, ht.2.2]
  · intro ht
    exact ht.elim

/-- **Three-point candidate verification.** A more granular alternative
to `candidate_eq_extract`: instead of requiring corridor-wide matching,
just three pointwise equalities (at `t = 0, -ε₁, -ε₂`) suffice. The
extract algebra reduces to Cramer at three points; this lemma surfaces
that fact. -/
lemma AperyConnectionData.candidate_eq_extract_of_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hF₁ : d.F (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hF₂ : d.F (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular ∧
    a_half = d.extractHalf ε₁ ε₂ ∧
    a₁ = d.extractOne ε₁ ε₂ := by
  have hcand : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F
      ({0, -ε₁, -ε₂} : Set ℝ) := by
    intro t ht
    rcases ht with ht | ht | ht
    · subst ht
      rw [add_zero]
      exact hF₀
    · subst ht
      exact hF₁
    · rcases ht with ht
      subst ht
      exact hF₂
  have h0 : (0 : ℝ) ∈ ({0, -ε₁, -ε₂} : Set ℝ) := by left; rfl
  have hε₁mem : (-ε₁) ∈ ({0, -ε₁, -ε₂} : Set ℝ) := by right; left; rfl
  have hε₂mem : (-ε₂) ∈ ({0, -ε₁, -ε₂} : Set ℝ) := by right; right; rfl
  exact hcand.eq_extract h0 hε₁mem hε₂mem hdet

/-- **GFA-side three-point candidate verification.** Variant of
`candidate_eq_extract_of_three_points` where the two probe-shift
hypotheses are stated against `aperyGFAReal` (rather than `d.F`).
Both probe shifts must land in the unconditional disk `[0, 1/64)`
so that `F_shift_eq_GFA` can convert. The `t = 0` hypothesis is
unavoidably `d.F`-side since `z₁ ∉ [0, 1/64)`. -/
lemma AperyConnectionData.candidate_eq_extract_via_GFA_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hz₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hz₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hG₁ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hG₂ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular ∧
    a_half = d.extractHalf ε₁ ε₂ ∧
    a₁ = d.extractOne ε₁ ε₂ := by
  have hF₁ : d.F (Number.aperyConifoldZ1Poly + (-ε₁)) =
      aperyBranchTriple a₀ a_half a₁ (-ε₁) := by
    rw [d.F_shift_eq_GFA hz₁]; exact hG₁
  have hF₂ : d.F (Number.aperyConifoldZ1Poly + (-ε₂)) =
      aperyBranchTriple a₀ a_half a₁ (-ε₂) := by
    rw [d.F_shift_eq_GFA hz₂]; exact hG₂
  exact d.candidate_eq_extract_of_three_points hF₀ hF₁ hF₂ hdet

/-- **Component selectors of `candidate_eq_extract_of_three_points`.**
Three lemmas, one per coefficient, for downstream code that only needs
one extract value. -/
lemma AperyConnectionData.candidate_eq_extractRegular_of_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hF₁ : d.F (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hF₂ : d.F (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular :=
  (d.candidate_eq_extract_of_three_points hF₀ hF₁ hF₂ hdet).1

lemma AperyConnectionData.candidate_eq_extractHalf_of_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hF₁ : d.F (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hF₂ : d.F (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a_half = d.extractHalf ε₁ ε₂ :=
  (d.candidate_eq_extract_of_three_points hF₀ hF₁ hF₂ hdet).2.1

lemma AperyConnectionData.candidate_eq_extractOne_of_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hF₁ : d.F (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hF₂ : d.F (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₁ = d.extractOne ε₁ ε₂ :=
  (d.candidate_eq_extract_of_three_points hF₀ hF₁ hF₂ hdet).2.2

/-- **GFA-side component selectors of three-point verification.** Three
lemmas, one per coefficient, mirroring the F-side selectors. -/
lemma AperyConnectionData.candidate_eq_extractRegular_via_GFA_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hz₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hz₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hG₁ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hG₂ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = d.extractRegular :=
  (d.candidate_eq_extract_via_GFA_three_points hF₀ hz₁ hz₂ hG₁ hG₂ hdet).1

lemma AperyConnectionData.candidate_eq_extractHalf_via_GFA_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hz₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hz₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hG₁ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hG₂ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a_half = d.extractHalf ε₁ ε₂ :=
  (d.candidate_eq_extract_via_GFA_three_points hF₀ hz₁ hz₂ hG₁ hG₂ hdet).2.1

lemma AperyConnectionData.candidate_eq_extractOne_via_GFA_three_points
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (hF₀ : d.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple a₀ a_half a₁ 0)
    {ε₁ ε₂ : ℝ}
    (hz₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hz₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hG₁ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₁))
    (hG₂ : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
        aperyBranchTriple a₀ a_half a₁ (-ε₂))
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₁ = d.extractOne ε₁ ε₂ :=
  (d.candidate_eq_extract_via_GFA_three_points hF₀ hz₁ hz₂ hG₁ hG₂ hdet).2.2

/-- **`HasAperyConnectionData ⇒ HasAperyAnalyticExtension`.** Projection
along the `extends` field: any connection-data witness automatically
gives an analytic-extension witness. -/
lemma HasAperyConnectionData.toHasAperyAnalyticExtension :
    HasAperyConnectionData → HasAperyAnalyticExtension
  | ⟨d⟩ => ⟨d.toAperyAnalyticExtension⟩

/-- **Extract a concrete `AperyConnectionData` from `HasAperyConnectionData`.**
Standard `Classical.choice` lift; downstream code may use this when it
just needs *some* connection data (e.g. to talk about *the* extract
triple under non-degenerate Δ). -/
noncomputable def HasAperyConnectionData.choose
    (h : HasAperyConnectionData) : AperyConnectionData :=
  Classical.choice h

/-- **`Has`-form derived from a witness `AperyConnectionData`.** -/
lemma AperyConnectionData.toHasAperyConnectionData
    (d : AperyConnectionData) : HasAperyConnectionData := ⟨d⟩

/-- **`Has`-form derived from a witness `AperyAnalyticExtension`.** -/
lemma AperyAnalyticExtension.toHasAperyAnalyticExtension
    (ext : AperyAnalyticExtension) : HasAperyAnalyticExtension := ⟨ext⟩

/-- **`extractHalf` is symmetric under probe swap.** Lift of
`aperyExtractHalf_swap` to `AperyConnectionData`. Unconditional (no
`hdet` required since the swap negates both numerator and denominator). -/
lemma AperyConnectionData.extractHalf_swap
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    d.extractHalf ε₂ ε₁ = d.extractHalf ε₁ ε₂ :=
  aperyExtractHalf_swap d.F ε₁ ε₂

/-- **`extractOne` is symmetric under probe swap.** Lift of
`aperyExtractOne_swap`. Unconditional. -/
lemma AperyConnectionData.extractOne_swap
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    d.extractOne ε₂ ε₁ = d.extractOne ε₁ ε₂ :=
  aperyExtractOne_swap d.F ε₁ ε₂

/-- **`AperyAnalyticExtension` extensionality.** Two analytic extensions
are equal as soon as their `F`-fields agree. The two `Prop` fields
(`agrees_on_small`, `continuousOn_corridor`) are determined by proof
irrelevance. -/
lemma AperyAnalyticExtension.ext
    {ext₁ ext₂ : AperyAnalyticExtension} (hF : ext₁.F = ext₂.F) :
    ext₁ = ext₂ := by
  obtain ⟨F₁, _, _⟩ := ext₁
  obtain ⟨F₂, _, _⟩ := ext₂
  cases hF
  rfl

/-- **`AperyConnectionData` extensionality.** Two connection-data
witnesses are equal as soon as their analytic extension and corridor
agree. The two `Prop` fields (`zero_mem`, `has_conn`) are determined by
proof irrelevance. -/
lemma AperyConnectionData.ext_iff_extension_corridor
    {d₁ d₂ : AperyConnectionData}
    (h_ext : d₁.toAperyAnalyticExtension = d₂.toAperyAnalyticExtension)
    (h_corridor : d₁.corridor = d₂.corridor) : d₁ = d₂ := by
  obtain ⟨ext₁, c₁, _, _⟩ := d₁
  obtain ⟨ext₂, c₂, _, _⟩ := d₂
  cases h_ext
  cases h_corridor
  rfl

/-- **`restrictCorridor` is idempotent on the same corridor.** Restricting
`d` to its own corridor returns `d` itself. Proven by extensionality:
both extension and corridor agree, the `Prop` fields collapse. -/
@[simp] lemma AperyConnectionData.restrictCorridor_self
    (d : AperyConnectionData) :
    d.restrictCorridor (subset_refl d.corridor) d.zero_mem = d :=
  AperyConnectionData.ext_iff_extension_corridor rfl rfl

/-- **`restrictCorridor` composes.** Two nested restrictions equal a
single restriction along the composed inclusion. -/
lemma AperyConnectionData.restrictCorridor_trans
    (d : AperyConnectionData) {J K : Set ℝ}
    (hJ : J ⊆ d.corridor) (h0J : (0 : ℝ) ∈ J)
    (hK : K ⊆ J) (h0K : (0 : ℝ) ∈ K) :
    (d.restrictCorridor hJ h0J).restrictCorridor hK h0K =
      d.restrictCorridor (hK.trans hJ) h0K :=
  AperyConnectionData.ext_iff_extension_corridor rfl rfl

/-- **`of_witness` round-trip.** Rebuilding `AperyConnectionData` from
its own extension, corridor, zero membership, and Has-connection
witness returns the original data. -/
@[simp] lemma AperyConnectionData.of_witness_self
    (d : AperyConnectionData) :
    AperyConnectionData.of_witness d.toAperyAnalyticExtension
        d.corridor d.zero_mem d.has_conn = d :=
  AperyConnectionData.ext_iff_extension_corridor rfl rfl

/-- **`of_witness` projection back to extension.** -/
@[simp] lemma AperyConnectionData.of_witness_toAperyAnalyticExtension
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) :
    (AperyConnectionData.of_witness ext I h0 h).toAperyAnalyticExtension =
      ext := rfl

/-- **The extract triple satisfies `IsAperyConnectionCoeffsOn`.** Under
non-degenerate Δ, the Cramer-extracted triple
`(extractRegular, extractHalf ε₁ ε₂, extractOne ε₁ ε₂)` is in fact a
genuine connection-coefficient triple representing `d.F` on the entire
corridor (not just at `0, -ε₁, -ε₂`). Bridge from `shifted_eq_extract`
via `of_shifted_eqOn`. -/
lemma AperyConnectionData.is_extract_triple
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn d.extractRegular
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) d.F d.corridor :=
  IsAperyConnectionCoeffsOn.of_shifted_eqOn _ _ _ _ _
    (d.shifted_eq_extract hε₁ hε₂ hdet)

/-- **`F` is connection-coefficient representable on the corridor.**
Existential wrapper: `d.F` is `HasAperyConnectionCoeffsOn` on `corridor`.
This is just `d.has_conn`, restated here for convenience. -/
lemma AperyConnectionData.has_extract_triple
    (d : AperyConnectionData) :
    HasAperyConnectionCoeffsOn d.F d.corridor := d.has_conn

/-- **Pointwise reconstruction at a single corridor shift.**
The shift-form `F (z₁ + t)` matches the extract-superposition at any
`t ∈ corridor`. -/
lemma AperyConnectionData.F_shift_eq_extract_at
    (d : AperyConnectionData) {ε₁ ε₂ t : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ d.corridor) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple d.extractRegular
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) t :=
  d.shifted_eq_extract hε₁ hε₂ hdet ht

/-- **Extract triple is `IsAperyConnectionCoeffsOn` on any sub-corridor.**
Restriction of `is_extract_triple` along a subset `J ⊆ corridor`. The
probes `-ε₁`, `-ε₂` only need to live in the *full* corridor — once the
extract triple represents `F` on `corridor`, it represents `F` on every
subset. -/
lemma AperyConnectionData.is_extract_triple_mono
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn d.extractRegular
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂) d.F J :=
  (d.is_extract_triple hε₁ hε₂ hdet).mono hJ

/-- **Extract triple agrees with the restricted-corridor extract.**
Since `restrictCorridor` preserves the underlying `F` and the Cramer
formulas only see `F`, the extract triple is unchanged after restriction.
This is a packaged restatement of the three `restrictCorridor_extract*`
simp projections. -/
lemma AperyConnectionData.extractTriple_restrictCorridor_eq
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) (ε₁ ε₂ : ℝ) :
    ((d.restrictCorridor hJ h0).extractRegular,
      (d.restrictCorridor hJ h0).extractHalf ε₁ ε₂,
      (d.restrictCorridor hJ h0).extractOne ε₁ ε₂) =
    (d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂) := rfl

/-- **Has-form: connection-coefficient property descends to sub-corridor.**
This is just `d.has_conn.mono`, surfaced under the `extract`-flavored
naming for downstream parity. -/
lemma AperyConnectionData.has_extract_triple_mono
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor) :
    HasAperyConnectionCoeffsOn d.F J := d.has_conn.mono hJ

/-- **`overlapShifts` projection through `restrictCorridor`.** Restricting
to a sub-corridor `J` produces the overlap `J ∩ disk-shift`. Holds by
`rfl` since `restrictCorridor` only swaps out the `corridor` field and
`overlapShifts` is a definitional intersection with that field. -/
@[simp] lemma AperyConnectionData.restrictCorridor_overlapShifts
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) :
    (d.restrictCorridor hJ h0).overlapShifts =
      J ∩ {t : ℝ | Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)} :=
  rfl

/-- **`overlapShifts` is monotone in the corridor.** A sub-corridor's
overlap sits inside the full corridor's overlap. -/
lemma AperyConnectionData.restrictCorridor_overlapShifts_subset
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) :
    (d.restrictCorridor hJ h0).overlapShifts ⊆ d.overlapShifts := fun _ ht =>
  ⟨hJ ht.1, ht.2⟩

/-- **GFA-on-overlap descends to sub-corridor (Is-form).** If
`(-ε₁), (-ε₂)` lie in the sub-corridor `J` (so the connection holds
there), then on `(d.restrictCorridor hJ h0).overlapShifts` the GFA
equals the extract-triple superposition. The extract triple is
unchanged (`extractTriple_restrictCorridor_eq`). -/
lemma AperyConnectionData.GFA_isAperyConnectionCoeffsOn_overlapShifts_restrict
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ J) (hε₂ : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn d.extractRegular
        (d.extractHalf ε₁ ε₂) (d.extractOne ε₁ ε₂)
        aperyGFAReal (d.restrictCorridor hJ h0).overlapShifts :=
  (d.GFA_isAperyConnectionCoeffsOn_overlapShifts (hJ hε₁) (hJ hε₂) hdet).mono
    (d.restrictCorridor_overlapShifts_subset hJ h0)

/-- **Has-form variant.** Same as the Is-form, just wrapped in the
existential. -/
lemma AperyConnectionData.GFA_hasAperyConnectionCoeffsOn_overlapShifts_restrict
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ J) (hε₂ : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    HasAperyConnectionCoeffsOn aperyGFAReal
      (d.restrictCorridor hJ h0).overlapShifts :=
  ⟨_, _, _, d.GFA_isAperyConnectionCoeffsOn_overlapShifts_restrict hJ h0 hε₁ hε₂ hdet⟩

/-- **Generalized GFA ↔ F equivalence on a disk-shift set.** If every
`t ∈ S` makes `z₁ + t` land in the unconditional disk `[0, 1/64)`, then
GFA and `d.F` agree at `z₁ + t`, so a candidate triple matches one
side iff it matches the other on all of `S`. This is the corridor-free
generalization of `candidate_GFA_iff_F_on_overlapShifts` — drops the
`d.corridor` half of the overlap intersection. -/
lemma AperyConnectionData.candidate_GFA_iff_F_on_disk_shifts
    (d : AperyConnectionData) (a₀ a_half a₁ : ℝ)
    {S : Set ℝ}
    (hS : ∀ t ∈ S,
      Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    Set.EqOn (fun t => aperyGFAReal (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) S ↔
      Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t) S := by
  constructor
  · intro h t ht
    have hFGFA : d.F (Number.aperyConifoldZ1Poly + t) =
        aperyGFAReal (Number.aperyConifoldZ1Poly + t) :=
      d.F_shift_eq_GFA (hS t ht)
    have hGFAt := h ht
    change d.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple a₀ a_half a₁ t
    rw [hFGFA]
    exact hGFAt
  · intro h t ht
    have hFGFA : d.F (Number.aperyConifoldZ1Poly + t) =
        aperyGFAReal (Number.aperyConifoldZ1Poly + t) :=
      d.F_shift_eq_GFA (hS t ht)
    have hFt := h ht
    change aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple a₀ a_half a₁ t
    rw [← hFGFA]
    exact hFt

/-- **Sub-corridor candidate equivalence.** Specialization of
`candidate_GFA_iff_F_on_disk_shifts` to the overlap of a sub-corridor.
The disk-shift hypothesis comes from the second projection of
`overlapShifts`. -/
lemma AperyConnectionData.candidate_GFA_iff_F_on_overlapShifts_restrict
    (d : AperyConnectionData) {J : Set ℝ} (hJ : J ⊆ d.corridor)
    (h0 : (0 : ℝ) ∈ J) (a₀ a_half a₁ : ℝ) :
    Set.EqOn (fun t => aperyGFAReal (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t)
        (d.restrictCorridor hJ h0).overlapShifts ↔
      Set.EqOn (fun t => d.F (Number.aperyConifoldZ1Poly + t))
        (fun t => aperyBranchTriple a₀ a_half a₁ t)
        (d.restrictCorridor hJ h0).overlapShifts :=
  d.candidate_GFA_iff_F_on_disk_shifts a₀ a_half a₁ (fun _ ht => ht.2)

/-- **Minimal-corridor `AperyConnectionData` from any analytic extension.**
Every `AperyAnalyticExtension` upgrades to an `AperyConnectionData` with
the trivial corridor `{0}`, since `HasAperyConnectionCoeffsOn ext.F {0}`
always holds (`HasAperyConnectionCoeffsOn.singleton_zero`). The
non-trivial work — proving the connection on a *useful* corridor — is
deferred; this minimal lift exists unconditionally. -/
def AperyAnalyticExtension.toMinimalConnectionData
    (ext : AperyAnalyticExtension) : AperyConnectionData where
  toAperyAnalyticExtension := ext
  corridor := {0}
  zero_mem := rfl
  has_conn := HasAperyConnectionCoeffsOn.singleton_zero ext.F

/-- **Projection: minimal-corridor data has corridor `{0}`.** -/
@[simp] lemma AperyAnalyticExtension.toMinimalConnectionData_corridor
    (ext : AperyAnalyticExtension) :
    ext.toMinimalConnectionData.corridor = ({0} : Set ℝ) := rfl

/-- **Projection: minimal-corridor data has the same `F`.** -/
@[simp] lemma AperyAnalyticExtension.toMinimalConnectionData_F
    (ext : AperyAnalyticExtension) :
    ext.toMinimalConnectionData.F = ext.F := rfl

/-- **Projection: minimal-corridor data has the same analytic
extension.** -/
@[simp] lemma AperyAnalyticExtension.toMinimalConnectionData_toAperyAnalyticExtension
    (ext : AperyAnalyticExtension) :
    ext.toMinimalConnectionData.toAperyAnalyticExtension = ext := rfl

/-- **`AperyAnalyticExtension` ⇒ `HasAperyConnectionData`.** Every
analytic extension has *some* connection data (with the minimal trivial
corridor). Useful when downstream code needs only the `Has`-level
existence. -/
lemma AperyAnalyticExtension.hasAperyConnectionData
    (ext : AperyAnalyticExtension) : HasAperyConnectionData :=
  ⟨ext.toMinimalConnectionData⟩

/-- **`HasAperyAnalyticExtension ⇒ HasAperyConnectionData`.** Existential
lift through `toMinimalConnectionData`: the two `Has`-level wrappers
collapse modulo the trivial-corridor minimal lift. -/
lemma HasAperyAnalyticExtension.toHasAperyConnectionData :
    HasAperyAnalyticExtension → HasAperyConnectionData
  | ⟨ext⟩ => ext.hasAperyConnectionData

/-- **`F` agrees with `aperyGFAReal` on the unconditional disk.**
Pointwise restatement of the `agrees_on_small` field. -/
lemma AperyAnalyticExtension.F_eq_GFA_on_small (ext : AperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.F z = aperyGFAReal z := ext.agrees_on_small hz

/-- **Two analytic extensions agree on the unconditional disk.** Since
both restrict to `aperyGFAReal` there, they coincide. The disk is the
only region where uniqueness is *unconditional*; outside requires the
identity-of-analytic-functions theorem. -/
lemma AperyAnalyticExtension.F_unique_on_small
    (ext₁ ext₂ : AperyAnalyticExtension) :
    Set.EqOn ext₁.F ext₂.F (Set.Ico (0 : ℝ) (1 / 64)) := fun z hz => by
  rw [ext₁.F_eq_GFA_on_small hz, ext₂.F_eq_GFA_on_small hz]

/-- **Minimal-data extract: regular = `ext.F z₁`.** -/
@[simp] lemma AperyAnalyticExtension.toMinimalConnectionData_extractRegular
    (ext : AperyAnalyticExtension) :
    ext.toMinimalConnectionData.extractRegular =
      ext.F Number.aperyConifoldZ1Poly := rfl

/-- **`toMinimalConnectionData` is determined by `F`.** Two analytic
extensions with the same `F`-field produce the same minimal connection
data. Follows from `AperyAnalyticExtension.ext` plus
`ext_iff_extension_corridor`. -/
lemma AperyAnalyticExtension.toMinimalConnectionData_congr
    {ext₁ ext₂ : AperyAnalyticExtension} (hF : ext₁.F = ext₂.F) :
    ext₁.toMinimalConnectionData = ext₂.toMinimalConnectionData :=
  AperyConnectionData.ext_iff_extension_corridor
    (AperyAnalyticExtension.ext hF) rfl

/-- **Connection residual of an `AperyConnectionData`.** The Cramer
formulas all involve `aperyConnectionResidual d.F ε`; this thin wrapper
gives it a name on the connection-data side for downstream readability. -/
noncomputable def AperyConnectionData.connectionResidual
    (d : AperyConnectionData) (ε : ℝ) : ℝ :=
  aperyConnectionResidual d.F ε

/-- **Connection residual unfold.** -/
lemma AperyConnectionData.connectionResidual_def
    (d : AperyConnectionData) (ε : ℝ) :
    d.connectionResidual ε =
      d.F (Number.aperyConifoldZ1Poly + (-ε)) -
        d.extractRegular * aperyBranchAmplitude_zero ε := rfl

/-- **Connection residual at `ε = 0` is zero.** Lift of
`aperyConnectionResidual_zero` to the data layer. -/
@[simp] lemma AperyConnectionData.connectionResidual_zero
    (d : AperyConnectionData) :
    d.connectionResidual 0 = 0 :=
  aperyConnectionResidual_zero d.F

/-- **Connection residual via GFA when probe lands in disk.** If
`z₁ + (-ε) ∈ [0, 1/64)`, then `d.F` may be replaced by `aperyGFAReal`
inside `connectionResidual` (the boundary `f(z₁)` term is unchanged
since `z₁ ∉ disk`, so it stays as `extractRegular`). -/
lemma AperyConnectionData.connectionResidual_via_GFA
    (d : AperyConnectionData) {ε : ℝ}
    (hε : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.connectionResidual ε =
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        d.extractRegular * aperyBranchAmplitude_zero ε := by
  unfold AperyConnectionData.connectionResidual aperyConnectionResidual
  rw [d.F_shift_eq_GFA hε]
  rfl

/-- **`extractHalf` in `connectionResidual` form.** The Cramer formula
written with named residuals: `extractHalf = (R₁·V₁₂ − R₂·V₁₁) / Δ`. -/
lemma AperyConnectionData.extractHalf_eq_residual_form
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    d.extractHalf ε₁ ε₂ =
      (d.connectionResidual ε₁ * aperyBranchValue_one ε₂ -
        d.connectionResidual ε₂ * aperyBranchValue_one ε₁) /
        aperyConnectionDet ε₁ ε₂ := rfl

/-- **`extractOne` in `connectionResidual` form.** The Cramer formula
written with named residuals: `extractOne = (−R₁·A_½₂ + R₂·A_½₁) / Δ`. -/
lemma AperyConnectionData.extractOne_eq_residual_form
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    d.extractOne ε₁ ε₂ =
      (-(d.connectionResidual ε₁ * aperyBranchAmplitude_half ε₂) +
        d.connectionResidual ε₂ * aperyBranchAmplitude_half ε₁) /
        aperyConnectionDet ε₁ ε₂ := rfl

/-- **`extractHalf` Cramer numerator vanishes when both residuals
vanish.** If `connectionResidual` is zero at both probes, the half-branch
extract is zero (regardless of Δ). -/
lemma AperyConnectionData.extractHalf_eq_zero_of_residual_zero
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (h₁ : d.connectionResidual ε₁ = 0)
    (h₂ : d.connectionResidual ε₂ = 0) :
    d.extractHalf ε₁ ε₂ = 0 := by
  rw [d.extractHalf_eq_residual_form, h₁, h₂]
  ring

/-- **`extractOne` Cramer numerator vanishes when both residuals
vanish.** -/
lemma AperyConnectionData.extractOne_eq_zero_of_residual_zero
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (h₁ : d.connectionResidual ε₁ = 0)
    (h₂ : d.connectionResidual ε₂ = 0) :
    d.extractOne ε₁ ε₂ = 0 := by
  rw [d.extractOne_eq_residual_form, h₁, h₂]
  ring

/-- **Connection residual = singular-branch contribution.** Under
non-degenerate Δ and `-ε ∈ corridor`, the residual at `ε` equals the
singular branches' value at `-ε`:
`d.connectionResidual ε = (extractHalf)·A_½(ε) + (extractOne)·V_1(ε)`.

This is the structural meaning of `connectionResidual`: it isolates the
non-regular part of `F (z₁ - ε)` by stripping `extractRegular·A_0(ε)`. -/
lemma AperyConnectionData.connectionResidual_eq_singular_part
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor) :
    d.connectionResidual ε =
      d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε +
        d.extractOne ε₁ ε₂ * aperyBranchValue_one ε := by
  have hF := d.shifted_eq_extract hε₁ hε₂ hdet hε
  unfold AperyConnectionData.connectionResidual aperyConnectionResidual
  simp only at hF
  rw [hF, aperyBranchTriple_at_neg_eps, ← d.extractRegular_eq]
  ring

/-- **Connection residual vanishes when singular extracts vanish.**
Direct corollary of `connectionResidual_eq_singular_part`: if both
`extractHalf` and `extractOne` are zero, then `d.connectionResidual ε = 0`
at every `-ε ∈ corridor`. -/
lemma AperyConnectionData.connectionResidual_eq_zero_of_singular_zero
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor)
    (hHalf : d.extractHalf ε₁ ε₂ = 0)
    (hOne : d.extractOne ε₁ ε₂ = 0) :
    d.connectionResidual ε = 0 := by
  rw [d.connectionResidual_eq_singular_part hε₁ hε₂ hdet hε, hHalf, hOne]
  ring

/-- **Right-endpoint reconstruction at `z₁ − ε`.** Specialisation of
`shifted_eq_extract` at `t = -ε`, expanded into the named-amplitude
form `A_0(ε) · extractRegular + A_½(ε) · extractHalf + V_1(ε) · extractOne`.
Direct lift of `IsAperyConnectionCoeffsOn.right_endpoint` to the
connection-data layer. -/
lemma AperyConnectionData.F_right_endpoint
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor) :
    d.F (Number.aperyConifoldZ1Poly + (-ε)) =
      d.extractRegular * aperyBranchAmplitude_zero ε +
        d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε +
        d.extractOne ε₁ ε₂ * aperyBranchValue_one ε :=
  (d.is_extract_triple hε₁ hε₂ hdet).right_endpoint hε

/-- **Connection residual vanishes iff `F` is purely regular at `−ε`.**
Diagnostic equivalence: `d.connectionResidual ε = 0` exactly when
`d.F (z₁ − ε)` is captured by the regular branch alone. -/
lemma AperyConnectionData.connectionResidual_eq_zero_iff
    (d : AperyConnectionData) (ε : ℝ) :
    d.connectionResidual ε = 0 ↔
      d.F (Number.aperyConifoldZ1Poly + (-ε)) =
        d.extractRegular * aperyBranchAmplitude_zero ε := by
  rw [d.connectionResidual_def, sub_eq_zero]

/-- **Right-endpoint reconstruction via GFA on disk overlap.** When the
probe `z₁ − ε` lands in the unconditional disk, `aperyGFAReal (z₁ − ε)`
equals the extract-triple amplitude superposition. Combination of
`F_right_endpoint` (F-side) with `F_shift_eq_GFA` (F = GFA on disk). -/
lemma AperyConnectionData.GFA_right_endpoint
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      d.extractRegular * aperyBranchAmplitude_zero ε +
        d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε +
        d.extractOne ε₁ ε₂ * aperyBranchValue_one ε := by
  rw [← d.F_shift_eq_GFA hdisk]
  exact d.F_right_endpoint hε₁ hε₂ hdet hε

/-- **GFA-side connection residual = singular part on overlap.** When
both `−ε ∈ corridor` and `z₁ − ε ∈ disk`, the residual computed from
`aperyGFAReal` (via `connectionResidual_via_GFA`) equals the singular
branches' value at `−ε`. Combines `connectionResidual_via_GFA` with
`connectionResidual_eq_singular_part`. -/
lemma AperyConnectionData.GFA_residual_eq_singular_part
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        d.extractRegular * aperyBranchAmplitude_zero ε =
      d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε +
        d.extractOne ε₁ ε₂ * aperyBranchValue_one ε := by
  rw [← d.connectionResidual_via_GFA hdisk]
  exact d.connectionResidual_eq_singular_part hε₁ hε₂ hdet hε

/-- **`extractRegular` depends only on `F`.** Two connection-data
witnesses with equal `F`-fields produce the same regular extract. -/
lemma AperyConnectionData.extractRegular_congr
    {d₁ d₂ : AperyConnectionData} (hF : d₁.F = d₂.F) :
    d₁.extractRegular = d₂.extractRegular := by
  show d₁.F _ = d₂.F _
  rw [hF]

/-- **`extractHalf` depends only on `F`.** -/
lemma AperyConnectionData.extractHalf_congr
    {d₁ d₂ : AperyConnectionData} (hF : d₁.F = d₂.F) (ε₁ ε₂ : ℝ) :
    d₁.extractHalf ε₁ ε₂ = d₂.extractHalf ε₁ ε₂ := by
  show aperyExtractHalf d₁.F ε₁ ε₂ = aperyExtractHalf d₂.F ε₁ ε₂
  rw [hF]

/-- **`extractOne` depends only on `F`.** -/
lemma AperyConnectionData.extractOne_congr
    {d₁ d₂ : AperyConnectionData} (hF : d₁.F = d₂.F) (ε₁ ε₂ : ℝ) :
    d₁.extractOne ε₁ ε₂ = d₂.extractOne ε₁ ε₂ := by
  show aperyExtractOne d₁.F ε₁ ε₂ = aperyExtractOne d₂.F ε₁ ε₂
  rw [hF]

/-- **`connectionResidual` depends only on `F`.** -/
lemma AperyConnectionData.connectionResidual_congr
    {d₁ d₂ : AperyConnectionData} (hF : d₁.F = d₂.F) (ε : ℝ) :
    d₁.connectionResidual ε = d₂.connectionResidual ε := by
  unfold AperyConnectionData.connectionResidual aperyConnectionResidual
  rw [hF]

/-- **`aperyConnectionDet` non-vanishing forces probes nonzero.**
Connection-data wrapper of `aperyConnectionDet_ne_zero_probes_nonzero`. -/
lemma AperyConnectionData.det_ne_zero_probes_nonzero
    (_d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    ε₁ ≠ 0 ∧ ε₂ ≠ 0 ∧ ε₁ ≠ ε₂ :=
  aperyConnectionDet_ne_zero_probes_nonzero hdet

/-- **Residual difference between two `AperyConnectionData` on disk
overlap.** When `z₁ − ε` lies in the unconditional disk, both `d_i.F`
reduce to `aperyGFAReal` there, so the only difference between
`d₁.connectionResidual ε` and `d₂.connectionResidual ε` comes from the
`extractRegular` term: residual difference
`= -(extractRegular₁ − extractRegular₂) · A_0(ε)`. -/
lemma AperyConnectionData.connectionResidual_sub_on_disk
    (d₁ d₂ : AperyConnectionData) {ε : ℝ}
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d₁.connectionResidual ε - d₂.connectionResidual ε =
      -((d₁.extractRegular - d₂.extractRegular) *
          aperyBranchAmplitude_zero ε) := by
  rw [d₁.connectionResidual_via_GFA hdisk,
      d₂.connectionResidual_via_GFA hdisk]
  ring

/-- **Two-data residual equality on disk overlap.** Specialisation of
`connectionResidual_sub_on_disk`: residuals coincide iff the regular
extracts coincide (provided `A_0(ε) ≠ 0`). -/
lemma AperyConnectionData.connectionResidual_eq_iff_extractRegular_eq_on_disk
    (d₁ d₂ : AperyConnectionData) {ε : ℝ}
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hA : aperyBranchAmplitude_zero ε ≠ 0) :
    d₁.connectionResidual ε = d₂.connectionResidual ε ↔
      d₁.extractRegular = d₂.extractRegular := by
  rw [← sub_eq_zero (a := d₁.connectionResidual ε),
      d₁.connectionResidual_sub_on_disk d₂ hdisk]
  constructor
  · intro h
    have hzero := neg_eq_zero.mp h
    rcases mul_eq_zero.mp hzero with hreg | hAzero
    · linarith [sub_eq_zero.mp hreg]
    · exact absurd hAzero hA
  · intro h
    rw [show d₁.extractRegular - d₂.extractRegular = 0 from by
      rw [h]; ring]
    ring

/-- **`extractHalf` difference between two ConnectionData on disk overlap.**
When both probes' shifts land in the disk, each residual difference is a
multiple of `(extractRegular₁ − extractRegular₂)`, so the entire
`extractHalf` difference factors through that single number. -/
lemma AperyConnectionData.extractHalf_sub_on_disk
    (d₁ d₂ : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d₁.extractHalf ε₁ ε₂ - d₂.extractHalf ε₁ ε₂ =
      -((d₁.extractRegular - d₂.extractRegular) *
        (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₂ -
          aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₁)) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [d₁.extractHalf_eq_residual_form, d₂.extractHalf_eq_residual_form,
      ← sub_div]
  congr 1
  have hR₁ := d₁.connectionResidual_sub_on_disk d₂ hdisk₁
  have hR₂ := d₁.connectionResidual_sub_on_disk d₂ hdisk₂
  have hR₁' : d₁.connectionResidual ε₁ = d₂.connectionResidual ε₁ +
      -((d₁.extractRegular - d₂.extractRegular) *
          aperyBranchAmplitude_zero ε₁) := by linarith
  have hR₂' : d₁.connectionResidual ε₂ = d₂.connectionResidual ε₂ +
      -((d₁.extractRegular - d₂.extractRegular) *
          aperyBranchAmplitude_zero ε₂) := by linarith
  rw [hR₁', hR₂']
  ring

/-- **`extractOne` difference between two ConnectionData on disk overlap.**
Same setup as `extractHalf_sub_on_disk`; the factor on the right uses
`A_½` instead of `V_1`. -/
lemma AperyConnectionData.extractOne_sub_on_disk
    (d₁ d₂ : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d₁.extractOne ε₁ ε₂ - d₂.extractOne ε₁ ε₂ =
      -((d₁.extractRegular - d₂.extractRegular) *
        (aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₁ -
          aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₂)) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [d₁.extractOne_eq_residual_form, d₂.extractOne_eq_residual_form,
      ← sub_div]
  congr 1
  have hR₁ := d₁.connectionResidual_sub_on_disk d₂ hdisk₁
  have hR₂ := d₁.connectionResidual_sub_on_disk d₂ hdisk₂
  have hR₁' : d₁.connectionResidual ε₁ = d₂.connectionResidual ε₁ +
      -((d₁.extractRegular - d₂.extractRegular) *
          aperyBranchAmplitude_zero ε₁) := by linarith
  have hR₂' : d₁.connectionResidual ε₂ = d₂.connectionResidual ε₂ +
      -((d₁.extractRegular - d₂.extractRegular) *
          aperyBranchAmplitude_zero ε₂) := by linarith
  rw [hR₁', hR₂']
  ring

/-- **`extractRegular` equality from F-equality at z₁.** Trivial: both
sides reduce to the same `F z₁` value definitionally. -/
lemma AperyConnectionData.extractRegular_eq_of_F_eq_at_z1
    (d₁ d₂ : AperyConnectionData)
    (hF : d₁.F Number.aperyConifoldZ1Poly = d₂.F Number.aperyConifoldZ1Poly) :
    d₁.extractRegular = d₂.extractRegular := by
  rw [d₁.extractRegular_eq, d₂.extractRegular_eq, hF]

/-- **`extractHalf` equality from F-equality at z₁ when probes land in disk.**
By `extractHalf_sub_on_disk`, the difference factors through
`(extractRegular₁ − extractRegular₂)`, which vanishes when the two F's
agree at z₁. -/
lemma AperyConnectionData.extractHalf_eq_of_F_eq_at_z1_on_disk
    (d₁ d₂ : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hF : d₁.F Number.aperyConifoldZ1Poly = d₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d₁.extractHalf ε₁ ε₂ = d₂.extractHalf ε₁ ε₂ := by
  have hsub := d₁.extractHalf_sub_on_disk d₂ hdisk₁ hdisk₂
  have hR := AperyConnectionData.extractRegular_eq_of_F_eq_at_z1 d₁ d₂ hF
  rw [hR, sub_self, zero_mul, neg_zero, zero_div] at hsub
  linarith

/-- **`extractOne` equality from F-equality at z₁ when probes land in disk.**
Companion of `extractHalf_eq_of_F_eq_at_z1_on_disk`. -/
lemma AperyConnectionData.extractOne_eq_of_F_eq_at_z1_on_disk
    (d₁ d₂ : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hF : d₁.F Number.aperyConifoldZ1Poly = d₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d₁.extractOne ε₁ ε₂ = d₂.extractOne ε₁ ε₂ := by
  have hsub := d₁.extractOne_sub_on_disk d₂ hdisk₁ hdisk₂
  have hR := AperyConnectionData.extractRegular_eq_of_F_eq_at_z1 d₁ d₂ hF
  rw [hR, sub_self, zero_mul, neg_zero, zero_div] at hsub
  linarith

/-- **All three extracts agree from F-equality at z₁ when probes land in disk.**
Bundles the three previous lemmas as a 3-tuple. -/
lemma AperyConnectionData.extractTriple_eq_of_F_eq_at_z1_on_disk
    (d₁ d₂ : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hF : d₁.F Number.aperyConifoldZ1Poly = d₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    (d₁.extractRegular, d₁.extractHalf ε₁ ε₂, d₁.extractOne ε₁ ε₂) =
      (d₂.extractRegular, d₂.extractHalf ε₁ ε₂, d₂.extractOne ε₁ ε₂) := by
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · exact AperyConnectionData.extractRegular_eq_of_F_eq_at_z1 d₁ d₂ hF
  · exact AperyConnectionData.extractHalf_eq_of_F_eq_at_z1_on_disk
      d₁ d₂ hF hdisk₁ hdisk₂
  · exact AperyConnectionData.extractOne_eq_of_F_eq_at_z1_on_disk
      d₁ d₂ hF hdisk₁ hdisk₂

/-- **Ext-level connection residual.** Defined via the minimal
connection data wrapper. The thin definition gives an extract API
directly on `AperyAnalyticExtension` — no need to thread a corridor
witness when the only signal we want is the residual at a disk shift. -/
noncomputable def AperyAnalyticExtension.connectionResidual
    (ext : AperyAnalyticExtension) (ε : ℝ) : ℝ :=
  ext.toMinimalConnectionData.connectionResidual ε

/-- **Ext-level residual unfold.** Same Cramer-residual formula as for
`AperyConnectionData` but rooted on the ext-layer `F` field. -/
lemma AperyAnalyticExtension.connectionResidual_def
    (ext : AperyAnalyticExtension) (ε : ℝ) :
    ext.connectionResidual ε =
      ext.F (Number.aperyConifoldZ1Poly + (-ε)) -
        ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε := rfl

/-- **Ext-level residual at `ε = 0` is zero.** -/
@[simp] lemma AperyAnalyticExtension.connectionResidual_zero
    (ext : AperyAnalyticExtension) :
    ext.connectionResidual 0 = 0 :=
  ext.toMinimalConnectionData.connectionResidual_zero

/-- **Ext-level residual via GFA when probe lands in disk.** Same
`agrees_on_small` substitution as for the connection-data layer. -/
lemma AperyAnalyticExtension.connectionResidual_via_GFA
    (ext : AperyAnalyticExtension) {ε : ℝ}
    (hε : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.connectionResidual ε =
      aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε := by
  unfold AperyAnalyticExtension.connectionResidual
  rw [ext.toMinimalConnectionData.connectionResidual_via_GFA hε]
  rfl

/-- **Ext-level residual difference on disk overlap.** The difference
between two analytic extensions' residuals on disk factors through
their F-difference at `z₁`. -/
lemma AperyAnalyticExtension.connectionResidual_sub_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε : ℝ}
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.connectionResidual ε - ext₂.connectionResidual ε =
      -((ext₁.F Number.aperyConifoldZ1Poly -
          ext₂.F Number.aperyConifoldZ1Poly) *
        aperyBranchAmplitude_zero ε) := by
  rw [ext₁.connectionResidual_via_GFA hdisk,
      ext₂.connectionResidual_via_GFA hdisk]
  ring

/-- **Ext-level residual eq from F-eq at `z₁` on disk.** -/
lemma AperyAnalyticExtension.connectionResidual_eq_of_F_eq_at_z1_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε : ℝ}
    (hF : ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.connectionResidual ε = ext₂.connectionResidual ε := by
  rw [ext₁.connectionResidual_via_GFA hdisk,
      ext₂.connectionResidual_via_GFA hdisk, hF]

/-- **Ext-level extractRegular.** Shadows the data-layer field via
`toMinimalConnectionData`. By `toMinimalConnectionData_extractRegular`,
this is just `ext.F z₁`. -/
noncomputable def AperyAnalyticExtension.extractRegular
    (ext : AperyAnalyticExtension) : ℝ :=
  ext.toMinimalConnectionData.extractRegular

/-- **Ext-level extractRegular reduces to `F z₁`.** -/
@[simp] lemma AperyAnalyticExtension.extractRegular_eq
    (ext : AperyAnalyticExtension) :
    ext.extractRegular = ext.F Number.aperyConifoldZ1Poly := rfl

/-- **Ext-level extractHalf.** Two-probe Cramer extract delegated to
the minimal connection data. -/
noncomputable def AperyAnalyticExtension.extractHalf
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) : ℝ :=
  ext.toMinimalConnectionData.extractHalf ε₁ ε₂

/-- **Ext-level extractOne.** -/
noncomputable def AperyAnalyticExtension.extractOne
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) : ℝ :=
  ext.toMinimalConnectionData.extractOne ε₁ ε₂

/-- **Ext-level extractHalf from connection residuals.** Mirror of
`AperyConnectionData.extractHalf_eq_residual_form`. -/
lemma AperyAnalyticExtension.extractHalf_eq_residual_form
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.extractHalf ε₁ ε₂ =
      (ext.connectionResidual ε₁ * aperyBranchValue_one ε₂ -
        ext.connectionResidual ε₂ * aperyBranchValue_one ε₁) /
        aperyConnectionDet ε₁ ε₂ :=
  ext.toMinimalConnectionData.extractHalf_eq_residual_form ε₁ ε₂

/-- **Ext-level extractOne from connection residuals.** -/
lemma AperyAnalyticExtension.extractOne_eq_residual_form
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.extractOne ε₁ ε₂ =
      (-(ext.connectionResidual ε₁ * aperyBranchAmplitude_half ε₂) +
        ext.connectionResidual ε₂ * aperyBranchAmplitude_half ε₁) /
        aperyConnectionDet ε₁ ε₂ :=
  ext.toMinimalConnectionData.extractOne_eq_residual_form ε₁ ε₂

/-- **Ext-level extractRegular eq from F-eq at `z₁`.** Trivial via
`extractRegular_eq`. -/
lemma AperyAnalyticExtension.extractRegular_eq_of_F_eq_at_z1
    (ext₁ ext₂ : AperyAnalyticExtension)
    (hF : ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly) :
    ext₁.extractRegular = ext₂.extractRegular := by
  rw [ext₁.extractRegular_eq, ext₂.extractRegular_eq, hF]

/-- **Ext-level extractHalf eq from F-eq at `z₁` on disk.** -/
lemma AperyAnalyticExtension.extractHalf_eq_of_F_eq_at_z1_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hF : ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.extractHalf ε₁ ε₂ = ext₂.extractHalf ε₁ ε₂ :=
  AperyConnectionData.extractHalf_eq_of_F_eq_at_z1_on_disk
    ext₁.toMinimalConnectionData ext₂.toMinimalConnectionData hF hdisk₁ hdisk₂

/-- **Ext-level extractOne eq from F-eq at `z₁` on disk.** -/
lemma AperyAnalyticExtension.extractOne_eq_of_F_eq_at_z1_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hF : ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.extractOne ε₁ ε₂ = ext₂.extractOne ε₁ ε₂ :=
  AperyConnectionData.extractOne_eq_of_F_eq_at_z1_on_disk
    ext₁.toMinimalConnectionData ext₂.toMinimalConnectionData hF hdisk₁ hdisk₂

/-- **Ext-level connection coefficients triple.** Bundles the three
extracts `(a₀, a_½, a₁)` from an analytic extension. The `a₀` slot is
the right-endpoint value `ext.F z₁` (probe-independent), the other two
slots use the Cramer formula at probes `(ε₁, ε₂)`. -/
noncomputable def AperyAnalyticExtension.connectionCoefficients
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) : ℝ × ℝ × ℝ :=
  (ext.extractRegular, ext.extractHalf ε₁ ε₂, ext.extractOne ε₁ ε₂)

/-- **First component is the regular extract.** -/
@[simp] lemma AperyAnalyticExtension.connectionCoefficients_fst
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    (ext.connectionCoefficients ε₁ ε₂).1 = ext.extractRegular := rfl

/-- **Second component is the half-branch extract.** -/
@[simp] lemma AperyAnalyticExtension.connectionCoefficients_snd_fst
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    (ext.connectionCoefficients ε₁ ε₂).2.1 = ext.extractHalf ε₁ ε₂ := rfl

/-- **Third component is the one-branch extract.** -/
@[simp] lemma AperyAnalyticExtension.connectionCoefficients_snd_snd
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    (ext.connectionCoefficients ε₁ ε₂).2.2 = ext.extractOne ε₁ ε₂ := rfl

/-- **Connection coefficients agree from F-eq at `z₁` on disk.** Bundles
the three `*_eq_of_F_eq_at_z1{_on_disk}` lemmas as a triple equality. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_of_F_eq_at_z1_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hF : ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.connectionCoefficients ε₁ ε₂ = ext₂.connectionCoefficients ε₁ ε₂ := by
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · exact ext₁.extractRegular_eq_of_F_eq_at_z1 ext₂ hF
  · exact ext₁.extractHalf_eq_of_F_eq_at_z1_on_disk ext₂ hF hdisk₁ hdisk₂
  · exact ext₁.extractOne_eq_of_F_eq_at_z1_on_disk ext₂ hF hdisk₁ hdisk₂

/-- **Connection coefficients agree from full F-eq.** Stronger version
(no disk hypothesis): if the two ext-layer F-fields agree everywhere,
all three extracts agree at any probes. -/
lemma AperyAnalyticExtension.connectionCoefficients_congr
    {ext₁ ext₂ : AperyAnalyticExtension} (hF : ext₁.F = ext₂.F) (ε₁ ε₂ : ℝ) :
    ext₁.connectionCoefficients ε₁ ε₂ = ext₂.connectionCoefficients ε₁ ε₂ := by
  unfold AperyAnalyticExtension.connectionCoefficients
        AperyAnalyticExtension.extractRegular
        AperyAnalyticExtension.extractHalf
        AperyAnalyticExtension.extractOne
  rw [AperyAnalyticExtension.toMinimalConnectionData_congr hF]

/-- **Ext-level extractHalf probe-swap symmetry.** Unconditional. -/
lemma AperyAnalyticExtension.extractHalf_swap
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.extractHalf ε₂ ε₁ = ext.extractHalf ε₁ ε₂ :=
  ext.toMinimalConnectionData.extractHalf_swap ε₁ ε₂

/-- **Ext-level extractOne probe-swap symmetry.** Unconditional. -/
lemma AperyAnalyticExtension.extractOne_swap
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.extractOne ε₂ ε₁ = ext.extractOne ε₁ ε₂ :=
  ext.toMinimalConnectionData.extractOne_swap ε₁ ε₂

/-- **Connection coefficients triple is invariant under probe swap.**
The regular slot is probe-independent; the half/one slots are
symmetric under swap by `extractHalf_swap`/`extractOne_swap`. -/
lemma AperyAnalyticExtension.connectionCoefficients_swap
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.connectionCoefficients ε₂ ε₁ = ext.connectionCoefficients ε₁ ε₂ := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact ext.extractHalf_swap ε₁ ε₂
  · exact ext.extractOne_swap ε₁ ε₂

/-- **Diagonal probes give the (extractRegular, 0/0, 0/0) degenerate
triple.** When `ε₁ = ε₂`, `aperyConnectionDet` vanishes (`_self`
lemma) so half/one extracts evaluate to `0/0 = 0`. The regular slot
remains `ext.F z₁`. -/
@[simp] lemma AperyAnalyticExtension.connectionCoefficients_diagonal
    (ext : AperyAnalyticExtension) (ε : ℝ) :
    ext.connectionCoefficients ε ε =
      (ext.F Number.aperyConifoldZ1Poly, 0, 0) := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · change ext.toMinimalConnectionData.extractHalf ε ε = 0
    unfold AperyConnectionData.extractHalf aperyExtractHalf
    simp
  · change ext.toMinimalConnectionData.extractOne ε ε = 0
    unfold AperyConnectionData.extractOne aperyExtractOne
    simp

/-- **Data-layer connection coefficients triple.** Same packaging as
the ext-layer version, but on `AperyConnectionData`. -/
noncomputable def AperyConnectionData.connectionCoefficients
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) : ℝ × ℝ × ℝ :=
  (d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂)

/-- **First slot is regular extract.** -/
@[simp] lemma AperyConnectionData.connectionCoefficients_fst
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    (d.connectionCoefficients ε₁ ε₂).1 = d.extractRegular := rfl

/-- **Second slot is half-branch extract.** -/
@[simp] lemma AperyConnectionData.connectionCoefficients_snd_fst
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    (d.connectionCoefficients ε₁ ε₂).2.1 = d.extractHalf ε₁ ε₂ := rfl

/-- **Third slot is one-branch extract.** -/
@[simp] lemma AperyConnectionData.connectionCoefficients_snd_snd
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    (d.connectionCoefficients ε₁ ε₂).2.2 = d.extractOne ε₁ ε₂ := rfl

/-- **Bridge: ext-layer coefficients via the underlying minimal data.**
Definitionally the ext-layer coefficients of `ext` are the data-layer
coefficients of `ext.toMinimalConnectionData`. -/
@[simp] lemma AperyAnalyticExtension.connectionCoefficients_eq_minimal
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.connectionCoefficients ε₁ ε₂ =
      ext.toMinimalConnectionData.connectionCoefficients ε₁ ε₂ := rfl

/-- **Data-layer coefficients agree from F-eq.** Two connection-data
witnesses with equal `F` produce the same triple at any probes. -/
lemma AperyConnectionData.connectionCoefficients_congr
    {d₁ d₂ : AperyConnectionData} (hF : d₁.F = d₂.F) (ε₁ ε₂ : ℝ) :
    d₁.connectionCoefficients ε₁ ε₂ = d₂.connectionCoefficients ε₁ ε₂ := by
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · exact AperyConnectionData.extractRegular_congr hF
  · exact AperyConnectionData.extractHalf_congr hF ε₁ ε₂
  · exact AperyConnectionData.extractOne_congr hF ε₁ ε₂

/-- **Data-layer coefficients probe-swap symmetry.** -/
lemma AperyConnectionData.connectionCoefficients_swap
    (d : AperyConnectionData) (ε₁ ε₂ : ℝ) :
    d.connectionCoefficients ε₂ ε₁ = d.connectionCoefficients ε₁ ε₂ := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact d.extractHalf_swap ε₁ ε₂
  · exact d.extractOne_swap ε₁ ε₂

/-- **Reconstruction via named coefficients.** Pointwise version of
`is_extract_triple` keyed by `connectionCoefficients` instead of the
three separate extracts. The shift-form `F (z₁ + t)` matches
`aperyBranchTriple` evaluated at the projections of the named triple. -/
lemma AperyConnectionData.F_shift_eq_branchTriple_via_coefficients
    (d : AperyConnectionData) {ε₁ ε₂ t : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ d.corridor) :
    d.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple
        (d.connectionCoefficients ε₁ ε₂).1
        (d.connectionCoefficients ε₁ ε₂).2.1
        (d.connectionCoefficients ε₁ ε₂).2.2 t :=
  d.F_shift_eq_extract_at hε₁ hε₂ hdet ht

/-- **Right-endpoint reconstruction via named coefficients.** Same as
`F_right_endpoint` but with the three extract values replaced by the
named coefficients triple. -/
lemma AperyConnectionData.F_right_endpoint_via_coefficients
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ d.corridor) :
    d.F (Number.aperyConifoldZ1Poly + (-ε)) =
      (d.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε +
        (d.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
        (d.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε :=
  d.F_right_endpoint hε₁ hε₂ hdet hε

/-- **`is_extract_triple` via named coefficients.** -/
lemma AperyConnectionData.is_extract_triple_via_coefficients
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn
        (d.connectionCoefficients ε₁ ε₂).1
        (d.connectionCoefficients ε₁ ε₂).2.1
        (d.connectionCoefficients ε₁ ε₂).2.2
        d.F d.corridor :=
  d.is_extract_triple hε₁ hε₂ hdet

/-- **Ext-layer right-endpoint reconstruction.** At `t = 0`, the
branch triple collapses to its first component (the regular extract),
which is `ext.F z₁`. Unconditional on probes (regular slot is
probe-independent). -/
lemma AperyAnalyticExtension.F_at_z1_eq_branchTriple_via_coefficients
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.F Number.aperyConifoldZ1Poly =
      aperyBranchTriple
        (ext.connectionCoefficients ε₁ ε₂).1
        (ext.connectionCoefficients ε₁ ε₂).2.1
        (ext.connectionCoefficients ε₁ ε₂).2.2 0 := by
  rw [aperyBranchTriple_at_zero]
  rfl

/-- **Ext-layer right-endpoint reconstruction (named-amplitude form).**
At `ε = 0` (`t = 0`), the named-amplitude form
`a₀·A_0(0) + a_½·A_½(0) + a₁·V_1(0)` reduces to `a₀ · 1 = ext.F z₁`. -/
lemma AperyAnalyticExtension.F_at_z1_eq_amplitudeForm_via_coefficients
    (ext : AperyAnalyticExtension) (ε₁ ε₂ : ℝ) :
    ext.F Number.aperyConifoldZ1Poly =
      (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero 0 +
        (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half 0 +
        (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one 0 := by
  rw [aperyBranchAmplitude_zero_at_zero, aperyBranchAmplitude_half_at_zero,
      aperyBranchValue_one_at_zero]
  show ext.F Number.aperyConifoldZ1Poly =
    (ext.connectionCoefficients ε₁ ε₂).1 * 1 + _ * 0 + _ * 0
  ring_nf
  rfl

/-- **Coefficients uniqueness on data layer.** Any user-supplied
witness triple `(a₀, a_half, a₁)` for `d.F` on `d.corridor` must equal
the Cramer-extracted `connectionCoefficients`. Lift of
`IsAperyConnectionCoeffsOn.eq_extract`. -/
lemma AperyConnectionData.connectionCoefficients_unique
    (d : AperyConnectionData) {a₀ a_half a₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = d.connectionCoefficients ε₁ ε₂ := by
  obtain ⟨h0, h_half, h_one⟩ := ha.eq_extract d.zero_mem hε₁ hε₂ hdet
  show (a₀, a_half, a₁) =
    (d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂)
  rw [h0, h_half, h_one]
  rfl

/-- **Coefficients are determined by the F-field and probes.** Two
witnesses for the same `f` on the same corridor produce the same
extracted triple (regardless of which witness is chosen). -/
lemma AperyConnectionData.connectionCoefficients_unique_witnesses
    (d : AperyConnectionData) {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ d.F d.corridor)
    (hb : IsAperyConnectionCoeffsOn b₀ b_half b₁ d.F d.corridor)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = (b₀, b_half, b₁) := by
  rw [d.connectionCoefficients_unique ha hε₁ hε₂ hdet,
      ← d.connectionCoefficients_unique hb hε₁ hε₂ hdet]

/-- **`of_witness` connectionCoefficients projection.** The coefficients
of an `of_witness`-built ConnectionData coincide with the ext-layer
coefficients of the underlying `ext`. -/
@[simp] lemma AperyConnectionData.of_witness_connectionCoefficients
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I) (ε₁ ε₂ : ℝ) :
    (AperyConnectionData.of_witness ext I h0 h).connectionCoefficients ε₁ ε₂ =
      ext.connectionCoefficients ε₁ ε₂ := rfl

/-- **Ext-layer coefficients uniqueness via a corridor witness.**
Given an analytic extension `ext` and an `IsAperyConnectionCoeffsOn`
witness `(a₀, a_half, a₁)` on a corridor `I` containing both probe
directions and `0`, the witness triple equals the ext-layer
`connectionCoefficients`. The witness's corridor is allowed to be
larger than `{0}`; we use it through `of_witness` to gain a real
ConnectionData and then apply data-layer uniqueness. -/
lemma AperyAnalyticExtension.connectionCoefficients_unique_via_witness
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    {a₀ a_half a₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = ext.connectionCoefficients ε₁ ε₂ := by
  have h_has : HasAperyConnectionCoeffsOn ext.F I := ha.hasAperyConnectionCoeffsOn
  have :=
    (AperyConnectionData.of_witness ext I h0 h_has).connectionCoefficients_unique
      ha hε₁ hε₂ hdet
  rw [this]
  rfl

/-- **Ext-layer coefficients form a valid `IsAperyConnectionCoeffsOn`
witness.** Given any Has-witness on a corridor `I` (containing `0` and
both probe directions, with `hdet ≠ 0`), the Cramer-extracted triple
itself satisfies the connection-coefficient predicate on `I`. -/
lemma AperyAnalyticExtension.coefficients_isAperyConnectionCoeffsOn
    (ext : AperyAnalyticExtension) (I : Set ℝ) (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    IsAperyConnectionCoeffsOn
      (ext.connectionCoefficients ε₁ ε₂).1
      (ext.connectionCoefficients ε₁ ε₂).2.1
      (ext.connectionCoefficients ε₁ ε₂).2.2
      ext.F I :=
  (AperyConnectionData.of_witness ext I h0 h).is_extract_triple_via_coefficients
    hε₁ hε₂ hdet

/-- **Ext-layer reconstruction on the witness corridor.** Pointwise
form: with a Has-witness on `I`, the shift-form `ext.F (z₁ + t)`
matches the branch triple at the named ext-layer coefficients for all
`t ∈ I`. -/
lemma AperyAnalyticExtension.F_shift_eq_branchTriple_via_coefficients_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple
        (ext.connectionCoefficients ε₁ ε₂).1
        (ext.connectionCoefficients ε₁ ε₂).2.1
        (ext.connectionCoefficients ε₁ ε₂).2.2 t :=
  ext.coefficients_isAperyConnectionCoeffsOn I h0 h hε₁ hε₂ hdet t ht

/-- **Ext-layer right-endpoint reconstruction (named-amplitude form,
on a witness corridor).** With a Has-witness on `I` containing `-ε`,
the value `ext.F (z₁ + (-ε))` decomposes as
`a₀·A_0(ε) + a_½·A_½(ε) + a₁·V_1(ε)` with `(a₀, a_½, a₁) =
ext.connectionCoefficients`. -/
lemma AperyAnalyticExtension.F_right_endpoint_via_coefficients_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + (-ε)) =
      (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε +
        (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
        (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε :=
  (AperyConnectionData.of_witness ext I h0 h).F_right_endpoint_via_coefficients
    hε₁ hε₂ hdet hε

/-- **Ext-layer reconstruction transfers across F-equality.** If two
ext's have the same F, they share the same connection coefficients,
and any pointwise reconstruction transfers from one to the other. -/
lemma AperyAnalyticExtension.F_shift_eq_branchTriple_transfer
    {ext₁ ext₂ : AperyAnalyticExtension} (hF : ext₁.F = ext₂.F)
    {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext₂.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I) :
    ext₁.F (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple
        (ext₂.connectionCoefficients ε₁ ε₂).1
        (ext₂.connectionCoefficients ε₁ ε₂).2.1
        (ext₂.connectionCoefficients ε₁ ε₂).2.2 t := by
  rw [show ext₁.F = ext₂.F from hF]
  exact ext₂.F_shift_eq_branchTriple_via_coefficients_on h0 h hε₁ hε₂ hdet ht

/-- **Ext-layer connection residual = singular part on witness corridor.**
With a Has-witness on `I` containing `-ε`, the ext-layer
`connectionResidual ε` equals the singular-branches contribution
`a_½·A_½(ε) + a₁·V_1(ε)`. -/
lemma AperyAnalyticExtension.connectionResidual_eq_singular_part_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I) :
    ext.connectionResidual ε =
      (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
        (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε := by
  have h_data := (AperyConnectionData.of_witness ext I h0 h).connectionResidual_eq_singular_part
    hε₁ hε₂ hdet hε
  -- of_witness's connectionResidual equals ext's connectionResidual
  -- since both delegate to aperyConnectionResidual ext.F ε
  exact h_data

/-- **Ext-layer connection residual vanishes when both singular extracts
are zero (on witness corridor).** -/
lemma AperyAnalyticExtension.connectionResidual_eq_zero_of_singular_zero_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hHalf : (ext.connectionCoefficients ε₁ ε₂).2.1 = 0)
    (hOne : (ext.connectionCoefficients ε₁ ε₂).2.2 = 0) :
    ext.connectionResidual ε = 0 := by
  rw [ext.connectionResidual_eq_singular_part_on h0 h hε₁ hε₂ hdet hε,
      hHalf, hOne]
  ring

/-- **Ext-layer GFA residual = singular part on disk overlap.**
Specialisation of `connectionResidual_eq_singular_part_on` to the
case where the probe `-ε` ALSO lands in the disk: the GFA-side
residual `aperyGFAReal(z₁−ε) − a₀·A_0(ε)` equals the singular part. -/
lemma AperyAnalyticExtension.GFA_residual_eq_singular_part_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε =
      (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
        (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε := by
  change aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
      ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε =
    (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
      (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε
  rw [← ext.connectionResidual_via_GFA hdisk]
  exact ext.connectionResidual_eq_singular_part_on h0 h hε₁ hε₂ hdet hε

/-- **Ext-layer GFA residual vanishes when both singular extracts are
zero (on disk overlap).** Direct corollary of
`GFA_residual_eq_singular_part_on` with the singular contribution
collapsed by the hypotheses. -/
lemma AperyAnalyticExtension.GFA_residual_eq_zero_of_singular_zero_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hHalf : (ext.connectionCoefficients ε₁ ε₂).2.1 = 0)
    (hOne : (ext.connectionCoefficients ε₁ ε₂).2.2 = 0) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
        (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε = 0 := by
  rw [ext.GFA_residual_eq_singular_part_on h0 h hε₁ hε₂ hdet hε hdisk,
      hHalf, hOne]
  ring

/-- **Ext-layer GFA value = regular branch on disk overlap when
singular extracts vanish.** Rearranged form of
`GFA_residual_eq_zero_of_singular_zero_on`: under the singular-vanish
hypothesis, `aperyGFAReal(z₁−ε) = a₀·A_0(ε)` exactly on the disk
overlap region. This is the structural meaning of "only the regular
branch contributes": the local series at `z₁` collapses to a regular
power series. -/
lemma AperyAnalyticExtension.GFA_eq_regular_branch_of_singular_zero_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hHalf : (ext.connectionCoefficients ε₁ ε₂).2.1 = 0)
    (hOne : (ext.connectionCoefficients ε₁ ε₂).2.2 = 0) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε := by
  have h_zero := ext.GFA_residual_eq_zero_of_singular_zero_on
    h0 h hε₁ hε₂ hdet hε hdisk hHalf hOne
  linarith

/-- **Ext-layer GFA reconstruction on disk overlap.** Combines
`F_right_endpoint_via_coefficients_on` (witness corridor) with
`agrees_on_small` (disk identification): on the overlap of the
witness corridor and the unconditional disk, the GFA value matches
the named-amplitude branch decomposition. -/
lemma AperyAnalyticExtension.GFA_eq_branchTriple_via_coefficients_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε +
        (ext.connectionCoefficients ε₁ ε₂).2.1 * aperyBranchAmplitude_half ε +
        (ext.connectionCoefficients ε₁ ε₂).2.2 * aperyBranchValue_one ε := by
  rw [← ext.F_eq_GFA_on_small hdisk]
  exact ext.F_right_endpoint_via_coefficients_on h0 h hε₁ hε₂ hdet hε

/-- **Ext-layer F reconstruction collapses to regular branch on the
witness corridor when both singular extracts vanish.** Pointwise
form: under singular-vanish, the witness corridor reconstruction at
`z₁ + (-ε)` reduces to `a₀·A_0(ε)` for every `-ε ∈ I`. -/
lemma AperyAnalyticExtension.F_right_endpoint_eq_regular_branch_of_singular_zero_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hε : (-ε) ∈ I)
    (hHalf : (ext.connectionCoefficients ε₁ ε₂).2.1 = 0)
    (hOne : (ext.connectionCoefficients ε₁ ε₂).2.2 = 0) :
    ext.F (Number.aperyConifoldZ1Poly + (-ε)) =
      (ext.connectionCoefficients ε₁ ε₂).1 * aperyBranchAmplitude_zero ε := by
  rw [ext.F_right_endpoint_via_coefficients_on h0 h hε₁ hε₂ hdet hε,
      hHalf, hOne]
  ring

/-- **Ext-layer half-extract probe invariance.** With a Has-witness on
`I` containing both probe pairs, the half-branch extract is independent
of the probe choice. -/
lemma AperyAnalyticExtension.extractHalf_probe_invariant_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε₁' ε₂' : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hε₁' : (-ε₁') ∈ I) (hε₂' : (-ε₂') ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdet' : aperyConnectionDet ε₁' ε₂' ≠ 0) :
    ext.extractHalf ε₁ ε₂ = ext.extractHalf ε₁' ε₂' :=
  (AperyConnectionData.of_witness ext I h0 h).extractHalf_probe_invariant
    hε₁ hε₂ hε₁' hε₂' hdet hdet'

/-- **Ext-layer one-extract probe invariance.** -/
lemma AperyAnalyticExtension.extractOne_probe_invariant_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε₁' ε₂' : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hε₁' : (-ε₁') ∈ I) (hε₂' : (-ε₂') ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdet' : aperyConnectionDet ε₁' ε₂' ≠ 0) :
    ext.extractOne ε₁ ε₂ = ext.extractOne ε₁' ε₂' :=
  (AperyConnectionData.of_witness ext I h0 h).extractOne_probe_invariant
    hε₁ hε₂ hε₁' hε₂' hdet hdet'

/-- **Ext-layer connectionCoefficients triple is probe-invariant.**
The full `(a₀, a_½, a₁)` bundle is intrinsic to the extension and the
witness, independent of which probe pair extracts the singular part.
The first component is always `ext.F z₁` (probe-independent by
construction); the latter two are probe-invariant by the data-layer
lemmas. -/
lemma AperyAnalyticExtension.connectionCoefficients_probe_invariant_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε₁' ε₂' : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hε₁' : (-ε₁') ∈ I) (hε₂' : (-ε₂') ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdet' : aperyConnectionDet ε₁' ε₂' ≠ 0) :
    ext.connectionCoefficients ε₁ ε₂ = ext.connectionCoefficients ε₁' ε₂' := by
  unfold AperyAnalyticExtension.connectionCoefficients
  refine Prod.ext rfl ?_
  refine Prod.ext ?_ ?_
  · exact ext.extractHalf_probe_invariant_on h0 h hε₁ hε₂ hε₁' hε₂' hdet hdet'
  · exact ext.extractOne_probe_invariant_on h0 h hε₁ hε₂ hε₁' hε₂' hdet hdet'

/-- **Ext-layer half-extract via GFA values on the disk.** When both
probes `-ε₁, -ε₂` land in the unconditional disk, the half-extract is
expressible directly via `aperyGFAReal` evaluations and `ext.F z₁`,
without needing the abstract `connectionResidual` wrapper. -/
lemma AperyAnalyticExtension.extractHalf_via_GFA_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractHalf ε₁ ε₂ =
      ((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₁) *
            aperyBranchValue_one ε₂ -
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₂) *
            aperyBranchValue_one ε₁) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [ext.extractHalf_eq_residual_form,
      ext.connectionResidual_via_GFA hdisk₁,
      ext.connectionResidual_via_GFA hdisk₂]

/-- **Ext-layer one-extract via GFA values on the disk.** Same as
`extractHalf_via_GFA_on_disk` but for the `V_1` branch coefficient. -/
lemma AperyAnalyticExtension.extractOne_via_GFA_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractOne ε₁ ε₂ =
      (-((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
            ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₁) *
              aperyBranchAmplitude_half ε₂) +
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₂) *
            aperyBranchAmplitude_half ε₁) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [ext.extractOne_eq_residual_form,
      ext.connectionResidual_via_GFA hdisk₁,
      ext.connectionResidual_via_GFA hdisk₂]

/-- **Ext-layer connectionCoefficients via GFA values on the disk.**
Triple-bundle form: when both probes hit the disk, all three
coefficients are expressible directly via GFA values plus `ext.F z₁`.
The first slot is `ext.F z₁` itself (probe-independent), the latter
two are the Cramer ratios of GFA-side residuals. -/
lemma AperyAnalyticExtension.connectionCoefficients_via_GFA_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.connectionCoefficients ε₁ ε₂ =
      (ext.F Number.aperyConifoldZ1Poly,
        ext.extractHalf ε₁ ε₂,
        ext.extractOne ε₁ ε₂) := by
  unfold AperyAnalyticExtension.connectionCoefficients
  rw [ext.extractRegular_eq]

/-- **Ext-layer connectionCoefficients fst slot determines `ext.F z₁`.**
Direct corollary of `extractRegular_eq` and `connectionCoefficients_fst`.
The `a₀` slot is *literally* the right-endpoint value, so two
extensions with equal `connectionCoefficients` triples necessarily
share the same `ext.F z₁`. -/
lemma AperyAnalyticExtension.F_at_z1_eq_of_connectionCoefficients_eq
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (h : ext₁.connectionCoefficients ε₁ ε₂ = ext₂.connectionCoefficients ε₁ ε₂) :
    ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly := by
  have h1 : (ext₁.connectionCoefficients ε₁ ε₂).1 =
      (ext₂.connectionCoefficients ε₁ ε₂).1 := by rw [h]
  simpa using h1

/-- **Ext-layer connectionCoefficients on disk overlap iff F-eq at z₁.**
Iff form combining `connectionCoefficients_eq_of_F_eq_at_z1_on_disk`
(backward) with `F_at_z1_eq_of_connectionCoefficients_eq` (forward).
On the disk overlap, two extensions share the same Cramer-extracted
connection coefficients exactly when their right-endpoint values
`ext.F z₁` agree — the disk-side GFA values being shared by
`agrees_on_small`. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_iff_F_eq_at_z1_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.connectionCoefficients ε₁ ε₂ = ext₂.connectionCoefficients ε₁ ε₂ ↔
      ext₁.F Number.aperyConifoldZ1Poly = ext₂.F Number.aperyConifoldZ1Poly := by
  refine ⟨fun h => ext₁.F_at_z1_eq_of_connectionCoefficients_eq ext₂ h, fun hF => ?_⟩
  exact ext₁.connectionCoefficients_eq_of_F_eq_at_z1_on_disk ext₂ hF hdisk₁ hdisk₂

/-- **Ext-layer half-extract is affine in `ext.F z₁` on disk.**
Splits `extractHalf` into the disk-only GFA-side baseline and the
`ext.F z₁`-dependent correction. Direct algebraic rearrangement of
`extractHalf_via_GFA_on_disk`. -/
lemma AperyAnalyticExtension.extractHalf_affine_in_F_at_z1_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractHalf ε₁ ε₂ =
      (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) * aperyBranchValue_one ε₂ -
          aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) * aperyBranchValue_one ε₁) /
          aperyConnectionDet ε₁ ε₂ -
        ext.F Number.aperyConifoldZ1Poly *
          ((aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₂ -
              aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₁) /
              aperyConnectionDet ε₁ ε₂) := by
  rw [ext.extractHalf_via_GFA_on_disk hdisk₁ hdisk₂]
  field_simp
  ring

/-- **Ext-layer one-extract is affine in `ext.F z₁` on disk.**
Companion of `extractHalf_affine_in_F_at_z1_on_disk`. The
`ext.F z₁`-dependent term has the opposite sign because of the
sign convention in the `aperyExtractOne` Cramer formula. -/
lemma AperyAnalyticExtension.extractOne_affine_in_F_at_z1_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractOne ε₁ ε₂ =
      (-(aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) *
              aperyBranchAmplitude_half ε₂) +
          aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) *
            aperyBranchAmplitude_half ε₁) /
          aperyConnectionDet ε₁ ε₂ +
        ext.F Number.aperyConifoldZ1Poly *
          ((aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₂ -
              aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₁) /
              aperyConnectionDet ε₁ ε₂) := by
  rw [ext.extractOne_via_GFA_on_disk hdisk₁ hdisk₂]
  field_simp
  ring

/-- **Ext-layer half-extract difference factors through F-at-z₁
difference on disk.** Direct corollary of
`extractHalf_affine_in_F_at_z1_on_disk` for two extensions: the
GFA-only baseline cancels (both use the same `aperyGFAReal`),
leaving only the right-endpoint-value difference times the
geometric multiplier. -/
lemma AperyAnalyticExtension.extractHalf_sub_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.extractHalf ε₁ ε₂ - ext₂.extractHalf ε₁ ε₂ =
      -((ext₁.F Number.aperyConifoldZ1Poly - ext₂.F Number.aperyConifoldZ1Poly) *
        (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₂ -
          aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₁)) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [ext₁.extractHalf_affine_in_F_at_z1_on_disk hdisk₁ hdisk₂,
      ext₂.extractHalf_affine_in_F_at_z1_on_disk hdisk₁ hdisk₂]
  ring

/-- **Ext-layer one-extract difference factors through F-at-z₁
difference on disk.** Companion of `extractHalf_sub_on_disk` with
`A_½` in place of `V_1`. -/
lemma AperyAnalyticExtension.extractOne_sub_on_disk
    (ext₁ ext₂ : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext₁.extractOne ε₁ ε₂ - ext₂.extractOne ε₁ ε₂ =
      -((ext₁.F Number.aperyConifoldZ1Poly - ext₂.F Number.aperyConifoldZ1Poly) *
        (aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₁ -
          aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₂)) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [ext₁.extractOne_affine_in_F_at_z1_on_disk hdisk₁ hdisk₂,
      ext₂.extractOne_affine_in_F_at_z1_on_disk hdisk₁ hdisk₂]
  ring

/-- **`IsAperyConnectionCoeffsOn` first slot equals `f` at `z₁`.** Any
witness triple `(a₀, a_½, a₁)` for `f` on a corridor containing `0`
must have `a₀ = f(z₁)`. Specialisation of the predicate at `t = 0`,
using `aperyBranchTriple_at_zero` to collapse the singular branches.
This is the predicate-level identity behind the data and ext layer
`F_at_z1 = extractRegular` simp lemmas. -/
lemma IsAperyConnectionCoeffsOn.fst_eq_f_at_z1
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) (h0 : (0 : ℝ) ∈ I) :
    f Number.aperyConifoldZ1Poly = a₀ := by
  have h_app := h 0 h0
  rw [add_zero, aperyBranchTriple_at_zero] at h_app
  exact h_app

/-- **Singular extracts vanish ⇒ witness collapses to regular branch
(predicate level).** Any `IsAperyConnectionCoeffsOn` witness with
`a_half = a₁ = 0` reduces to the pure-regular case
`f(z₁ + t) = a₀ · yAperyZero(1, t)`. -/
lemma IsAperyConnectionCoeffsOn.collapse_to_regular
    {a₀ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ 0 0 f I) :
    ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yAperyZero a₀ t := by
  intro t ht
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  have h_half : yAperyHalf 0 t = 0 := by
    have := yAperyHalf_smul_c₀ 0 1 t
    simp at this
    exact this
  have h_one : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 1 t
    simp at this
    exact this
  rw [h_half, h_one, add_zero, add_zero] at h_app
  exact h_app

/-- **Pure-half witness collapses to the half branch.** Companion of
`collapse_to_regular`: when `a₀ = a₁ = 0`, the witness reduces to
`f(z₁ + t) = yAperyHalf a_half t`. -/
lemma IsAperyConnectionCoeffsOn.collapse_to_half
    {a_half : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 a_half 0 f I) :
    ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yAperyHalf a_half t := by
  intro t ht
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  have h_zero : yAperyZero 0 t = 0 := by
    have := yAperyZero_smul_c₀ 0 1 t
    simp at this
    exact this
  have h_one : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 1 t
    simp at this
    exact this
  rw [h_zero, h_one, zero_add, add_zero] at h_app
  exact h_app

/-- **Pure-one witness collapses to the one branch.** Companion of
`collapse_to_regular`: when `a₀ = a_half = 0`, the witness reduces to
`f(z₁ + t) = yApery a₁ t`. -/
lemma IsAperyConnectionCoeffsOn.collapse_to_one
    {a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 0 a₁ f I) :
    ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yApery a₁ t := by
  intro t ht
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  have h_zero : yAperyZero 0 t = 0 := by
    have := yAperyZero_smul_c₀ 0 1 t
    simp at this
    exact this
  have h_half : yAperyHalf 0 t = 0 := by
    have := yAperyHalf_smul_c₀ 0 1 t
    simp at this
    exact this
  rw [h_zero, h_half, zero_add, zero_add] at h_app
  exact h_app

/-- **Pure-regular witness iff pointwise regular branch.** Combines
`collapse_to_regular` (forward) with `of_pure_regular` (backward).
A witness with both singular slots zero captures exactly the
"f restricted to the corridor right of z₁ is the regular branch"
condition. -/
lemma IsAperyConnectionCoeffsOn.pure_regular_iff
    {a₀ : ℝ} {f : ℝ → ℝ} {I : Set ℝ} :
    IsAperyConnectionCoeffsOn a₀ 0 0 f I ↔
      ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yAperyZero a₀ t :=
  ⟨fun h => h.collapse_to_regular,
    fun h => IsAperyConnectionCoeffsOn.of_pure_regular a₀ f I h⟩

/-- **Pure-half witness iff pointwise half branch.** -/
lemma IsAperyConnectionCoeffsOn.pure_half_iff
    {a_half : ℝ} {f : ℝ → ℝ} {I : Set ℝ} :
    IsAperyConnectionCoeffsOn 0 a_half 0 f I ↔
      ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yAperyHalf a_half t :=
  ⟨fun h => h.collapse_to_half,
    fun h => IsAperyConnectionCoeffsOn.of_pure_half a_half f I h⟩

/-- **Pure-one witness iff pointwise one branch.** -/
lemma IsAperyConnectionCoeffsOn.pure_one_iff
    {a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ} :
    IsAperyConnectionCoeffsOn 0 0 a₁ f I ↔
      ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = yApery a₁ t :=
  ⟨fun h => h.collapse_to_one,
    fun h => IsAperyConnectionCoeffsOn.of_pure_one a₁ f I h⟩

/-- **Subtracting the regular branch zeroes the regular slot.** Given
any `(a₀, a_half, a₁)` witness for `f` on `I`, subtracting the regular
branch `aperyRegularPartShift a₀` (the canonical
`yAperyZero a₀ (z − z₁)`) yields a `(0, a_half, a₁)` witness for the
difference. Reduces a general witness to a pure-singular witness. -/
lemma IsAperyConnectionCoeffsOn.sub_regular
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) :
    IsAperyConnectionCoeffsOn 0 a_half a₁
      (fun z => f z - yAperyZero a₀ (z - Number.aperyConifoldZ1Poly)) I := by
  have hreg : IsAperyConnectionCoeffsOn a₀ 0 0
      (fun z => yAperyZero a₀ (z - Number.aperyConifoldZ1Poly)) I := by
    apply IsAperyConnectionCoeffsOn.of_pure_regular
    intro t _
    simp
  have hsub := h.sub hreg
  simp only [sub_zero, sub_self] at hsub
  exact hsub

/-- **Subtracting the half branch zeroes the half slot.** Companion of
`sub_regular`. -/
lemma IsAperyConnectionCoeffsOn.sub_half
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) :
    IsAperyConnectionCoeffsOn a₀ 0 a₁
      (fun z => f z - yAperyHalf a_half (z - Number.aperyConifoldZ1Poly)) I := by
  have hhalf : IsAperyConnectionCoeffsOn 0 a_half 0
      (fun z => yAperyHalf a_half (z - Number.aperyConifoldZ1Poly)) I := by
    apply IsAperyConnectionCoeffsOn.of_pure_half
    intro t _
    simp
  have hsub := h.sub hhalf
  simp only [sub_zero, sub_self] at hsub
  exact hsub

/-- **Subtracting the one branch zeroes the one slot.** Companion of
`sub_regular`. -/
lemma IsAperyConnectionCoeffsOn.sub_one
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) :
    IsAperyConnectionCoeffsOn a₀ a_half 0
      (fun z => f z - yApery a₁ (z - Number.aperyConifoldZ1Poly)) I := by
  have hone : IsAperyConnectionCoeffsOn 0 0 a₁
      (fun z => yApery a₁ (z - Number.aperyConifoldZ1Poly)) I := by
    apply IsAperyConnectionCoeffsOn.of_pure_one
    intro t _
    simp
  have hsub := h.sub hone
  simp only [sub_zero, sub_self] at hsub
  exact hsub

/-- **Full witness decomposition.** Chaining `sub_regular`, `sub_half`,
and `sub_one`: subtracting all three pure branches from a connection
witness yields a `(0, 0, 0)` witness for the residual function. -/
lemma IsAperyConnectionCoeffsOn.sub_all
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) :
    IsAperyConnectionCoeffsOn 0 0 0
      (fun z => f z - yAperyZero a₀ (z - Number.aperyConifoldZ1Poly)
                    - yAperyHalf a_half (z - Number.aperyConifoldZ1Poly)
                    - yApery a₁ (z - Number.aperyConifoldZ1Poly)) I :=
  ((h.sub_regular).sub_half).sub_one

/-- **Pointwise zero residual from full decomposition.** A `(0, 0, 0)`
witness collapses to `f (z₁ + t) = 0` on `I`, since each pure branch
vanishes at zero seed. -/
lemma IsAperyConnectionCoeffsOn.eq_zero_of_pure_zero
    {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn 0 0 0 f I) :
    ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) = 0 := by
  intro t ht
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  have h0 : yAperyZero 0 t = 0 := by
    have := yAperyZero_smul_c₀ 0 1 t
    simp at this
    exact this
  have h_half : yAperyHalf 0 t = 0 := by
    have := yAperyHalf_smul_c₀ 0 1 t
    simp at this
    exact this
  have h_one : yApery 0 t = 0 := by
    have := yApery_smul_c₀ 0 1 t
    simp at this
    exact this
  rw [h0, h_half, h_one] at h_app
  linarith

/-- **Full decomposition at the value level.** Applying `sub_all` and
`eq_zero_of_pure_zero` together: a connection witness implies
`f (z₁ + t) = yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t`
on the corridor (an unfolded restatement of the predicate). -/
lemma IsAperyConnectionCoeffsOn.f_decomposes
    {a₀ a_half a₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (h : IsAperyConnectionCoeffsOn a₀ a_half a₁ f I) :
    ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t := by
  intro t ht
  have h_app := h t ht
  unfold aperyBranchTriple at h_app
  exact h_app

/-- **Data-layer explicit decomposition.** Lifts `f_decomposes` to
`AperyConnectionData`: on the corridor, `F (z₁ + t)` equals the
explicit Frobenius branch sum with extracted seed coefficients. -/
lemma AperyConnectionData.F_decomposes
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    ∀ t ∈ d.corridor, d.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t
        + yAperyHalf (d.extractHalf ε₁ ε₂) t
        + yApery (d.extractOne ε₁ ε₂) t := by
  intro t ht
  have h := d.shifted_eq_extract hε₁ hε₂ hdet ht
  unfold aperyBranchTriple at h
  exact h

/-- **Data-layer subtraction-zero form.** Equivalent reformulation of
`F_decomposes`: subtracting all three Frobenius branches from `F (z₁+t)`
gives zero on the corridor. -/
lemma AperyConnectionData.F_sub_branches_eq_zero
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    ∀ t ∈ d.corridor,
      d.F (Number.aperyConifoldZ1Poly + t)
        - yAperyZero d.extractRegular t
        - yAperyHalf (d.extractHalf ε₁ ε₂) t
        - yApery (d.extractOne ε₁ ε₂) t = 0 := by
  intro t ht
  have h := d.F_decomposes hε₁ hε₂ hdet t ht
  linarith

/-- **Ext-layer Frobenius-branch decomposition on a witness corridor.**
Unfolded form of `F_shift_eq_branchTriple_via_coefficients_on`: writes
`ext.F (z₁ + t)` as the explicit `Y₀ + Y_{1/2} + Y₁` sum with
extracted seed coefficients. -/
lemma AperyAnalyticExtension.F_decomposes_via_coefficients_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero (ext.connectionCoefficients ε₁ ε₂).1 t
        + yAperyHalf (ext.connectionCoefficients ε₁ ε₂).2.1 t
        + yApery (ext.connectionCoefficients ε₁ ε₂).2.2 t := by
  have h_branch :=
    ext.F_shift_eq_branchTriple_via_coefficients_on h0 h hε₁ hε₂ hdet ht
  unfold aperyBranchTriple at h_branch
  exact h_branch

/-- **Ext-layer subtraction-zero reformulation.** The three Frobenius
branches subtracted from `ext.F (z₁ + t)` give zero on the corridor. -/
lemma AperyAnalyticExtension.F_sub_branches_eq_zero_via_coefficients_on
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I) :
    ext.F (Number.aperyConifoldZ1Poly + t)
      - yAperyZero (ext.connectionCoefficients ε₁ ε₂).1 t
      - yAperyHalf (ext.connectionCoefficients ε₁ ε₂).2.1 t
      - yApery (ext.connectionCoefficients ε₁ ε₂).2.2 t = 0 := by
  have h_dec := ext.F_decomposes_via_coefficients_on h0 h hε₁ hε₂ hdet ht
  linarith

/-- **Disk-overlap Frobenius-branch decomposition.** Combining
`F_decomposes_via_coefficients_on` with `F_eq_GFA_on_small`: on the
disk overlap, the GFA itself decomposes as the explicit
`Y₀ + Y_{1/2} + Y₁` sum at the ext-layer extracted coefficients. -/
lemma AperyAnalyticExtension.GFA_decomposes_via_coefficients_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      yAperyZero (ext.connectionCoefficients ε₁ ε₂).1 t
        + yAperyHalf (ext.connectionCoefficients ε₁ ε₂).2.1 t
        + yApery (ext.connectionCoefficients ε₁ ε₂).2.2 t := by
  rw [← ext.F_eq_GFA_on_small hdisk]
  exact ext.F_decomposes_via_coefficients_on h0 h hε₁ hε₂ hdet ht

/-- **Inversion (predicate level).** Given an explicit Frobenius
branch decomposition `f (z₁ + t) = yAperyZero b₀ t + yAperyHalf b_half t
+ yApery b₁ t` on `I`, `f` satisfies `IsAperyConnectionCoeffsOn` with
seed `(b₀, b_half, b₁)`. The hypothesis-folding direction. -/
lemma IsAperyConnectionCoeffsOn.of_F_decomposes
    {b₀ b_half b₁ : ℝ} {f : ℝ → ℝ} {I : Set ℝ}
    (hF : ∀ t ∈ I, f (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t) :
    IsAperyConnectionCoeffsOn b₀ b_half b₁ f I := by
  intro t ht
  rw [hF t ht]
  unfold aperyBranchTriple
  rfl

/-- **Inversion (ext layer).** If `ext.F (z₁ + t) = yAperyZero b₀ t +
yAperyHalf b_half t + yApery b₁ t` on a corridor `I` containing `0` and
both probe directions, then `(b₀, b_half, b₁)` equals the ext-layer
connection coefficients at any non-degenerate probe pair. Recovers
the seed triple from the decomposition. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_of_F_decomposes
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (b₀, b_half, b₁) = ext.connectionCoefficients ε₁ ε₂ :=
  ext.connectionCoefficients_unique_via_witness I h0
    (IsAperyConnectionCoeffsOn.of_F_decomposes hF) hε₁ hε₂ hdet

/-- **Componentwise inversion.** Pulls each named extract value out of
`connectionCoefficients_eq_of_F_decomposes`. -/
lemma AperyAnalyticExtension.extracts_eq_of_F_decomposes
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    ext.extractRegular = b₀ ∧
      ext.extractHalf ε₁ ε₂ = b_half ∧
        ext.extractOne ε₁ ε₂ = b₁ := by
  have h_eq :=
    ext.connectionCoefficients_eq_of_F_decomposes h0 hF hε₁ hε₂ hdet
  have h_fst : (b₀, b_half, b₁).1 = (ext.connectionCoefficients ε₁ ε₂).1 :=
    congrArg Prod.fst h_eq
  have h_snd_fst :
      (b₀, b_half, b₁).2.1 = (ext.connectionCoefficients ε₁ ε₂).2.1 :=
    congrArg (fun p => p.2.1) h_eq
  have h_snd_snd :
      (b₀, b_half, b₁).2.2 = (ext.connectionCoefficients ε₁ ε₂).2.2 :=
    congrArg (fun p => p.2.2) h_eq
  refine ⟨?_, ?_, ?_⟩
  · simpa using h_fst.symm
  · simpa using h_snd_fst.symm
  · simpa using h_snd_snd.symm

/-- **Connection-data constructor from explicit Frobenius sum.** Given
an analytic extension whose `F` decomposes as the explicit
`Y₀ + Y_{1/2} + Y₁` form on `I` (containing `0`), produces an
`AperyConnectionData` with corridor `I`. -/
noncomputable def AperyAnalyticExtension.connectionDataOfDecomposition
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t) :
    AperyConnectionData :=
  AperyConnectionData.of_witness ext I h0
    (IsAperyConnectionCoeffsOn.of_F_decomposes hF).hasAperyConnectionCoeffsOn

/-- **Constructor corridor.** -/
@[simp] lemma AperyAnalyticExtension.connectionDataOfDecomposition_corridor
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t) :
    (ext.connectionDataOfDecomposition h0 hF).corridor = I := rfl

/-- **Constructor F.** -/
@[simp] lemma AperyAnalyticExtension.connectionDataOfDecomposition_F
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t) :
    (ext.connectionDataOfDecomposition h0 hF).F = ext.F := rfl

/-- **Constructor extractRegular.** Evaluating the decomposition at
`t = 0` (and using `yAperyHalf_at_zero`, `yApery_at_zero`) shows that
`ext.F z₁ = b₀`, which is exactly the regular extract. -/
@[simp] lemma AperyAnalyticExtension.connectionDataOfDecomposition_extractRegular
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t) :
    (ext.connectionDataOfDecomposition h0 hF).extractRegular = b₀ := by
  have h_at_0 := hF 0 h0
  simp at h_at_0
  exact h_at_0

/-- **Constructor extractHalf.** With non-degenerate Cramer determinant
at probes inside the corridor, the half-branch extract equals the
prescribed `b_half` seed. -/
lemma AperyAnalyticExtension.connectionDataOfDecomposition_extractHalf
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (ext.connectionDataOfDecomposition h0 hF).extractHalf ε₁ ε₂ = b_half :=
  (ext.extracts_eq_of_F_decomposes h0 hF hε₁ hε₂ hdet).2.1

/-- **Constructor extractOne.** Companion of `_extractHalf`. -/
lemma AperyAnalyticExtension.connectionDataOfDecomposition_extractOne
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ : ℝ}
    (hF : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (ext.connectionDataOfDecomposition h0 hF).extractOne ε₁ ε₂ = b₁ :=
  (ext.extracts_eq_of_F_decomposes h0 hF hε₁ hε₂ hdet).2.2

/-- **Decomposition uniqueness (triple form).** Two explicit
`Y₀ + Y_{1/2} + Y₁` decompositions of the same `ext.F` on the same
corridor have identical seed triples. -/
lemma AperyAnalyticExtension.F_decomposition_eq
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ b₀' b_half' b₁' : ℝ}
    (hF₁ : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    (hF₂ : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀' t + yAperyHalf b_half' t + yApery b₁' t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (b₀, b_half, b₁) = (b₀', b_half', b₁') := by
  have h1 := ext.connectionCoefficients_eq_of_F_decomposes h0 hF₁ hε₁ hε₂ hdet
  have h2 := ext.connectionCoefficients_eq_of_F_decomposes h0 hF₂ hε₁ hε₂ hdet
  exact h1.trans h2.symm

/-- **Decomposition uniqueness (componentwise form).** Splits
`F_decomposition_eq` into three scalar equalities. -/
lemma AperyAnalyticExtension.F_decomposition_unique
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {b₀ b_half b₁ b₀' b_half' b₁' : ℝ}
    (hF₁ : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    (hF₂ : ∀ t ∈ I, ext.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀' t + yAperyHalf b_half' t + yApery b₁' t)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    b₀ = b₀' ∧ b_half = b_half' ∧ b₁ = b₁' := by
  have h_eq := ext.F_decomposition_eq h0 hF₁ hF₂ hε₁ hε₂ hdet
  refine ⟨?_, ?_, ?_⟩
  · exact congrArg Prod.fst h_eq
  · exact congrArg (fun p => p.2.1) h_eq
  · exact congrArg (fun p => p.2.2) h_eq

/-- **Predicate-level seed uniqueness.** Two
`IsAperyConnectionCoeffsOn` witnesses for the same `ext.F` on the
same corridor share the same seed triple. -/
lemma IsAperyConnectionCoeffsOn.eq_seeds_via_ext
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    (hb : IsAperyConnectionCoeffsOn b₀ b_half b₁ ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = (b₀, b_half, b₁) := by
  have h1 := ext.connectionCoefficients_unique_via_witness I h0 ha hε₁ hε₂ hdet
  have h2 := ext.connectionCoefficients_unique_via_witness I h0 hb hε₁ hε₂ hdet
  exact h1.trans h2.symm

/-- **Witness corridor restriction (mono).** If a witness holds on `I`
and `J ⊆ I` still contains `0` and the probe directions, the
ext-layer connection coefficients are recovered from the restricted
witness on `J` exactly as from the unrestricted one. -/
lemma AperyAnalyticExtension.connectionCoefficients_witness_mono
    (ext : AperyAnalyticExtension) {I J : Set ℝ} (hJI : J ⊆ I)
    (h0J : (0 : ℝ) ∈ J)
    {a₀ a_half a₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ J) (hε₂ : (-ε₂) ∈ J)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = ext.connectionCoefficients ε₁ ε₂ :=
  ext.connectionCoefficients_unique_via_witness J h0J (ha.mono hJI)
    hε₁ hε₂ hdet

/-- **Cross-corridor witness consistency.** Two
`IsAperyConnectionCoeffsOn` witnesses for the same `ext.F` on
possibly different corridors `I₁`, `I₂`, each containing the same
probe directions and `0`, must yield identical seed triples. -/
lemma AperyAnalyticExtension.connectionCoefficients_witness_consistent
    (ext : AperyAnalyticExtension)
    {I₁ I₂ : Set ℝ} (h0₁ : (0 : ℝ) ∈ I₁) (h0₂ : (0 : ℝ) ∈ I₂)
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I₁)
    (hb : IsAperyConnectionCoeffsOn b₀ b_half b₁ ext.F I₂)
    {ε₁ ε₂ : ℝ}
    (hε₁₁ : (-ε₁) ∈ I₁) (hε₂₁ : (-ε₂) ∈ I₁)
    (hε₁₂ : (-ε₁) ∈ I₂) (hε₂₂ : (-ε₂) ∈ I₂)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = (b₀, b_half, b₁) := by
  have h1 := ext.connectionCoefficients_unique_via_witness I₁ h0₁ ha hε₁₁ hε₂₁ hdet
  have h2 := ext.connectionCoefficients_unique_via_witness I₂ h0₂ hb hε₁₂ hε₂₂ hdet
  exact h1.trans h2.symm

/-- **Cross-corridor componentwise consistency.** Splits
`connectionCoefficients_witness_consistent` into three scalar
equalities. -/
lemma AperyAnalyticExtension.witness_seeds_consistent
    (ext : AperyAnalyticExtension)
    {I₁ I₂ : Set ℝ} (h0₁ : (0 : ℝ) ∈ I₁) (h0₂ : (0 : ℝ) ∈ I₂)
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (ha : IsAperyConnectionCoeffsOn a₀ a_half a₁ ext.F I₁)
    (hb : IsAperyConnectionCoeffsOn b₀ b_half b₁ ext.F I₂)
    {ε₁ ε₂ : ℝ}
    (hε₁₁ : (-ε₁) ∈ I₁) (hε₂₁ : (-ε₂) ∈ I₁)
    (hε₁₂ : (-ε₁) ∈ I₂) (hε₂₂ : (-ε₂) ∈ I₂)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    a₀ = b₀ ∧ a_half = b_half ∧ a₁ = b₁ := by
  have h_eq := ext.connectionCoefficients_witness_consistent
    h0₁ h0₂ ha hb hε₁₁ hε₂₁ hε₁₂ hε₂₂ hdet
  refine ⟨?_, ?_, ?_⟩
  · exact congrArg Prod.fst h_eq
  · exact congrArg (fun p => p.2.1) h_eq
  · exact congrArg (fun p => p.2.2) h_eq

/-- **F-pullback invariance on a corridor.** If two ext objects'
`F` fields agree on `z₁ + I` (with `I` containing `0` and both probe
directions), their connection coefficients at those probes agree. Only
three values of `F` are actually used (at `z₁`, `z₁ + (-ε₁)`,
`z₁ + (-ε₂)`); the corridor framing keeps the statement uniform. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_of_F_eq_on_corridor
    {ext₁ ext₂ : AperyAnalyticExtension} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hF : ∀ t ∈ I, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      ext₂.F (Number.aperyConifoldZ1Poly + t)) :
    ext₁.connectionCoefficients ε₁ ε₂ = ext₂.connectionCoefficients ε₁ ε₂ := by
  have hF0 : ext₁.F Number.aperyConifoldZ1Poly =
      ext₂.F Number.aperyConifoldZ1Poly := by
    have := hF 0 h0
    rwa [add_zero] at this
  have hFε₁ := hF (-ε₁) hε₁
  have hFε₂ := hF (-ε₂) hε₂
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · simp [AperyAnalyticExtension.connectionCoefficients,
      AperyAnalyticExtension.extractRegular_eq, hF0]
  · change aperyExtractHalf ext₁.F ε₁ ε₂ = aperyExtractHalf ext₂.F ε₁ ε₂
    unfold aperyExtractHalf aperyConnectionResidual
    rw [hF0, hFε₁, hFε₂]
  · change aperyExtractOne ext₁.F ε₁ ε₂ = aperyExtractOne ext₂.F ε₁ ε₂
    unfold aperyExtractOne aperyConnectionResidual
    rw [hF0, hFε₁, hFε₂]

/-- **Componentwise F-pullback invariance.** Splits
`connectionCoefficients_eq_of_F_eq_on_corridor` into the three named
extracts. -/
lemma AperyAnalyticExtension.extracts_eq_of_F_eq_on_corridor
    {ext₁ ext₂ : AperyAnalyticExtension} {I : Set ℝ}
    (h0 : (0 : ℝ) ∈ I)
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hF : ∀ t ∈ I, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      ext₂.F (Number.aperyConifoldZ1Poly + t)) :
    ext₁.extractRegular = ext₂.extractRegular ∧
      ext₁.extractHalf ε₁ ε₂ = ext₂.extractHalf ε₁ ε₂ ∧
        ext₁.extractOne ε₁ ε₂ = ext₂.extractOne ε₁ ε₂ := by
  have h_eq :=
    AperyAnalyticExtension.connectionCoefficients_eq_of_F_eq_on_corridor
      h0 hε₁ hε₂ hF
  refine ⟨?_, ?_, ?_⟩
  · exact congrArg Prod.fst h_eq
  · exact congrArg (fun p => p.2.1) h_eq
  · exact congrArg (fun p => p.2.2) h_eq

/-- **Same-corridor cross-ext decomposition equality.** Two ext objects
whose `F` agrees on a corridor `I` and which both admit explicit
Frobenius-sum decompositions on `I` must share the same seed triple. -/
lemma AperyAnalyticExtension.decomposition_eq_under_F_eq_on_corridor
    {ext₁ ext₂ : AperyAnalyticExtension} {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (hF₁ : ∀ t ∈ I, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t)
    (hF₂ : ∀ t ∈ I, ext₂.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    (hF_eq : ∀ t ∈ I, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      ext₂.F (Number.aperyConifoldZ1Poly + t))
    {ε₁ ε₂ : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    (a₀, a_half, a₁) = (b₀, b_half, b₁) := by
  have hF₂' : ∀ t ∈ I, ext₂.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t := by
    intro t ht
    rw [← hF_eq t ht, hF₁ t ht]
  exact ext₂.F_decomposition_eq h0 hF₂' hF₂ hε₁ hε₂ hdet

/-- **General cross-ext decomposition equality.** Each ext object has
its own corridor (`I₁`, `I₂`) and decomposition; their `F`s agree on a
third corridor `J` containing `0` and both probe directions. The seed
triples of the two decompositions then coincide. Combines
`connectionCoefficients_eq_of_F_decomposes` with
`connectionCoefficients_eq_of_F_eq_on_corridor`. -/
lemma AperyAnalyticExtension.decomposition_eq_cross_corridor
    {ext₁ ext₂ : AperyAnalyticExtension}
    {I₁ I₂ : Set ℝ} (h0₁ : (0 : ℝ) ∈ I₁) (h0₂ : (0 : ℝ) ∈ I₂)
    {a₀ a_half a₁ b₀ b_half b₁ : ℝ}
    (hF₁ : ∀ t ∈ I₁, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero a₀ t + yAperyHalf a_half t + yApery a₁ t)
    (hF₂ : ∀ t ∈ I₂, ext₂.F (Number.aperyConifoldZ1Poly + t) =
      yAperyZero b₀ t + yAperyHalf b_half t + yApery b₁ t)
    {ε₁ ε₂ : ℝ}
    (hε₁₁ : (-ε₁) ∈ I₁) (hε₂₁ : (-ε₂) ∈ I₁)
    (hε₁₂ : (-ε₁) ∈ I₂) (hε₂₂ : (-ε₂) ∈ I₂)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {J : Set ℝ} (h0J : (0 : ℝ) ∈ J)
    (hε₁J : (-ε₁) ∈ J) (hε₂J : (-ε₂) ∈ J)
    (hF_eq : ∀ t ∈ J, ext₁.F (Number.aperyConifoldZ1Poly + t) =
      ext₂.F (Number.aperyConifoldZ1Poly + t)) :
    (a₀, a_half, a₁) = (b₀, b_half, b₁) := by
  have h₁ := ext₁.connectionCoefficients_eq_of_F_decomposes h0₁ hF₁ hε₁₁ hε₂₁ hdet
  have h₂ := ext₂.connectionCoefficients_eq_of_F_decomposes h0₂ hF₂ hε₁₂ hε₂₂ hdet
  have h_coeff :=
    AperyAnalyticExtension.connectionCoefficients_eq_of_F_eq_on_corridor
      h0J hε₁J hε₂J hF_eq
  exact h₁.trans (h_coeff.trans h₂.symm)

/-- **Canonical half-branch extract (parameterised by a chosen value
`c₀` for `F z₁`).** Factors the ext-dependence out of the disk-form
`extractHalf_via_GFA_on_disk`: only `c₀` and the GFA itself enter. -/
noncomputable def aperyCanonicalExtractHalf (c₀ ε₁ ε₂ : ℝ) : ℝ :=
  ((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
        c₀ * aperyBranchAmplitude_zero ε₁) *
          aperyBranchValue_one ε₂ -
      (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
        c₀ * aperyBranchAmplitude_zero ε₂) *
          aperyBranchValue_one ε₁) /
      aperyConnectionDet ε₁ ε₂

/-- **Canonical one-branch extract.** Companion of
`aperyCanonicalExtractHalf`. -/
noncomputable def aperyCanonicalExtractOne (c₀ ε₁ ε₂ : ℝ) : ℝ :=
  (-((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
        c₀ * aperyBranchAmplitude_zero ε₁) *
          aperyBranchAmplitude_half ε₂) +
      (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
        c₀ * aperyBranchAmplitude_zero ε₂) *
          aperyBranchAmplitude_half ε₁) /
      aperyConnectionDet ε₁ ε₂

/-- **Ext-layer extractHalf factors through canonical form on disk.**
When both probes land in the disk, the ext-layer extract equals the
canonical extract at `c₀ = ext.F z₁`. -/
lemma AperyAnalyticExtension.extractHalf_eq_canonical_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractHalf ε₁ ε₂ =
      aperyCanonicalExtractHalf (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂ := by
  rw [ext.extractHalf_via_GFA_on_disk hdisk₁ hdisk₂]
  rfl

/-- **Ext-layer extractOne factors through canonical form on disk.**
Companion of `extractHalf_eq_canonical_on_disk`. -/
lemma AperyAnalyticExtension.extractOne_eq_canonical_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.extractOne ε₁ ε₂ =
      aperyCanonicalExtractOne (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂ := by
  rw [ext.extractOne_via_GFA_on_disk hdisk₁ hdisk₂]
  rfl

/-- **Canonical Apéry connection coefficients triple.** Bundles the
seed `c₀ = F z₁` and the canonical Half / One extracts into the
familiar `(a₀, a_½, a₁)` triple shape, parameterised purely by `c₀`
and the probe pair. -/
noncomputable def aperyCanonicalConnectionCoefficients
    (c₀ ε₁ ε₂ : ℝ) : ℝ × ℝ × ℝ :=
  (c₀, aperyCanonicalExtractHalf c₀ ε₁ ε₂,
    aperyCanonicalExtractOne c₀ ε₁ ε₂)

/-- **First slot is the seed.** -/
@[simp] lemma aperyCanonicalConnectionCoefficients_fst
    (c₀ ε₁ ε₂ : ℝ) :
    (aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂).1 = c₀ := rfl

/-- **Second slot is the canonical half-extract.** -/
@[simp] lemma aperyCanonicalConnectionCoefficients_snd_fst
    (c₀ ε₁ ε₂ : ℝ) :
    (aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂).2.1 =
      aperyCanonicalExtractHalf c₀ ε₁ ε₂ := rfl

/-- **Third slot is the canonical one-extract.** -/
@[simp] lemma aperyCanonicalConnectionCoefficients_snd_snd
    (c₀ ε₁ ε₂ : ℝ) :
    (aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂).2.2 =
      aperyCanonicalExtractOne c₀ ε₁ ε₂ := rfl

/-- **Ext-layer connectionCoefficients factors through canonical form
on disk.** When both probes hit the disk, the ext-layer triple equals
the canonical triple at `c₀ = ext.F z₁`. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_canonical_on_disk
    (ext : AperyAnalyticExtension) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.connectionCoefficients ε₁ ε₂ =
      aperyCanonicalConnectionCoefficients
        (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂ := by
  refine Prod.ext ?_ (Prod.ext ?_ ?_)
  · simp [AperyAnalyticExtension.extractRegular_eq]
  · exact ext.extractHalf_eq_canonical_on_disk hdisk₁ hdisk₂
  · exact ext.extractOne_eq_canonical_on_disk hdisk₁ hdisk₂

/-- **Canonical triple is injective in the seed.** Two canonical
connection coefficient triples at the same probe pair agree iff they
share `c₀` (forward via fst projection). -/
@[simp] lemma aperyCanonicalConnectionCoefficients_eq_iff
    {c₀ c₀' ε₁ ε₂ : ℝ} :
    aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂ =
        aperyCanonicalConnectionCoefficients c₀' ε₁ ε₂ ↔ c₀ = c₀' := by
  constructor
  · intro h
    have := congrArg Prod.fst h
    simpa using this
  · intro h
    subst h
    rfl

/-- **Ext × canonical iff on disk.** The ext-layer connection
coefficients equal a canonical triple at seed `c₀` iff `ext.F z₁ = c₀`.
Sharpens `connectionCoefficients_eq_canonical_on_disk` into an iff. -/
lemma AperyAnalyticExtension.connectionCoefficients_eq_canonical_iff_F_at_z1
    (ext : AperyAnalyticExtension) {c₀ ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    ext.connectionCoefficients ε₁ ε₂ =
        aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂ ↔
      ext.F Number.aperyConifoldZ1Poly = c₀ := by
  rw [ext.connectionCoefficients_eq_canonical_on_disk hdisk₁ hdisk₂,
      aperyCanonicalConnectionCoefficients_eq_iff]

/-- **Canonical half-extract is symmetric under probe swap.** Mirrors
`aperyExtractHalf_swap` at the canonical layer; pure algebra in the
`(c₀, ε₁, ε₂)` triple — ext-independent. -/
lemma aperyCanonicalExtractHalf_swap (c₀ ε₁ ε₂ : ℝ) :
    aperyCanonicalExtractHalf c₀ ε₂ ε₁ = aperyCanonicalExtractHalf c₀ ε₁ ε₂ := by
  unfold aperyCanonicalExtractHalf
  rw [aperyConnectionDet_swap, div_neg, ← neg_div]
  congr 1
  ring

/-- **Canonical one-extract is symmetric under probe swap.** Companion
of `aperyCanonicalExtractHalf_swap`. -/
lemma aperyCanonicalExtractOne_swap (c₀ ε₁ ε₂ : ℝ) :
    aperyCanonicalExtractOne c₀ ε₂ ε₁ = aperyCanonicalExtractOne c₀ ε₁ ε₂ := by
  unfold aperyCanonicalExtractOne
  rw [aperyConnectionDet_swap, div_neg, ← neg_div]
  congr 1
  ring

/-- **Canonical triple is invariant under probe swap.** The seed `c₀`
slot is probe-independent; the half/one slots use the canonical-layer
swap symmetry. -/
lemma aperyCanonicalConnectionCoefficients_swap (c₀ ε₁ ε₂ : ℝ) :
    aperyCanonicalConnectionCoefficients c₀ ε₂ ε₁ =
      aperyCanonicalConnectionCoefficients c₀ ε₁ ε₂ := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact aperyCanonicalExtractHalf_swap c₀ ε₁ ε₂
  · exact aperyCanonicalExtractOne_swap c₀ ε₁ ε₂

/-- **Canonical half-extract vanishes on diagonal probes.** When
`ε₁ = ε₂ = ε`, the numerator is identically zero (by ring) and so the
ratio is `0` regardless of `aperyConnectionDet ε ε = 0`. -/
@[simp] lemma aperyCanonicalExtractHalf_self (c₀ ε : ℝ) :
    aperyCanonicalExtractHalf c₀ ε ε = 0 := by
  unfold aperyCanonicalExtractHalf
  rw [show
    ((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
            c₀ * aperyBranchAmplitude_zero ε) *
              aperyBranchValue_one ε -
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
            c₀ * aperyBranchAmplitude_zero ε) *
              aperyBranchValue_one ε) = 0 from by ring]
  exact zero_div _

/-- **Canonical one-extract vanishes on diagonal probes.** Companion of
`aperyCanonicalExtractHalf_self`. -/
@[simp] lemma aperyCanonicalExtractOne_self (c₀ ε : ℝ) :
    aperyCanonicalExtractOne c₀ ε ε = 0 := by
  unfold aperyCanonicalExtractOne
  rw [show
    (-((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
            c₀ * aperyBranchAmplitude_zero ε) *
              aperyBranchAmplitude_half ε) +
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) -
            c₀ * aperyBranchAmplitude_zero ε) *
              aperyBranchAmplitude_half ε) = 0 from by ring]
  exact zero_div _

/-- **Canonical triple at diagonal probes is `(c₀, 0, 0)`.** Mirrors the
ext-layer `connectionCoefficients_diagonal`: at coincident probes the
half/one slots collapse and only the seed survives. -/
@[simp] lemma aperyCanonicalConnectionCoefficients_diagonal (c₀ ε : ℝ) :
    aperyCanonicalConnectionCoefficients c₀ ε ε = (c₀, 0, 0) := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact aperyCanonicalExtractHalf_self c₀ ε
  · exact aperyCanonicalExtractOne_self c₀ ε

/-- **Raw half-extract vanishes on diagonal probes.** Mirror of
`aperyConnectionDet_self`: at coincident probes the Cramer numerator is
identically zero (by ring), so the ratio is `0` regardless of the
denominator. -/
@[simp] lemma aperyExtractHalf_self (f : ℝ → ℝ) (ε : ℝ) :
    aperyExtractHalf f ε ε = 0 := by
  unfold aperyExtractHalf
  rw [show
    (aperyConnectionResidual f ε * aperyBranchValue_one ε -
        aperyConnectionResidual f ε * aperyBranchValue_one ε) = 0 from by ring]
  exact zero_div _

/-- **Raw one-extract vanishes on diagonal probes.** Companion of
`aperyExtractHalf_self`. -/
@[simp] lemma aperyExtractOne_self (f : ℝ → ℝ) (ε : ℝ) :
    aperyExtractOne f ε ε = 0 := by
  unfold aperyExtractOne
  rw [show
    (-(aperyConnectionResidual f ε * aperyBranchAmplitude_half ε) +
        aperyConnectionResidual f ε * aperyBranchAmplitude_half ε) = 0 from by ring]
  exact zero_div _

/-- **Data-layer half-extract vanishes on diagonal probes.** Lift of
`aperyExtractHalf_self`. -/
@[simp] lemma AperyConnectionData.extractHalf_self
    (d : AperyConnectionData) (ε : ℝ) : d.extractHalf ε ε = 0 :=
  aperyExtractHalf_self d.F ε

/-- **Data-layer one-extract vanishes on diagonal probes.** Lift of
`aperyExtractOne_self`. -/
@[simp] lemma AperyConnectionData.extractOne_self
    (d : AperyConnectionData) (ε : ℝ) : d.extractOne ε ε = 0 :=
  aperyExtractOne_self d.F ε

/-- **Data-layer connection coefficients triple at diagonal probes.**
Mirrors the ext-layer `connectionCoefficients_diagonal`: the seed slot
is `d.extractRegular`; the half/one slots collapse to `0`. -/
@[simp] lemma AperyConnectionData.connectionCoefficients_diagonal
    (d : AperyConnectionData) (ε : ℝ) :
    d.connectionCoefficients ε ε = (d.extractRegular, 0, 0) := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact d.extractHalf_self ε
  · exact d.extractOne_self ε

/-- **Ext-layer half-extract vanishes on diagonal probes.** Lift of
`AperyConnectionData.extractHalf_self` through `toMinimalConnectionData`.
Allows direct `ext.extractHalf ε ε`-rewrites without going through
`connectionCoefficients_diagonal`. -/
@[simp] lemma AperyAnalyticExtension.extractHalf_self
    (ext : AperyAnalyticExtension) (ε : ℝ) :
    ext.extractHalf ε ε = 0 :=
  ext.toMinimalConnectionData.extractHalf_self ε

/-- **Ext-layer one-extract vanishes on diagonal probes.** Companion of
`AperyAnalyticExtension.extractHalf_self`. -/
@[simp] lemma AperyAnalyticExtension.extractOne_self
    (ext : AperyAnalyticExtension) (ε : ℝ) :
    ext.extractOne ε ε = 0 :=
  ext.toMinimalConnectionData.extractOne_self ε

/-- **Disk-overlap GFA decomposition in canonical form.** When all three
probes (probes `ε₁`, `ε₂` and corridor point `t`) hit the small disk and
the corridor hypotheses hold, the Apéry GFA decomposes as the explicit
`Y₀ + Y_{1/2} + Y₁` sum at the *canonical* extracts seeded by `ext.F z₁`.
This eliminates the ext layer from the RHS: only `ext.F z₁` and explicit
GFA values at the probes appear (through `aperyCanonicalExtract{Half,One}`).
Composes `GFA_decomposes_via_coefficients_on_disk` with
`connectionCoefficients_eq_canonical_on_disk`. -/
lemma AperyAnalyticExtension.GFA_decomposes_canonical_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ t : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (ht : t ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      yAperyZero (ext.F Number.aperyConifoldZ1Poly) t
        + yAperyHalf
            (aperyCanonicalExtractHalf
              (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂) t
        + yApery
            (aperyCanonicalExtractOne
              (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂) t := by
  have h_GFA :=
    ext.GFA_decomposes_via_coefficients_on_disk h0 h hε₁ hε₂ hdet ht hdisk
  have h_canon :=
    ext.connectionCoefficients_eq_canonical_on_disk hdisk_ε₁ hdisk_ε₂
  rw [h_GFA, h_canon]
  rfl

/-- **Cramer self-consistency at the first probe.** The canonical
extracts at `(c₀, ε₁, ε₂)` are *defined* via Cramer's rule from the GFA
values at `-ε₁, -ε₂`; substituting the first probe back into the
right-endpoint formula recovers the GFA value identically. Pure algebra
under `hdet`, no ext / disk hypothesis. -/
lemma aperyGFAReal_eq_canonical_rhs_at_probe1
    (c₀ : ℝ) {ε₁ ε₂ : ℝ} (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
      c₀ * aperyBranchAmplitude_zero ε₁ +
        aperyCanonicalExtractHalf c₀ ε₁ ε₂ * aperyBranchAmplitude_half ε₁ +
        aperyCanonicalExtractOne c₀ ε₁ ε₂ * aperyBranchValue_one ε₁ := by
  unfold aperyCanonicalExtractHalf aperyCanonicalExtractOne
  field_simp [hdet]
  unfold aperyConnectionDet
  ring

/-- **Cramer self-consistency at the second probe.** Companion of
`aperyGFAReal_eq_canonical_rhs_at_probe1`. -/
lemma aperyGFAReal_eq_canonical_rhs_at_probe2
    (c₀ : ℝ) {ε₁ ε₂ : ℝ} (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
      c₀ * aperyBranchAmplitude_zero ε₂ +
        aperyCanonicalExtractHalf c₀ ε₁ ε₂ * aperyBranchAmplitude_half ε₂ +
        aperyCanonicalExtractOne c₀ ε₁ ε₂ * aperyBranchValue_one ε₂ := by
  unfold aperyCanonicalExtractHalf aperyCanonicalExtractOne
  field_simp [hdet]
  unfold aperyConnectionDet
  ring

/-- **GFA right-endpoint at any disk probe in canonical form.**
Specialization of `GFA_decomposes_canonical_on_disk` at `t = -ε`,
converted through `yAperyXX_at_neg_eps` into the named-amplitude form.
For any probe `ε` whose `-ε` lies in both the corridor and the disk,
`aperyGFAReal (z₁ - ε)` admits the closed-form decomposition
`c₀·A_0(ε) + canonExHalf·A_½(ε) + canonExOne·V_1(ε)`, where `c₀ =
ext.F z₁` and the canonical extracts are seeded at the same `c₀`. The
RHS is fully explicit in `c₀` and the GFA values at `-ε₁, -ε₂`. -/
lemma AperyAnalyticExtension.GFA_right_endpoint_canonical_on_disk
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε : ℝ} (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (hε : (-ε) ∈ I)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε +
        aperyCanonicalExtractHalf
            (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂ *
          aperyBranchAmplitude_half ε +
        aperyCanonicalExtractOne
            (ext.F Number.aperyConifoldZ1Poly) ε₁ ε₂ *
          aperyBranchValue_one ε := by
  have h_decomp :=
    ext.GFA_decomposes_canonical_on_disk h0 h hε₁ hε₂ hdet hε hdisk
      hdisk_ε₁ hdisk_ε₂
  rw [h_decomp, yAperyZero_at_neg_eps, yAperyHalf_at_neg_eps,
    yApery_at_neg_eps]

/-- **Data-layer half-extract via GFA values on the disk.** Mirror of
`AperyAnalyticExtension.extractHalf_via_GFA_on_disk` at the data layer.
When both probes hit the disk, the half-extract is expressible directly
via `aperyGFAReal` evaluations and `d.extractRegular` (= `d.F z₁`). -/
lemma AperyConnectionData.extractHalf_via_GFA_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractHalf ε₁ ε₂ =
      ((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
          d.extractRegular * aperyBranchAmplitude_zero ε₁) *
            aperyBranchValue_one ε₂ -
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          d.extractRegular * aperyBranchAmplitude_zero ε₂) *
            aperyBranchValue_one ε₁) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [d.extractHalf_eq_residual_form,
      d.connectionResidual_via_GFA hdisk₁,
      d.connectionResidual_via_GFA hdisk₂]

/-- **Data-layer one-extract via GFA values on the disk.** Companion of
`extractHalf_via_GFA_on_disk`. -/
lemma AperyConnectionData.extractOne_via_GFA_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractOne ε₁ ε₂ =
      (-((aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) -
            d.extractRegular * aperyBranchAmplitude_zero ε₁) *
              aperyBranchAmplitude_half ε₂) +
        (aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) -
          d.extractRegular * aperyBranchAmplitude_zero ε₂) *
            aperyBranchAmplitude_half ε₁) /
        aperyConnectionDet ε₁ ε₂ := by
  rw [d.extractOne_eq_residual_form,
      d.connectionResidual_via_GFA hdisk₁,
      d.connectionResidual_via_GFA hdisk₂]

/-- **Data-layer half-extract factors through canonical form on disk.**
Mirror of `AperyAnalyticExtension.extractHalf_eq_canonical_on_disk`. -/
lemma AperyConnectionData.extractHalf_eq_canonical_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractHalf ε₁ ε₂ =
      aperyCanonicalExtractHalf d.extractRegular ε₁ ε₂ := by
  rw [d.extractHalf_via_GFA_on_disk hdisk₁ hdisk₂]
  rfl

/-- **Data-layer one-extract factors through canonical form on disk.**
Mirror of `AperyAnalyticExtension.extractOne_eq_canonical_on_disk`. -/
lemma AperyConnectionData.extractOne_eq_canonical_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.extractOne ε₁ ε₂ =
      aperyCanonicalExtractOne d.extractRegular ε₁ ε₂ := by
  rw [d.extractOne_via_GFA_on_disk hdisk₁ hdisk₂]
  rfl

/-- **Data-layer connectionCoefficients factors through canonical form
on disk.** Mirror of
`AperyAnalyticExtension.connectionCoefficients_eq_canonical_on_disk`. -/
lemma AperyConnectionData.connectionCoefficients_eq_canonical_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    d.connectionCoefficients ε₁ ε₂ =
      aperyCanonicalConnectionCoefficients d.extractRegular ε₁ ε₂ := by
  refine Prod.ext rfl (Prod.ext ?_ ?_)
  · exact d.extractHalf_eq_canonical_on_disk hdisk₁ hdisk₂
  · exact d.extractOne_eq_canonical_on_disk hdisk₁ hdisk₂

/-- **Data-layer GFA decomposition in canonical form.** Mirror of
`AperyAnalyticExtension.GFA_decomposes_canonical_on_disk` at the data
layer. When all three (probes ε₁, ε₂ and corridor point t) hit corridor
+ disk, `aperyGFAReal (z₁ + t)` decomposes as the explicit branch
triple at the canonical extracts seeded by `d.extractRegular`. -/
lemma AperyConnectionData.GFA_decomposes_canonical_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {t : ℝ} (htC : t ∈ d.corridor)
    (hz : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      aperyBranchTriple d.extractRegular
        (aperyCanonicalExtractHalf d.extractRegular ε₁ ε₂)
        (aperyCanonicalExtractOne d.extractRegular ε₁ ε₂) t := by
  rw [d.GFA_eq_branchTriple_on_overlap hε₁ hε₂ hdet htC hz,
      d.extractHalf_eq_canonical_on_disk hdisk_ε₁ hdisk_ε₂,
      d.extractOne_eq_canonical_on_disk hdisk_ε₁ hdisk_ε₂]

/-- **Data-layer GFA right-endpoint at any disk probe in canonical form.**
Specialization of `GFA_decomposes_canonical_on_disk` at `t = -ε` via
`yAperyXX_at_neg_eps`. Closed-form right-endpoint identity:
`aperyGFAReal (z₁ - ε) = d.extractRegular·A_0(ε) + canonExHalf·A_½(ε) +
canonExOne·V_1(ε)`, with seed `d.extractRegular`. -/
lemma AperyConnectionData.GFA_right_endpoint_canonical_on_disk
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (hε : (-ε) ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      d.extractRegular * aperyBranchAmplitude_zero ε +
        aperyCanonicalExtractHalf d.extractRegular ε₁ ε₂ *
          aperyBranchAmplitude_half ε +
        aperyCanonicalExtractOne d.extractRegular ε₁ ε₂ *
          aperyBranchValue_one ε := by
  have h_decomp :=
    d.GFA_decomposes_canonical_on_disk hε₁ hε₂ hdet hε hdisk hdisk_ε₁ hdisk_ε₂
  rw [h_decomp]
  unfold aperyBranchTriple
  rw [yAperyZero_at_neg_eps, yAperyHalf_at_neg_eps, yApery_at_neg_eps]

/-- **Right-endpoint identity using data-layer extracts directly.**
The most natural form: at any disk probe `ε`, `aperyGFAReal (z₁ - ε)`
equals the explicit closed form
`d.extractRegular·A_0(ε) + d.extractHalf·A_½(ε) + d.extractOne·V_1(ε)`,
without going through the canonical layer. Only `ε` needs disk
membership; `ε₁, ε₂` only need to be valid corridor probes with nonzero
det. -/
lemma AperyConnectionData.GFA_right_endpoint_via_data
    (d : AperyConnectionData) {ε₁ ε₂ ε : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0) (hε : (-ε) ∈ d.corridor)
    (hdisk : Number.aperyConifoldZ1Poly + (-ε) ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε)) =
      d.extractRegular * aperyBranchAmplitude_zero ε +
        d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε +
        d.extractOne ε₁ ε₂ * aperyBranchValue_one ε := by
  rw [d.GFA_eq_branchTriple_on_overlap hε₁ hε₂ hdet hε hdisk]
  unfold aperyBranchTriple
  rw [yAperyZero_at_neg_eps, yAperyHalf_at_neg_eps, yApery_at_neg_eps]

/-- **Swap invariance of the canonical GFA decomposition.** Since the
canonical extracts are swap-symmetric in `(ε₁, ε₂)`, the canonical
branch triple superposition is too — at every `t`. Pure consequence of
`aperyCanonicalExtractHalf_swap` and `aperyCanonicalExtractOne_swap`. -/
lemma aperyBranchTriple_canonical_swap (c₀ ε₁ ε₂ t : ℝ) :
    aperyBranchTriple c₀
        (aperyCanonicalExtractHalf c₀ ε₂ ε₁)
        (aperyCanonicalExtractOne c₀ ε₂ ε₁) t =
      aperyBranchTriple c₀
        (aperyCanonicalExtractHalf c₀ ε₁ ε₂)
        (aperyCanonicalExtractOne c₀ ε₁ ε₂) t := by
  rw [aperyCanonicalExtractHalf_swap, aperyCanonicalExtractOne_swap]

/-- **Linear independence of the half/one branch amplitudes at two
probes.** If a linear combination
`α·A_½(ε) + β·V_1(ε) = 0` vanishes at both `ε = ε₁` and `ε = ε₂` whose
Cramer det is nonzero, then `α = β = 0`. Pure algebraic 2×2 fact, used
to prove uniqueness of `(extractHalf, extractOne)` from the right-
endpoint identity. -/
lemma aperyBranch_linearly_independent_at_two_probes
    {ε₁ ε₂ : ℝ} (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {α β : ℝ}
    (h1 : α * aperyBranchAmplitude_half ε₁ + β * aperyBranchValue_one ε₁ = 0)
    (h2 : α * aperyBranchAmplitude_half ε₂ + β * aperyBranchValue_one ε₂ = 0) :
    α = 0 ∧ β = 0 := by
  have hα : α * aperyConnectionDet ε₁ ε₂ = 0 := by
    have := congrArg (· * aperyBranchValue_one ε₂) h1
    have h2' := congrArg (· * aperyBranchValue_one ε₁) h2
    simp only at this h2'
    unfold aperyConnectionDet
    linarith [this, h2']
  have hβ : β * aperyConnectionDet ε₁ ε₂ = 0 := by
    have h1' := congrArg (· * aperyBranchAmplitude_half ε₂) h1
    have h2' := congrArg (· * aperyBranchAmplitude_half ε₁) h2
    simp only at h1' h2'
    unfold aperyConnectionDet
    linarith [h1', h2']
  refine ⟨?_, ?_⟩
  · exact (mul_eq_zero.mp hα).resolve_right hdet
  · exact (mul_eq_zero.mp hβ).resolve_right hdet

/-- **Uniqueness of half/one amplitudes at two probes.** If two
amplitude pairs `(c_h, c_1)` and `(c_h', c_1')` give the same
combination `c_h·A_½(ε) + c_1·V_1(ε)` at both `ε₁` and `ε₂` (Cramer det
nonzero), they are equal. Direct subtraction + linear independence. -/
lemma aperyBranchAmplitudes_unique_at_two_probes
    {ε₁ ε₂ : ℝ} (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {c_h c_h' c_1 c_1' : ℝ}
    (h1 : c_h * aperyBranchAmplitude_half ε₁ + c_1 * aperyBranchValue_one ε₁ =
          c_h' * aperyBranchAmplitude_half ε₁ + c_1' * aperyBranchValue_one ε₁)
    (h2 : c_h * aperyBranchAmplitude_half ε₂ + c_1 * aperyBranchValue_one ε₂ =
          c_h' * aperyBranchAmplitude_half ε₂ + c_1' * aperyBranchValue_one ε₂) :
    c_h = c_h' ∧ c_1 = c_1' := by
  have h1' : (c_h - c_h') * aperyBranchAmplitude_half ε₁
              + (c_1 - c_1') * aperyBranchValue_one ε₁ = 0 := by ring_nf; linarith
  have h2' : (c_h - c_h') * aperyBranchAmplitude_half ε₂
              + (c_1 - c_1') * aperyBranchValue_one ε₂ = 0 := by ring_nf; linarith
  obtain ⟨hα, hβ⟩ := aperyBranch_linearly_independent_at_two_probes hdet h1' h2'
  exact ⟨sub_eq_zero.mp hα, sub_eq_zero.mp hβ⟩

/-- **Uniqueness of the full branch triple at two probes.** If two
triples `(c₀, c_h, c_1)` and `(c₀, c_h', c_1')` (sharing the same
seed `c₀`) give the same right-endpoint value
`c₀·A_0(ε) + c_h·A_½(ε) + c_1·V_1(ε)` at both `ε₁` and `ε₂` (Cramer det
nonzero), then `c_h = c_h'` and `c_1 = c_1'`. The seed `c₀` cancels
out — uniqueness is two-dimensional. -/
lemma aperyBranchTriple_endpoint_unique
    {ε₁ ε₂ : ℝ} (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    {c₀ c_h c_h' c_1 c_1' : ℝ}
    (h1 : c₀ * aperyBranchAmplitude_zero ε₁
            + c_h * aperyBranchAmplitude_half ε₁
            + c_1 * aperyBranchValue_one ε₁ =
          c₀ * aperyBranchAmplitude_zero ε₁
            + c_h' * aperyBranchAmplitude_half ε₁
            + c_1' * aperyBranchValue_one ε₁)
    (h2 : c₀ * aperyBranchAmplitude_zero ε₂
            + c_h * aperyBranchAmplitude_half ε₂
            + c_1 * aperyBranchValue_one ε₂ =
          c₀ * aperyBranchAmplitude_zero ε₂
            + c_h' * aperyBranchAmplitude_half ε₂
            + c_1' * aperyBranchValue_one ε₂) :
    c_h = c_h' ∧ c_1 = c_1' := by
  have h1' :
      c_h * aperyBranchAmplitude_half ε₁ + c_1 * aperyBranchValue_one ε₁ =
      c_h' * aperyBranchAmplitude_half ε₁ + c_1' * aperyBranchValue_one ε₁ := by
    linarith
  have h2' :
      c_h * aperyBranchAmplitude_half ε₂ + c_1 * aperyBranchValue_one ε₂ =
      c_h' * aperyBranchAmplitude_half ε₂ + c_1' * aperyBranchValue_one ε₂ := by
    linarith
  exact aperyBranchAmplitudes_unique_at_two_probes hdet h1' h2'

/-- **Uniqueness of `(extractHalf, extractOne)` from the GFA right-
endpoint identity.** Any pair `(c_h, c_1)` such that the right-endpoint
formula
`aperyGFAReal (z₁ - ε) = d.extractRegular·A_0(ε) + c_h·A_½(ε) +
c_1·V_1(ε)` holds at both `ε = ε₁` and `ε = ε₂` (det nonzero, both in
disk) must satisfy `c_h = d.extractHalf ε₁ ε₂` and
`c_1 = d.extractOne ε₁ ε₂`. The Cramer formulae are the unique
solution. -/
lemma AperyConnectionData.extracts_unique_from_right_endpoint
    (d : AperyConnectionData) {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    {c_h c_1 : ℝ}
    (h1 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
            d.extractRegular * aperyBranchAmplitude_zero ε₁
              + c_h * aperyBranchAmplitude_half ε₁
              + c_1 * aperyBranchValue_one ε₁)
    (h2 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
            d.extractRegular * aperyBranchAmplitude_zero ε₂
              + c_h * aperyBranchAmplitude_half ε₂
              + c_1 * aperyBranchValue_one ε₂) :
    c_h = d.extractHalf ε₁ ε₂ ∧ c_1 = d.extractOne ε₁ ε₂ := by
  have h1' := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet hε₁ hdisk_ε₁
  have h2' := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet hε₂ hdisk_ε₂
  have eq1 :
      d.extractRegular * aperyBranchAmplitude_zero ε₁
          + c_h * aperyBranchAmplitude_half ε₁
          + c_1 * aperyBranchValue_one ε₁ =
        d.extractRegular * aperyBranchAmplitude_zero ε₁
          + d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε₁
          + d.extractOne ε₁ ε₂ * aperyBranchValue_one ε₁ := by
    rw [← h1, h1']
  have eq2 :
      d.extractRegular * aperyBranchAmplitude_zero ε₂
          + c_h * aperyBranchAmplitude_half ε₂
          + c_1 * aperyBranchValue_one ε₂ =
        d.extractRegular * aperyBranchAmplitude_zero ε₂
          + d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε₂
          + d.extractOne ε₁ ε₂ * aperyBranchValue_one ε₂ := by
    rw [← h2, h2']
  exact aperyBranchTriple_endpoint_unique hdet eq1 eq2

/-- **Ext-layer mirror of `extracts_unique_from_right_endpoint`.** Any
pair `(c_h, c_1)` such that the right-endpoint formula
`aperyGFAReal (z₁ - ε) = ext.F z₁·A_0(ε) + c_h·A_½(ε) + c_1·V_1(ε)`
holds at both `ε = ε₁` and `ε = ε₂` (det nonzero, both in disk and
witness corridor) must satisfy
`c_h = aperyExtractHalf ext.F ε₁ ε₂` and
`c_1 = aperyExtractOne ext.F ε₁ ε₂`. -/
lemma AperyAnalyticExtension.extracts_unique_from_right_endpoint
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hdisk_ε₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk_ε₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    {c_h c_1 : ℝ}
    (h1 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
            ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₁
              + c_h * aperyBranchAmplitude_half ε₁
              + c_1 * aperyBranchValue_one ε₁)
    (h2 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
            ext.F Number.aperyConifoldZ1Poly * aperyBranchAmplitude_zero ε₂
              + c_h * aperyBranchAmplitude_half ε₂
              + c_1 * aperyBranchValue_one ε₂) :
    c_h = aperyExtractHalf ext.F ε₁ ε₂ ∧
      c_1 = aperyExtractOne ext.F ε₁ ε₂ :=
  (AperyConnectionData.of_witness ext I h0 h).extracts_unique_from_right_endpoint
    hε₁ hε₂ hdet hdisk_ε₁ hdisk_ε₂ h1 h2

/-- **3×3 Cramer determinant for the three branch amplitudes at three
probes.** Cofactor expansion of the 3×3 matrix
`[[A_0(ε_i), A_½(ε_i), V_1(ε_i)] | i = 1,2,3]` along the first
column (`A_0`). Used to detect simultaneous linear independence of
`A_0`, `A_½`, `V_1` as functions of `ε`. -/
noncomputable def apery3Det (ε₁ ε₂ ε₃ : ℝ) : ℝ :=
  aperyBranchAmplitude_zero ε₁ * aperyConnectionDet ε₂ ε₃ -
    aperyBranchAmplitude_zero ε₂ * aperyConnectionDet ε₁ ε₃ +
      aperyBranchAmplitude_zero ε₃ * aperyConnectionDet ε₁ ε₂

/-- **3-probe linear independence of branch amplitudes.** If
`α₀·A_0(ε) + α_h·A_½(ε) + α_1·V_1(ε) = 0` at three probes ε₁, ε₂, ε₃
with `apery3Det ε₁ ε₂ ε₃ ≠ 0`, then `α₀ = α_h = α_1 = 0`. Pure 3×3
Cramer fact: each coefficient times `apery3Det` equals a cofactor
combination of the three equations, so vanishes when all equations are
zero. -/
lemma aperyBranch_linearly_independent_at_three_probes
    {ε₁ ε₂ ε₃ : ℝ} (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    {α₀ α_h α_1 : ℝ}
    (h1 : α₀ * aperyBranchAmplitude_zero ε₁
            + α_h * aperyBranchAmplitude_half ε₁
            + α_1 * aperyBranchValue_one ε₁ = 0)
    (h2 : α₀ * aperyBranchAmplitude_zero ε₂
            + α_h * aperyBranchAmplitude_half ε₂
            + α_1 * aperyBranchValue_one ε₂ = 0)
    (h3 : α₀ * aperyBranchAmplitude_zero ε₃
            + α_h * aperyBranchAmplitude_half ε₃
            + α_1 * aperyBranchValue_one ε₃ = 0) :
    α₀ = 0 ∧ α_h = 0 ∧ α_1 = 0 := by
  have key0 :
      (α₀ * aperyBranchAmplitude_zero ε₁ + α_h * aperyBranchAmplitude_half ε₁
            + α_1 * aperyBranchValue_one ε₁) * aperyConnectionDet ε₂ ε₃
        - (α₀ * aperyBranchAmplitude_zero ε₂ + α_h * aperyBranchAmplitude_half ε₂
            + α_1 * aperyBranchValue_one ε₂) * aperyConnectionDet ε₁ ε₃
        + (α₀ * aperyBranchAmplitude_zero ε₃ + α_h * aperyBranchAmplitude_half ε₃
            + α_1 * aperyBranchValue_one ε₃) * aperyConnectionDet ε₁ ε₂ =
      α₀ * apery3Det ε₁ ε₂ ε₃ := by
    unfold apery3Det aperyConnectionDet; ring
  have key_h :
      -(α₀ * aperyBranchAmplitude_zero ε₁ + α_h * aperyBranchAmplitude_half ε₁
            + α_1 * aperyBranchValue_one ε₁) *
          (aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₃
            - aperyBranchAmplitude_zero ε₃ * aperyBranchValue_one ε₂)
        + (α₀ * aperyBranchAmplitude_zero ε₂ + α_h * aperyBranchAmplitude_half ε₂
            + α_1 * aperyBranchValue_one ε₂) *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₃
            - aperyBranchAmplitude_zero ε₃ * aperyBranchValue_one ε₁)
        - (α₀ * aperyBranchAmplitude_zero ε₃ + α_h * aperyBranchAmplitude_half ε₃
            + α_1 * aperyBranchValue_one ε₃) *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchValue_one ε₂
            - aperyBranchAmplitude_zero ε₂ * aperyBranchValue_one ε₁) =
      α_h * apery3Det ε₁ ε₂ ε₃ := by
    unfold apery3Det aperyConnectionDet; ring
  have key_1 :
      (α₀ * aperyBranchAmplitude_zero ε₁ + α_h * aperyBranchAmplitude_half ε₁
            + α_1 * aperyBranchValue_one ε₁) *
          (aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₃
            - aperyBranchAmplitude_zero ε₃ * aperyBranchAmplitude_half ε₂)
        - (α₀ * aperyBranchAmplitude_zero ε₂ + α_h * aperyBranchAmplitude_half ε₂
            + α_1 * aperyBranchValue_one ε₂) *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₃
            - aperyBranchAmplitude_zero ε₃ * aperyBranchAmplitude_half ε₁)
        + (α₀ * aperyBranchAmplitude_zero ε₃ + α_h * aperyBranchAmplitude_half ε₃
            + α_1 * aperyBranchValue_one ε₃) *
          (aperyBranchAmplitude_zero ε₁ * aperyBranchAmplitude_half ε₂
            - aperyBranchAmplitude_zero ε₂ * aperyBranchAmplitude_half ε₁) =
      α_1 * apery3Det ε₁ ε₂ ε₃ := by
    unfold apery3Det aperyConnectionDet; ring
  have hα₀ : α₀ * apery3Det ε₁ ε₂ ε₃ = 0 := by
    rw [← key0, h1, h2, h3]; ring
  have hα_h : α_h * apery3Det ε₁ ε₂ ε₃ = 0 := by
    rw [← key_h, h1, h2, h3]; ring
  have hα_1 : α_1 * apery3Det ε₁ ε₂ ε₃ = 0 := by
    rw [← key_1, h1, h2, h3]; ring
  refine ⟨?_, ?_, ?_⟩
  · exact (mul_eq_zero.mp hα₀).resolve_right h3det
  · exact (mul_eq_zero.mp hα_h).resolve_right h3det
  · exact (mul_eq_zero.mp hα_1).resolve_right h3det

/-- **Full-triple uniqueness from three probes.** Two triples
`(c₀, c_h, c_1)` and `(c₀', c_h', c_1')` agreeing at three probes
ε₁, ε₂, ε₃ with `apery3Det ≠ 0` are component-wise equal. Direct
subtraction + 3-probe linear independence. Three-dimensional analogue
of `aperyBranchTriple_endpoint_unique` (which leaves c₀ free). -/
lemma aperyBranchTriple_unique_at_three_probes
    {ε₁ ε₂ ε₃ : ℝ} (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    {c₀ c₀' c_h c_h' c_1 c_1' : ℝ}
    (h1 : c₀ * aperyBranchAmplitude_zero ε₁
            + c_h * aperyBranchAmplitude_half ε₁
            + c_1 * aperyBranchValue_one ε₁ =
          c₀' * aperyBranchAmplitude_zero ε₁
            + c_h' * aperyBranchAmplitude_half ε₁
            + c_1' * aperyBranchValue_one ε₁)
    (h2 : c₀ * aperyBranchAmplitude_zero ε₂
            + c_h * aperyBranchAmplitude_half ε₂
            + c_1 * aperyBranchValue_one ε₂ =
          c₀' * aperyBranchAmplitude_zero ε₂
            + c_h' * aperyBranchAmplitude_half ε₂
            + c_1' * aperyBranchValue_one ε₂)
    (h3 : c₀ * aperyBranchAmplitude_zero ε₃
            + c_h * aperyBranchAmplitude_half ε₃
            + c_1 * aperyBranchValue_one ε₃ =
          c₀' * aperyBranchAmplitude_zero ε₃
            + c_h' * aperyBranchAmplitude_half ε₃
            + c_1' * aperyBranchValue_one ε₃) :
    c₀ = c₀' ∧ c_h = c_h' ∧ c_1 = c_1' := by
  have e1 : (c₀ - c₀') * aperyBranchAmplitude_zero ε₁
              + (c_h - c_h') * aperyBranchAmplitude_half ε₁
              + (c_1 - c_1') * aperyBranchValue_one ε₁ = 0 := by
    linear_combination h1
  have e2 : (c₀ - c₀') * aperyBranchAmplitude_zero ε₂
              + (c_h - c_h') * aperyBranchAmplitude_half ε₂
              + (c_1 - c_1') * aperyBranchValue_one ε₂ = 0 := by
    linear_combination h2
  have e3 : (c₀ - c₀') * aperyBranchAmplitude_zero ε₃
              + (c_h - c_h') * aperyBranchAmplitude_half ε₃
              + (c_1 - c_1') * aperyBranchValue_one ε₃ = 0 := by
    linear_combination h3
  obtain ⟨hα₀, hα_h, hα_1⟩ :=
    aperyBranch_linearly_independent_at_three_probes h3det e1 e2 e3
  exact ⟨sub_eq_zero.mp hα₀, sub_eq_zero.mp hα_h, sub_eq_zero.mp hα_1⟩

/-- **Data-layer full-triple uniqueness from three disk probes.** Any
candidate triple `(c₀, c_h, c_1)` matching the GFA right-endpoint
formula at three disk probes ε₁, ε₂, ε₃ (with `apery3Det ≠ 0` and pair
`(ε₁, ε₂)` having nonzero `aperyConnectionDet`) must equal
`(d.extractRegular, d.extractHalf ε₁ ε₂, d.extractOne ε₁ ε₂)`. Combines
`d.GFA_right_endpoint_via_data` (the data-layer right-endpoint
identity) with the algebraic 3-probe triple uniqueness. Closes the
algebraic side of Gap E in the data-layer interface. -/
lemma AperyConnectionData.triple_unique_from_three_disk_probes
    (d : AperyConnectionData) {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ d.corridor) (hε₂ : (-ε₂) ∈ d.corridor)
    (hε₃ : (-ε₃) ∈ d.corridor)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64))
    {c₀ c_h c_1 : ℝ}
    (h1 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
            c₀ * aperyBranchAmplitude_zero ε₁
              + c_h * aperyBranchAmplitude_half ε₁
              + c_1 * aperyBranchValue_one ε₁)
    (h2 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
            c₀ * aperyBranchAmplitude_zero ε₂
              + c_h * aperyBranchAmplitude_half ε₂
              + c_1 * aperyBranchValue_one ε₂)
    (h3 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₃)) =
            c₀ * aperyBranchAmplitude_zero ε₃
              + c_h * aperyBranchAmplitude_half ε₃
              + c_1 * aperyBranchValue_one ε₃) :
    c₀ = d.extractRegular ∧
      c_h = d.extractHalf ε₁ ε₂ ∧ c_1 = d.extractOne ε₁ ε₂ := by
  have hd1 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₁ hdisk₁
  have hd2 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₂ hdisk₂
  have hd3 := d.GFA_right_endpoint_via_data hε₁ hε₂ hdet12 hε₃ hdisk₃
  have eq1 :
      c₀ * aperyBranchAmplitude_zero ε₁ + c_h * aperyBranchAmplitude_half ε₁
          + c_1 * aperyBranchValue_one ε₁ =
        d.extractRegular * aperyBranchAmplitude_zero ε₁
          + d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε₁
          + d.extractOne ε₁ ε₂ * aperyBranchValue_one ε₁ := by
    rw [← h1, hd1]
  have eq2 :
      c₀ * aperyBranchAmplitude_zero ε₂ + c_h * aperyBranchAmplitude_half ε₂
          + c_1 * aperyBranchValue_one ε₂ =
        d.extractRegular * aperyBranchAmplitude_zero ε₂
          + d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε₂
          + d.extractOne ε₁ ε₂ * aperyBranchValue_one ε₂ := by
    rw [← h2, hd2]
  have eq3 :
      c₀ * aperyBranchAmplitude_zero ε₃ + c_h * aperyBranchAmplitude_half ε₃
          + c_1 * aperyBranchValue_one ε₃ =
        d.extractRegular * aperyBranchAmplitude_zero ε₃
          + d.extractHalf ε₁ ε₂ * aperyBranchAmplitude_half ε₃
          + d.extractOne ε₁ ε₂ * aperyBranchValue_one ε₃ := by
    rw [← h3, hd3]
  exact aperyBranchTriple_unique_at_three_probes h3det eq1 eq2 eq3

/-- **Ext-layer mirror of `triple_unique_from_three_disk_probes`.** Any
candidate triple matching the GFA right-endpoint at three disk probes
must equal `(ext.F z₁, aperyExtractHalf ext.F ε₁ ε₂,
aperyExtractOne ext.F ε₁ ε₂)`. Direct delegation through
`AperyConnectionData.of_witness`. -/
lemma AperyAnalyticExtension.triple_unique_from_three_disk_probes
    (ext : AperyAnalyticExtension) {I : Set ℝ} (h0 : (0 : ℝ) ∈ I)
    (h : HasAperyConnectionCoeffsOn ext.F I)
    {ε₁ ε₂ ε₃ : ℝ}
    (hε₁ : (-ε₁) ∈ I) (hε₂ : (-ε₂) ∈ I) (hε₃ : (-ε₃) ∈ I)
    (hdet12 : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (h3det : apery3Det ε₁ ε₂ ε₃ ≠ 0)
    (hdisk₁ : Number.aperyConifoldZ1Poly + (-ε₁) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₂ : Number.aperyConifoldZ1Poly + (-ε₂) ∈ Set.Ico (0 : ℝ) (1 / 64))
    (hdisk₃ : Number.aperyConifoldZ1Poly + (-ε₃) ∈ Set.Ico (0 : ℝ) (1 / 64))
    {c₀ c_h c_1 : ℝ}
    (h1 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₁)) =
            c₀ * aperyBranchAmplitude_zero ε₁
              + c_h * aperyBranchAmplitude_half ε₁
              + c_1 * aperyBranchValue_one ε₁)
    (h2 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₂)) =
            c₀ * aperyBranchAmplitude_zero ε₂
              + c_h * aperyBranchAmplitude_half ε₂
              + c_1 * aperyBranchValue_one ε₂)
    (h3 : aperyGFAReal (Number.aperyConifoldZ1Poly + (-ε₃)) =
            c₀ * aperyBranchAmplitude_zero ε₃
              + c_h * aperyBranchAmplitude_half ε₃
              + c_1 * aperyBranchValue_one ε₃) :
    c₀ = ext.F Number.aperyConifoldZ1Poly ∧
      c_h = aperyExtractHalf ext.F ε₁ ε₂ ∧
        c_1 = aperyExtractOne ext.F ε₁ ε₂ :=
  (AperyConnectionData.of_witness ext I h0 h).triple_unique_from_three_disk_probes
    hε₁ hε₂ hε₃ hdet12 h3det hdisk₁ hdisk₂ hdisk₃ h1 h2 h3

/-- **`apery3Det` swap antisymmetry: positions 1↔2.** Like the 2×2 det,
the 3×3 det negates under any single transposition. -/
lemma apery3Det_swap12 (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₂ ε₁ ε₃ = -(apery3Det ε₁ ε₂ ε₃) := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` swap antisymmetry: positions 1↔3.** -/
lemma apery3Det_swap13 (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₃ ε₂ ε₁ = -(apery3Det ε₁ ε₂ ε₃) := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` swap antisymmetry: positions 2↔3.** -/
lemma apery3Det_swap23 (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₁ ε₃ ε₂ = -(apery3Det ε₁ ε₂ ε₃) := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` vanishes when probes 1 and 2 coincide.** -/
@[simp] lemma apery3Det_self12 (ε ε₃ : ℝ) :
    apery3Det ε ε ε₃ = 0 := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` vanishes when probes 1 and 3 coincide.** -/
@[simp] lemma apery3Det_self13 (ε ε₂ : ℝ) :
    apery3Det ε ε₂ ε = 0 := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` vanishes when probes 2 and 3 coincide.** -/
@[simp] lemma apery3Det_self23 (ε₁ ε : ℝ) :
    apery3Det ε₁ ε ε = 0 := by
  unfold apery3Det aperyConnectionDet; ring

/-- **Cyclic symmetry of `apery3Det`.** Cycling the three probes
preserves the det (composition of two swaps). -/
lemma apery3Det_cycle (ε₁ ε₂ ε₃ : ℝ) :
    apery3Det ε₂ ε₃ ε₁ = apery3Det ε₁ ε₂ ε₃ := by
  unfold apery3Det aperyConnectionDet; ring

/-- **`apery3Det` factored form (positive probes).** Pulls the
`√ε_a·√ε_b` prefactor out of each 2×2 connection minor in the cofactor
expansion. With all three probes nonneg, every minor exposes its own
Vandermonde-like bracket. The terms still don't share a common
`√ε₁·√ε₂·√ε₃` factor (each cofactor only has two of the three sqrt
factors), but each minor's sqrt structure is now visible — the right
form for asymptotic / Vandermonde analysis. -/
lemma apery3Det_factored {ε₁ ε₂ ε₃ : ℝ}
    (h₁ : 0 ≤ ε₁) (h₂ : 0 ≤ ε₂) (h₃ : 0 ≤ ε₃) :
    apery3Det ε₁ ε₂ ε₃ =
      aperyBranchAmplitude_zero ε₁ *
        (Real.sqrt ε₂ * Real.sqrt ε₃ *
          (Real.sqrt ε₂ * aperyBranchHalfCore ε₃ * aperyBranchOneCore ε₂ -
            Real.sqrt ε₃ * aperyBranchHalfCore ε₂ * aperyBranchOneCore ε₃)) -
      aperyBranchAmplitude_zero ε₂ *
        (Real.sqrt ε₁ * Real.sqrt ε₃ *
          (Real.sqrt ε₁ * aperyBranchHalfCore ε₃ * aperyBranchOneCore ε₁ -
            Real.sqrt ε₃ * aperyBranchHalfCore ε₁ * aperyBranchOneCore ε₃)) +
      aperyBranchAmplitude_zero ε₃ *
        (Real.sqrt ε₁ * Real.sqrt ε₂ *
          (Real.sqrt ε₁ * aperyBranchHalfCore ε₂ * aperyBranchOneCore ε₁ -
            Real.sqrt ε₂ * aperyBranchHalfCore ε₁ * aperyBranchOneCore ε₂)) := by
  unfold apery3Det
  rw [aperyConnectionDet_factored h₂ h₃,
      aperyConnectionDet_factored h₁ h₃,
      aperyConnectionDet_factored h₁ h₂]

/-- **Joint continuity of `apery3Det` on the 3D Frobenius cube.** Given
the hypothesis bundle for ρ = 0, 1/2, 1 (sharing M₀, B, threshold, disk),
the function `(ε₁, ε₂, ε₃) ↦ apery3Det ε₁ ε₂ ε₃` is continuous on
`Icc(-s, s) ×ˢ Icc(-s, s) ×ˢ Icc(-s, s)`. The cofactor expansion is
linear in `A_0` minors and uses `aperyConnectionDet` for each 2×2 block;
each piece is continuous by composition with the three coordinate
projections. -/
lemma apery3Det_continuousOn_general
    (M₀ : ℕ) (B : ℝ) (hB_nn : 0 ≤ B)
    (hM0_small_zero : ∀ m, M₀ ≤ m → (|(0 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_zero : ∀ m, M₀ ≤ m → 3 * |(0 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_zero : ∀ m', M₀ ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(0 : ℝ)| - (2 : ℝ)))
    (hM0_small_half : ∀ m, M₀ ≤ m →
        (|(1 / 2 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_half : ∀ m, M₀ ≤ m →
        3 * |(1 / 2 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_half : ∀ m', M₀ ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(1 / 2 : ℝ)| - (2 : ℝ)))
    (hM0_small_one : ∀ m, M₀ ≤ m → (|(1 : ℝ)| + (2 : ℝ)) < ((m + 1 : ℕ) : ℝ))
    (hM0_large_one : ∀ m, M₀ ≤ m → 3 * |(1 : ℝ)| + 3 * (2 : ℝ) ≤ (m : ℝ))
    (hM0_thresh_one : ∀ m', M₀ ≤ m' →
        2 * |Polynomial.eval Number.aperyConifoldZ1Poly Number.aperyQconifold| ≤
          |Polynomial.eval Number.aperyConifoldZ1Poly
              (Polynomial.derivative Number.aperyPconifold)| *
            (((m' + 1 : ℕ) : ℝ) - |(1 : ℝ)| - (2 : ℝ)))
    (hB : ∀ j ∈ Finset.range 4, ∀ ℓ : ℕ,
        |Polynomial.coeff (taylorShift
          ((aperyPsSeq 0 0 Number.aperyQconifold Number.aperyPconifold) j)
          Number.aperyConifoldZ1Poly) ℓ| ≤ B)
    (s : ℝ) (hs_nn : 0 ≤ s)
    (hs_lt : s * (1 + 2 * (4 : ℝ) * B * ((2 : ℝ) ^ 3) /
      |Polynomial.eval Number.aperyConifoldZ1Poly
        (Polynomial.derivative Number.aperyPconifold)|) < 1) :
    ContinuousOn (fun p : ℝ × ℝ × ℝ => apery3Det p.1 p.2.1 p.2.2)
      ((Set.Icc (-s) s) ×ˢ ((Set.Icc (-s) s) ×ˢ (Set.Icc (-s) s))) := by
  set S : Set ℝ := Set.Icc (-s) s with hS_def
  set Cube : Set (ℝ × ℝ × ℝ) := S ×ˢ (S ×ˢ S) with hCube_def
  have hAzero : ContinuousOn aperyBranchAmplitude_zero S :=
    aperyBranchAmplitude_zero_continuousOn_general M₀ B hB_nn
      hM0_small_zero hM0_large_zero hM0_thresh_zero hB s hs_nn hs_lt
  have hDet2 : ContinuousOn (fun p : ℝ × ℝ => aperyConnectionDet p.1 p.2)
      (S ×ˢ S) :=
    aperyConnectionDet_continuousOn_general M₀ B hB_nn
      hM0_small_half hM0_large_half hM0_thresh_half
      hM0_small_one hM0_large_one hM0_thresh_one
      hB s hs_nn hs_lt
  have hp1_cont : ContinuousOn (fun p : ℝ × ℝ × ℝ => p.1) Cube :=
    continuous_fst.continuousOn
  have hp21_cont : ContinuousOn (fun p : ℝ × ℝ × ℝ => p.2.1) Cube :=
    (continuous_fst.comp continuous_snd).continuousOn
  have hp22_cont : ContinuousOn (fun p : ℝ × ℝ × ℝ => p.2.2) Cube :=
    (continuous_snd.comp continuous_snd).continuousOn
  have hmaps_p1 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => p.1) Cube S := fun _ hp => hp.1
  have hmaps_p21 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => p.2.1) Cube S := fun _ hp => hp.2.1
  have hmaps_p22 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => p.2.2) Cube S := fun _ hp => hp.2.2
  have hA1 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyBranchAmplitude_zero p.1) Cube :=
    hAzero.comp hp1_cont hmaps_p1
  have hA2 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyBranchAmplitude_zero p.2.1) Cube :=
    hAzero.comp hp21_cont hmaps_p21
  have hA3 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyBranchAmplitude_zero p.2.2) Cube :=
    hAzero.comp hp22_cont hmaps_p22
  -- pair maps for Δ minors
  have hpair_23 : ContinuousOn (fun p : ℝ × ℝ × ℝ => (p.2.1, p.2.2)) Cube :=
    ((continuous_fst.comp continuous_snd).prodMk
      (continuous_snd.comp continuous_snd)).continuousOn
  have hpair_13 : ContinuousOn (fun p : ℝ × ℝ × ℝ => (p.1, p.2.2)) Cube :=
    (continuous_fst.prodMk (continuous_snd.comp continuous_snd)).continuousOn
  have hpair_12 : ContinuousOn (fun p : ℝ × ℝ × ℝ => (p.1, p.2.1)) Cube :=
    (continuous_fst.prodMk (continuous_fst.comp continuous_snd)).continuousOn
  have hmaps_23 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => (p.2.1, p.2.2)) Cube (S ×ˢ S) :=
    fun _ hp => Set.mk_mem_prod hp.2.1 hp.2.2
  have hmaps_13 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => (p.1, p.2.2)) Cube (S ×ˢ S) :=
    fun _ hp => Set.mk_mem_prod hp.1 hp.2.2
  have hmaps_12 : Set.MapsTo (fun p : ℝ × ℝ × ℝ => (p.1, p.2.1)) Cube (S ×ˢ S) :=
    fun _ hp => Set.mk_mem_prod hp.1 hp.2.1
  have hD23 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyConnectionDet p.2.1 p.2.2) Cube :=
    hDet2.comp hpair_23 hmaps_23
  have hD13 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyConnectionDet p.1 p.2.2) Cube :=
    hDet2.comp hpair_13 hmaps_13
  have hD12 : ContinuousOn (fun p : ℝ × ℝ × ℝ => aperyConnectionDet p.1 p.2.1) Cube :=
    hDet2.comp hpair_12 hmaps_12
  exact ((hA1.mul hD23).sub (hA2.mul hD13)).add (hA3.mul hD12)

