    (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    h.some.F a ∈
      Set.Icc
        (sInf (h.some.F '' Set.Icc a b))
        (sSup (h.some.F '' Set.Icc a b)) :=
  h.some_F_mem_Icc_sInf_sSup_sub ha hab hb ⟨le_refl a, hab⟩

/-- **Right endpoint `some.F b ∈ Icc [sInf, sSup]`.** -/
lemma HasAperyAnalyticExtension.some_F_right_mem_Icc_sInf_sSup_sub
