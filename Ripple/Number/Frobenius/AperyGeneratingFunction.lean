    d.zero_mem h0 hε₁_d hε₂_d hε₁ hε₂ hdet hI hJ ht htneg

/-! #### GFA-layer chain capstones -/

/-- **GFA-layer right-side basis on the chain-glued corridor.** When
`z₁ + t` lies in the GFA convergence disk, the series value equals
the Y₀+Y₁ Frobenius combination at the canonical data extracts — even
for `t ∈ d.corridor ∪ ⋃ i, J i`. -/
lemma AperyConnectionData.GFA_eq_yZero_plus_yOne_on_right_via_iUnion
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i))
    {t : ℝ} (ht : t ∈ d.corridor ∪ ⋃ i, J i) (htnn : 0 ≤ t)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t) =
      yAperyZero d.extractRegular t + yApery (d.extractOne ε₁ ε₂) t := by
  rw [← d.F_shift_eq_GFA hdisk]
  exact d.F_eq_yZero_plus_yOne_on_right_via_iUnion
    hε₁_d hε₂_d h0 hε₁ hε₂ hdet hJ ht htnn

/-- **GFA-layer Y_½ isolation on the chain-glued corridor.** -/
lemma AperyConnectionData.GFA_yHalf_isolated_via_iUnion
    (d : AperyConnectionData) {ι : Type*} {J : ι → Set ℝ}
    {ε₁ ε₂ : ℝ}
    (hε₁_d : (-ε₁) ∈ d.corridor) (hε₂_d : (-ε₂) ∈ d.corridor)
    (h0 : ∀ i, (0 : ℝ) ∈ J i)
    (hε₁ : ∀ i, (-ε₁) ∈ J i) (hε₂ : ∀ i, (-ε₂) ∈ J i)
    (hdet : aperyConnectionDet ε₁ ε₂ ≠ 0)
    (hJ : ∀ i, HasAperyConnectionCoeffsOn d.F (J i))
    {t : ℝ} (ht : t ∈ d.corridor ∪ ⋃ i, J i)
    (hdisk : Number.aperyConifoldZ1Poly + t ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    aperyGFAReal (Number.aperyConifoldZ1Poly + t)
