    (le_trans ha haa') ha'b
    ha (le_trans haa' ha'b) hb
    (Icc_a'_b_subset_Icc_a_b haa')

/-! ### `some.F` pointwise evaluation, positivity, and monotonicity -/

/-- **`some.F` at 0 equals 1.** Direct combination of `F_at_zero` and `aperyGFAReal_zero`. -/
lemma HasAperyAnalyticExtension.some_F_at_zero_eq_one
    (h : HasAperyAnalyticExtension) :
    h.some.F 0 = 1 := by
  rw [h.some.F_at_zero, aperyGFAReal_zero]

/-- **`some.F z ≥ 1` for `z ∈ [0, 1/64)`.** Transfer from `aperyGFAReal_ge_one_of_nonneg`
via the agreement on `Ico 0 (1/64)`. -/
lemma HasAperyAnalyticExtension.some_F_ge_one_of_mem_Ico
    (h : HasAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    1 ≤ h.some.F z := by
  rw [h.some_F_eqOn_aperyGFAReal_Ico_one_div_64 hz]
  exact aperyGFAReal_ge_one_of_nonneg hz.1 hz.2

/-- **`some.F z > 0` for `z ∈ [0, 1/64)`.** Immediate from `some_F_ge_one_of_mem_Ico`. -/
lemma HasAperyAnalyticExtension.some_F_pos_of_mem_Ico
    (h : HasAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) (1 / 64)) :
    0 < h.some.F z :=
  lt_of_lt_of_le zero_lt_one (h.some_F_ge_one_of_mem_Ico hz)

/-- **`some.F` is strictly monotone on `[0, 1/64)`.** Transfer from
`aperyGFAReal_strict_mono_on_nonneg` via agreement on the half-open interval. -/
lemma HasAperyAnalyticExtension.some_F_strictMonoOn_Ico
    (h : HasAperyAnalyticExtension) :
    StrictMonoOn h.some.F (Set.Ico (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 h12
  rw [h.some_F_eqOn_aperyGFAReal_Ico_one_div_64 hz1,
      h.some_F_eqOn_aperyGFAReal_Ico_one_div_64 hz2]
  exact aperyGFAReal_strict_mono_on_nonneg hz1.1 h12 hz2.2

/-- **`some.F` is injective on `[0, 1/64)`.** Direct corollary of strict monotonicity. -/
lemma HasAperyAnalyticExtension.some_F_injOn_Ico
    (h : HasAperyAnalyticExtension) :
    Set.InjOn h.some.F (Set.Ico (0 : ℝ) (1 / 64)) :=
  h.some_F_strictMonoOn_Ico.injOn

/-! ### `HasCorridor` positivity, monotonicity, and injectivity on `Icc 0 (1/64)` -/

/-- **`aperyGFAReal z ≥ 1` for `z ∈ [0, 1/64]` under `HasCorridor`.**
On the half-open part this is `aperyGFAReal_ge_one_of_nonneg`; at the closed
endpoint `z = 1/64` the bound is inherited by continuity. -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_ge_one_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Icc (0 : ℝ) (1 / 64)) :
    1 ≤ aperyGFAReal z := by
  by_cases hz' : z < 1 / 64
  · exact aperyGFAReal_ge_one_of_nonneg hz.1 hz'
  · have hz_eq : z = 1 / 64 := le_antisymm hz.2 (not_lt.mp hz')
    subst hz_eq
    -- aperyGFAReal (1/64) is the limit of aperyGFAReal on [0, 1/64),
    -- where aperyGFAReal ≥ 1.  Since {x | 1 ≤ x} is closed and
    -- aperyGFAReal is continuous on [0, 1/64], the bound extends.
    have h_cont := h.continuousOn_aperyGFAReal_Icc_one_div_64
    have h_mem : (1 / 64 : ℝ) ∈ Set.Icc (0 : ℝ) (1 / 64) :=
      ⟨by norm_num, le_refl _⟩
    -- The preimage of the closed set [1, ∞) intersected with [0, 1/64] is closed
    have h_preimage_closed :
        IsClosed (Set.Icc (0 : ℝ) (1 / 64) ∩ aperyGFAReal ⁻¹' (Set.Ici 1)) :=
      h_cont.preimage_isClosed_of_isClosed isClosed_Icc isClosed_Ici
    -- All points in [0, 1/64) lie in this set
    have h_dense_sub : Set.Ico (0 : ℝ) (1 / 64) ⊆
        Set.Icc (0 : ℝ) (1 / 64) ∩ aperyGFAReal ⁻¹' (Set.Ici 1) := by
      intro w hw
      exact ⟨⟨hw.1, le_of_lt hw.2⟩,
             Set.mem_Ici.mpr (aperyGFAReal_ge_one_of_nonneg hw.1 hw.2)⟩
    -- closure [0, 1/64) = [0, 1/64]
    have h_dense : closure (Set.Ico (0 : ℝ) (1 / 64)) = Set.Icc (0 : ℝ) (1 / 64) :=
      closure_Ico (by norm_num : (0 : ℝ) ≠ 1 / 64)
    -- closure_minimal gives: closure (Ico ...) ⊆ closed set
    -- Rewriting closure via h_dense gives: Icc ⊆ closed set
    have h_contains : Set.Icc (0 : ℝ) (1 / 64) ⊆
        Set.Icc (0 : ℝ) (1 / 64) ∩ aperyGFAReal ⁻¹' (Set.Ici 1) := by
      have := closure_minimal h_dense_sub h_preimage_closed
      rwa [h_dense] at this
    exact Set.mem_Ici.mp (h_contains h_mem).2

/-- **`aperyGFAReal z > 0` for `z ∈ [0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_pos_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Icc (0 : ℝ) (1 / 64)) :
    0 < aperyGFAReal z :=
  lt_of_lt_of_le zero_lt_one (h.aperyGFAReal_ge_one_of_mem_Icc hz)

/-- **`aperyGFAReal` is strictly monotone on `[0, 1/64]` under `HasCorridor`.**
On `[0, 1/64)` this is the unconditional `aperyGFAReal_strictMonoOn_Ico`. The
extension to the closed endpoint uses continuity and the fact that
`aperyGFAReal` values on `(z₁, 1/64)` are all `> aperyGFAReal z₁`. -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_strictMonoOn_Icc
    (h : HasCorridorAperyAnalyticExtension) :
    StrictMonoOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 h12
  by_cases hz2' : z₂ < 1 / 64
  · -- Both in [0, 1/64), use the unconditional result
    exact aperyGFAReal_strict_mono_on_nonneg hz1.1 h12 hz2'
  · -- z₂ = 1/64
    have hz2_eq : z₂ = 1 / 64 := le_antisymm hz2.2 (not_lt.mp hz2')
    subst hz2_eq
    -- z₁ < 1/64, so pick a midpoint m with z₁ < m < 1/64
    have hz1_nonneg : 0 ≤ z₁ := hz1.1
    have h_mid : z₁ < (z₁ + 1 / 64) / 2 := by linarith
    have h_mid_lt : (z₁ + 1 / 64) / 2 < 1 / 64 := by linarith
    have h_mid_nonneg : 0 ≤ (z₁ + 1 / 64) / 2 := by linarith
    -- aperyGFAReal z₁ < aperyGFAReal m
    have h_step1 := aperyGFAReal_strict_mono_on_nonneg hz1_nonneg h_mid h_mid_lt
    -- aperyGFAReal m ≤ aperyGFAReal (1/64) by closure argument:
    -- {x ∈ [m, 1/64] | aperyGFAReal m ≤ aperyGFAReal x} is closed and contains [m, 1/64)
    have h_cont := h.continuousOn_aperyGFAReal_Icc_one_div_64
    have h_cont_sub : ContinuousOn aperyGFAReal
        (Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64)) :=
      h_cont.mono (Set.Icc_subset_Icc_left h_mid_nonneg)
    have h_preimage_closed :
        IsClosed (Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + 1 / 64) / 2)))) :=
      h_cont_sub.preimage_isClosed_of_isClosed isClosed_Icc isClosed_Ici
    have h_sub : Set.Ico ((z₁ + 1 / 64) / 2) (1 / 64) ⊆
        Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) ∩
          aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + 1 / 64) / 2))) := by
      intro w hw
      refine ⟨⟨hw.1, le_of_lt hw.2⟩, show aperyGFAReal ((z₁ + 1 / 64) / 2) ≤ aperyGFAReal w from ?_⟩
      rcases eq_or_lt_of_le hw.1 with rfl | hmw
      · exact le_refl _
      · exact le_of_lt (aperyGFAReal_strict_mono_on_nonneg h_mid_nonneg hmw hw.2)
    have h_closure : closure (Set.Ico ((z₁ + 1 / 64) / 2) (1 / 64)) =
        Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) :=
      closure_Ico (by linarith : (z₁ + 1 / 64) / 2 ≠ 1 / 64)
    have h_step2 : aperyGFAReal ((z₁ + 1 / 64) / 2) ≤ aperyGFAReal (1 / 64) := by
      have h_mem_Icc : (1 / 64 : ℝ) ∈ Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) :=
        ⟨by linarith, le_refl _⟩
      have h_contains : Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) ⊆
          Set.Icc ((z₁ + 1 / 64) / 2) (1 / 64) ∩
            aperyGFAReal ⁻¹' (Set.Ici (aperyGFAReal ((z₁ + 1 / 64) / 2))) := by
        have := closure_minimal h_sub h_preimage_closed
        rwa [h_closure] at this
      exact Set.mem_Ici.mp (h_contains h_mem_Icc).2
    exact lt_of_lt_of_le h_step1 h_step2

/-- **`aperyGFAReal` is injective on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_injOn_Icc
    (h : HasCorridorAperyAnalyticExtension) :
    Set.InjOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) :=
  h.aperyGFAReal_strictMonoOn_Icc.injOn

/-- **`some.F z ≥ 1` for `z ∈ [0, 1/64]` under `HasCorridor`.** Transfer from
`aperyGFAReal_ge_one_of_mem_Icc` via `some_F_eqOn_aperyGFAReal_Icc_one_div_64`. -/
lemma HasCorridorAperyAnalyticExtension.some_F_ge_one_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Icc (0 : ℝ) (1 / 64)) :
    1 ≤ h.toHasAperyAnalyticExtension.some.F z := by
  rw [h.some_F_eqOn_aperyGFAReal_Icc_one_div_64 hz]
  exact h.aperyGFAReal_ge_one_of_mem_Icc hz

/-- **`some.F z > 0` for `z ∈ [0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_pos_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {z : ℝ} (hz : z ∈ Set.Icc (0 : ℝ) (1 / 64)) :
    0 < h.toHasAperyAnalyticExtension.some.F z :=
  lt_of_lt_of_le zero_lt_one (h.some_F_ge_one_of_mem_Icc hz)

/-- **`some.F` is strictly monotone on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_strictMonoOn_Icc
    (h : HasCorridorAperyAnalyticExtension) :
    StrictMonoOn h.toHasAperyAnalyticExtension.some.F (Set.Icc (0 : ℝ) (1 / 64)) := by
  intro z₁ hz1 z₂ hz2 h12
  rw [h.some_F_eqOn_aperyGFAReal_Icc_one_div_64 hz1,
      h.some_F_eqOn_aperyGFAReal_Icc_one_div_64 hz2]
  exact h.aperyGFAReal_strictMonoOn_Icc hz1 hz2 h12

/-- **`some.F` is injective on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_injOn_Icc
    (h : HasCorridorAperyAnalyticExtension) :
    Set.InjOn h.toHasAperyAnalyticExtension.some.F (Set.Icc (0 : ℝ) (1 / 64)) :=
  h.some_F_strictMonoOn_Icc.injOn

/-! ### `HasCorridor` concrete `sInf`/`sSup` pinning via strict monotonicity

Under `HasCorridor`, strict monotonicity pins the minimum of `aperyGFAReal`
(and `some.F`) on `[0, 1/64]` to `z = 0` (value `1`) and the maximum to
`z = 1/64`. This gives concrete values for `sInf` and `sSup`. -/

/-- **`z = 0` is the minimum of `aperyGFAReal` on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.isMinOn_aperyGFAReal_Icc_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    IsMinOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) 0 := by
  intro z hz
  show aperyGFAReal 0 ≤ aperyGFAReal z
  rcases eq_or_lt_of_le hz.1 with rfl | hpos
  · exact le_refl _
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc
      ⟨le_refl _, by norm_num⟩ hz hpos)

/-- **`z = 1/64` is the maximum of `aperyGFAReal` on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.isMaxOn_aperyGFAReal_Icc_at_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    IsMaxOn aperyGFAReal (Set.Icc (0 : ℝ) (1 / 64)) (1 / 64) := by
  intro z hz
  show aperyGFAReal z ≤ aperyGFAReal (1 / 64)
  rcases lt_or_eq_of_le hz.2 with hlt | rfl
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc hz
      ⟨by norm_num, le_refl _⟩ hlt)
  · exact le_refl _

/-- **`sInf` of `aperyGFAReal` image on `[0, 1/64]` equals `1` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_eq_one
    (h : HasCorridorAperyAnalyticExtension) :
    sInf (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) = 1 := by
  have h_isLeast : IsLeast (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64))
      (aperyGFAReal 0) := by
    constructor
    · exact ⟨0, ⟨le_refl _, by norm_num⟩, rfl⟩
    · rintro y ⟨z, hz, rfl⟩
      exact h.isMinOn_aperyGFAReal_Icc_at_zero hz
  rw [h_isLeast.csInf_eq, aperyGFAReal_zero]

/-- **`sSup` of `aperyGFAReal` image on `[0, 1/64]` equals `aperyGFAReal (1/64)`
under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_eq
    (h : HasCorridorAperyAnalyticExtension) :
    sSup (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64)) = aperyGFAReal (1 / 64) := by
  have h_isGreatest : IsGreatest (aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64))
      (aperyGFAReal (1 / 64)) := by
    constructor
    · exact ⟨1 / 64, ⟨by norm_num, le_refl _⟩, rfl⟩
    · rintro y ⟨z, hz, rfl⟩
      exact h.isMaxOn_aperyGFAReal_Icc_at_one_div_64 hz
  exact h_isGreatest.csSup_eq

/-- **Image of `aperyGFAReal` on `[0, 1/64]` equals `[1, aperyGFAReal(1/64)]`
under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_eq_concrete
    (h : HasCorridorAperyAnalyticExtension) :
    aperyGFAReal '' Set.Icc (0 : ℝ) (1 / 64) =
      Set.Icc 1 (aperyGFAReal (1 / 64)) := by
  rw [h.aperyGFAReal_image_Icc_one_div_64_eq_Icc_sInf_sSup,
      h.sInf_aperyGFAReal_image_Icc_eq_one,
      h.sSup_aperyGFAReal_image_Icc_eq]

/-- **`z = 0` is the minimum of `some.F` on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.isMinOn_some_F_Icc_at_zero
    (h : HasCorridorAperyAnalyticExtension) :
    IsMinOn h.toHasAperyAnalyticExtension.some.F (Set.Icc (0 : ℝ) (1 / 64)) 0 := by
  intro z hz
  show h.toHasAperyAnalyticExtension.some.F 0 ≤
    h.toHasAperyAnalyticExtension.some.F z
  rcases eq_or_lt_of_le hz.1 with rfl | hpos
  · exact le_refl _
  · exact le_of_lt (h.some_F_strictMonoOn_Icc
      ⟨le_refl _, by norm_num⟩ hz hpos)

/-- **`z = 1/64` is the maximum of `some.F` on `[0, 1/64]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.isMaxOn_some_F_Icc_at_one_div_64
    (h : HasCorridorAperyAnalyticExtension) :
    IsMaxOn h.toHasAperyAnalyticExtension.some.F
      (Set.Icc (0 : ℝ) (1 / 64)) (1 / 64) := by
  intro z hz
  show h.toHasAperyAnalyticExtension.some.F z ≤
    h.toHasAperyAnalyticExtension.some.F (1 / 64)
  rcases lt_or_eq_of_le hz.2 with hlt | rfl
  · exact le_of_lt (h.some_F_strictMonoOn_Icc hz
      ⟨by norm_num, le_refl _⟩ hlt)
  · exact le_refl _

/-- **`sInf` of `some.F` image on `[0, 1/64]` equals `1` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_some_F_image_Icc_eq_one
    (h : HasCorridorAperyAnalyticExtension) :
    sInf (h.toHasAperyAnalyticExtension.some.F '' Set.Icc (0 : ℝ) (1 / 64)) = 1 := by
  rw [h.some_F_image_Icc_eq_aperyGFAReal_image,
      h.sInf_aperyGFAReal_image_Icc_eq_one]

/-- **`sSup` of `some.F` image on `[0, 1/64]` equals `some.F (1/64)`
under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_some_F_image_Icc_eq
    (h : HasCorridorAperyAnalyticExtension) :
    sSup (h.toHasAperyAnalyticExtension.some.F '' Set.Icc (0 : ℝ) (1 / 64)) =
      h.toHasAperyAnalyticExtension.some.F (1 / 64) := by
  rw [h.some_F_image_Icc_eq_aperyGFAReal_image,
      h.sSup_aperyGFAReal_image_Icc_eq,
      h.some_F_eqOn_aperyGFAReal_Icc_one_div_64
        ⟨by norm_num, le_refl _⟩]

/-! ### `HasCorridor` generic sub-interval `sInf`/`sSup` pinning

On any sub-interval `[a, b] ⊆ [0, 1/64]`, strict monotonicity pins:
- `sInf (aperyGFAReal '' [a, b]) = aperyGFAReal a`
- `sSup (aperyGFAReal '' [a, b]) = aperyGFAReal b`
- `image = [aperyGFAReal a, aperyGFAReal b]` -/

/-- **Min of `aperyGFAReal` on `[a, b] ⊆ [0, 1/64]` is at `z = a`.** -/
lemma HasCorridorAperyAnalyticExtension.isMinOn_aperyGFAReal_Icc_at_left
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    IsMinOn aperyGFAReal (Set.Icc a b) a := by
  intro z hz
  show aperyGFAReal a ≤ aperyGFAReal z
  rcases eq_or_lt_of_le hz.1 with rfl | hpos
  · exact le_refl _
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc
      ⟨ha, le_trans hab hb⟩
      ⟨le_trans ha (le_of_lt hpos), le_trans hz.2 hb⟩ hpos)

/-- **Max of `aperyGFAReal` on `[a, b] ⊆ [0, 1/64]` is at `z = b`.** -/
lemma HasCorridorAperyAnalyticExtension.isMaxOn_aperyGFAReal_Icc_at_right
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    IsMaxOn aperyGFAReal (Set.Icc a b) b := by
  intro z hz
  show aperyGFAReal z ≤ aperyGFAReal b
  rcases lt_or_eq_of_le hz.2 with hlt | rfl
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc
      ⟨le_trans ha hz.1, le_trans (le_of_lt hlt) hb⟩
      ⟨le_trans ha hab, hb⟩ hlt)
  · exact le_refl _

/-- **`sInf (aperyGFAReal '' [a, b]) = aperyGFAReal a` for `[a, b] ⊆ [0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_aperyGFAReal_image_Icc_eq_left
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sInf (aperyGFAReal '' Set.Icc a b) = aperyGFAReal a :=
  IsLeast.csInf_eq ⟨⟨a, ⟨le_refl _, hab⟩, rfl⟩,
    fun _ ⟨z, hz, e⟩ => e ▸ h.isMinOn_aperyGFAReal_Icc_at_left ha hab hb hz⟩

/-- **`sSup (aperyGFAReal '' [a, b]) = aperyGFAReal b` for `[a, b] ⊆ [0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_aperyGFAReal_image_Icc_eq_right
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sSup (aperyGFAReal '' Set.Icc a b) = aperyGFAReal b :=
  IsGreatest.csSup_eq ⟨⟨b, ⟨hab, le_refl _⟩, rfl⟩,
    fun _ ⟨z, hz, e⟩ => e ▸ h.isMaxOn_aperyGFAReal_Icc_at_right ha hab hb hz⟩

/-- **Image of `aperyGFAReal` on `[a, b] ⊆ [0, 1/64]` equals
`[aperyGFAReal a, aperyGFAReal b]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_image_Icc_sub_eq_concrete
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    aperyGFAReal '' Set.Icc a b =
      Set.Icc (aperyGFAReal a) (aperyGFAReal b) := by
  have hb' : b < Number.aperyConifoldZ1Poly :=
    lt_of_le_of_lt hb aperyConifoldZ1Poly_gt_one_div_64
  rw [h.aperyGFAReal_image_Icc_general_eq_Icc_sInf_sSup ha hab hb',
      h.sInf_aperyGFAReal_image_Icc_eq_left ha hab hb,
      h.sSup_aperyGFAReal_image_Icc_eq_right ha hab hb]

/-- **`sInf (some.F '' [a, b]) = aperyGFAReal a` for `[a, b] ⊆ [0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.sInf_some_F_image_Icc_sub_eq_left
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sInf (h.toHasAperyAnalyticExtension.some.F '' Set.Icc a b) =
      aperyGFAReal a := by
  rw [h.some_F_image_Icc_sub_eq_aperyGFAReal ha hb,
      h.sInf_aperyGFAReal_image_Icc_eq_left ha hab hb]

/-- **`sSup (some.F '' [a, b]) = aperyGFAReal b` for `[a, b] ⊆ [0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.sSup_some_F_image_Icc_sub_eq_right
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    sSup (h.toHasAperyAnalyticExtension.some.F '' Set.Icc a b) =
      aperyGFAReal b := by
  rw [h.some_F_image_Icc_sub_eq_aperyGFAReal ha hb,
      h.sSup_aperyGFAReal_image_Icc_eq_right ha hab hb]

/-! ### `HasCorridor` concrete value bounds at `z = 1/64`

Strict monotonicity gives `aperyGFAReal (1/64) > 1`. Combined with
the quadratic/cubic partial sums, we get quantitative lower bounds. -/

/-- **`aperyGFAReal (1/64) > 1` under `HasCorridor`.** From strict mono
and `aperyGFAReal 0 = 1`. -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_one_div_64_gt_one
    (h : HasCorridorAperyAnalyticExtension) :
    1 < aperyGFAReal (1 / 64) := by
  calc 1 = aperyGFAReal 0 := aperyGFAReal_zero.symm
    _ < aperyGFAReal (1 / 64) :=
        h.aperyGFAReal_strictMonoOn_Icc
          ⟨le_refl _, by norm_num⟩ ⟨by norm_num, le_refl _⟩ (by norm_num)

/-- **`aperyGFAReal (1/64) > 0` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_one_div_64_pos
    (h : HasCorridorAperyAnalyticExtension) :
    0 < aperyGFAReal (1 / 64) :=
  lt_trans zero_lt_one h.aperyGFAReal_one_div_64_gt_one

/-- **`some.F (1/64) > 1` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_one_div_64_gt_one
    (h : HasCorridorAperyAnalyticExtension) :
    1 < h.toHasAperyAnalyticExtension.some.F (1 / 64) := by
  rw [h.some_F_eqOn_aperyGFAReal_Icc_one_div_64 ⟨by norm_num, le_refl _⟩]
  exact h.aperyGFAReal_one_div_64_gt_one

/-- **`some.F (1/64) > 0` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_one_div_64_pos
    (h : HasCorridorAperyAnalyticExtension) :
    0 < h.toHasAperyAnalyticExtension.some.F (1 / 64) :=
  lt_trans zero_lt_one h.some_F_one_div_64_gt_one

/-! ### `HasCorridor` quantitative lower bounds on `aperyGFAReal (1/64)` via partial sums

The partial sums `aperyGFAPartial N (1/64)` are computable lower bounds
for `aperyGFAReal (1/64)` under `HasCorridor`. The key: for `z ∈ [0, 1/64)`,
partial sums are unconditional lower bounds. By continuity (from
`HasCorridor`), taking the limit as `z → (1/64)⁻` gives
`aperyGFAPartial N (1/64) ≤ aperyGFAReal (1/64)`.

However, this needs a closure argument for each partial sum. Instead, we
use the simpler route: `aperyGFAReal_ge_one_of_mem_Icc` already gives
`1 ≤ aperyGFAReal (1/64)`. The stronger bounds from partial sums on the
open interval `[0, 1/64)` are already unconditionally available for
`z < 1/64` and thus for any downstream use via the `some.F` transfer. -/

/-- **Strict `1 < aperyGFAReal b` for `0 < b ≤ 1/64` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_gt_one_of_pos_le_one_div_64
    (h : HasCorridorAperyAnalyticExtension)
    {b : ℝ} (hb_pos : 0 < b) (hb : b ≤ 1 / 64) :
    1 < aperyGFAReal b := by
  calc 1 = aperyGFAReal 0 := aperyGFAReal_zero.symm
    _ < aperyGFAReal b :=
        h.aperyGFAReal_strictMonoOn_Icc
          ⟨le_refl _, by norm_num⟩ ⟨le_of_lt hb_pos, hb⟩ hb_pos

/-- **Strict `1 < some.F b` for `0 < b ≤ 1/64` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_gt_one_of_pos_le_one_div_64
    (h : HasCorridorAperyAnalyticExtension)
    {b : ℝ} (hb_pos : 0 < b) (hb : b ≤ 1 / 64) :
    1 < h.toHasAperyAnalyticExtension.some.F b := by
  rw [h.some_F_eqOn_aperyGFAReal_Icc_one_div_64 ⟨le_of_lt hb_pos, hb⟩]
  exact h.aperyGFAReal_gt_one_of_pos_le_one_div_64 hb_pos hb

/-! ### `HasCorridor` concrete SurjOn / IVT on sub-intervals

With `sInf = GFA(a)` and `sSup = GFA(b)`, the generic SurjOn / IVT atoms
specialize to concrete interval targets `[GFA(a), GFA(b)]`. -/

/-- **`SurjOn aperyGFAReal (Icc a b) (Icc (GFA a) (GFA b))` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.surjOn_aperyGFAReal_Icc_sub_concrete
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    Set.SurjOn aperyGFAReal (Set.Icc a b)
      (Set.Icc (aperyGFAReal a) (aperyGFAReal b)) := by
  rw [← h.aperyGFAReal_image_Icc_sub_eq_concrete ha hab hb]
  exact Set.surjOn_image _ _

/-- **IVT realizer: every `y ∈ [GFA(a), GFA(b)]` is hit by some
`z ∈ [a, b]` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.exists_aperyGFAReal_eq_of_mem_concrete
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64)
    {y : ℝ} (hy : y ∈ Set.Icc (aperyGFAReal a) (aperyGFAReal b)) :
    ∃ z ∈ Set.Icc a b, aperyGFAReal z = y := by
  have h_surj := h.surjOn_aperyGFAReal_Icc_sub_concrete ha hab hb hy
  obtain ⟨z, hz_mem, hz_eq⟩ := h_surj
  exact ⟨z, hz_mem, hz_eq⟩

/-- **`MapsTo aperyGFAReal (Icc a b) (Icc (GFA a) (GFA b))` under `HasCorridor`.** -/
lemma HasCorridorAperyAnalyticExtension.mapsTo_aperyGFAReal_Icc_sub_concrete
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hab : a ≤ b) (hb : b ≤ 1 / 64) :
    Set.MapsTo aperyGFAReal (Set.Icc a b)
      (Set.Icc (aperyGFAReal a) (aperyGFAReal b)) := by
  rw [← h.aperyGFAReal_image_Icc_sub_eq_concrete ha hab hb]
  exact Set.mapsTo_image _ _

/-! ### `HasCorridor` monotone bounds from strict mono

Strict monotonicity gives pointwise comparisons: `a ≤ z ≤ b ⇒
GFA(a) ≤ GFA(z) ≤ GFA(b)`. These are more ergonomic than going through
sInf/sSup when the endpoints are known. -/

/-- **`aperyGFAReal a ≤ aperyGFAReal z` for `a ≤ z` in `[0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_mono_left
    (h : HasCorridorAperyAnalyticExtension)
    {a z : ℝ} (ha : 0 ≤ a) (haz : a ≤ z) (hz : z ≤ 1 / 64) :
    aperyGFAReal a ≤ aperyGFAReal z := by
  rcases eq_or_lt_of_le haz with rfl | hlt
  · exact le_refl _
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc
      ⟨ha, le_trans haz hz⟩ ⟨le_trans ha haz, hz⟩ hlt)

/-- **`aperyGFAReal z ≤ aperyGFAReal b` for `z ≤ b` in `[0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_mono_right
    (h : HasCorridorAperyAnalyticExtension)
    {z b : ℝ} (hz : 0 ≤ z) (hzb : z ≤ b) (hb : b ≤ 1 / 64) :
    aperyGFAReal z ≤ aperyGFAReal b := by
  rcases eq_or_lt_of_le hzb with rfl | hlt
  · exact le_refl _
  · exact le_of_lt (h.aperyGFAReal_strictMonoOn_Icc
      ⟨hz, le_trans hzb hb⟩ ⟨le_trans hz hzb, hb⟩ hlt)

/-- **Two-sided bound: `GFA(a) ≤ GFA(z) ≤ GFA(b)` for `z ∈ [a, b] ⊆ [0, 1/64]`.** -/
lemma HasCorridorAperyAnalyticExtension.aperyGFAReal_mem_Icc_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hb : b ≤ 1 / 64)
    {z : ℝ} (hz : z ∈ Set.Icc a b) :
    aperyGFAReal z ∈ Set.Icc (aperyGFAReal a) (aperyGFAReal b) :=
  ⟨h.aperyGFAReal_mono_left ha hz.1 (le_trans hz.2 hb),
   h.aperyGFAReal_mono_right (le_trans ha hz.1) hz.2 hb⟩

/-- **Two-sided bound for `some.F`: `GFA(a) ≤ some.F(z) ≤ GFA(b)`.** -/
lemma HasCorridorAperyAnalyticExtension.some_F_mem_Icc_of_mem_Icc
    (h : HasCorridorAperyAnalyticExtension)
    {a b : ℝ} (ha : 0 ≤ a) (hb : b ≤ 1 / 64)
    {z : ℝ} (hz : z ∈ Set.Icc a b) :
    h.toHasAperyAnalyticExtension.some.F z ∈
      Set.Icc (aperyGFAReal a) (aperyGFAReal b) := by
  rw [h.some_F_eqOn_aperyGFAReal_Icc_one_div_64
    ⟨le_trans ha hz.1, le_trans hz.2 hb⟩]
  exact h.aperyGFAReal_mem_Icc_of_mem_Icc ha hb hz

/-- **`HasAperyAnalyticExtension` holds unconditionally.** With Gap F closed,
`aperyGFAReal` itself serves as the extension function: it agrees with
itself on `Ico 0 (1/64)` and is continuous on `Ico 0 z₁`. -/
noncomputable def aperyAnalyticExtension_canonical : AperyAnalyticExtension where
  F := aperyGFAReal
  agrees_on_small := fun _ _ => rfl
  continuousOn_corridor := aperyGFAReal_continuousOn_corridor

/-- **`HasAperyAnalyticExtension` is unconditionally true.** -/
lemma hasAperyAnalyticExtension_unconditional : HasAperyAnalyticExtension :=
  ⟨aperyAnalyticExtension_canonical⟩

/-- **`HasCorridorAperyAnalyticExtension` is unconditionally true.** Since
`F = aperyGFAReal`, the corridor-wide agreement is trivially `rfl`. -/
lemma hasCorridorAperyAnalyticExtension_unconditional :
    HasCorridorAperyAnalyticExtension :=
  ⟨aperyAnalyticExtension_canonical, fun _ _ => rfl⟩

/-- **Unconditional `AperyConnectionData`.** Canonical minimal connection
data from the unconditional extension. Corridor = `{0}`. -/
noncomputable def aperyConnectionData_canonical : AperyConnectionData :=
  aperyAnalyticExtension_canonical.toMinimalConnectionData

/-- **Unconditional `HasAperyConnectionData`.** -/
lemma hasAperyConnectionData_unconditional : HasAperyConnectionData :=
  ⟨aperyConnectionData_canonical⟩

/-! ### Unconditional wrappers for key `HasCorridor` results

With `HasCorridorAperyAnalyticExtension` unconditionally true, every result
conditioned on it is now a free theorem. These wrappers make the most
important results available without any hypothesis. -/

/-- **`aperyGFAReal` is continuous on `[0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_continuousOn_Ico_z1_unconditional :
    ContinuousOn aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :=
  aperyGFAReal_continuousOn_corridor

/-- **`aperyGFAReal` is continuous on `[a, b]` for `0 ≤ a`, `b < z₁`.** Unconditional. -/
lemma aperyGFAReal_continuousOn_Icc_unconditional
    {a b : ℝ} (ha : 0 ≤ a) (hb : b < Number.aperyConifoldZ1Poly) :
    ContinuousOn aperyGFAReal (Set.Icc a b) :=
  hasCorridorAperyAnalyticExtension_unconditional.continuousOn_aperyGFAReal_Icc_general ha hb

/-- **`aperyGFAReal` is strictly monotone on `[0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_strictMonoOn_Ico_z1_unconditional :
    StrictMonoOn aperyGFAReal
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :=
  fun _ hz1 _ hz2 h12 =>
    aperyGFAReal_strict_mono_on_nonneg_z1 hz1.1 h12 hz2.2

/-- **`aperyGFAReal z ≥ 1` for `z ∈ [0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_ge_one_Ico_z1_unconditional
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    1 ≤ aperyGFAReal z :=
  aperyGFAReal_ge_one_of_nonneg_z1 hz.1 hz.2

/-- **`aperyGFAReal z > 0` for `z ∈ [0, z₁)`.** Unconditional. -/
lemma aperyGFAReal_pos_Ico_z1_unconditional
    {z : ℝ} (hz : z ∈ Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) :
    0 < aperyGFAReal z :=
  aperyGFAReal_pos_of_nonneg_z1 hz.1 hz.2

/-- **Image `aperyGFAReal '' [0, b] = [1, GFA(b)]` for `0 < b < z₁`.** Unconditional. -/
lemma aperyGFAReal_image_Icc_eq_concrete_z1_unconditional
    {b : ℝ} (hb_pos : 0 < b) (hb : b < Number.aperyConifoldZ1Poly) :
    aperyGFAReal '' Set.Icc 0 b = Set.Icc 1 (aperyGFAReal b) := by
  have h_cont := aperyGFAReal_continuousOn_Icc_z1 (le_of_lt hb_pos) hb
  have h_nonempty := (Set.nonempty_Icc.mpr (le_of_lt hb_pos)).image aperyGFAReal
  have h_compact := isCompact_Icc.image_of_continuousOn h_cont
  apply Set.eq_of_subset_of_subset
  · rintro y ⟨z, hz, rfl⟩
    refine ⟨?_, (aperyGFAReal_strictMonoOn_Icc_z1 hb_pos hb).monotoneOn
        hz ⟨le_of_lt hb_pos, le_refl _⟩ hz.2⟩
    -- Show 1 ≤ aperyGFAReal z; uses ge_one
    rw [show (1 : ℝ) = aperyGFAReal 0 from aperyGFAReal_zero.symm]
    exact (aperyGFAReal_strictMonoOn_Icc_z1 hb_pos hb).monotoneOn
        ⟨le_refl _, le_of_lt hb_pos⟩ hz hz.1
  · obtain ⟨zmin, hzmin_mem, hzmin_eq⟩ := h_compact.sInf_mem h_nonempty
    obtain ⟨zmax, hzmax_mem, hzmax_eq⟩ := h_compact.sSup_mem h_nonempty
    have hsInf := aperyGFAReal_sInf_image_Icc_eq_one_z1 hb_pos hb
    have hsSup := aperyGFAReal_sSup_image_Icc_eq_right_z1 hb_pos hb
    rw [hsInf] at hzmin_eq
    rw [hsSup] at hzmax_eq
    rw [← hzmin_eq, ← hzmax_eq]
    exact h_cont.surjOn_Icc hzmin_mem hzmax_mem

/-! ### Derivative series summability

The formal derivative of `aperyGFAReal` is `∑ (n+1) a_{n+1} z^n`. Since
`a_{n+1} ≤ R^{n+1}`, the derivative series is dominated by `∑ (n+1) R^{n+1} z^n`
which converges for `|z| < 1/R = z₁`. -/

/-- **Summability of the formal derivative series on `|z| < z₁`.** -/
lemma aperyGFAReal_deriv_summable_z1 {z : ℝ}
    (hz : |z| < Number.aperyConifoldZ1Poly) :
    Summable (fun n : ℕ => ((n + 1 : ℕ) : ℝ) * (Number.aperyA (n + 1) : ℝ) * z ^ n) := by
  rw [aperyConifoldZ1Poly_eq_inv_R] at hz
  have hR := aperyR_pos
  have hr_nn : 0 ≤ aperyR * |z| := mul_nonneg hR.le (abs_nonneg z)
  have hr_lt : aperyR * |z| < 1 := by
    calc aperyR * |z| < aperyR * (1 / aperyR) := mul_lt_mul_of_pos_left hz hR
      _ = 1 := mul_one_div_cancel aperyR_ne_zero
  have hr_norm : ‖aperyR * |z|‖ < 1 := by rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]; exact hr_lt
  -- Bound: (n+1) · a_{n+1} · |z|^n ≤ (n+1) · R^{n+1} · |z|^n = R · (n+1) · (R|z|)^n
  have hsum : Summable (fun n : ℕ => aperyR * ((n + 1 : ℕ) : ℝ) * (aperyR * |z|) ^ n) := by
    -- (n+1) = n + 1, so aperyR·(n+1)·r^n = aperyR·n·r^n + aperyR·r^n.
    have h_pow : Summable (fun n : ℕ => aperyR * (n : ℝ) * (aperyR * |z|) ^ n) := by
      have h := summable_pow_mul_geometric_of_norm_lt_one (R := ℝ) 1 hr_norm
      refine (h.mul_left aperyR).congr (fun n => ?_)
      simp [mul_comm, mul_left_comm, pow_one]
    have h_geom : Summable (fun n : ℕ => aperyR * (aperyR * |z|) ^ n) :=
      (summable_geometric_of_norm_lt_one hr_norm).mul_left aperyR
    refine (h_pow.add h_geom).congr (fun n => ?_)
    push_cast; ring
  refine Summable.of_norm_bounded hsum (fun n => ?_)
  have hAn : (Number.aperyA (n + 1) : ℝ) ≤ aperyR ^ (n + 1) := aperyA_le_pow_conifold (n + 1)
  have hAn_nn : (0 : ℝ) ≤ (Number.aperyA (n + 1) : ℝ) := by exact_mod_cast Nat.zero_le _
  have hn_nn : (0 : ℝ) ≤ ((n + 1 : ℕ) : ℝ) := by positivity
  rw [Real.norm_eq_abs, abs_mul, abs_mul, abs_pow,
      abs_of_nonneg hn_nn, abs_of_nonneg hAn_nn]
  calc ((n + 1 : ℕ) : ℝ) * (Number.aperyA (n + 1) : ℝ) * |z| ^ n
      ≤ ((n + 1 : ℕ) : ℝ) * aperyR ^ (n + 1) * |z| ^ n :=
        mul_le_mul_of_nonneg_right
          (mul_le_mul_of_nonneg_left hAn hn_nn) (pow_nonneg (abs_nonneg z) n)
    _ = aperyR * ((n + 1 : ℕ) : ℝ) * (aperyR * |z|) ^ n := by
        rw [pow_succ]; ring

/-! ### Standard probe evaluation in the full disk

The three standard probes `z₁/2`, `z₁/3`, `z₁/4` (shifted from the conifold)
now have unconditional GFA evaluability. -/

/-- **`z₁/2` is in the convergence disk.** -/
lemma half_z1_in_full_disk :
    Number.aperyConifoldZ1Poly / 2 ∈
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · exact div_nonneg (le_of_lt aperyConifoldZ1Poly_pos) (by norm_num)
  · linarith [aperyConifoldZ1Poly_pos]

/-- **`2z₁/3` is in the convergence disk.** -/
lemma two_thirds_z1_in_full_disk :
    2 * Number.aperyConifoldZ1Poly / 3 ∈
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · exact div_nonneg (mul_nonneg (by norm_num) (le_of_lt aperyConifoldZ1Poly_pos)) (by norm_num)
  · linarith [aperyConifoldZ1Poly_pos]

/-- **`3z₁/4` is in the convergence disk.** -/
lemma three_quarters_z1_in_full_disk :
    3 * Number.aperyConifoldZ1Poly / 4 ∈
      Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly := by
  refine ⟨?_, ?_⟩
  · exact div_nonneg (mul_nonneg (by norm_num) (le_of_lt aperyConifoldZ1Poly_pos)) (by norm_num)
  · linarith [aperyConifoldZ1Poly_pos]

/-- **GFA is summable at `z₁/2`.** -/
lemma aperyGFAReal_summable_at_half_z1 :
    Summable (fun n : ℕ => (Number.aperyA n : ℝ) *
      (Number.aperyConifoldZ1Poly / 2) ^ n) :=
  aperyGFAReal_summable_z1 (by
    rw [abs_of_nonneg (half_z1_in_full_disk.1)]
    exact half_z1_in_full_disk.2)

/-- **GFA ≥ 1 at `z₁/2`.** -/
lemma aperyGFAReal_ge_one_at_half_z1 :
    1 ≤ aperyGFAReal (Number.aperyConifoldZ1Poly / 2) :=
  aperyGFAReal_ge_one_of_nonneg_z1 half_z1_in_full_disk.1 half_z1_in_full_disk.2

/-- **GFA > 1 at `z₁/2`.** -/
lemma aperyGFAReal_gt_one_at_half_z1 :
    1 < aperyGFAReal (Number.aperyConifoldZ1Poly / 2) :=
  aperyGFAReal_gt_one_of_pos_z1
    (div_pos aperyConifoldZ1Poly_pos (by norm_num))
    half_z1_in_full_disk.2

/-- **GFA values at the three standard probes are pairwise distinct.**
Follows from strict monotonicity and the ordering `z₁/2 < 2z₁/3 < 3z₁/4`. -/
lemma aperyGFAReal_standard_probes_distinct :
    aperyGFAReal (Number.aperyConifoldZ1Poly / 2) <
      aperyGFAReal (2 * Number.aperyConifoldZ1Poly / 3) ∧
    aperyGFAReal (2 * Number.aperyConifoldZ1Poly / 3) <
      aperyGFAReal (3 * Number.aperyConifoldZ1Poly / 4) := by
  have hz1_pos := aperyConifoldZ1Poly_pos
  constructor
  · exact aperyGFAReal_strict_mono_on_nonneg_z1
