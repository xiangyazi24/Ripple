    AperyLocalAnalyticExtension.chain_F_eq_unionFromParams_F_at
      params n ts ht_zero ht_last h_pieces h_corridor ?_
  exact ⟨hz.1, lt_of_le_of_lt hz.2 ha_lt⟩

