        params n ts ht_zero ht_last h_pieces).F
      (AperyLocalAnalyticExtension.fromChainGFAInteriorDisks
        params n ts ht_zero ht_last h_pieces).F
      (Set.Ico (0 : ℝ) Number.aperyConifoldZ1Poly) := by
  intro z hz
  rw [AperyLocalAnalyticExtension.ofChainGFAInteriorDisksCoveringSplit_F_eq_aperyGFAReal_on_corridor
        params n ts ht_zero ht_last h_pieces hz,
      ← AperyLocalAnalyticExtension.fromChainGFAInteriorDisks_F_eq_aperyGFAReal_on_corridor
        params n ts ht_zero ht_last h_pieces hz]

